   "source": [
    "from pathlib import Path\n",
    "\n",
    "from tqdm import tqdm\n",
    "\n",
    "import tarfile\n",
    "\n",
    "import gzip\n",
    "\n",
    "import os\n",
    "\n",
    "import shutil  # For handling wrm if needed (copy if not compressed)\n",
    "\n",
    "# Set your base directory (adjust if needed)\n",
    "\n",
    "print(f\"Extracting from: {BASE_DIR}\")\n",
    "\n",
    "# Function for recursive extraction with progress\n",
    "\n",
    "def extract_recursive(base_dir, dry_run=True):\n",
    "\n",
    "    # Find all target files recursively\n",
    "\n",
    "    target_files = list(base_dir.rglob('*.tar.gz')) + list(base_dir.rglob('*.gz')) + list(base_dir.rglob('*.wrm'))\n",
    "\n",
    "    target_files = sorted(set(target_files))  # Dedup if overlaps\n",
    "\n",
    "    \n",
    "\n",
    "    # Progress bar for files\n",
    "\n",
    "    for file_path in tqdm(target_files, desc=\"Extracting files\", unit=\"file\"):\n",
    "\n",
    "        rel_path = file_path.relative_to(base_dir)\n",
    "\n",
    "        if dry_run:\n",
    "\n",
    "            print(f\"[DRY RUN] Would extract: {rel_path}\")\n",
    "\n",
    "            continue\n",
    "\n",
    "        \n",
    "\n",
    "        try:\n",
    "\n",
    "            output_dir = file_path.parent\n",
    "\n",
    "            if file_path.suffixes == ['.tar', '.gz']:  # .tar.gz\n",
    "\n",
    "                with tarfile.open(file_path, 'r:gz') as tar:\n",
    "\n",
    "                    tar.extractall(path=output_dir)\n",
    "\n",
    "                print(f\"Extracted tar.gz: {rel_path}\")\n",
    "\n",
    "            elif file_path.suffix == '.gz':  # .gz (e.g., fa.gz, csv.gz, gff3.gz)\n",
    "\n",
    "                with gzip.open(file_path, 'rb') as f_in:\n",
    "\n",
    "                    decompressed_path = output_dir / file_path.stem  # Remove .gz\n",
    "\n",
    "                    if decompressed_path.exists():\n",
    "\n",
    "                        print(f\"Skipping existing: {decompressed_path}\")\n",
    "\n",
    "                        continue\n",
    "\n",
    "                    with open(decompressed_path, 'wb') as f_out:\n",
    "\n",
    "                        shutil.copyfileobj(f_in, f_out)\n",
    "\n",
    "                print(f\"Extracted gz: {rel_path} to {decompressed_path}\")\n",
    "\n",
    "            elif file_path.suffix == '.wrm':  # .wrm (WormBase dumps; often text, copy if not gz)\n",
    "\n",
    "                # Assume .wrm is uncompressed or simple; copy to 'extracted' if needed\n",
    "\n",
    "                extracted_path = output_dir / 'extracted'\n",
    "\n",
    "                extracted_path.mkdir(exist_ok=True)\n",
    "\n",
    "                shutil.copy(file_path, extracted_path / file_path.name)\n",
    "\n",
    "                print(f\"Copied .wrm: {rel_path} to {extracted_path}\")\n",
    "\n",
    "            else:\n",
    "\n",
    "                print(f\"Skipped unsupported: {rel_path}\")\n",
    "\n",
    "            # Optional: Remove original if successful (uncomment if desired)\n",
    "\n",
    "            # file_path.unlink()\n",
    "\n",
    "        except Exception as e:\n",
    "\n",
    "            print(f\"Error extracting {rel_path}: {e}\")\n",
    "\n",
    "# Run with dry_run=True first to preview; set False for real extraction\n",
    "\n",
    "extract_recursive(BASE_DIR, dry_run=False)"
   ]
