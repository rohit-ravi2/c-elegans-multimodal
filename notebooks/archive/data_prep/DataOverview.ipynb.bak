   "source": [
    "# Cell 1 — Setup\n",
    "import os\n",
    "import shutil\n",
    "from pathlib import Path\n",
    "from collections import defaultdict\n",
    "import pandas as pd\n",
    "\n",
    "DATA_DIR = Path(\"data\")\n",
    "EXCLUDE_DIRS = {\"Originals\"}  # keep untouched\n",
    "DRY_RUN = False  # change to False to actually move files\n",
    "\n",
    "# collect all files recursively under data/\n",
    "records = []\n",
    "for root, _, files in os.walk(DATA_DIR):\n",
    "    if any(excl in root for excl in EXCLUDE_DIRS):\n",
    "        continue\n",
    "    for f in files:\n",
    "        path = Path(root) / f\n",
    "        if not path.is_file():\n",
    "            continue\n",
    "        ext = path.suffix.lower().strip(\".\") or \"[no_ext]\"\n",
    "        records.append({\"path\": str(path), \"ext\": ext})\n",
    "print(f\"Found {len(records)} files to categorize.\")\n"
   ]
  },
