   "source": [
    "from pathlib import Path\n",
    "from tqdm import tqdm\n",
    "import os\n",
    "import re\n",
    "import json\n",
    "import shutil\n",
    "from datetime import datetime\n",
    "import gzip  # For potential checks\n",
    "\n",
    "# Set your base directory (adjust if needed)\n",
    "BASE_DIR = Path('./').resolve()\n",
    "print(f\"Real Maximal Purge (Fixed): {BASE_DIR}\")\n",
    "\n",
    "# Fixed criteria (same as before)\n",
    "CRITERIA = {\n",
    "    'name_patterns_junk': [  # Comprehensive\n",
    "        r'\\.DS_Store$', r'\\.gitignore$', r'\\.gitkeep$', r'\\.__pycache__$',\n",
    "        r'\\.swp$', r'\\.swo$', r'~$', r'\\.tmp$', r'\\.bak$', r'\\.pyc$', r'\\.pyo$',\n",
    "        r'\\.log$', r'\\.err$', r'\\.out$', r'error|temp|fail|cache|lock|crash|debug',\n",
    "        r'index\\.html$', r'COMMIT_EDITMSG$', r'HEAD$', r'\\.git/'\n",
    "    ],\n",
    "    'content_keywords_bad': ['error', 'temp', 'fail', 'cache', 'git', 'debug', 'crash', 'lock'],\n",
    "    'content_keywords_bio': ['gene', 'wbgene', 'neuron', 'motif', 'expr', 'expression', 'lineage', 'connectome', 'synapse', 'unc', 'sax', 'netrin', 'rob', 'ncRNA', 'ws297', 'track', 'ontology'],\n",
    "    'suspicion_threshold': -5,\n",
    "    'exclude_dirs': ['organized', '.git', 'backups'],\n",
    "    'exclude_exts': ['.ipynb', '.csv', '.tsv', '.fa', '.gff', '.gtf', '.wrm', '.json', '.pkl', '.npy', '.nml', '.net', '.xml', '.bb', '.wib', '.ace', '.obo']\n",
    "}\n",
    "\n",
    "def is_text_file(file_path):\n",
    "    \"\"\"Quick binary check.\"\"\"\n",
    "    try:\n",
    "        with open(file_path, 'rb') as f:\n",
    "            sample = f.read(512)\n",
    "            printable = sum(1 for b in sample if 32 <= b <= 126 or b in [10, 13]) / len(sample)\n",
    "        return printable > 0.5\n",
    "    except:\n",
    "        return False\n",
    "\n",
    "def suspicion_score(file_path, criteria):\n",
    "    \"\"\"Improved score.\"\"\"\n",
    "    if not is_text_file(file_path):\n",
    "        return 0\n",
    "    score = 0\n",
    "    try:\n",
    "        with open(file_path, 'r', errors='ignore') as f:\n",
    "            sample = f.read(1024).lower()\n",
    "            for kw in criteria['content_keywords_bio']:\n",
    "                score += sample.count(kw)\n",
    "            for kw in criteria['content_keywords_bad']:\n",
    "                score -= 2 * sample.count(kw)\n",
    "    except:\n",
    "        pass\n",
    "    return score\n",
    "\n",
    "def is_useless(file_path, criteria):\n",
    "    \"\"\"Check.\"\"\"\n",
    "    name = file_path.name.lower()\n",
    "    \n",
    "    if file_path.suffix in criteria['exclude_exts'] or any(ex in file_path.parent.name for ex in criteria['exclude_dirs']):\n",
    "        return False, \"Protected (ext/dir)\"\n",
    "    \n",
    "    if any(re.search(pat, name) for pat in criteria['name_patterns_junk']):\n",
    "        return True, \"Junk name pattern\"\n",
    "    \n",
    "    known_cats = ['connectomes', 'lineage', 'expression', 'motif', 'genome', 'neuron']\n",
    "    if any(cat in name for cat in known_cats):\n",
    "        return False, \"Known category\"\n",
    "    \n",
    "    score = suspicion_score(file_path, criteria)\n",
    "    if score < criteria['suspicion_threshold']:\n",
    "        return True, f\"Unknown low score ({score})\"\n",
    "    \n",
    "    return False, \"Kept (relevant)\"\n",
    "\n",
    "def real_maximal_purge(base_dir, dry_run=False):\n",
    "    all_files = [f for f in base_dir.rglob('*') if f.is_file()]\n",
    "    all_files = sorted(all_files)\n",
    "    \n",
    "    # Fixed log init\n",
    "    log = {\n",
    "        'deleted': [], 'potential_deletes': [], 'counts': {'total': len(all_files), 'deleted': 0, 'kept': 0}, 'errors': []\n",
    "    }\n",
    "    \n",
    "    # Backup if not dry\n",
    "    if not dry_run:\n",
    "        backup_dir = base_dir / f'backups_purge_{datetime.now().strftime(\"%Y%m%d_%H%M%S\")}'\n",
    "        backup_dir.mkdir(exist_ok=True)\n",
    "        print(f\"Creating backup: {backup_dir}\")\n",
    "        for file_path in tqdm(all_files, desc=\"Backing up\", unit=\"file\"):\n",
    "            rel = file_path.relative_to(base_dir)\n",
    "            shutil.copy2(file_path, backup_dir / rel)\n",
    "        print(\"Backup complete.\")\n",
    "    \n",
    "    # Purge loop\n",
    "    for file_path in tqdm(all_files, desc=\"Purging files\", unit=\"file\"):\n",
    "        rel_path = file_path.relative_to(base_dir)\n",
    "        is_junk, reason = is_useless(file_path, CRITERIA)\n",
    "        \n",
    "        if is_junk:\n",
    "            log['counts']['deleted'] += 1\n",
    "            entry = {'path': str(rel_path), 'reason': reason, 'size_kb': round(file_path.stat().st_size / 1024, 2)}\n",
    "            if dry_run:\n",
    "                log['potential_deletes'].append(entry)\n",
    "            else:\n",
    "                try:\n",
    "                    file_path.unlink()\n",
    "                    log['deleted'].append(entry)\n",
    "                except Exception as e:\n",
    "                    log['errors'].append(str(rel_path) + f\": {e}\")\n",
    "        else:\n",
    "            log['counts']['kept'] += 1\n",
    "    \n",
    "    # Save log\n",
    "    log_path = base_dir / 'purge_log.json'\n",
    "    with open(log_path, 'w') as f:\n",
    "        json.dump(log, f, indent=4)\n",
    "    \n",
    "    print(f\"\\nPurge Summary: Deleted {log['counts']['deleted']}/{log['counts']['total']} files.\")\n",
    "    print(\"Top 20 deletes:\")\n",
    "    candidates = log['potential_deletes'] if dry_run else log['deleted']\n",
    "    for item in candidates[-20:]:\n",
    "        print(f\"  - {item['path']} ({item['reason']}, {item['size_kb']}KB)\")\n",
    "    print(f\"Full log: {log_path}\")\n",
    "\n",
    "# Run dry first (True); flip to False for real after inspect\n",
    "real_maximal_purge(BASE_DIR, dry_run=True)"
   ]
  },
