   "source": [
    "# Cell 1 — Identify old thematic directories (non-extension folders)\n",
    "from pathlib import Path\n",
    "\n",
    "DATA_DIR = Path(\"data\")\n",
    "KEEP_FOLDERS = {\"Originals\"}  # optional: keep any you explicitly want\n",
    "VALID_EXTS = {d.name for d in DATA_DIR.iterdir() if d.is_dir() and \".\" not in d.name and len(d.name) <= 6}\n",
    "\n",
    "suspect_dirs = []\n",
    "for d in DATA_DIR.iterdir():\n",
    "    if d.is_dir():\n",
    "        name = d.name\n",
    "        # we treat short extension-like names (csv, npz, tsv, etc.) as valid\n",
    "        if \".\" in name or len(name) <= 6:\n",
    "            continue\n",
    "        if name not in KEEP_FOLDERS:\n",
    "            suspect_dirs.append(d)\n",
    "\n",
    "print(\"📂 Potentially redundant (non-file-type) folders:\\n\")\n",
    "for s in suspect_dirs:\n",
    "    print(f\" - {s}\")\n",
    "\n",
    "print(f\"\\nTotal: {len(suspect_dirs)} folders marked for review.\")\n"
   ]
  },
