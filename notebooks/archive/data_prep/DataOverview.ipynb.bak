   "source": [
    "# Cell 1 — Define raw vs processed extensions\n",
    "import shutil\n",
    "from pathlib import Path\n",
    "\n",
    "DATA_DIR = Path(\"data\")\n",
    "RAW_DIR = DATA_DIR / \"raw\"\n",
    "PROCESSED_DIR = DATA_DIR / \"processed\"\n",
    "RAW_DIR.mkdir(exist_ok=True)\n",
    "PROCESSED_DIR.mkdir(exist_ok=True)\n",
    "\n",
    "# Rough heuristics: tweak if needed\n",
    "RAW_EXTS = {\n",
    "    \"fa\", \"fasta\", \"gff3\", \"gtf\", \"gz\", \"tar\", \"tar_gz\", \"zip\", \"rds\", \"rdata\",\n",
    "    \"sql\", \"wb\", \"wib\", \"hal\", \"ace\", \"bw\", \"vcf\", \"2bit\"\n",
    "}\n",
    "PROCESSED_EXTS = {\n",
    "    \"csv\", \"tsv\", \"json\", \"yaml\", \"yml\", \"xml\", \"npz\", \"npy\", \"pkl\", \"pt\", \n",
    "    \"xlsx\", \"xls\", \"parquet\", \"txt\", \"log\"\n",
    "}\n",
    "\n",
    "# collect all current type folders in data/\n",
    "type_folders = [d for d in DATA_DIR.iterdir() if d.is_dir() and d.name not in {\"raw\", \"processed\", \"Originals\"}]\n",
    "print(f\"Found {len(type_folders)} type-based folders to classify.\")\n"
   ]
  },
