    "# Cell 1 — Utilities\n",
    "import os, re, hashlib, shutil\n",
    "import pandas as pd\n",
    "from pathlib import Path\n",
    "from typing import Tuple, List\n",
    "\n",
    "OTHERS_DIR = Path(\"data/others\")\n",
    "\n",
    "# Up to 3-suffix normalization: e.g., file.fastq.gz -> \"fastq.gz\", genome.tar.gz -> \"tar.gz\"\n",
    "# Special cases mapped to conventional labels.\n",
    "COMPOUND_PREFER = {\n",
    "    (\"tar\", \"gz\"): \"tar.gz\",\n",
    "    (\"tar\", \"xz\"): \"tar.xz\",\n",
    "    (\"tar\", \"bz2\"): \"tar.bz2\",\n",
    "    (\"vcf\", \"gz\"): \"vcf.gz\",\n",
    "    (\"bw\",): \"bw\",\n",
    "    (\"2bit\",): \"2bit\",\n",
    "}\n",
    "\n",
    "TEXTY = {\"txt\", \"log\", \"md\", \"yaml\", \"yml\"}\n",
    "ARCHIVES = {\"zip\", \"tar\", \"tar.gz\", \"tar.xz\", \"tar.bz2\", \"gz\", \"xz\", \"bz2\"}\n",
    "TABLEY = {\"csv\", \"tsv\", \"xlsx\", \"xls\", \"rds\", \"rdata\", \"parquet\"}\n",
    "CODEY  = {\"py\", \"ipynb\", \"sh\", \"pyc\", \"mod\"}\n",
    "\n",
    "def clean_name(name: str) -> str:\n",
    "    # strip URL query suffixes like .html?c=s;o=d\n",
    "    name = re.sub(r\"\\?.*$\", \"\", name)\n",
    "    return name\n",
    "\n",
    "def norm_ext(path: Path) -> str:\n",
    "    name = clean_name(path.name)\n",
    "    p = Path(name)\n",
    "    # collect up to 3 suffixes (without dots)\n",
    "    suffs = [s.lstrip(\".\").lower() for s in p.suffixes][-3:]\n",
    "    if not suffs:\n",
    "        return \"[no_ext]\"\n",
    "    # try compound preferences (from the right)\n",
    "    for klen in (3, 2, 1):\n",
    "        if len(suffs) >= klen:\n",
    "            key = tuple(suffs[-klen:])\n",
    "            if key in COMPOUND_PREFER:\n",
    "                return COMPOUND_PREFER[key]\n",
    "    # fallback: last suffix\n",
    "    return suffs[-1]\n",
    "\n",
    "def file_hash(path: Path, block_size: int = 4 * 1024 * 1024) -> str:\n",
    "    h = hashlib.sha256()\n",
    "    with path.open(\"rb\") as f:\n",
    "        for chunk in iter(lambda: f.read(block_size), b\"\"):\n",
    "            h.update(chunk)\n",
    "    return h.hexdigest()\n"
   ]
  },
