   "source": [
    "# Cell 3 — Verify organization results\n",
    "post_stats = defaultdict(lambda: {\"count\": 0, \"size_MB\": 0.0})\n",
    "\n",
    "for sub in os.listdir(OTHERS_DIR):\n",
    "    path = os.path.join(OTHERS_DIR, sub)\n",
    "    if os.path.isdir(path):\n",
    "        for root, _, files in os.walk(path):\n",
    "            post_stats[sub][\"count\"] += len(files)\n",
    "            post_stats[sub][\"size_MB\"] += sum(\n",
    "                os.path.getsize(os.path.join(root, f)) / (1024 * 1024)\n",
    "                for f in files if os.path.isfile(os.path.join(root, f))\n",
    "            )\n",
    "\n",
    "df_post = (\n",
    "    pd.DataFrame([\n",
    "        {\"subfolder\": sub, \"count\": info[\"count\"], \"size_MB\": round(info[\"size_MB\"], 2)}\n",
    "        for sub, info in post_stats.items()\n",
    "    ])\n",
    "    .sort_values(by=\"size_MB\", ascending=False)\n",
    "    .reset_index(drop=True)\n",
    ")\n",
    "\n",
    "print(\"📊 Post-sort summary of 'others' folder:\\n\")\n",
    "display(df_post)\n"
   ]
  },
