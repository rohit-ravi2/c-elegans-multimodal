   "source": [
    "from pathlib import Path\n",
    "from tqdm import tqdm\n",
    "import gzip\n",
    "import os\n",
    "import re\n",
    "import json\n",
    "import shutil\n",
    "from datetime import datetime\n",
    "import struct  # For binary magic bytes\n",
    "\n",
    "# Set your genomes directory (adjust if needed; assume from organized)\n",
    "GENOMES_DIR = Path('/organized/genomes').resolve()  # Or BASE_DIR / 'genomes'\n",
    "print(f\"Purging genomes from: {GENOMES_DIR}\")\n",
    "\n",
    "# Validators by ext (aggressive: fail = delete)\n",
    "def validate_gz(file_path):\n",
    "    \"\"\"Check .gz: Decompress header/sample.\"\"\"\n",
    "    try:\n",
    "        with gzip.open(file_path, 'rt') as f:\n",
    "            f.read(1024)  # Sample bytes\n",
    "        return True, \"Valid gz\"\n",
    "    except:\n",
    "        return False, \"Gzip fail (corrupted)\"\n",
    "\n",
    "def validate_fa(file_path):\n",
    "    \"\"\"Check .fa/.fasta: Header >, non-empty seq.\"\"\"\n",
    "    try:\n",
    "        with open(file_path, 'r') as f:\n",
    "            lines = f.readlines()[:10]  # Sample\n",
    "            if not lines or not any(line.startswith('>') for line in lines):\n",
    "                return False, \"No FASTA header\"\n",
    "            seq_line = next((l for l in lines if l.startswith('>') is False), None)\n",
    "            if not seq_line or not re.match(r'^[ACGTNacgtn\\s]+$', seq_line.strip()):\n",
    "                return False, \"Invalid seq content\"\n",
    "        return True, \"Valid FASTA\"\n",
    "    except:\n",
    "        return False, \"Read fail\"\n",
    "\n",
    "def validate_gff_gtf(file_path):\n",
    "    \"\"\"Check .gff/.gtf: Tab-delim, 9+ cols.\"\"\"\n",
    "    try:\n",
    "        with open(file_path, 'r') as f:\n",
    "            lines = [l.strip() for l in f.readlines()[:5] if l.strip() and not l.startswith('#')]\n",
    "            if not lines:\n",
    "                return False, \"Empty/no data\"\n",
    "            cols = lines[0].split('\\t')\n",
    "            if len(cols) < 9:\n",
    "                return False, \"Wrong col count\"\n",
    "        return True, \"Valid GFF/GTF\"\n",
    "    except:\n",
    "        return False, \"Read fail\"\n",
    "\n",
    "def validate_wrm_ace_bb(file_path):\n",
    "    \"\"\"Check .wrm/.ace (text dumps), .bb (bigBed binary).\"\"\"\n",
    "    ext = file_path.suffix.lower()\n",
    "    if ext == '.bb':\n",
    "        try:\n",
    "            with open(file_path, 'rb') as f:\n",
    "                magic = f.read(4)\n",
    "                if magic != b'BBBB':\n",
    "                    return False, \"Bad bigBed magic\"\n",
    "            return True, \"Valid bigBed\"\n",
    "        except:\n",
    "            return False, \"Binary read fail\"\n",
    "    else:  # .wrm/.ace: Non-empty text\n",
    "        try:\n",
    "            with open(file_path, 'r') as f:\n",
    "                content = f.read(1024)\n",
    "                if len(content.strip()) == 0:\n",
    "                    return False, \"Empty content\"\n",
    "                if re.search(r'\\b(WBGene|Class|Method|Text)\\b', content):  # WormBase keywords\n",
    "                    return True, \"Valid WormBase text\"\n",
    "            return False, \"No WormBase markers\"\n",
    "        except:\n",
    "            return False, \"Read fail\"\n",
    "\n",
    "def validate_file(file_path):\n",
    "    \"\"\"Aggressive validator by ext.\"\"\"\n",
    "    ext = file_path.suffix.lower()\n",
    "    if ext.endswith('.gz'):\n",
    "        return validate_gz(file_path)\n",
    "    elif ext in ['.fa', '.fasta']:\n",
    "        return validate_fa(file_path)\n",
    "    elif ext in ['.gff', '.gtf', '.gff3']:\n",
    "        return validate_gff_gtf(file_path)\n",
    "    elif ext in ['.wrm', '.ace', '.bb']:\n",
    "        return validate_wrm_ace_bb(file_path)\n",
    "    else:  # Other/unknown: Basic non-empty text/binary\n",
    "        try:\n",
    "            stat = file_path.stat()\n",
    "            if stat.st_size == 0:\n",
    "                return False, \"Zero size\"\n",
    "            with open(file_path, 'rb') as f:\n",
    "                f.read(512)  # Basic read\n",
    "            return True, \"Basic valid\"\n",
    "        except:\n",
    "            return False, \"Open fail\"\n",
    "\n",
    "def aggressive_genome_purge(genomes_dir, dry_run=True):\n",
    "    all_files = [f for f in genomes_dir.rglob('*') if f.is_file()]\n",
    "    all_files = sorted(all_files)\n",
    "    \n",
    "    log = {'potential_deletes': [], 'counts': {'total': len(all_files), 'corrupted': 0, 'valid': 0}, 'errors': []}\n",
    "    \n",
    "    # Backup if not dry\n",
    "    if not dry_run:\n",
    "        backup_dir = genomes_dir.parent / f'genomes_backup_{datetime.now().strftime(\"%Y%m%d_%H%M%S\")}'\n",
    "        backup_dir.mkdir(exist_ok=True)\n",
    "        print(f\"Backing up to: {backup_dir}\")\n",
    "        for file_path in tqdm(all_files, desc=\"Backing up\", unit=\"file\"):\n",
    "            rel = file_path.relative_to(genomes_dir)\n",
    "            shutil.copy2(file_path, backup_dir / rel)\n",
    "        print(\"Backup complete.\")\n",
    "    \n",
    "    # Purge loop with progress\n",
    "    for file_path in tqdm(all_files, desc=\"Validating/ Purging\", unit=\"file\"):\n",
    "        rel_path = file_path.relative_to(genomes_dir)\n",
    "        is_valid, reason = validate_file(file_path)\n",
    "        \n",
    "        if not is_valid:\n",
    "            log['counts']['corrupted'] += 1\n",
    "            entry = {'path': str(rel_path), 'reason': reason, 'size_kb': round(file_path.stat().st_size / 1024, 2)}\n",
    "            if dry_run:\n",
    "                log['potential_deletes'].append(entry)\n",
    "            else:\n",
    "                try:\n",
    "                    file_path.unlink()\n",
    "                    log['potential_deletes'].append(entry)  # Log as 'deleted'\n",
    "                except Exception as e:\n",
    "                    log['errors'].append(str(rel_path) + f\": {e}\")\n",
    "        else:\n",
    "            log['counts']['valid'] += 1\n",
    "    \n",
    "    # Save log\n",
    "    log_path = genomes_dir / 'genome_purge_log.json'\n",
    "    with open(log_path, 'w') as f:\n",
    "        json.dump(log, f, indent=4)\n",
    "    \n",
    "    print(f\"\\nGenome Purge Summary: Corrupted {log['counts']['corrupted']}/{log['counts']['total']} files.\")\n",
    "    print(\"Top 20 corrupted:\")\n",
    "    candidates = log['potential_deletes']\n",
    "    for item in candidates[:20]:\n",
    "        print(f\"  - {item['path']} ({item['reason']}, {item['size_kb']}KB)\")\n",
    "    print(f\"Full log: {log_path}\")\n",
    "\n",
    "# Run dry first (True); flip to False for real aggressive purge\n",
    "aggressive_genome_purge(GENOMES_DIR, dry_run=True)"
   ]
  },
