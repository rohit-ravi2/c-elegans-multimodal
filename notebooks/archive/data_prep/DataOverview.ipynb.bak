    "        if os.path.isdir(item_path):\n",
    "            # Count files and subdirectories\n",
    "            sub_items = os.listdir(item_path)\n",
    "            num_files = len([x for x in sub_items if os.path.isfile(os.path.join(item_path, x))])\n",
    "            num_dirs = len([x for x in sub_items if os.path.isdir(os.path.join(item_path, x))])\n",
    "            print(f\"  - {item} (directory): {len(sub_items)} elements ({num_files} files, {num_dirs} subdirectories)\")\n",
    "            # List up to 5 sample items\n",
    "            if sub_items:\n",
    "                print(\"    Sample contents:\")\n",
    "                for sub_item in sub_items[:5]:\n",
    "                    sub_path = os.path.join(item_path, sub_item)\n",
    "                    print(f\"      - {sub_item} {'(directory)' if os.path.isdir(sub_path) else '(file)'}\")\n",
    "            else:\n",
    "                print(\"    (empty)\")\n",
    "        else:\n",
    "            print(f\"  - {item} (file)\")\n",
    "else:\n",
    "    print(f\"{data_dir}/ does not exist.\")"
