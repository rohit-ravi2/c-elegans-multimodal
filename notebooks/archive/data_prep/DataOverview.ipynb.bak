      "\u001b[36mCell\u001b[39m\u001b[36m \u001b[39m\u001b[32mIn[16]\u001b[39m\u001b[32m, line 101\u001b[39m, in \u001b[36mreal_maximal_purge\u001b[39m\u001b[34m(base_dir, dry_run)\u001b[39m\n\u001b[32m     99\u001b[39m log[\u001b[33m'\u001b[39m\u001b[33mcounts\u001b[39m\u001b[33m'\u001b[39m][\u001b[33m'\u001b[39m\u001b[33mdeleted\u001b[39m\u001b[33m'\u001b[39m] += \u001b[32m1\u001b[39m\n\u001b[32m    100\u001b[39m \u001b[38;5;28;01mif\u001b[39;00m dry_run:\n\u001b[32m--> \u001b[39m\u001b[32m101\u001b[39m     \u001b[43mlog\u001b[49m\u001b[43m[\u001b[49m\u001b[33;43m'\u001b[39;49m\u001b[33;43mpotential_deletes\u001b[39;49m\u001b[33;43m'\u001b[39;49m\u001b[43m]\u001b[49m.append({\u001b[33m'\u001b[39m\u001b[33mpath\u001b[39m\u001b[33m'\u001b[39m: \u001b[38;5;28mstr\u001b[39m(rel_path), \u001b[33m'\u001b[39m\u001b[33mreason\u001b[39m\u001b[33m'\u001b[39m: reason, \u001b[33m'\u001b[39m\u001b[33msize_kb\u001b[39m\u001b[33m'\u001b[39m: \u001b[38;5;28mround\u001b[39m(file_path.stat().st_size / \u001b[32m1024\u001b[39m, \u001b[32m2\u001b[39m)})\n\u001b[32m    102\u001b[39m \u001b[38;5;28;01melse\u001b[39;00m:\n\u001b[32m    103\u001b[39m     \u001b[38;5;28;01mtry\u001b[39;00m:\n",
