    "import os\n",
    "import shutil\n",
    "import json\n",
    "from datetime import datetime\n",
    "\n",
    "def get_file_extension(file):\n",
    "    \"\"\"Get file extension, handling compound extensions like .tar.gz.\"\"\"\n",
    "    base, ext = os.path.splitext(file)\n",
    "    if ext == '.gz':\n",
    "        base, sub_ext = os.path.splitext(base)\n",
    "        return f\"{sub_ext}.gz\"\n",
    "    return ext.lower() or 'no_extension'\n",
    "\n",
    "def reorganize_files_by_type(root_dir):\n",
    "    \"\"\"Reorganize files in root_dir/data/ by file type and handle top-level files.\"\"\"\n",
    "    data_dir = os.path.join(root_dir, \"data\")\n",
    "    log = {\"moved_files\": [], \"errors\": [], \"created_folders\": []}\n",
    "    \n",
    "    # Create base directories\n",
    "    base_dirs = {\n",
    "        'scripts': os.path.join(root_dir, 'scripts'),\n",
    "        'logs': os.path.join(root_dir, 'logs'),\n",
    "        'data': data_dir\n",
    "    }\n",
    "    for dir_name, dir_path in base_dirs.items():\n",
    "        if not os.path.exists(dir_path):\n",
    "            os.makedirs(dir_path)\n",
    "            log[\"created_folders\"].append(dir_path)\n",
    "    \n",
    "    # Map common file types to folders\n",
    "    file_type_map = {\n",
    "        '.csv': 'csv',\n",
    "        '.tsv': 'tsv',\n",
    "        '.fa': 'fa',\n",
    "        '.fasta': 'fa',\n",
    "        '.gff3': 'gff3',\n",
    "        '.gtf': 'gtf',\n",
    "        '.parquet': 'parquet',\n",
    "        '.pkl': 'pkl',\n",
    "        '.html': 'html',\n",
    "        '.png': 'png',\n",
    "        '.json': 'json',\n",
    "        '.npz': 'npz',\n",
    "        '.tar.gz': 'tar_gz',\n",
    "        '.nml': 'nml',\n",
    "        '.gpi.gz': 'gpi_gz',\n",
    "        'no_extension': 'no_extension'\n",
    "    }\n",
    "    \n",
    "    # Create type-based subfolders in data/\n",
    "    for folder in file_type_map.values():\n",
    "        folder_path = os.path.join(data_dir, folder)\n",
    "        if not os.path.exists(folder_path):\n",
    "            os.makedirs(folder_path)\n",
    "            log[\"created_folders\"].append(folder_path)\n",
    "    \n",
    "    # Process top-level files in root_dir\n",
    "    for item in os.listdir(root_dir):\n",
    "        item_path = os.path.join(root_dir, item)\n",
    "        if os.path.isfile(item_path):\n",
    "            ext = get_file_extension(item)\n",
    "            if item.endswith('.ipynb'):\n",
    "                new_path = os.path.join(base_dirs['scripts'], item)\n",
    "            elif ext == '.json':\n",
    "                new_path = os.path.join(base_dirs['logs'], item)\n",
    "            else:\n",
    "                continue  # Skip other top-level files\n",
    "            try:\n",
    "                shutil.move(item_path, new_path)\n",
    "                log[\"moved_files\"].append({\"original\": item_path, \"new\": new_path})\n",
    "            except Exception as e:\n",
    "                log[\"errors\"].append(f\"Error moving {item_path}: {str(e)}\")\n",
    "    \n",
    "    # Process files in data/ subdirectories\n",
    "    for dirpath, _, filenames in os.walk(data_dir):\n",
    "        # Skip type-based folders to avoid reprocessing moved files\n",
    "        if os.path.basename(dirpath) in file_type_map.values():\n",
    "            continue\n",
    "        for filename in filenames:\n",
    "            file_path = os.path.join(dirpath, filename)\n",
    "            ext = get_file_extension(filename)\n",
    "            folder_name = file_type_map.get(ext, 'other')\n",
    "            new_dir = os.path.join(data_dir, folder_name)\n",
    "            new_path = os.path.join(new_dir, filename)\n",
    "            \n",
    "            # Handle filename conflicts\n",
    "            base, file_ext = os.path.splitext(filename)\n",
    "            counter = 1\n",
    "            while os.path.exists(new_path):\n",
    "                new_filename = f\"{base}_{counter}{file_ext}\"\n",
    "                new_path = os.path.join(new_dir, new_filename)\n",
    "                counter += 1\n",
    "            \n",
    "            try:\n",
    "                shutil.move(file_path, new_path)\n",
    "                log[\"moved_files\"].append({\"original\": file_path, \"new\": new_path})\n",
    "            except Exception as e:\n",
    "                log[\"errors\"].append(f\"Error moving {file_path}: {str(e)}\")\n",
    "    \n",
    "    # Save log\n",
    "    log_file = os.path.join(base_dirs['logs'], f\"reorganize_by_type_log_{datetime.now().strftime('%Y%m%d_%H%M%S')}.json\")\n",
    "    with open(log_file, 'w') as f:\n",
    "        json.dump(log, f, indent=4)\n",
    "    \n",
    "    # Print summary\n",
    "    print(f\"File reorganization complete. Log saved to {log_file}\")\n",
    "    print(f\"Files moved: {len(log['moved_files'])}\")\n",
    "    print(f\"Folders created: {len(log['created_folders'])}\")\n",
    "    print(f\"Errors: {len(log['errors'])}\")\n",
    "    if log[\"errors\"]:\n",
    "        print(\"Errors encountered:\")\n",
    "        for error in log[\"errors\"][:5]:\n",
    "            print(f\"  - {error}\")\n",
    "\n",
    "# Run the function\n",
    "root_dir = \"/mnt/ssd4tb/Desktop/C-Elegans\"\n",
    "if os.path.exists(root_dir):\n",
    "    reorganize_files_by_type(root_dir)\n",
    "else:\n",
    "    print(f\"Directory {root_dir} does not exist.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "a227f985",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 1 — Setup\n",
    "import os\n",
    "import pandas as pd\n",
    "\n",
    "# Set base directory\n",
    "BASE_DIR = \"data\"\n",
    "summary = []\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "99ac84a5",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 2 — Count files and calculate size for each subdirectory\n",
    "for subdir in sorted(os.listdir(BASE_DIR)):\n",
    "    full_path = os.path.join(BASE_DIR, subdir)\n",
    "    if os.path.isdir(full_path):\n",
    "        file_count = 0\n",
    "        total_size = 0\n",
    "        for root, _, files in os.walk(full_path):\n",
    "            file_count += len(files)\n",
    "            total_size += sum(\n",
    "                os.path.getsize(os.path.join(root, f)) for f in files if os.path.isfile(os.path.join(root, f))\n",
    "            )\n",
    "        summary.append({\n",
    "            \"folder\": subdir,\n",
    "            \"file_count\": file_count,\n",
    "            \"total_size_MB\": round(total_size / (1024 * 1024), 2)\n",
    "        })\n",
    "\n",
    "df = pd.DataFrame(summary).sort_values(by=\"file_count\", ascending=False).reset_index(drop=True)\n"
   ]
  },
