   "source": [
    "from pathlib import Path\n",
    "\n",
    "import os\n",
    "\n",
    "import pandas as pd  # For later previews and dataframes\n",
    "\n",
    "# Set your base directory (adjust if needed)\n",
    "\n",
    "BASE_DIR = Path('./').resolve()\n",
    "\n",
    "print(f\"Base directory: {BASE_DIR}\")\n",
    "\n",
    "# Function to recursively list structure (limited depth to avoid overwhelm)\n",
    "\n",
    "def list_directory_structure(path, depth=0, max_depth=3):\n",
    "\n",
    "    if depth > max_depth:\n",
    "\n",
    "        return\n",
    "\n",
    "    for item in sorted(os.listdir(path)):\n",
    "\n",
    "        item_path = os.path.join(path, item)\n",
    "\n",
    "        print('  ' * depth + '- ' + item)\n",
    "\n",
    "        if os.path.isdir(item_path):\n",
    "\n",
    "            list_directory_structure(item_path, depth + 1, max_depth)\n",
    "\n",
    "# Run the listing\n",
    "\n",
    "list_directory_structure(str(BASE_DIR))"
   ]
  },
