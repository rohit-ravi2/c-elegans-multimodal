   "source": [
    "from pathlib import Path\n",
    "from tqdm import tqdm\n",
    "import pandas as pd\n",
    "import json\n",
    "import gzip\n",
    "import os\n",
    "import re\n",
    "import shutil\n",
    "from datetime import datetime\n",
    "import struct  # Binary checks\n",
    "\n",
    "# Set your base directory\n",
    "BASE_DIR = Path('./').resolve()\n",
    "print(f\"Full Project Purge & Restructure (Fixed Backup): {BASE_DIR}\")\n",
    "\n",
    "# Categories for /data subdirs (same)\n",
    "DATA_CATEGORIES = {\n",
    "    'connectomes_edges': ['connectome', 'edges', 'synapse', 'adjacency'],\n",
    "    'lineages': ['lineage', 'neuronlineage'],\n",
    "    'expressions': ['expr', 'expression', 'gene_expr', 'rna', 'transcript'],\n",
    "    'motifs': ['motif', 'participation', 'enrichment', 'spearman'],\n",
    "    'genomes': ['genome', 'genomic', 'fa', 'gff', 'gtf', 'cds', 'protein', 'mrna', 'wrm', 'block'],\n",
    "    'neurons_metadata': ['neuron', 'meta', 'tuple', 'cells', 'cengen', 'neuronconnect']\n",
    "}\n",
    "\n",
    "# Validators (same as before)\n",
    "def validate_csv_tsv(file_path):\n",
    "    try:\n",
    "        pd.read_csv(file_path, nrows=5)\n",
    "        return True, \"Valid CSV/TSV\"\n",
    "    except:\n",
    "        return False, \"Pandas read fail\"\n",
    "\n",
    "def validate_json(file_path):\n",
    "    try:\n",
    "        with open(file_path, 'r') as f:\n",
    "            json.load(f)\n",
    "        return True, \"Valid JSON\"\n",
    "    except:\n",
    "        return False, \"JSON load fail\"\n",
    "\n",
    "def validate_fa(file_path):\n",
    "    try:\n",
    "        with open(file_path, 'r') as f:\n",
    "            lines = f.readlines()[:10]\n",
    "            if not lines or not any(line.startswith('>') for line in lines):\n",
    "                return False, \"No FASTA header\"\n",
    "            seq_line = next((l.strip() for l in lines if not l.startswith('>')), '')\n",
    "            if not re.match(r'^[ACGTNacgtn\\s]+$', seq_line):\n",
    "                return False, \"Invalid seq\"\n",
    "        return True, \"Valid FASTA\"\n",
    "    except:\n",
    "        return False, \"Read fail\"\n",
    "\n",
    "def validate_gff_gtf(file_path):\n",
    "    try:\n",
    "        with open(file_path, 'r') as f:\n",
    "            lines = [l.strip() for l in f.readlines()[:5] if l.strip() and not l.startswith('#')]\n",
    "            if not lines:\n",
    "                return False, \"Empty/no data\"\n",
    "            cols = lines[0].split('\\t')\n",
    "            if len(cols) < 9:\n",
    "                return False, \"Wrong col count\"\n",
    "        return True, \"Valid GFF/GTF\"\n",
    "    except:\n",
    "        return False, \"Read fail\"\n",
    "\n",
    "def validate_text_generic(file_path):\n",
    "    try:\n",
    "        with open(file_path, 'r', errors='ignore') as f:\n",
    "            content = f.read(1024)\n",
    "            if len(content.strip()) == 0:\n",
    "                return False, \"Empty content\"\n",
    "        return True, \"Valid text\"\n",
    "    except:\n",
    "        return False, \"Open fail\"\n",
    "\n",
    "def validate_binary(file_path):\n",
    "    ext = file_path.suffix.lower()\n",
    "    try:\n",
    "        if ext.endswith('.gz'):\n",
    "            with gzip.open(file_path, 'rb') as f:\n",
    "                f.read(512)\n",
    "            return True, \"Valid gz binary\"\n",
    "        elif ext == '.bb':\n",
    "            with open(file_path, 'rb') as f:\n",
    "                magic = f.read(4)\n",
    "                if magic != b'BBBB':\n",
    "                    return False, \"Bad bigBed magic\"\n",
    "            return True, \"Valid bigBed\"\n",
    "        with open(file_path, 'rb') as f:\n",
    "            f.read(512)\n",
    "        return True, \"Valid binary\"\n",
    "    except:\n",
    "        return False, \"Binary read fail\"\n",
    "\n",
    "def validate_file(file_path):\n",
    "    ext = file_path.suffix.lower()\n",
    "    if ext in ['.csv', '.tsv']:\n",
    "        return validate_csv_tsv(file_path)\n",
    "    elif ext == '.json':\n",
    "        return validate_json(file_path)\n",
    "    elif ext in ['.fa', '.fasta']:\n",
    "        return validate_fa(file_path)\n",
    "    elif ext in ['.gff', '.gtf', '.gff3']:\n",
    "        return validate_gff_gtf(file_path)\n",
    "    elif ext in ['.txt', '.wrm', '.ace', '.obo']:\n",
    "        return validate_text_generic(file_path)\n",
    "    elif ext.endswith('.gz') or ext in ['.bb', '.wib']:\n",
    "        return validate_binary(file_path)\n",
    "    else:\n",
    "        try:\n",
    "            with open(file_path, 'rb') as f:\n",
    "                f.read(512)\n",
    "            return True, \"Basic valid\"\n",
    "        except:\n",
    "            return False, \"Open fail\"\n",
    "\n",
    "def full_purge_restructure(base_dir, dry_run=True):\n",
    "    # Create target structure\n",
    "    data_dir = base_dir / 'data'\n",
    "    logs_dir = base_dir / 'logs'\n",
    "    if not dry_run:\n",
    "        data_dir.mkdir(exist_ok=True)\n",
    "        logs_dir.mkdir(exist_ok=True)\n",
    "    \n",
    "    all_files = [f for f in base_dir.rglob('*') if f.is_file() and f not in [data_dir, logs_dir]]\n",
    "    all_files = sorted(all_files)\n",
    "    \n",
    "    log = {'moves': [], 'deletes': [], 'counts': {'total': len(all_files), 'moved': 0, 'deleted': 0, 'kept_root': 0}, 'errors': []}\n",
    "    \n",
    "    # Backup if not dry (fixed: Create nested dirs before copy)\n",
    "    if not dry_run:\n",
    "        backup_dir = base_dir / f'full_backup_{datetime.now().strftime(\"%Y%m%d_%H%M%S\")}'\n",
    "        backup_dir.mkdir(exist_ok=True)\n",
    "        print(f\"Creating backup: {backup_dir}\")\n",
    "        for file_path in tqdm(all_files, desc=\"Backing up\", unit=\"file\"):\n",
    "            rel = file_path.relative_to(base_dir)\n",
    "            backup_target = backup_dir / rel\n",
    "            backup_target.parent.mkdir(parents=True, exist_ok=True)  # Trailblaze parents\n",
    "            shutil.copy2(file_path, backup_target)\n",
    "        print(\"Backup complete.\")\n",
    "    \n",
    "    # Process files\n",
    "    for file_path in tqdm(all_files, desc=\"Categorizing/Validating\", unit=\"file\"):\n",
    "        rel_path = file_path.relative_to(base_dir)\n",
    "        name_lower = file_path.name.lower()\n",
    "        \n",
    "        # Notebooks: Keep in root\n",
    "        if file_path.suffix == '.ipynb':\n",
    "            log['counts']['kept_root'] += 1\n",
    "            continue\n",
    "        \n",
    "        # Categorize for move\n",
    "        category = 'uncategorized'\n",
    "        for cat, keys in DATA_CATEGORIES.items():\n",
    "            if any(key in name_lower for key in keys):\n",
    "                category = cat\n",
    "                break\n",
    "        \n",
    "        target_subdir = data_dir / category\n",
    "        if not dry_run:\n",
    "            target_subdir.mkdir(exist_ok=True)\n",
    "        \n",
    "        target_path = target_subdir / file_path.name\n",
    "        \n",
    "        # Validate readability\n",
    "        is_readable, reason = validate_file(file_path)\n",
    "        \n",
    "        if not is_readable:\n",
    "            log['counts']['deleted'] += 1\n",
    "            entry = {'path': str(rel_path), 'reason': f\"Corrupted: {reason}\", 'size_kb': round(file_path.stat().st_size / 1024, 2)}\n",
    "            if dry_run:\n",
    "                log['deletes'].append(entry)\n",
    "            else:\n",
    "                try:\n",
    "                    file_path.unlink()\n",
    "                    log['deletes'].append(entry)\n",
    "                except Exception as e:\n",
    "                    log['errors'].append(str(rel_path) + f\": {e}\")\n",
    "        else:\n",
    "            # Readable: Move or keep\n",
    "            if category != 'uncategorized':\n",
    "                log['counts']['moved'] += 1\n",
    "                entry = {'path': str(rel_path), 'to': f\"data/{category}/{file_path.name}\", 'reason': \"Readable data move\", 'size_kb': round(file_path.stat().st_size / 1024, 2)}\n",
    "                if dry_run:\n",
    "                    log['moves'].append(entry)\n",
    "                else:\n",
    "                    shutil.move(file_path, target_path)\n",
    "                    log['moves'].append(entry)\n",
    "            else:\n",
    "                log['counts']['kept_root'] += 1\n",
    "    \n",
    "    # Save log to /logs\n",
    "    if not dry_run:\n",
    "        logs_dir.mkdir(exist_ok=True)\n",
    "    log_path = logs_dir / 'full_purge_log.json'\n",
    "    with open(log_path, 'w') as f:\n",
    "        json.dump(log, f, indent=4)\n",
    "    \n",
    "    # Structure summary\n",
    "    print(f\"\\nRestructure Summary:\")\n",
    "    print(f\"Total files processed: {log['counts']['total']}\")\n",
    "    print(f\"Moved to /data: {log['counts']['moved']}\")\n",
    "    print(f\"Deleted corrupted: {log['counts']['deleted']}\")\n",
    "    print(f\"Kept in root: {log['counts']['kept_root']}\")\n",
    "    print(\"Sample moves:\")\n",
    "    for item in log['moves'][:5]:\n",
    "        print(f\"  - {item['path']} → {item['to']}\")\n",
    "    print(\"Sample deletes:\")\n",
    "    for item in log['deletes'][:5]:\n",
    "        print(f\"  - {item['path']} ({item['reason']})\")\n",
    "    print(f\"Full log: {log_path}\")\n",
    "\n",
    "# For real run (False); dry=True for test\n",
    "full_purge_restructure(BASE_DIR, dry_run=False)"
   ]
