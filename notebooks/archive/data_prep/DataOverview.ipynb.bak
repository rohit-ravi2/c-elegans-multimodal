   "source": [
    "# Cell 4 — Show counts in each new category\n",
    "import os\n",
    "\n",
    "def summarize_folder(base):\n",
    "    summary = []\n",
    "    for sub in sorted(base.iterdir()):\n",
    "        if sub.is_dir():\n",
    "            total_size = sum(\n",
    "                os.path.getsize(os.path.join(root, f))\n",
    "                for root, _, files in os.walk(sub)\n",
    "                for f in files\n",
    "            )\n",
    "            file_count = sum(len(files) for _, _, files in os.walk(sub))\n",
    "            summary.append({\n",
    "                \"folder\": sub.name,\n",
    "                \"file_count\": file_count,\n",
    "                \"size_MB\": round(total_size / (1024 * 1024), 2)\n",
    "            })\n",
    "    return pd.DataFrame(summary).sort_values(\"size_MB\", ascending=False)\n",
    "\n",
    "print(\"📊 Raw folders:\")\n",
    "display(summarize_folder(RAW_DIR))\n",
    "print(\"📊 Processed folders:\")\n",
    "display(summarize_folder(PROCESSED_DIR))\n"
   ]
  },
