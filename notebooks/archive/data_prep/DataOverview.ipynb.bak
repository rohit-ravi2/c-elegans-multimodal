   "source": [
    "import os\n",
    "\n",
    "# Get the directory where the notebook is located (root directory)\n",
    "root_dir = os.getcwd()\n",
    "\n",
    "# List to store empty directories\n",
    "empty_dirs = []\n",
    "\n",
    "# Walk through all directories in the root directory\n",
    "for dirpath, dirnames, filenames in os.walk(root_dir):\n",
    "    # Check if the directory is empty (no files and no subdirectories)\n",
    "    if not dirnames and not filenames:\n",
    "        empty_dirs.append(dirpath)\n",
    "\n",
    "# Print the empty directories\n",
    "if empty_dirs:\n",
    "    print(\"Empty directories found:\")\n",
    "    for dir in empty_dirs:\n",
    "        print(dir)\n",
    "else:\n",
    "    print(\"No empty directories found in the root directory.\")"
   ]
  },
