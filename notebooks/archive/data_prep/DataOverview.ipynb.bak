   "source": [
    "# Cell 2 — Build move plan\n",
    "move_plan = []\n",
    "for folder in type_folders:\n",
    "    name = folder.name.lower()\n",
    "    if name in RAW_EXTS:\n",
    "        target = RAW_DIR / name\n",
    "    elif name in PROCESSED_EXTS:\n",
    "        target = PROCESSED_DIR / name\n",
    "    else:\n",
    "        # default: unknown goes to processed (safer)\n",
    "        target = PROCESSED_DIR / name\n",
    "    move_plan.append((folder, target))\n",
    "\n",
    "print(\"📂 Planned classification:\")\n",
    "for src, dst in move_plan:\n",
    "    print(f\" - {src.name} → {dst}\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 24,
   "id": "1b8db2cd",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✅ Moved 37 folders.\n"
     ]
    }
   ],
   "source": [
    "# Cell 3 — Execute move\n",
    "DRY_RUN = False  # change to False to actually move folders\n",
    "\n",
    "if DRY_RUN:\n",
    "    print(\"ℹ️ DRY_RUN=True — preview only. Set to False to execute.\")\n",
    "else:\n",
    "    moved = 0\n",
    "    for src, dst in move_plan:\n",
    "        if not dst.exists():\n",
    "            dst.parent.mkdir(parents=True, exist_ok=True)\n",
    "        try:\n",
    "            shutil.move(str(src), str(dst))\n",
    "            moved += 1\n",
    "        except Exception as e:\n",
    "            print(f\"⚠️ Could not move {src}: {e}\")\n",
    "    print(f\"✅ Moved {moved} folders.\")\n"
   ]
  },
