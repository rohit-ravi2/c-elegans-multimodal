   ],
   "source": [
    "# Function to preview files matching bio-keywords (limited rows for quick scan)\n",
    "def preview_key_files(base_dir, preview_limit=5):\n",
    "    key_patterns = ['connectome', 'lineage', 'expression', 'motif', 'genome', 'neuron', 'edges']\n",
    "    previews = {}\n",
    "    for root, dirs, filenames in os.walk(base_dir):\n",
    "        for filename in filenames:\n",
    "            if any(pattern in filename.lower() for pattern in key_patterns) and filename.lower().endswith(('.csv', '.tsv', '.xlsx')):\n",
    "                file_path = os.path.join(root, filename)\n",
    "                try:\n",
    "                    if filename.endswith('.csv') or filename.endswith('.tsv'):\n",
    "                        df = pd.read_csv(file_path, nrows=preview_limit, sep='\\t' if '.tsv' in filename else ',')\n",
    "                    elif filename.endswith('.xlsx'):\n",
    "                        df = pd.read_excel(file_path, nrows=preview_limit)\n",
    "                    previews[filename] = df.to_string(index=False)\n",
    "                except Exception as e:\n",
    "                    previews[filename] = f\"Error: {e}\"\n",
    "    \n",
    "    for file, preview in previews.items():\n",
    "        print(f\"\\nPreview of {file}:\")\n",
    "        print(preview)\n",
    "\n",
    "# Run previews\n",
    "preview_key_files(str(BASE_DIR))"
   ]
  },
