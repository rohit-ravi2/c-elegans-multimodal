   "source": [
    "# Cell 1 — Setup paths and scan \"others\" folder\n",
    "import os\n",
    "import pandas as pd\n",
    "from collections import defaultdict\n",
    "\n",
    "OTHERS_DIR = \"data/others\"\n",
    "\n",
    "file_stats = defaultdict(lambda: {\"count\": 0, \"size_MB\": 0.0})\n",
    "\n",
    "for root, _, files in os.walk(OTHERS_DIR):\n",
    "    for f in files:\n",
    "        path = os.path.join(root, f)\n",
    "        if not os.path.isfile(path):\n",
    "            continue\n",
    "        ext = os.path.splitext(f)[1].lower() or \"[no_ext]\"\n",
    "        file_stats[ext][\"count\"] += 1\n",
    "        file_stats[ext][\"size_MB\"] += os.path.getsize(path) / (1024 * 1024)\n",
    "\n",
    "df_ext = (\n",
    "    pd.DataFrame([\n",
    "        {\"extension\": ext, \"count\": info[\"count\"], \"size_MB\": round(info[\"size_MB\"], 2)}\n",
    "        for ext, info in file_stats.items()\n",
    "    ])\n",
    "    .sort_values(by=\"size_MB\", ascending=False)\n",
    "    .reset_index(drop=True)\n",
    ")\n",
    "\n",
    "print(f\"📁 File Type Summary for: {OTHERS_DIR}\\n\")\n",
    "display(df_ext)\n",
    "print(f\"\\nTotal files scanned: {df_ext['count'].sum()}\")\n",
    "print(f\"Total size: {df_ext['size_MB'].sum():.2f} MB\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 23,
   "id": "4b05c09a",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 2 — Organize files in \"others\" by type (optional)\n",
    "import shutil\n",
    "\n",
    "for ext in df_ext[\"extension\"]:\n",
    "    clean_name = ext.strip(\".\") if ext != \"[no_ext]\" else \"no_extension\"\n",
    "    target_dir = os.path.join(OTHERS_DIR, clean_name)\n",
    "    os.makedirs(target_dir, exist_ok=True)\n",
    "\n",
    "    for root, _, files in os.walk(OTHERS_DIR):\n",
    "        for f in files:\n",
    "            path = os.path.join(root, f)\n",
    "            if not os.path.isfile(path):\n",
    "                continue\n",
    "            current_ext = os.path.splitext(f)[1].lower() or \"[no_ext]\"\n",
    "            if current_ext == ext and not os.path.samefile(root, target_dir):\n",
    "                try:\n",
    "                    shutil.move(path, os.path.join(target_dir, f))\n",
    "                except Exception as e:\n",
    "                    print(f\"⚠️ Could not move {f}: {e}\")\n"
   ]
  },
