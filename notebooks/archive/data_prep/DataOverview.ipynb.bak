   "source": [
    "import os\n",
    "import hashlib\n",
    "import json\n",
    "from datetime import datetime\n",
    "\n",
    "def compute_md5(file_path):\n",
    "    \"\"\"Compute MD5 hash of a file.\"\"\"\n",
    "    hash_md5 = hashlib.md5()\n",
    "    with open(file_path, \"rb\") as f:\n",
    "        for chunk in iter(lambda: f.read(4096), b\"\"):\n",
    "            hash_md5.update(chunk)\n",
    "    return hash_md5.hexdigest()\n",
    "\n",
    "def find_and_remove_duplicates(root_dir):\n",
    "    \"\"\"Find and remove duplicate files in root_dir recursively.\"\"\"\n",
    "    # Dictionary to store hash: [file_paths]\n",
    "    hash_dict = {}\n",
    "    # Log for actions taken\n",
    "    log = {\"duplicates_found\": [], \"duplicates_removed\": [], \"errors\": []}\n",
    "    \n",
    "    # Walk through all subdirectories\n",
    "    for dirpath, _, filenames in os.walk(root_dir):\n",
    "        for filename in filenames:\n",
    "            file_path = os.path.join(dirpath, filename)\n",
    "            try:\n",
    "                file_hash = compute_md5(file_path)\n",
    "                if file_hash in hash_dict:\n",
    "                    hash_dict[file_hash].append(file_path)\n",
    "                else:\n",
    "                    hash_dict[file_hash] = [file_path]\n",
    "            except Exception as e:\n",
    "                log[\"errors\"].append(f\"Error processing {file_path}: {str(e)}\")\n",
    "    \n",
    "    # Identify duplicates (files with same hash)\n",
    "    for file_hash, file_paths in hash_dict.items():\n",
    "        if len(file_paths) > 1:\n",
    "            # Keep the first file, mark others as duplicates\n",
    "            keep_file = file_paths[0]\n",
    "            duplicate_files = file_paths[1:]\n",
    "            log[\"duplicates_found\"].append({\n",
    "                \"hash\": file_hash,\n",
    "                \"kept\": keep_file,\n",
    "                \"duplicates\": duplicate_files\n",
    "            })\n",
    "            # Remove duplicate files\n",
    "            for dup_file in duplicate_files:\n",
    "                try:\n",
    "                    os.remove(dup_file)\n",
    "                    log[\"duplicates_removed\"].append(dup_file)\n",
    "                except Exception as e:\n",
    "                    log[\"errors\"].append(f\"Error removing {dup_file}: {str(e)}\")\n",
    "    \n",
    "    # Save log to file\n",
    "    log_file = os.path.join(root_dir, f\"duplicate_removal_log_{datetime.now().strftime('%Y%m%d_%H%M%S')}.json\")\n",
    "    with open(log_file, 'w') as f:\n",
    "        json.dump(log, f, indent=4)\n",
    "    \n",
    "    # Print summary\n",
    "    print(f\"Duplicate removal complete. Log saved to {log_file}\")\n",
    "    print(f\"Files scanned: {sum(len(paths) for paths in hash_dict.values())}\")\n",
    "    print(f\"Unique files: {len(hash_dict)}\")\n",
    "    print(f\"Duplicates found: {sum(len(paths) - 1 for paths in hash_dict.values() if len(paths) > 1)}\")\n",
    "    print(f\"Duplicates removed: {len(log['duplicates_removed'])}\")\n",
    "    print(f\"Errors: {len(log['errors'])}\")\n",
    "    if log[\"errors\"]:\n",
    "        print(\"Errors encountered:\")\n",
    "        for error in log[\"errors\"][:5]:  # Show up to 5 errors\n",
    "            print(f\"  - {error}\")\n",
    "\n",
    "# Run the function\n",
    "data_dir = \"/mnt/ssd4tb/Desktop/C-Elegans/data\"\n",
    "if os.path.exists(data_dir):\n",
    "    find_and_remove_duplicates(data_dir)\n",
    "else:\n",
    "    print(f\"Directory {data_dir} does not exist.\")"
   ]
  },
