    "# Cell 4 — Delete redundant directories\n",
    "import shutil\n",
    "\n",
    "if not suspect_dirs:\n",
    "    print(\"✅ No folders to delete.\")\n",
    "elif DRY_RUN:\n",
    "    print(\"⚠️ DRY_RUN=True — no deletions performed. Change to False and re-run.\")\n",
    "else:\n",
    "    deleted = 0\n",
    "    for d in suspect_dirs:\n",
    "        try:\n",
    "            shutil.rmtree(d)\n",
    "            deleted += 1\n",
    "        except Exception as e:\n",
    "            print(f\"⚠️ Failed to delete {d}: {e}\")\n",
    "    print(f\"🗑️ Deleted {deleted} folders successfully.\")\n"
   ]
