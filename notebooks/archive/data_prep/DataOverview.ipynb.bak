   "source": [
    "from pathlib import Path\n",
    "from tqdm import tqdm\n",
    "import os\n",
    "import re\n",
    "import json\n",
    "from datetime import datetime\n",
    "\n",
    "# Set your base directory (adjust if needed)\n",
    "BASE_DIR = Path('./').resolve()\n",
    "print(f\"Maximal Dry-Run Purge: {BASE_DIR}\")\n",
    "\n",
    "# Expanded criteria (no size, protect .nml, comprehensive patterns)\n",
    "CRITERIA = {\n",
    "    'name_patterns_junk': [  # Comprehensive regex for trash\n",
    "        r'\\.DS_Store$', r'\\.gitignore$', r'\\.gitkeep$', r'\\.__pycache__$',  # Git/Mac/Python\n",
    "        r'\\.swp$', r'\\.swo$', r'~$', r'\\.tmp$', r'\\.bak$', r'\\.pyc$', r'\\.pyo$',  # Edits/temps\n",
    "        r'\\.log$', r'\\.err$', r'\\.out$', r'error|temp|fail|cache|lock|crash|debug',  # Logs/errors\n",
    "        r'index\\.html$', r'\\.ace$', r'\\.xml$',  # Clutter/ACEDB (flag unknowns)\n",
    "        r'COMMIT_EDITMSG$', r'HEAD$', r'\\.git/'  # Git internals\n",
    "    ],\n",
    "    'content_keywords_bad': ['error', 'temp', 'fail', 'cache', 'git', 'debug', 'crash', 'lock'],  # Junk signals\n",
    "    'content_keywords_bio': ['gene', 'wbgene', 'neuron', 'motif', 'expr', 'expression', 'lineage', 'connectome', 'synapse', 'unc', 'sax', 'netrin', 'rob'],  # Worm/bio boost (from Hobert/lit)\n",
    "    'suspicion_threshold': 0,  # <0 score = purge for unknowns\n",
    "    'exclude_dirs': ['organized', '.git', 'backups'],  # Never touch\n",
    "    'exclude_exts': ['.ipynb', '.csv', '.tsv', '.fa', '.gff', '.gtf', '.wrm', '.json', '.pkl', '.npy', '.nml', '.net', '.xml']  # Protect bio/ML/sim (added .nml, .net, .xml)\n",
    "}\n",
    "\n",
    "def suspicion_score(file_path, criteria):\n",
    "    \"\"\"Score for unknowns: Bio words - junk words.\"\"\"\n",
    "    score = 0\n",
    "    try:\n",
    "        with open(file_path, 'r', errors='ignore') as f:\n",
    "            sample = f.read(1024).lower()  # First KB for speed\n",
    "            for kw in criteria['content_keywords_bio']:\n",
    "                score += sample.count(kw)\n",
    "            for kw in criteria['content_keywords_bad']:\n",
    "                score -= 2 * sample.count(kw)\n",
    "    except:\n",
    "        pass  # Binary/non-text: Neutral 0\n",
    "    return score\n",
    "\n",
    "def is_useless(file_path, criteria):\n",
    "    \"\"\"Maximal check: Returns (True, reason) if purge.\"\"\"\n",
    "    name = file_path.name.lower()\n",
    "    \n",
    "    # Protected?\n",
    "    if file_path.suffix in criteria['exclude_exts'] or any(ex in file_path.parent.name for ex in criteria['exclude_dirs']):\n",
    "        return False, \"Protected (ext/dir)\"\n",
    "    \n",
    "    # Junk name?\n",
    "    if any(re.search(pat, name) for pat in criteria['name_patterns_junk']):\n",
    "        return True, \"Junk name pattern\"\n",
    "    \n",
    "    # Unknowns: Low score?\n",
    "    if any(cat in name for cat in ['connectomes', 'lineage', 'expression', 'motif', 'genome', 'neuron']):  # Known categories\n",
    "        return False, \"Known category\"\n",
    "    \n",
    "    # Unknown: Score it\n",
    "    score = suspicion_score(file_path, criteria)\n",
    "    if score < criteria['suspicion_threshold']:\n",
    "        return True, f\"Unknown low score ({score})\"\n",
    "    \n",
    "    return False, \"Kept (relevant)\"\n",
    "\n",
    "def maximal_dry_purge(base_dir):\n",
    "    all_files = [f for f in base_dir.rglob('*') if f.is_file()]\n",
    "    all_files = sorted(all_files)\n",
    "    \n",
    "    log = {'potential_deletes': [], 'counts': {'total': len(all_files), 'purge_candidates': 0, 'kept': 0}, 'errors': []}\n",
    "    \n",
    "    # Progress bar\n",
    "    for file_path in tqdm(all_files, desc=\"Dry-Run Purge Scan\", unit=\"file\"):\n",
    "        rel_path = file_path.relative_to(base_dir)\n",
    "        is_junk, reason = is_useless(file_path, CRITERIA)\n",
    "        \n",
    "        if is_junk:\n",
    "            log['counts']['purge_candidates'] += 1\n",
    "            log['potential_deletes'].append({'path': str(rel_path), 'reason': reason, 'size_kb': round(file_path.stat().st_size / 1024, 2)})\n",
    "        else:\n",
    "            log['counts']['kept'] += 1\n",
    "    \n",
    "    # Save/print log\n",
    "    log_path = base_dir / 'maximal_purge_dry_log.json'\n",
    "    with open(log_path, 'w') as f:\n",
    "        json.dump(log, f, indent=4)\n",
    "    \n",
    "    print(f\"\\nDry-Run Summary: {log['counts']['purge_candidates']}/{log['counts']['total']} candidates for purge.\")\n",
    "    print(\"Top 20 candidates:\")\n",
    "    for item in log['potential_deletes'][:20]:\n",
    "        print(f\"  - {item['path']} ({item['reason']}, {item['size_kb']}KB)\")\n",
    "    print(f\"\\nFull log: {log_path} (inspect for false positives, e.g., grep .nml to confirm kept).\")\n",
    "    \n",
    "    if log['potential_deletes']:\n",
    "        print(f\"\\nSample reasons: {set(item['reason'] for item in log['potential_deletes'][:10])}\")\n",
    "    else:\n",
    "        print(\"No candidates—dir already tidy!\")\n",
    "\n",
    "# Run the dry-run\n",
    "maximal_dry_purge(BASE_DIR)"
   ]
  },
