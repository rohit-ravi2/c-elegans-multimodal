   "source": [
    "import os\n",
    "\n",
    "# Get the root directory (where the notebook is located)\n",
    "root_dir = os.getcwd()\n",
    "\n",
    "# List to store empty directories\n",
    "empty_dirs = []\n",
    "\n",
    "# Get immediate subdirectories in the root directory\n",
    "subdirs = [os.path.join(root_dir, d) for d in os.listdir(root_dir) if os.path.isdir(os.path.join(root_dir, d))]\n",
    "\n",
    "# Check each subdirectory for emptiness\n",
    "for dirpath in subdirs:\n",
    "    # Check if the directory is empty (no files and no subdirectories)\n",
    "    if not os.listdir(dirpath):\n",
    "        empty_dirs.append(dirpath)\n",
    "\n",
    "# Print the empty directories\n",
    "if empty_dirs:\n",
    "    print(\"Empty directories found in C-Elegans/:\")\n",
    "    for dir in empty_dirs:\n",
    "        print(dir)\n",
    "else:\n",
    "    print(\"No empty directories found in C-Elegans/.\")"
   ]
  },
