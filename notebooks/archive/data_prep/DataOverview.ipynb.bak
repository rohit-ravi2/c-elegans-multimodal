   "source": [
    "# Cell 3 — Build move plan (each ext → data/<ext>/)\n",
    "plan = []\n",
    "for _, row in df.iterrows():\n",
    "    src = Path(row[\"path\"])\n",
    "    ext = row[\"ext\"]\n",
    "    target_dir = DATA_DIR / ext\n",
    "    dst = target_dir / src.name\n",
    "    if src.parent != target_dir:\n",
    "        plan.append((src, dst))\n",
    "\n",
    "print(f\"Planned moves: {len(plan)}\")\n",
    "for i, (src, dst) in enumerate(plan[:20], 1):\n",
    "    print(f\"{i:3d}. {src} -> {dst}\")\n",
    "if len(plan) > 20:\n",
    "    print(f\"...and {len(plan)-20} more\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 13,
   "id": "67b8e896",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✅ Moved 472 files.\n"
     ]
    }
   ],
   "source": [
    "# Cell 4 — Execute moves if DRY_RUN=False\n",
    "if DRY_RUN:\n",
    "    print(\"ℹ️ DRY_RUN=True — no files moved. Set DRY_RUN=False to execute.\")\n",
    "else:\n",
    "    moved = 0\n",
    "    for src, dst in plan:\n",
    "        dst.parent.mkdir(parents=True, exist_ok=True)\n",
    "        try:\n",
    "            shutil.move(str(src), str(dst))\n",
    "            moved += 1\n",
    "        except Exception as e:\n",
    "            print(f\"⚠️ Failed to move {src}: {e}\")\n",
    "    print(f\"✅ Moved {moved} files.\")\n"
   ]
  },
