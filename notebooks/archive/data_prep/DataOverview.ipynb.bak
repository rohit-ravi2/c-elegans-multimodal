   "source": [
    "import pandas as pd\n",
    "from pathlib import Path\n",
    "import numpy as np\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "from tqdm import tqdm\n",
    "from scipy.stats import entropy\n",
    "\n",
    "# Paths\n",
    "DATA_DIR = Path('/mnt/ssd4tb/Desktop/C-Elegans/data')\n",
    "expr_df = pd.read_csv(DATA_DIR / 'expressions' / 'gene_expr_CeNGEN_base_mapped.csv', index_col=0)  # ~1k neurons x 20k genes\n",
    "edges_df = pd.read_csv(DATA_DIR / 'connectomes_edges' / 'merged_edges_with_relatedness.csv')  # Weights\n",
    "genome_annot = pd.read_csv(DATA_DIR / 'genomes' / 'genome_data_master.tsv', sep='\\t')  # Gene IDs + annotations\n",
    "\n",
    "# Step 1: Detect and Map Hobert Gene Symbols to WBGene IDs\n",
    "hobert_genes = ['unc-3', 'unc-30', 'tph-1', 'cat-2', 'flp-1', 'nlp-1', 'unc-6', 'unc-40']\n",
    "# Possible column names for gene symbols\n",
    "possible_name_cols = ['Gene_name', 'Gene_symbol', 'Name', 'gene_name', 'gene_symbol']\n",
    "name_col = next((col for col in possible_name_cols if col in genome_annot.columns), None)\n",
    "\n",
    "if name_col is None:\n",
    "    raise KeyError(f\"No recognizable gene name column found in {genome_annot.columns.tolist()}. Please check the file or specify the correct column.\")\n",
    "\n",
    "gene_id_map = dict(zip(genome_annot[name_col].str.lower(), genome_annot['GeneID']))\n",
    "wbgenes = [gene_id_map.get(gene.lower(), gene) for gene in hobert_genes]  # Fallback to name if not found\n",
    "print(f\"Mapped genes: {dict(zip(hobert_genes, wbgenes))}\")  # Debug mapping\n",
    "\n",
    "# Filter expr_df to include only mapped genes\n",
    "valid_wbgenes = [wb for wb in wbgenes if wb in expr_df.columns]\n",
    "if len(valid_wbgenes) < len(wbgenes):\n",
    "    print(f\"Warning: Some genes not found in expr_df: {set(wbgenes) - set(valid_wbgenes)}\")\n",
    "expr_df = expr_df[valid_wbgenes]  # Subset to valid genes\n",
    "\n",
    "# Step 2: Pseudo-Time Ordering (Corrected: Neurons)\n",
    "pca = PCA(n_components=1)\n",
    "expr_scaled = StandardScaler().fit_transform(expr_df)  # Scale neuron expr\n",
    "expr_pca = pca.fit_transform(expr_scaled)  # 1D traj per neuron\n",
    "pseudo_time = np.argsort(expr_pca.flatten())  # Sort neurons by pseudo-time\n",
    "expr_sorted = expr_df.iloc[pseudo_time]  # Reorder neurons\n",
    "\n",
    "# Step 3: Build Markov Transition Matrix (First-Order, Per Gene)\n",
    "n_states = 5  # Discretize expr into 5 bins (low to high)\n",
    "trans_matrix = np.zeros((n_states, n_states))\n",
    "\n",
    "for gene in tqdm(valid_wbgenes):\n",
    "    expr_series = expr_sorted[gene].values  # Expr across neurons in pseudo-time\n",
    "    bins = np.digitize(expr_series, np.percentile(expr_series, np.linspace(0, 100, n_states+1)))\n",
    "    for i in range(len(bins) - 1):\n",
    "        current_state = bins[i] - 1  # 0-based index\n",
    "        next_state = bins[i + 1] - 1  # 0-based index\n",
    "        if 0 <= current_state < n_states and 0 <= next_state < n_states:\n",
    "            trans_matrix[current_state, next_state] += 1  # Transition count\n",
    "trans_matrix = trans_matrix / trans_matrix.sum(axis=1, keepdims=True)  # Normalize to probs\n",
    "\n",
    "# Entropy (Rigor Check: Low entropy = predictable transitions)\n",
    "entropies = [entropy(row[row > 0]) for row in trans_matrix]\n",
    "print(f\"Transition Entropies: {entropies} (gate <0.5 = predictable)\")\n",
    "\n",
    "# Step 4: Link to Weights (Corr with Mean Weight per State)\n",
    "# Aggregate weights by neuron (mean chem weight as proxy)\n",
    "neuron_weights = edges_df.groupby('pre')[['chem_weight']].mean().reindex(expr_df.index).fillna(0)\n",
    "state_weights = np.array([neuron_weights.iloc[pseudo_time][bins == i + 1].mean() for i in range(n_states)])\n",
    "\n",
    "# Corr between state transition probs and weight changes\n",
    "weight_corr = [np.corrcoef(trans_matrix[i], np.diff(state_weights, prepend=state_weights[0]))[0, 1]\n",
    "               for i in range(n_states) if trans_matrix[i].sum() > 0]\n",
    "print(f\"Weight Correlations: {weight_corr} (gate >0.6 = functional link)\")\n",
    "\n",
    "# Output: Top genes by corr (average per gene transition impact)\n",
    "gene_corrs = []\n",
    "for gene in valid_wbgenes:\n",
    "    expr_series = expr_sorted[gene].values\n",
    "    bins = np.digitize(expr_series, np.percentile(expr_series, np.linspace(0, 100, n_states+1)))\n",
    "    state_weights_gene = np.array([neuron_weights.iloc[pseudo_time][bins == i + 1].mean() for i in range(n_states)])\n",
    "    corr = np.corrcoef(trans_matrix.mean(axis=0), np.diff(state_weights_gene, prepend=state_weights_gene[0]))[0, 1]\n",
    "    gene_corrs.append((gene_id_map.get(next((k for k, v in gene_id_map.items() if v == gene), gene), gene), corr))\n",
    "top_genes = sorted(gene_corrs, key=lambda x: abs(x[1]), reverse=True)[:3]\n",
    "print(f\"Top genes by weight link: {top_genes}\")"
   ]
  },
