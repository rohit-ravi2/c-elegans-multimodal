   "source": [
    "from pathlib import Path\n",
    "from tqdm import tqdm\n",
    "import os\n",
    "import shutil\n",
    "import hashlib\n",
    "import json\n",
    "\n",
    "# Set your base directory (adjust if needed)\n",
    "BASE_DIR = Path('./').resolve()\n",
    "print(f\"Cleaning: {BASE_DIR}\")\n",
    "\n",
    "# Define categories based on Cell 4 + extensions (customize if needed)\n",
    "CATEGORIES = {\n",
    "    'connectomes_edges': ['connectome', 'edges', 'synapse', 'adjacency'],\n",
    "    'lineages': ['lineage', 'neuronlineage'],\n",
    "    'expressions': ['expr', 'expression', 'gene_expr', 'rna', 'transcript'],\n",
    "    'motifs': ['motif', 'participation', 'enrichment', 'spearman'],\n",
    "    'genomes': ['genome', 'genomic', 'fa', 'gff', 'gtf', 'cds', 'protein', 'mrna', 'wrm', 'block'],\n",
    "    'neurons_metadata': ['neuron', 'meta', 'tuple', 'cells', 'cengen', 'neuronconnect'],\n",
    "    'others': []  # Catch-all\n",
    "}\n",
    "\n",
    "# Function for recursive cleanup with progress\n",
    "def clean_directory(base_dir, dry_run=True):\n",
    "    # Find all files recursively (exclude dirs)\n",
    "    all_files = [f for f in base_dir.rglob('*') if f.is_file()]\n",
    "    all_files = sorted(all_files)\n",
    "    \n",
    "    # Create organized subdir\n",
    "    organized_dir = base_dir / 'organized'\n",
    "    if not dry_run:\n",
    "        organized_dir.mkdir(exist_ok=True)\n",
    "    \n",
    "    # Log for actions/undo\n",
    "    log = {'moves': [], 'duplicates_deleted': [], 'empties_removed': [], 'errors': []}\n",
    "    \n",
    "    # Progress bar for files (categorize & move/dedup)\n",
    "    file_hashes = {}  # For dedup: path -> hash\n",
    "    for file_path in tqdm(all_files, desc=\"Processing files\", unit=\"file\"):\n",
    "        rel_path = file_path.relative_to(base_dir)\n",
    "        lower_name = file_path.name.lower()\n",
    "        \n",
    "        # Determine category\n",
    "        category = 'others'\n",
    "        for cat, keys in CATEGORIES.items():\n",
    "            if any(key in lower_name for key in keys):\n",
    "                category = cat\n",
    "                break\n",
    "        \n",
    "        # Target subdir\n",
    "        target_subdir = organized_dir / category\n",
    "        if not dry_run:\n",
    "            target_subdir.mkdir(exist_ok=True)\n",
    "        \n",
    "        # Dedup check: Compute MD5 hash\n",
    "        try:\n",
    "            with open(file_path, 'rb') as f:\n",
    "                file_hash = hashlib.md5(f.read()).hexdigest()\n",
    "            if file_hash in file_hashes:\n",
    "                dup_of = file_hashes[file_hash]\n",
    "                log['duplicates_deleted'].append(str(rel_path) + f\" (dup of {dup_of})\")\n",
    "                if not dry_run:\n",
    "                    file_path.unlink()  # Delete dup\n",
    "                continue\n",
    "            file_hashes[file_hash] = str(rel_path)\n",
    "        except Exception as e:\n",
    "            log['errors'].append(str(rel_path) + f\": {e}\")\n",
    "            continue\n",
    "        \n",
    "        # Move\n",
    "        target_path = target_subdir / file_path.name\n",
    "        if dry_run:\n",
    "            print(f\"[DRY] Would move {rel_path} to {category}/{file_path.name}\")\n",
    "        else:\n",
    "            shutil.move(file_path, target_path)\n",
    "            log['moves'].append(str(rel_path) + f\" -> {category}/{file_path.name}\")\n",
    "    \n",
    "    # Clean empty folders (recursive, with progress)\n",
    "    all_dirs = sorted([d for d in base_dir.rglob('*') if d.is_dir()], reverse=True)  # Bottom-up\n",
    "    for dir_path in tqdm(all_dirs, desc=\"Cleaning empty dirs\", unit=\"dir\"):\n",
    "        if not any(dir_path.iterdir()) and dir_path != organized_dir:  # Empty and not our new dir\n",
    "            if dry_run:\n",
    "                print(f\"[DRY] Would remove empty: {dir_path.relative_to(base_dir)}\")\n",
    "            else:\n",
    "                dir_path.rmdir()\n",
    "                log['empties_removed'].append(str(dir_path.relative_to(base_dir)))\n",
    "    \n",
    "    # Save log\n",
    "    log_path = base_dir / 'cleanup_log.json'\n",
    "    if not dry_run:\n",
    "        with open(log_path, 'w') as f:\n",
    "            json.dump(log, f, indent=4)\n",
    "    else:\n",
    "        print(\"\\n[DRY RUN LOG SAMPLE]:\")\n",
    "        print(json.dumps(log, indent=4)[:500] + \"...\")  # Truncated preview\n",
    "\n",
    "    print(\"\\nCleanup complete! Log at: cleanup_log.json\")\n",
    "\n",
    "# Run with dry_run=True first; set False for real cleanup\n",
    "clean_directory(BASE_DIR, dry_run=False)"
   ]
