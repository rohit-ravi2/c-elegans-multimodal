   "source": [
    "# Function to categorize and identify gaps (based on expected worm data)\n",
    "def categorize_and_flag_gaps(base_dir):\n",
    "    categories = {\n",
    "        'Connectomes/Edges': [], 'Lineages': [], 'Expressions': [], 'Motifs': [], 'Genomes': [], 'Neurons/Metadata': [], 'Others': []\n",
    "    }\n",
    "    for root, dirs, filenames in os.walk(base_dir):\n",
    "        for filename in filenames:\n",
    "            lower = filename.lower()\n",
    "            if 'connectome' in lower or 'edges' in lower:\n",
    "                categories['Connectomes/Edges'].append(filename)\n",
    "            elif 'lineage' in lower:\n",
    "                categories['Lineages'].append(filename)\n",
    "            elif 'expression' in lower or 'expr' in lower:\n",
    "                categories['Expressions'].append(filename)\n",
    "            elif 'motif' in lower:\n",
    "                categories['Motifs'].append(filename)\n",
    "            elif 'genome' in lower:\n",
    "                categories['Genomes'].append(filename)\n",
    "            elif 'neuron' in lower or 'meta' in lower:\n",
    "                categories['Neurons/Metadata'].append(filename)\n",
    "            else:\n",
    "                categories['Others'].append(filename)\n",
    "    \n",
    "    print(\"\\nCategorized Data:\")\n",
    "    for cat, items in categories.items():\n",
    "        print(f\"{cat}: {', '.join(items) if items else 'None found'}\")\n",
    "    \n",
    "    expected = ['Connectomes/Edges', 'Lineages', 'Expressions', 'Motifs', 'Genomes', 'Neurons/Metadata']\n",
    "    missing = [cat for cat in expected if not categories[cat]]\n",
    "    print(\"\\nPotentially Missing (for full worm analysis):\")\n",
    "    print(', '.join(missing) if missing else \"None apparent—check for quality/completeness.\")\n",
    "\n",
    "# Run categorization\n",
    "categorize_and_flag_gaps(str(BASE_DIR))"
   ]
  },
