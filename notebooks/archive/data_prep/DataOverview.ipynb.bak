   "source": [
    "# Cell 5 — Summarize the new structure after reorganization\n",
    "new_summary = defaultdict(lambda: {\"count\": 0, \"size_MB\": 0.0})\n",
    "\n",
    "for sub in os.listdir(DATA_DIR):\n",
    "    sub_path = DATA_DIR / sub\n",
    "    if sub_path.is_dir():\n",
    "        for root, _, files in os.walk(sub_path):\n",
    "            for f in files:\n",
    "                fp = Path(root) / f\n",
    "                new_summary[sub][\"count\"] += 1\n",
    "                new_summary[sub][\"size_MB\"] += fp.stat().st_size / (1024 * 1024)\n",
    "\n",
    "df_new = pd.DataFrame([\n",
    "    {\"folder\": k, \"count\": v[\"count\"], \"size_MB\": round(v[\"size_MB\"], 2)}\n",
    "    for k, v in new_summary.items()\n",
    "]).sort_values(\"size_MB\", ascending=False).reset_index(drop=True)\n",
    "\n",
    "print(\"📂 Final data/ structure summary:\")\n",
    "display(df_new)\n"
   ]
  },
