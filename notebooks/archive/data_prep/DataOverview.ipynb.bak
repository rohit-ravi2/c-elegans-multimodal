   "source": [
    "# Function to find and list files by type/size (focus on data formats)\n",
    "def scan_files(base_dir, extensions=['.csv', '.tsv', '.xlsx', '.pdf', '.pkl', '.gml', '.json']):\n",
    "    files = []\n",
    "    for root, dirs, filenames in os.walk(base_dir):\n",
    "        for filename in filenames:\n",
    "            if any(filename.lower().endswith(ext) for ext in extensions):\n",
    "                file_path = os.path.join(root, filename)\n",
    "                size_kb = os.path.getsize(file_path) / 1024\n",
    "                files.append({\n",
    "                    'Path': os.path.relpath(file_path, base_dir),\n",
    "                    'Size (KB)': round(size_kb, 2),\n",
    "                    'Extension': os.path.splitext(filename)[1].lower()\n",
    "                })\n",
    "    \n",
    "    df_files = pd.DataFrame(files)\n",
    "    if not df_files.empty:\n",
    "        print(\"Found files:\")\n",
    "        print(df_files.sort_values('Path').to_string(index=False))\n",
    "    else:\n",
    "        print(\"No relevant files found.\")\n",
    "\n",
    "# Run the scan\n",
    "scan_files(str(BASE_DIR))"
   ]
  },
