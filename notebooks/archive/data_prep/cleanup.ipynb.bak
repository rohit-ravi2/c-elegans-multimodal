    "import pandas as pd\n",
    "\n",
    "# Load substitute files (just show shape and columns)\n",
    "files = {\n",
    "    \"motif_participation_profiles.csv\": \"data/root_csvs/motif_participation_profiles.csv\",\n",
    "    \"merged_lineage_table.csv\": \"data/root_csvs/merged_lineage_table.csv\",\n",
    "    \"top_rich_motif_neurons.csv\": \"data/root_csvs/top_rich_motif_neurons.csv\"\n",
    "}\n",
    "\n",
    "for name, path in files.items():\n",
    "    try:\n",
    "        df = pd.read_csv(path)\n",
    "        print(f\"✅ {name} — Shape: {df.shape}\")\n",
    "        print(\"📌 Columns:\", df.columns.tolist())\n",
    "        print()\n",
    "    except Exception as e:\n",
    "        print(f\"❌ Failed to load {name}: {e}\")\n"
