   "source": [
    "# === Track 3 — Part 1 (Data Freeze) & Part 2 (Splits) ===\n",
    "# Notebook: track3_part1_part2.ipynb\n",
    "# Requirements: pandas, numpy, networkx, scipy, scikit-learn, tqdm, pyarrow, fastparquet\n",
    "\n",
    "import os, json, math, sys, re, warnings\n",
    "from pathlib import Path\n",
    "from collections import defaultdict, Counter\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import networkx as nx\n",
    "\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "from sklearn.cluster import KMeans\n",
    "from sklearn.model_selection import StratifiedShuffleSplit\n",
    "from sklearn.metrics import pairwise_distances\n",
    "from tqdm import tqdm\n",
    "\n",
    "warnings.filterwarnings(\"ignore\", category=UserWarning)\n",
    "\n",
    "# --- Project paths\n",
    "ROOT = Path.cwd()\n",
    "T3 = ROOT / \"track3\"\n",
    "DATA = T3 / \"data\"\n",
    "SPLITS = DATA / \"splits\"\n",
    "REPORTS = T3 / \"reports\"\n",
    "FIGS = REPORTS / \"figures\"\n",
    "\n",
    "for p in [DATA, SPLITS, REPORTS, FIGS]:\n",
    "    p.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "# --- Input files (adjust if your filenames differ)\n",
    "FILE_MOTIFS   = ROOT / \"motif_participation_profiles.csv\"   # expects 'Neuron' + 419 motif columns\n",
    "FILE_LATENTS  = ROOT / \"latents_k2.pkl\"                     # DataFrame or dict with index 'Neuron' (110 dims)\n",
    "FILE_META     = ROOT / \"neuron_metadata.csv\"                # expects Neuron, Type, optional: BodyRegion, Side, IsGlia\n",
    "FILE_EDGES    = ROOT / \"merged_edges_with_relatedness.csv\"                   # expects Source, Target, Type ∈ {chemical,electrical}, SynapseCount\n",
    "\n",
    "# --- Outputs (frozen artifacts)\n",
    "OUT_GRAPH_PKL      = DATA / \"graph_final.pkl\"\n",
    "OUT_GRAPH_STATS    = DATA / \"graph_stats.json\"\n",
    "OUT_STRUCT_PARQ    = DATA / \"structural_features.parquet\"\n",
    "OUT_LINEAGE_PARQ   = DATA / \"lineage_features.parquet\"\n",
    "OUT_FEATURES_PARQ  = DATA / \"features_frozen.parquet\"\n",
    "OUT_LABELS_JSON    = DATA / \"label_manifest.json\"\n",
    "OUT_COLUMNS_JSON   = DATA / \"column_dictionary.json\"\n",
    "\n",
    "# --- Split outputs\n",
    "SEEDS = [13, 21, 34, 55, 89]\n",
    "SPLIT_FILES_RANDOM = {s: SPLITS / f\"random_seed{s}.json\" for s in SEEDS}\n",
    "SPLIT_FILES_BLOCK  = {s: SPLITS / f\"lineageblocked_seed{s}.json\" for s in SEEDS}\n",
    "GROUPS_FILES       = {s: SPLITS / f\"lineage_groups_seed{s}.parquet\" for s in SEEDS}\n",
    "AUDIT_DIR          = REPORTS / \"split_audits\"\n",
    "AUDIT_DIR.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "print(\"✔️ Paths ready.\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 16,
   "id": "010b70b3",
   "metadata": {},
   "outputs": [],
   "source": [
    "def read_latents_any(path: Path, fallback_index: pd.Index | None = None) -> pd.DataFrame:\n",
    "    \"\"\"\n",
    "    Robust loader for lineage/latent embeddings → DataFrame with index 'Neuron' and columns lin_0..lin_(d-1).\n",
    "\n",
    "    Now supports: list of 2D tensors/arrays where each item corresponds to ONE neuron/graph\n",
    "    and contains rows for nodes within that graph. We take the FIRST ROW per item (center neuron),\n",
    "    matching our Track 1 convention.\n",
    "    \"\"\"\n",
    "    obj = pd.read_pickle(path)\n",
    "\n",
    "    def to_numpy(x):\n",
    "        # Duck-typed torch.Tensor support without importing torch\n",
    "        if hasattr(x, \"detach\") and callable(getattr(x, \"detach\")):\n",
    "            try:\n",
    "                return x.detach().cpu().numpy()\n",
    "            except Exception:\n",
    "                return np.asarray(x)\n",
    "        return np.asarray(x)\n",
    "\n",
    "    def to_df(ids, X):\n",
    "        X = to_numpy(X)\n",
    "        if X.ndim == 1:\n",
    "            X = X.reshape(-1, 1)\n",
    "        if ids is None:\n",
    "            if fallback_index is None or len(fallback_index) != X.shape[0]:\n",
    "                raise ValueError(\n",
    "                    f\"No neuron IDs provided and fallback_index is unusable. \"\n",
    "                    f\"Got X shape {X.shape}, fallback_index len \"\n",
    "                    f\"{len(fallback_index) if fallback_index is not None else 'None'}.\"\n",
    "                )\n",
    "            ids = list(fallback_index)\n",
    "        cols = [f\"lin_{i}\" for i in range(X.shape[1])]\n",
    "        return pd.DataFrame(X, index=pd.Index(ids, name=\"Neuron\"), columns=cols)\n",
    "\n",
    "    # --- Direct formats handled early ---\n",
    "    if isinstance(obj, pd.DataFrame):\n",
    "        df = obj.copy()\n",
    "        if 'Neuron' in df.columns:\n",
    "            df = df.set_index('Neuron')\n",
    "        new_cols = {c: f\"lin_{i}\" for i, c in enumerate(df.columns) if not str(c).startswith(\"lin_\")}\n",
    "        return df.rename(columns=new_cols)\n",
    "\n",
    "    if isinstance(obj, dict):\n",
    "        low = {k.lower(): k for k in obj.keys()}\n",
    "        id_keys = [k for k in ['neurons','ids','index','nodes','names'] if k in low]\n",
    "        x_keys  = [k for k in ['x','z','emb','embeddings','latents','vectors','data','array'] if k in low]\n",
    "\n",
    "        ids = None\n",
    "        X = None\n",
    "        if x_keys:\n",
    "            X = obj[low[x_keys[0]]]\n",
    "        if id_keys:\n",
    "            ids = obj[low[id_keys[0]]]\n",
    "            if isinstance(ids, (pd.Index, pd.Series)):\n",
    "                ids = list(ids.values if isinstance(ids, pd.Series) else ids)\n",
    "\n",
    "        if isinstance(X, pd.DataFrame):\n",
    "            df = X.copy()\n",
    "            if 'Neuron' in df.columns:\n",
    "                df = df.set_index('Neuron')\n",
    "            new_cols = {c: f\"lin_{i}\" for i, c in enumerate(df.columns) if not str(c).startswith(\"lin_\")}\n",
    "            return df.rename(columns=new_cols)\n",
    "\n",
    "        if X is not None:\n",
    "            return to_df(ids, X)\n",
    "\n",
    "        raise ValueError(\"Unsupported dict structure for latents. Keys: \" + \", \".join(obj.keys()))\n",
    "\n",
    "    if isinstance(obj, (tuple, list)) and len(obj) == 2 and not isinstance(obj[0], dict):\n",
    "        a, b = obj\n",
    "        if isinstance(a, (list, tuple, pd.Index, pd.Series)) and (hasattr(b, \"shape\") or hasattr(b, \"detach\")):\n",
    "            ids = list(a if not isinstance(a, pd.Series) else a.values)\n",
    "            return to_df(ids, b)\n",
    "        if (hasattr(a, \"shape\") or hasattr(a, \"detach\")) and isinstance(b, (list, tuple, pd.Index, pd.Series)):\n",
    "            ids = list(b if not isinstance(b, pd.Series) else b.values)\n",
    "            return to_df(ids, a)\n",
    "        if hasattr(a, \"shape\") or hasattr(a, \"detach\"):\n",
    "            return to_df(None, a)\n",
    "\n",
    "    # --- LIST formats (including list of tensors/arrays) ---\n",
    "    if isinstance(obj, list):\n",
    "        if len(obj) == 0:\n",
    "            raise ValueError(\"Latents list is empty.\")\n",
    "\n",
    "        first = obj[0]\n",
    "\n",
    "        # Single wrapper → unwrap\n",
    "        if len(obj) == 1 and (isinstance(first, (pd.DataFrame, np.ndarray, list)) or hasattr(first, \"detach\")):\n",
    "            inner = first\n",
    "            if isinstance(inner, pd.DataFrame):\n",
    "                df = inner.copy()\n",
    "                if 'Neuron' in df.columns:\n",
    "                    df = df.set_index('Neuron')\n",
    "                new_cols = {c: f\"lin_{i}\" for i, c in enumerate(df.columns) if not str(c).startswith(\"lin_\")}\n",
    "                return df.rename(columns=new_cols)\n",
    "            return to_df(None, inner)\n",
    "\n",
    "        # List of dicts\n",
    "        if isinstance(first, dict):\n",
    "            id_keys = ['neuron','id','name','node','Neuron','ID','Name']\n",
    "            x_keys  = ['embedding','emb','vector','latent','feat','features','X','data']\n",
    "            ids, Xs = [], []\n",
    "            for item in obj:\n",
    "                nid = next((item[k] for k in id_keys if k in item), None)\n",
    "                vec_raw = next((item[k] for k in x_keys if k in item), None)\n",
    "                if vec_raw is None:\n",
    "                    raise ValueError(\"Latents dict item missing embedding/vector.\")\n",
    "                vec = to_numpy(vec_raw)\n",
    "                # If 2D, take first row (center neuron)\n",
    "                if vec.ndim == 2:\n",
    "                    vec = vec[0]\n",
    "                Xs.append(vec)\n",
    "                ids.append(nid)\n",
    "            X = np.vstack([x.reshape(1, -1) if x.ndim == 1 else x for x in Xs])\n",
    "            if any(i is None for i in ids):\n",
    "                ids = None\n",
    "            return to_df(ids, X)\n",
    "\n",
    "        # List of tuples: (id, vec) or (vec, id)\n",
    "        if isinstance(first, (tuple, list)) and len(first) == 2:\n",
    "            ids, Xs = [], []\n",
    "            for a, b in obj:\n",
    "                if (isinstance(a, (list, np.ndarray)) or hasattr(a, \"detach\")) and isinstance(b, str):\n",
    "                    vec = to_numpy(a); nid = b\n",
    "                elif (isinstance(b, (list, np.ndarray)) or hasattr(b, \"detach\")) and isinstance(a, str):\n",
    "                    vec = to_numpy(b); nid = a\n",
    "                else:\n",
    "                    vec = to_numpy(a); nid = None\n",
    "                if vec.ndim == 2:\n",
    "                    vec = vec[0]\n",
    "                Xs.append(vec)\n",
    "                ids.append(nid)\n",
    "            X = np.vstack([x.reshape(1, -1) if x.ndim == 1 else x for x in Xs])\n",
    "            if any(i is None for i in ids):\n",
    "                ids = None\n",
    "            return to_df(ids, X)\n",
    "\n",
    "        # ✅ List of tensors/arrays/vectors: one item per neuron/graph\n",
    "        if isinstance(first, (list, np.ndarray)) or hasattr(first, \"detach\"):\n",
    "            rows = []\n",
    "            for item in obj:\n",
    "                arr = to_numpy(item)\n",
    "                # If 2D (n_i × d), take FIRST ROW as representative embedding (center neuron)\n",
    "                if arr.ndim == 2:\n",
    "                    rows.append(arr[0])\n",
    "                elif arr.ndim == 1:\n",
    "                    rows.append(arr)\n",
    "                else:\n",
    "                    raise ValueError(f\"Unsupported latent item ndim={arr.ndim}\")\n",
    "            X = np.vstack([r.reshape(1, -1) if r.ndim == 1 else r for r in rows])\n",
    "            # IMPORTANT: Now rows == len(obj). Use fallback_index for IDs.\n",
    "            return to_df(None, X)\n",
    "\n",
    "        raise ValueError(f\"Unsupported list format for latents. First element type: {type(first)}\")\n",
    "\n",
    "    # Raw array/tensor\n",
    "    if hasattr(obj, \"shape\") or hasattr(obj, \"detach\"):\n",
    "        return to_df(None, obj)\n",
    "\n",
    "    raise ValueError(\"Unknown latents format; provide DataFrame, dict, tuple/list, or ndarray.\")\n",
    "\n",
    "\n",
    "\n",
    "def bilateral_base(neuron: str) -> str:\n",
    "    m = re.match(r\"^(.*?)([LR])$\", neuron)\n",
    "    return m.group(1) if m else neuron\n",
    "\n",
    "\n",
    "def clip_to_percentile(series: pd.Series, p: float = 99.0) -> pd.Series:\n",
    "    cap = np.percentile(series.values, p) if len(series) else 0.0\n",
    "    return np.minimum(series.values, cap)\n",
    "\n",
    "\n",
    "def save_json(path: Path, obj: dict):\n",
    "    with open(path, \"w\") as f:\n",
    "        json.dump(obj, f, indent=2)\n",
    "\n",
    "\n",
    "def load_csv_required(path: Path, required_cols):\n",
    "    df = pd.read_csv(path)\n",
    "    missing = [c for c in required_cols if c not in df.columns]\n",
    "    if missing:\n",
    "        raise ValueError(f\"{path.name} missing required columns: {missing}\")\n",
    "    return df\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 17,
   "id": "2eb6887c",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Motifs shape: (1533, 418) (accepting provided columns; previously expected ~419)\n",
      "Latents shape: (1533, 32) (expect ≈1533×110; IDs resolved = True)\n",
      "Edges shape: (27727, 6)\n",
      "\n",
      "Nulls:\n",
      "  motifs nulls: 0\n",
      "  latents nulls: 0\n",
      "  metadata nulls: 4599\n",
      "  edges nulls: 16242\n",
      "\n",
      "Neuron coverage in all (motifs ∩ latents ∩ metadata): 1533 of 1533 = 1.000\n"
     ]
    }
   ],
   "source": [
    "# Motifs\n",
    "motifs = pd.read_csv(FILE_MOTIFS)\n",
    "if 'Neuron' not in motifs.columns:\n",
    "    raise ValueError(\"motif_participation_profiles.csv must contain a 'Neuron' column.\")\n",
    "motifs = motifs.drop_duplicates(subset=['Neuron']).set_index('Neuron')\n",
    "motif_cols = list(motifs.columns)\n",
    "print(f\"Motifs shape: {motifs.shape} (accepting provided columns; previously expected ~419)\")\n",
    "\n",
    "# Metadata (loaded early so we can use its index as a fallback for latents if needed)\n",
    "meta_req = ['Neuron', 'Type']\n",
    "metadata = load_csv_required(FILE_META, meta_req).drop_duplicates(subset=['Neuron']).set_index('Neuron')\n",
    "for opt in ['BodyRegion', 'Side', 'IsGlia']:\n",
    "    if opt not in metadata.columns:\n",
    "        metadata[opt] = np.nan\n",
    "\n",
    "# Choose best fallback index for latents alignment if IDs are missing:\n",
    "# prefer motifs index (most complete), else metadata index\n",
    "fallback_idx = motifs.index if len(motifs.index) >= len(metadata.index) else metadata.index\n",
    "\n",
    "# Latents\n",
    "try:\n",
    "    latents = read_latents_any(FILE_LATENTS, fallback_index=fallback_idx)\n",
    "except Exception as e:\n",
    "    # Debugging aid: peek at object type/keys to help the error message\n",
    "    obj = pd.read_pickle(FILE_LATENTS)\n",
    "    info = f\"type={type(obj)}\"\n",
    "    if isinstance(obj, dict):\n",
    "        info += f\", keys={list(obj.keys())[:10]}\"\n",
    "    raise ValueError(f\"Failed to load latents: {e}\\nPeek: {info}\") from e\n",
    "\n",
    "latents = latents.loc[~latents.index.duplicated(keep='first')].copy()\n",
    "latent_cols = list(latents.columns)\n",
    "print(f\"Latents shape: {latents.shape} (expect ≈1533×110; IDs resolved = {latents.index.name=='Neuron'})\")\n",
    "\n",
    "# Edges\n",
    "edges_req = ['Source', 'Target', 'Type', 'SynapseCount']\n",
    "edges = load_csv_required(FILE_EDGES, edges_req).copy()\n",
    "print(f\"Edges shape: {edges.shape}\")\n",
    "\n",
    "# Basic sanity\n",
    "print(\"\\nNulls:\")\n",
    "print(\"  motifs nulls:\", int(motifs.isna().sum().sum()))\n",
    "print(\"  latents nulls:\", int(latents.isna().sum().sum()))\n",
    "print(\"  metadata nulls:\", int(metadata.isna().sum().sum()))\n",
    "print(\"  edges nulls:\", int(edges.isna().sum().sum()))\n",
    "\n",
    "# Intersections\n",
    "common_neurons = sorted(set(motifs.index) & set(latents.index) & set(metadata.index))\n",
    "coverage = len(common_neurons) / len(set(motifs.index))\n",
    "print(f\"\\nNeuron coverage in all (motifs ∩ latents ∩ metadata): {len(common_neurons)} \"\n",
    "      f\"of {len(set(motifs.index))} = {coverage:.3f}\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 19,
   "id": "0164c677",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✔️ Graph constructed with 1533 nodes and 13875 edges.\n"
     ]
    }
   ],
   "source": [
    "# Decide direction rules (frozen by plan):\n",
    "# - chemical: directed edges u->v with weight in w_chem\n",
    "# - electrical: treat as undirected by doubling (u->v and v->u), weight in w_elec\n",
    "\n",
    "edges['Type'] = edges['Type'].str.lower().str.strip()\n",
    "if not set(edges['Type']).issubset({'chemical', 'electrical'}):\n",
    "    raise ValueError(\"Edge 'Type' must be in {'chemical','electrical'}\")\n",
    "\n",
    "chem_mask = edges['Type'] == 'chemical'\n",
    "elec_mask = edges['Type'] == 'electrical'\n",
    "\n",
    "# Clip weights at P99 per channel\n",
    "chem_counts = edges.loc[chem_mask, 'SynapseCount'].fillna(0).astype(float)\n",
    "elec_counts = edges.loc[elec_mask, 'SynapseCount'].fillna(0).astype(float)\n",
    "\n",
    "chem_clip = clip_to_percentile(chem_counts, 99.0)\n",
    "elec_clip = clip_to_percentile(elec_counts, 99.0)\n",
    "\n",
    "edges.loc[chem_mask, 'w_chem'] = chem_clip\n",
    "edges.loc[chem_mask, 'w_elec'] = 0.0\n",
    "edges.loc[elec_mask, 'w_elec'] = elec_clip\n",
    "edges.loc[elec_mask, 'w_chem'] = 0.0\n",
    "\n",
    "# Build graph\n",
    "G = nx.DiGraph()\n",
    "# Add nodes (union across datasets we care about)\n",
    "all_nodes = sorted(set(motifs.index) | set(latents.index) | set(metadata.index))\n",
    "G.add_nodes_from(all_nodes)\n",
    "\n",
    "# Add chemical edges\n",
    "for _, r in edges.loc[chem_mask].iterrows():\n",
    "    u, v = r['Source'], r['Target']\n",
    "    if u == v:\n",
    "        continue  # drop self-loops by default\n",
    "    w_chem = float(r['w_chem'])\n",
    "    if G.has_edge(u, v):\n",
    "        G[u][v]['w_chem'] = G[u][v].get('w_chem', 0.0) + w_chem\n",
    "    else:\n",
    "        G.add_edge(u, v, w_chem=w_chem, w_elec=0.0)\n",
    "\n",
    "# Add electrical edges (both directions)\n",
    "for _, r in edges.loc[elec_mask].iterrows():\n",
    "    u, v = r['Source'], r['Target']\n",
    "    if u == v:\n",
    "        continue\n",
    "    w_elec = float(r['w_elec'])\n",
    "    for a, b in [(u, v), (v, u)]:\n",
    "        if G.has_edge(a, b):\n",
    "            G[a][b]['w_elec'] = G[a][b].get('w_elec', 0.0) + w_elec\n",
    "        else:\n",
    "            G.add_edge(a, b, w_chem=0.0, w_elec=w_elec)\n",
    "\n",
    "# Remove isolated nodes that are not in common_neurons? We keep all for now; features fill will handle.\n",
    "import pickle\n",
    "with open(OUT_GRAPH_PKL, \"wb\") as f:\n",
    "    pickle.dump(G, f)\n",
    "\n",
    "print(f\"✔️ Graph constructed with {G.number_of_nodes()} nodes and {G.number_of_edges()} edges.\")\n"
   ]
  },
