   "source": [
    "# === Cell 5 — Sprint Run (path-agnostic, builds Data & motifs from in-memory artifacts) ===\n",
    "import torch\n",
    "from torch_geometric.data import Data\n",
    "from sklearn.metrics import f1_score\n",
    "\n",
    "# Helper: build Data + masks for a given split (fit scaler on TRAIN only)\n",
    "def build_data_for(seed: int, mode: str, split_map):\n",
    "    tr_ids, va_ids, te_ids, *_ = load_split(split_map[seed])\n",
    "    tr_idx = torch.tensor([node_index[n] for n in tr_ids], dtype=torch.long)\n",
    "    va_idx = torch.tensor([node_index[n] for n in va_ids], dtype=torch.long)\n",
    "    te_idx = torch.tensor([node_index[n] for n in te_ids], dtype=torch.long)\n",
    "\n",
    "    # Fit preprocess on train → transform ALL nodes\n",
    "    pre = make_preprocessor()\n",
    "    X_tr_df = features.loc[tr_ids, numeric_cols + categorical_cols]\n",
    "    X_all_df = features.loc[node_ids, numeric_cols + categorical_cols]\n",
    "    pre.fit(X_tr_df)\n",
    "    X_all_np = pre.transform(X_all_df).astype(np.float32)\n",
    "\n",
    "    data = Data(\n",
    "        x=torch.tensor(X_all_np, dtype=torch.float32),\n",
    "        y=torch.tensor(y_all,    dtype=torch.long),\n",
    "        edge_index=edge_index,   # from earlier PyG setup (undirected)\n",
    "    )\n",
    "    # boolean masks\n",
    "    N = len(node_ids)\n",
    "    train_mask = torch.zeros(N, dtype=torch.bool); train_mask[tr_idx] = True\n",
    "    val_mask   = torch.zeros(N, dtype=torch.bool); val_mask[va_idx]   = True\n",
    "    test_mask  = torch.zeros(N, dtype=torch.bool); test_mask[te_idx]  = True\n",
    "    return data, train_mask, val_mask, test_mask\n",
    "\n",
    "# Motif tensors/scores from features + current edge_index\n",
    "def build_motif_inputs():\n",
    "    # 1) Boolean motif membership matrix (N × K)\n",
    "    M_raw = features.loc[node_ids, motif_cols].fillna(0)\n",
    "    M_bool = (M_raw.values > 0)                  # boolean for logical ops\n",
    "    M_float = M_bool.astype(\"float32\")           # for motif_feats tensor\n",
    "    motif_feats = torch.tensor(M_float, dtype=torch.float32)\n",
    "\n",
    "    # 2) Jaccard overlap per edge using boolean logic\n",
    "    src = edge_index[0].cpu().numpy()\n",
    "    dst = edge_index[1].cpu().numpy()\n",
    "    Su, Sv = M_bool[src], M_bool[dst]\n",
    "    inter = np.logical_and(Su, Sv).sum(axis=1).astype(\"float32\")\n",
    "    union = np.logical_or(Su, Sv).sum(axis=1).astype(\"float32\")\n",
    "    jacc  = inter / np.maximum(union, 1.0)\n",
    "\n",
    "    # 3) Map (u,v) -> score\n",
    "    pairs = list(zip(src.tolist(), dst.tolist()))\n",
    "    motif_scores = {(int(u), int(v)): float(s) for (u, v), s in zip(pairs, jacc)}\n",
    "    return motif_feats, motif_scores\n",
    "\n",
    "\n",
    "# Build motif inputs once\n",
    "motif_feats_all, motif_scores = build_motif_inputs()\n",
    "\n",
    "# Sweep seeds with gating + fusion using the GCNMotif model and train_model() you already defined\n",
    "SEEDS_BLOCKED = SEEDS  # [13,21,34,55,89] already defined\n",
    "results = []\n",
    "for seed in SEEDS_BLOCKED:\n",
    "    torch.manual_seed(seed)\n",
    "    data, train_mask, val_mask, test_mask = build_data_for(seed, \"lineage_blocked\", SPLIT_FILE_BLOCKED)\n",
    "\n",
    "    # Option: tweak these two to test sensitivity quickly\n",
    "    THRESH = 0.20   # gate threshold on motif overlap (0..1)\n",
    "    KEEP_P = 0.50   # keep-prob for low-motif edges\n",
    "\n",
    "    data_gated = data.clone()\n",
    "    data_gated = apply_motif_gating(data_gated, motif_scores, threshold=THRESH, keep_prob=KEEP_P)\n",
    "\n",
    "    model = GCNMotif(\n",
    "        in_dim=data_gated.x.size(1),\n",
    "        hidden_dim=256,\n",
    "        motif_dim=motif_feats_all.size(1),\n",
    "        num_classes=len(class_order),\n",
    "        dropout=0.3\n",
    "    )\n",
    "\n",
    "    val_f1, test_f1 = train_model(\n",
    "        model, data_gated, motif_feats_all, train_mask, val_mask, test_mask,\n",
    "        lr=1e-3, weight_decay=1e-3, epochs=300, patience=40\n",
    "    )\n",
    "    results.append({\"seed\": seed, \"val_macro_f1\": float(val_f1), \"test_macro_f1\": float(test_f1)})\n",
    "\n",
    "print(\"Sprint results (blocked):\")\n",
    "display(pd.DataFrame(results))\n",
    "print(\"Mean test macro-F1:\", np.mean([r[\"test_macro_f1\"] for r in results]))\n"
   ]
  },
