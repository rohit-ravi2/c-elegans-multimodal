   "source": [
    "# Cell 17 — Train & evaluate baselines using cached arrays (no preprocess in pipeline)\n",
    "\n",
    "models = [\"logreg\", \"linsvm\", \"mlp\"]\n",
    "rows, run_logs, errors = [], [], []\n",
    "\n",
    "outer = tqdm(SEEDS, desc=\"Seeds\", leave=True)\n",
    "for seed in outer:\n",
    "    bundle_rand = get_transformed_arrays(seed, \"random\", SPLIT_FILE_RANDOM)\n",
    "    bundle_blk  = get_transformed_arrays(seed, \"lineage_blocked\", SPLIT_FILE_BLOCKED)\n",
    "\n",
    "    for mode, bundle in [(\"random\", bundle_rand), (\"lineage_blocked\", bundle_blk)]:\n",
    "        inner = tqdm(models, desc=f\"{mode} seed={seed}\", leave=False)\n",
    "        for m in inner:\n",
    "            inner.set_postfix_str(m)\n",
    "            try:\n",
    "                clf = build_clf(m, seed)\n",
    "\n",
    "                # Fit on transformed arrays\n",
    "                t0 = time.perf_counter()\n",
    "                if m == \"mlp\":\n",
    "                    # try sample weights; if unsupported, fall back silently\n",
    "                    sw = sample_weights_for(bundle[\"y_tr\"])\n",
    "                    try:\n",
    "                        clf.fit(bundle[\"X_tr\"], bundle[\"y_tr\"], sample_weight=sw)\n",
    "                    except TypeError:\n",
    "                        clf.fit(bundle[\"X_tr\"], bundle[\"y_tr\"])\n",
    "                else:\n",
    "                    clf.fit(bundle[\"X_tr\"], bundle[\"y_tr\"])\n",
    "                t_fit = time.perf_counter() - t0\n",
    "\n",
    "                # Predict + eval\n",
    "                pred_va = clf.predict(bundle[\"X_va\"])\n",
    "                pred_te = clf.predict(bundle[\"X_te\"])\n",
    "                eval_va = evaluate(bundle[\"y_va\"], pred_va, class_order)\n",
    "                eval_te = evaluate(bundle[\"y_te\"], pred_te, class_order)\n",
    "\n",
    "                # Persist\n",
    "                tag = f\"{m}_{'random' if mode=='random' else 'lineageblocked'}_seed{seed}\"\n",
    "                out_dir = RESULTS / tag\n",
    "                out_dir.mkdir(parents=True, exist_ok=True)\n",
    "                with open(out_dir / \"val_metrics.json\", \"w\") as f:\n",
    "                    json.dump(eval_va, f, indent=2)\n",
    "                with open(out_dir / \"test_metrics.json\", \"w\") as f:\n",
    "                    json.dump(eval_te, f, indent=2)\n",
    "\n",
    "                rows.append({\n",
    "                    \"mode\": mode, \"model\": m, \"seed\": seed,\n",
    "                    \"val_macro_f1\": eval_va[\"macro_f1\"], \"val_accuracy\": eval_va[\"accuracy\"],\n",
    "                    \"test_macro_f1\": eval_te[\"macro_f1\"], \"test_accuracy\": eval_te[\"accuracy\"]\n",
    "                })\n",
    "                run_logs.append({\n",
    "                    \"mode\": mode, \"model\": m, \"seed\": seed,\n",
    "                    \"prep_fit_seconds\": bundle.get(\"fit_seconds\", None),\n",
    "                    \"fit_seconds\": t_fit\n",
    "                })\n",
    "\n",
    "            except Exception as e:\n",
    "                tb = traceback.format_exc(limit=3)\n",
    "                errors.append({\"mode\": mode, \"model\": m, \"seed\": seed, \"error\": str(e), \"traceback\": tb})\n",
    "                inner.set_postfix_str(f\"{m}:ERROR\")\n",
    "                continue\n",
    "\n",
    "print(\"✔️ Finished training & evaluation for all baselines.\")\n",
    "with open(RESULTS / \"baseline_run_logs.json\", \"w\") as f:\n",
    "    json.dump(run_logs, f, indent=2)\n",
    "if errors:\n",
    "    with open(RESULTS / \"baseline_errors.json\", \"w\") as f:\n",
    "        json.dump(errors, f, indent=2)\n",
    "    print(f\"⚠️ Completed with {len(errors)} error(s). See baseline_errors.json.\")\n"
   ]
  },
