    "## Part 4"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 56,
   "id": "46349ccb",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "PyG available: True\n",
      "✔️ GNN setup ready.\n"
     ]
    }
   ],
   "source": [
    "# === Track 3 — Part 4: GNN Hybrid (GraphSAGE if available; else GCN fallback) ===\n",
    "\n",
    "import os, json, time, math, pickle, warnings\n",
    "from pathlib import Path\n",
    "from collections import defaultdict\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import networkx as nx\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.nn.functional as F\n",
    "\n",
    "try:\n",
    "    from torch_geometric.utils import from_networkx\n",
    "    from torch_geometric.nn import SAGEConv\n",
    "    PYG_AVAILABLE = True\n",
    "except Exception:\n",
    "    PYG_AVAILABLE = False\n",
    "\n",
    "from sklearn.compose import ColumnTransformer\n",
    "from sklearn.preprocessing import StandardScaler, OneHotEncoder\n",
    "from sklearn.metrics import accuracy_score, f1_score, classification_report, confusion_matrix\n",
    "from sklearn.base import clone\n",
    "from tqdm.auto import tqdm\n",
    "\n",
    "warnings.filterwarnings(\"ignore\", category=UserWarning)\n",
    "\n",
    "ROOT = Path.cwd()\n",
    "T3 = ROOT / \"track3\"\n",
    "DATA = T3 / \"data\"\n",
    "SPLITS = DATA / \"splits\"\n",
    "RESULTS_GNN = T3 / \"results\" / \"gnn_hybrid\"\n",
    "RESULTS_GNN.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "# Inputs\n",
    "FEATURES_PARQ = DATA / \"features_frozen.parquet\"\n",
    "LABELS_JSON   = DATA / \"label_manifest.json\"\n",
    "COLS_JSON     = DATA / \"column_dictionary.json\"\n",
    "GRAPH_PKL     = DATA / \"graph_final.pkl\"\n",
    "\n",
    "SEEDS = [13, 21, 34, 55, 89]\n",
    "SPLIT_FILE_RANDOM  = {s: SPLITS / f\"random_seed{s}.json\" for s in SEEDS}\n",
    "SPLIT_FILE_BLOCKED = {s: SPLITS / f\"lineageblocked_seed{s}.json\" for s in SEEDS}\n",
    "\n",
    "print(f\"PyG available: {PYG_AVAILABLE}\")\n",
    "print(\"✔️ GNN setup ready.\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 59,
   "id": "3c9f3119",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load manifests\n",
    "with open(LABELS_JSON, \"r\") as f:\n",
    "    label_manifest = json.load(f)\n",
    "with open(COLS_JSON, \"r\") as f:\n",
    "    col_dict = json.load(f)\n",
    "\n",
    "class_order = label_manifest[\"class_order\"]\n",
    "label_to_id = {c: i for i, c in enumerate(class_order)}\n",
    "class_weights_map = label_manifest[\"class_weights\"]\n",
    "class_weights_vec = torch.tensor([class_weights_map[c] for c in class_order], dtype=torch.float32)\n",
    "\n",
    "# Load features table\n",
    "features = pd.read_parquet(FEATURES_PARQ).copy()\n",
    "node_ids = features.index.tolist()\n",
    "node_index = {n:i for i, n in enumerate(node_ids)}\n",
    "y_all = features[\"label_final\"].map(label_to_id).astype(int).values\n",
    "\n",
    "# Column groups\n",
    "struct_cols = col_dict[\"structural\"]\n",
    "lineage_cols = col_dict[\"lineage\"]\n",
    "motif_cols = col_dict[\"motifs\"]\n",
    "categorical_cols = [\"BodyRegion_raw\", \"Side_raw\"]\n",
    "numeric_cols = struct_cols + lineage_cols + motif_cols + [\"IsGlia\"]\n",
    "\n",
    "# Load graph\n",
    "with open(GRAPH_PKL, \"rb\") as f:\n",
    "    G = pickle.load(f)\n",
    "# Keep only nodes we have features for; drop others\n",
    "G = G.subgraph(node_ids).copy()\n",
    "\n",
    "# Convert to PyG Data if available; else build SciPy sparse for GCN fallback\n",
    "# Convert to PyG edge_index if available; else build SciPy sparse for GCN fallback\n",
    "if PYG_AVAILABLE:\n",
    "    # Relabel nodes → 0..N-1\n",
    "    H = nx.relabel_nodes(G, node_index)\n",
    "    # Build edge_index manually (avoid from_networkx grouping bug)\n",
    "    edges_list = list(H.edges())\n",
    "    if len(edges_list) == 0:\n",
    "        raise RuntimeError(\"Graph has no edges after relabeling.\")\n",
    "    pyg_edge_index = torch.tensor(edges_list, dtype=torch.long).t().contiguous()\n",
    "\n",
    "    # Optional: combined edge weights (not used by SAGEConv here, but kept if we add GCNConv later)\n",
    "    w = []\n",
    "    for u, v in edges_list:\n",
    "        d = H[u][v]\n",
    "        w_chem = float(d.get(\"w_chem\", 0.0))\n",
    "        w_elec = float(d.get(\"w_elec\", 0.0))\n",
    "        w.append(w_chem + w_elec)\n",
    "    edge_weight = torch.tensor(w, dtype=torch.float32)\n",
    "else:\n",
    "    import scipy.sparse as sp\n",
    "    # build adjacency with combined weights\n",
    "    rows, cols, vals = [], [], []\n",
    "    for u, v, d in G.edges(data=True):\n",
    "        ui = node_index[u]; vi = node_index[v]\n",
    "        w = float(d.get(\"w_chem\", 0.0)) + float(d.get(\"w_elec\", 0.0))\n",
    "        rows.append(ui); cols.append(vi); vals.append(w if w > 0 else 1.0)\n",
    "    N = len(node_ids)\n",
    "    A = sp.coo_matrix((vals, (rows, cols)), shape=(N, N), dtype=np.float32)\n",
    "    A = A + sp.eye(N, dtype=np.float32)\n",
    "    deg = np.asarray(A.sum(1)).ravel()\n",
    "    deg[deg == 0] = 1.0\n",
    "    D_inv_sqrt = sp.diags(1.0 / np.sqrt(deg))\n",
    "    A_norm = D_inv_sqrt @ A @ D_inv_sqrt\n",
    "    A_norm = A_norm.tocoo()\n",
    "    indices = torch.tensor(np.vstack([A_norm.row, A_norm.col]), dtype=torch.long)\n",
    "    values  = torch.tensor(A_norm.data, dtype=torch.float32)\n",
    "    A_sparse = torch.sparse_coo_tensor(indices, values, (N, N))\n",
    "\n",
    "\n",
    "def make_preprocessor():\n",
    "    return ColumnTransformer(\n",
    "        transformers=[\n",
    "            (\"num\", StandardScaler(with_mean=True, with_std=True), numeric_cols),\n",
    "            (\"cat\", OneHotEncoder(handle_unknown=\"ignore\", sparse_output=False), categorical_cols),\n",
    "        ],\n",
    "        remainder=\"drop\",\n",
    "        verbose_feature_names_out=False\n",
    "    )\n",
    "\n",
    "def load_split(payload_path: Path):\n",
    "    obj = json.loads(payload_path.read_text())\n",
    "    return obj[\"train\"], obj[\"val\"], obj[\"test\"], obj[\"seed\"], obj[\"mode\"]\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 60,
   "id": "35f66c73",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ---- Models ----\n",
    "\n",
    "class GCN2(nn.Module):\n",
    "    \"\"\"Simple 2-layer GCN using torch sparse matmul (fallback when PyG is unavailable).\"\"\"\n",
    "    def __init__(self, in_dim, hidden, out_dim, dropout=0.2):\n",
    "        super().__init__()\n",
    "        self.lin1 = nn.Linear(in_dim, hidden)\n",
    "        self.lin2 = nn.Linear(hidden, out_dim)\n",
    "        self.dropout = nn.Dropout(dropout)\n",
    "\n",
    "    def forward(self, X, A_sparse):\n",
    "        # X: [N, F], A_sparse: [N, N] sparse\n",
    "        Z = torch.sparse.mm(A_sparse, X)\n",
    "        Z = self.lin1(Z)\n",
    "        Z = F.relu(Z)\n",
    "        Z = self.dropout(Z)\n",
    "        Z = torch.sparse.mm(A_sparse, Z)\n",
    "        Z = self.lin2(Z)\n",
    "        return Z\n",
    "\n",
    "class SAGE2(nn.Module):\n",
    "    \"\"\"2-layer GraphSAGE using torch_geometric (if available).\"\"\"\n",
    "    def __init__(self, in_dim, hidden, out_dim, dropout=0.2):\n",
    "        super().__init__()\n",
    "        self.conv1 = SAGEConv(in_dim, hidden, aggr='mean', normalize=False)\n",
    "        self.conv2 = SAGEConv(hidden, out_dim, aggr='mean', normalize=False)\n",
    "        self.dropout = nn.Dropout(dropout)\n",
    "\n",
    "    def forward(self, x, edge_index):\n",
    "        z = self.conv1(x, edge_index)\n",
    "        z = F.relu(z)\n",
    "        z = self.dropout(z)\n",
    "        z = self.conv2(z, edge_index)\n",
    "        return z\n",
    "\n",
    "# ---- Train & Eval helpers ----\n",
    "\n",
    "@torch.no_grad()\n",
    "def eval_masks(logits, y_true, mask, label_names):\n",
    "    pred = logits.argmax(dim=1)\n",
    "    yt = y_true[mask].cpu().numpy()\n",
    "    yp = pred[mask].cpu().numpy()\n",
    "    all_labels = list(range(len(label_names)))\n",
    "    acc = accuracy_score(yt, yp)\n",
    "    macro_f1 = f1_score(yt, yp, average=\"macro\", zero_division=0)\n",
    "    per_class_f1 = f1_score(yt, yp, average=None, labels=all_labels, zero_division=0)\n",
    "    cm = confusion_matrix(yt, yp, labels=all_labels)\n",
    "    report = classification_report(yt, yp, labels=all_labels, target_names=label_names, zero_division=0, output_dict=True)\n",
    "    return {\n",
    "        \"accuracy\": float(acc),\n",
    "        \"macro_f1\": float(macro_f1),\n",
    "        \"per_class_f1\": {label_names[i]: float(per_class_f1[i]) for i in all_labels},\n",
    "        \"confusion_matrix\": cm.tolist(),\n",
    "        \"report\": report\n",
    "    }\n",
    "\n",
    "def train_one(seed, mode, split_map, hidden=256, lr=1e-3, weight_decay=5e-4, max_epochs=400, patience=30, dropout=0.2, device=None):\n",
    "    \"\"\"\n",
    "    Fit scaler+onehot on TRAIN only, transform all nodes, then train a 2-layer SAGE/GCN with early stopping on val macro-F1.\n",
    "    \"\"\"\n",
    "    device = device or (\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
    "\n",
    "    # Split\n",
    "    tr_ids, va_ids, te_ids, sd, md = load_split(split_map[seed])\n",
    "    tr_idx = np.array([node_index[n] for n in tr_ids], dtype=int)\n",
    "    va_idx = np.array([node_index[n] for n in va_ids], dtype=int)\n",
    "    te_idx = np.array([node_index[n] for n in te_ids], dtype=int)\n",
    "\n",
    "    # Preprocess features (fit on train only)\n",
    "    pre = make_preprocessor()\n",
    "    X_tr_df = features.loc[tr_ids, numeric_cols + categorical_cols]\n",
    "    X_va_df = features.loc[va_ids, numeric_cols + categorical_cols]\n",
    "    X_te_df = features.loc[te_ids, numeric_cols + categorical_cols]\n",
    "    X_all_df = features.loc[node_ids, numeric_cols + categorical_cols]\n",
    "\n",
    "    pre.fit(X_tr_df)\n",
    "    X_all_np = pre.transform(X_all_df).astype(np.float32)\n",
    "\n",
    "    X = torch.tensor(X_all_np, dtype=torch.float32, device=device)\n",
    "    y = torch.tensor(y_all, dtype=torch.long, device=device)\n",
    "\n",
    "    # Masks\n",
    "    train_mask = torch.zeros(len(node_ids), dtype=torch.bool, device=device)\n",
    "    val_mask   = torch.zeros_like(train_mask)\n",
    "    test_mask  = torch.zeros_like(train_mask)\n",
    "    train_mask[torch.tensor(tr_idx)] = True\n",
    "    val_mask[torch.tensor(va_idx)]   = True\n",
    "    test_mask[torch.tensor(te_idx)]  = True\n",
    "\n",
    "    # Model\n",
    "    in_dim, out_dim = X.shape[1], len(class_order)\n",
    "    if PYG_AVAILABLE:\n",
    "        model = SAGE2(in_dim, hidden, out_dim, dropout=dropout).to(device)\n",
    "        edge_index = pyg_edge_index.to(device)\n",
    "        edge_weight = None  # not used in SAGEConv here\n",
    "    else:\n",
    "        model = GCN2(in_dim, hidden, out_dim, dropout=dropout).to(device)\n",
    "        A_dev = A_sparse.coalesce().to(device)\n",
    "\n",
    "    # Optim\n",
    "    optimizer = torch.optim.Adam(model.parameters(), lr=lr, weight_decay=weight_decay)\n",
    "    weights = class_weights_vec.to(device)\n",
    "    best = {\"epoch\": -1, \"val_macro_f1\": -1.0, \"state_dict\": None}\n",
    "    history = []\n",
    "\n",
    "    for epoch in range(1, max_epochs+1):\n",
    "        model.train()\n",
    "        optimizer.zero_grad()\n",
    "        if PYG_AVAILABLE:\n",
    "            logits = model(X, edge_index)\n",
    "        else:\n",
    "            logits = model(X, A_dev)\n",
    "        loss = F.cross_entropy(logits[train_mask], y[train_mask], weight=weights)\n",
    "        loss.backward()\n",
    "        optimizer.step()\n",
    "\n",
    "        # Eval on val\n",
    "        model.eval()\n",
    "        with torch.no_grad():\n",
    "            if PYG_AVAILABLE:\n",
    "                logits = model(X, edge_index)\n",
    "            else:\n",
    "                logits = model(X, A_dev)\n",
    "            metrics_val = eval_masks(logits, y, val_mask, class_order)\n",
    "            metrics_te  = eval_masks(logits, y, test_mask, class_order)\n",
    "\n",
    "        history.append({\"epoch\": epoch, \"val_macro_f1\": metrics_val[\"macro_f1\"], \"loss\": float(loss.item())})\n",
    "\n",
    "        # Early stop tracking\n",
    "        if metrics_val[\"macro_f1\"] > best[\"val_macro_f1\"]:\n",
    "            best.update({\"epoch\": epoch, \"val_macro_f1\": metrics_val[\"macro_f1\"], \"state_dict\": {k:v.detach().cpu() for k,v in model.state_dict().items()}})\n",
    "\n",
    "        if epoch - best[\"epoch\"] >= patience:\n",
    "            break\n",
    "\n",
    "    # Restore best\n",
    "    if best[\"state_dict\"] is not None:\n",
    "        model.load_state_dict({k:v for k,v in best[\"state_dict\"].items()})\n",
    "\n",
    "    # Final eval\n",
    "    model.eval()\n",
    "    with torch.no_grad():\n",
    "        if PYG_AVAILABLE:\n",
    "            logits = model(X, edge_index)\n",
    "        else:\n",
    "            logits = model(X, A_dev)\n",
    "        metrics_tr  = eval_masks(logits, y, train_mask, class_order)\n",
    "        metrics_val = eval_masks(logits, y, val_mask, class_order)\n",
    "        metrics_te  = eval_masks(logits, y, test_mask, class_order)\n",
    "\n",
    "    return {\n",
    "        \"seed\": seed, \"mode\": mode, \"hidden\": hidden, \"lr\": lr, \"patience\": patience,\n",
    "        \"val_macro_f1\": metrics_val[\"macro_f1\"],\n",
    "        \"test_macro_f1\": metrics_te[\"macro_f1\"],\n",
    "        \"val\": metrics_val, \"test\": metrics_te, \"train\": metrics_tr,\n",
    "        \"history\": history, \"best_epoch\": best[\"epoch\"]\n",
    "    }\n"
   ]
  },
