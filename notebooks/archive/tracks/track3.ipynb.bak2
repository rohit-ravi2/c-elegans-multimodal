   "source": [
    "# === Cell N2: Runner for soft-motif GCN (blocked only) ===\n",
    "def train_gcn_softmotif(seed, alpha=0.5,\n",
    "                        hidden=256, lr=1e-3, wd=1e-3, dropout=0.1,\n",
    "                        max_epochs=400, patience=40, device=None):\n",
    "    device = device or (\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
    "    tr_idx, va_idx, te_idx, train_mask, val_mask, test_mask, e_train = masks_for(seed, \"lineage_blocked\", SPLIT_FILE_BLOCKED)\n",
    "\n",
    "    # Features (fit scaler on train only)\n",
    "    pre = make_preprocessor()\n",
    "    X_tr_df = features.iloc[tr_idx.cpu().numpy()][numeric_cols + categorical_cols]\n",
    "    X_all_df = features.loc[node_ids, numeric_cols + categorical_cols]\n",
    "    pre.fit(X_tr_df)\n",
    "    X_all = torch.tensor(pre.transform(X_all_df).astype(np.float32), dtype=torch.float32, device=device)\n",
    "    y = torch.tensor(y_all, dtype=torch.long, device=device)\n",
    "\n",
    "    # Weights\n",
    "    ew_blend = blended_weights_multiplicative(alpha).to(device)\n",
    "    ei_full  = edge_index.to(device)\n",
    "    ei_tr    = ei_full[:, e_train]\n",
    "    ew_tr    = ew_blend[e_train]\n",
    "\n",
    "    # Model/opt\n",
    "    model = GCN_EdgeWeight_Node(X_all.shape[1], hidden, len(class_order), dropout=dropout).to(device)\n",
    "    opt   = torch.optim.Adam(model.parameters(), lr=lr, weight_decay=wd)\n",
    "    weights = class_weights_vec.to(device)\n",
    "\n",
    "    best = {\"epoch\": -1, \"val_macro_f1\": -1.0, \"state\": None}; wait=0\n",
    "    for epoch in range(1, max_epochs+1):\n",
    "        model.train(); opt.zero_grad()\n",
    "        logits_tr = model(X_all, ei_tr, ew_tr)\n",
    "        loss = F.cross_entropy(logits_tr[train_mask.to(device)], y[train_mask.to(device)], weight=weights)\n",
    "        loss.backward(); opt.step()\n",
    "\n",
    "        model.eval()\n",
    "        with torch.no_grad():\n",
    "            logits = model(X_all, ei_full, ew_blend)\n",
    "            mv = eval_mask_node(logits, y, val_mask.to(device), class_order)[\"macro_f1\"]\n",
    "        if mv > best[\"val_macro_f1\"]:\n",
    "            best = {\"epoch\": epoch, \"val_macro_f1\": mv, \"state\": {k:v.detach().cpu() for k,v in model.state_dict().items()}}\n",
    "            wait=0\n",
    "        else:\n",
    "            wait+=1\n",
    "            if wait>=patience: break\n",
    "\n",
    "    if best[\"state\"] is not None:\n",
    "        model.load_state_dict(best[\"state\"])\n",
    "    model.eval()\n",
    "    with torch.no_grad():\n",
    "        logits = model(X_all, ei_full, ew_blend)\n",
    "        mte = eval_mask_node(logits, y, test_mask.to(device), class_order)\n",
    "    return best[\"val_macro_f1\"], mte[\"macro_f1\"]\n",
    "\n",
    "# Quick sweep over alpha on lineage-blocked\n",
    "alphas = [0.2, 0.5, 1.0]\n",
    "rows = []\n",
    "for seed in SEEDS:\n",
    "    for a in alphas:\n",
    "        v, t = train_gcn_softmotif(seed, alpha=a)\n",
    "        rows.append({\"seed\": seed, \"alpha\": a, \"val_macro_f1\": v, \"test_macro_f1\": t})\n",
    "        print(f\"[seed {seed}] α={a:.2f} → val={v:.3f}, test={t:.3f}\")\n",
    "\n",
    "soft_df = pd.DataFrame(rows).sort_values([\"alpha\",\"seed\"])\n",
    "display(soft_df)\n",
    "print(\"Means:\")\n",
    "display(soft_df.groupby(\"alpha\").agg(val_mean=(\"val_macro_f1\",\"mean\"),\n",
    "                                     test_mean=(\"test_macro_f1\",\"mean\"),\n",
    "                                     test_std=(\"test_macro_f1\",\"std\")).reset_index())\n"
   ]
  },
  {
