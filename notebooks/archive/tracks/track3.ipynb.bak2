   "source": [
    "def graph_summary(G: nx.DiGraph) -> dict:\n",
    "    weights_both = []\n",
    "    chem_e = 0\n",
    "    elec_e = 0\n",
    "    for u, v, d in G.edges(data=True):\n",
    "        w_chem = float(d.get('w_chem', 0.0))\n",
    "        w_elec = float(d.get('w_elec', 0.0))\n",
    "        weights_both.append(w_chem + w_elec)\n",
    "        if w_chem > 0: chem_e += 1\n",
    "        if w_elec > 0: elec_e += 1\n",
    "    try:\n",
    "        scc_count = nx.number_strongly_connected_components(G)\n",
    "    except Exception:\n",
    "        scc_count = None\n",
    "    try:\n",
    "        wcc_count = nx.number_weakly_connected_components(G)\n",
    "    except Exception:\n",
    "        wcc_count = None\n",
    "\n",
    "    in_deg = dict(G.in_degree())\n",
    "    out_deg = dict(G.out_degree())\n",
    "    total_deg = {n: in_deg.get(n,0) + out_deg.get(n,0) for n in G.nodes()}\n",
    "\n",
    "    top_in = sorted(in_deg.items(), key=lambda x: -x[1])[:10]\n",
    "    top_out = sorted(out_deg.items(), key=lambda x: -x[1])[:10]\n",
    "    top_total = sorted(total_deg.items(), key=lambda x: -x[1])[:10]\n",
    "\n",
    "    return {\n",
    "        \"nodes\": G.number_of_nodes(),\n",
    "        \"edges\": G.number_of_edges(),\n",
    "        \"edges_chem_count\": chem_e,\n",
    "        \"edges_elec_count\": elec_e,\n",
    "        \"weight_sum\": float(np.sum(weights_both)) if len(weights_both) else 0.0,\n",
    "        \"weight_median\": float(np.median(weights_both)) if len(weights_both) else 0.0,\n",
    "        \"weight_p95\": float(np.percentile(weights_both, 95)) if len(weights_both) else 0.0,\n",
    "        \"SCC_count\": scc_count,\n",
    "        \"WCC_count\": wcc_count,\n",
    "        \"top10_in_degree\": top_in,\n",
    "        \"top10_out_degree\": top_out,\n",
    "        \"top10_total_degree\": top_total\n",
    "    }\n",
    "\n",
    "stats = graph_summary(G)\n",
    "save_json(OUT_GRAPH_STATS, stats)\n",
    "print(json.dumps(stats, indent=2)[:2000])\n",
    "print(f\"✔️ Saved graph stats → {OUT_GRAPH_STATS}\")\n"
   ]
  },
