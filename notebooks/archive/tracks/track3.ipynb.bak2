     "text": [
      "[seed 13] stratified: train/hold=True, val/test=False | units: train=1011, val=217, test=217\n",
      "[seed 21] stratified: train/hold=True, val/test=False | units: train=1011, val=217, test=217\n",
      "[seed 34] stratified: train/hold=True, val/test=False | units: train=1011, val=217, test=217\n",
      "[seed 55] stratified: train/hold=True, val/test=False | units: train=1011, val=217, test=217\n",
      "[seed 89] stratified: train/hold=True, val/test=False | units: train=1011, val=217, test=217\n",
      "✔️ Random splits saved.\n"
     ]
    }
   ],
   "source": [
    "# Cell 10 — Random Stratified Splits (70/15/15) with Bilateral Constraint (fixed & robust)\n",
    "\n",
    "from sklearn.model_selection import StratifiedShuffleSplit, ShuffleSplit\n",
    "\n",
    "def stratified_units_split(neurons, labels, units, train_size=0.70, val_size=0.15, test_size=0.15, seed=13):\n",
    "    \"\"\"\n",
    "    Split at the UNIT level (bilateral pair or singleton).\n",
    "\n",
    "    Steps:\n",
    "      1) Assign each unit a representative label (majority label among its members).\n",
    "      2) Try stratified split of units -> train vs holdout, then stratified -> val vs test.\n",
    "         If stratification fails (e.g., too few units of some class), fall back to non-stratified splits.\n",
    "      3) Expand units back to neuron IDs.\n",
    "    \"\"\"\n",
    "    assert abs(train_size + val_size + test_size - 1.0) < 1e-6\n",
    "\n",
    "    # Representative label per unit (majority vote)\n",
    "    unit_labels = []\n",
    "    for u in units:\n",
    "        counts = df_sorted.loc[list(u), 'label_final'].value_counts()\n",
    "        lab = counts.idxmax()\n",
    "        unit_labels.append(lab)\n",
    "\n",
    "    units_arr = np.array(units, dtype=object)\n",
    "    y_arr = np.array(unit_labels)\n",
    "\n",
    "    # Helper: split indices with (stratified -> fallback to non-stratified) behavior\n",
    "    def split_indices_stratified_then_fallback(Xy_labels, train_frac, rnd):\n",
    "        # Try stratified\n",
    "        try:\n",
    "            sss = StratifiedShuffleSplit(n_splits=1, train_size=train_frac, random_state=rnd)\n",
    "            tr_idx, ho_idx = next(sss.split(np.zeros(len(Xy_labels)), Xy_labels))\n",
    "            return tr_idx, ho_idx, True\n",
    "        except Exception:\n",
    "            # Fallback: plain ShuffleSplit (not stratified)\n",
    "            ss = ShuffleSplit(n_splits=1, train_size=train_frac, random_state=rnd)\n",
    "            tr_idx, ho_idx = next(ss.split(np.zeros(len(Xy_labels))))\n",
    "            return tr_idx, ho_idx, False\n",
    "\n",
    "    # Split units -> train vs holdout\n",
    "    tr_idx, ho_idx, strat1 = split_indices_stratified_then_fallback(y_arr, train_size, seed)\n",
    "    units_train = units_arr[tr_idx]\n",
    "    units_hold  = units_arr[ho_idx]\n",
    "    y_hold      = y_arr[ho_idx]\n",
    "\n",
    "    # Split holdout -> val vs test\n",
    "    frac = val_size / (val_size + test_size)\n",
    "    val_idx, test_idx, strat2 = split_indices_stratified_then_fallback(y_hold, frac, seed + 1)\n",
    "    units_val  = units_hold[val_idx]\n",
    "    units_test = units_hold[test_idx]\n",
    "\n",
    "    # Expand back to neuron lists\n",
    "    def expand_units(uarr):\n",
    "        return [n for u in uarr for n in u]\n",
    "\n",
    "    train = sorted(expand_units(units_train))\n",
    "    val   = sorted(expand_units(units_val))\n",
    "    test  = sorted(expand_units(units_test))\n",
    "\n",
    "    # Optional: small print to confirm whether stratification held\n",
    "    print(f\"[seed {seed}] stratified: train/hold={strat1}, val/test={strat2} | \"\n",
    "          f\"units: train={len(units_train)}, val={len(units_val)}, test={len(units_test)}\")\n",
    "\n",
    "    return train, val, test\n",
    "\n",
    "# Generate and save random splits\n",
    "for seed in SEEDS:\n",
    "    neurons = df_sorted.index.tolist()\n",
    "    units = group_units_for_split(neurons)\n",
    "    train, val, test = stratified_units_split(neurons, df_sorted['label_final'], units, seed=seed)\n",
    "\n",
    "    payload = {\n",
    "        \"seed\": seed,\n",
    "        \"mode\": \"random\",\n",
    "        \"train\": train,\n",
    "        \"val\": val,\n",
    "        \"test\": test,\n",
    "        \"notes\": {\n",
    "            \"bilateral_pairs_enforced\": True,\n",
    "            \"unknown_included\": True,\n",
    "            \"k_lineage\": None\n",
    "        }\n",
    "    }\n",
    "    save_json(SPLIT_FILES_RANDOM[seed], payload)\n",
    "\n",
    "print(\"✔️ Random splits saved.\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 45,
   "id": "32436592",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✔️ Lineage‑blocked splits regenerated (robust).\n"
     ]
    }
   ],
   "source": [
    "# Cell 11 — Lineage‑Blocked Splits (robust: stratified by group majority label + no‑empty‑folds repair)\n",
    "\n",
    "from sklearn.model_selection import StratifiedShuffleSplit, ShuffleSplit\n",
    "\n",
    "def make_group_units(g_series: pd.Series) -> list[tuple]:\n",
    "    \"\"\"\n",
    "    Build atomic 'units' from lineage groups: one tuple of neuron IDs per group.\n",
    "    \"\"\"\n",
    "    units = []\n",
    "    for gid, members in g_series.groupby(g_series.values):\n",
    "        units.append(tuple(sorted(members.index.tolist())))\n",
    "    return units\n",
    "\n",
    "def unit_majority_labels(units: list[tuple]) -> np.ndarray:\n",
    "    \"\"\"\n",
    "    Majority label for each unit (by label_final in df_sorted).\n",
    "    \"\"\"\n",
    "    labs = []\n",
    "    for u in units:\n",
    "        counts = df_sorted.loc[list(u), 'label_final'].value_counts()\n",
    "        labs.append(counts.idxmax())\n",
    "    return np.array(labs)\n",
    "\n",
    "def split_units_stratified(units, y_units, train_frac, seed):\n",
    "    \"\"\"\n",
    "    Split units → train vs holdout (stratified, fallback to non‑stratified),\n",
    "    then holdout → val vs test with requested proportions.\n",
    "    Returns three lists of neuron IDs.\n",
    "    \"\"\"\n",
    "    units_arr = np.array(units, dtype=object)\n",
    "\n",
    "    def split_once(Xy, y, frac, rnd):\n",
    "        try:\n",
    "            sss = StratifiedShuffleSplit(n_splits=1, train_size=frac, random_state=rnd)\n",
    "            tr_idx, ho_idx = next(sss.split(np.zeros(len(y)), y))\n",
    "            return tr_idx, ho_idx, True\n",
    "        except Exception:\n",
    "            ss = ShuffleSplit(n_splits=1, train_size=frac, random_state=rnd)\n",
    "            tr_idx, ho_idx = next(ss.split(np.zeros(len(y))))\n",
    "            return tr_idx, ho_idx, False\n",
    "\n",
    "    tr_idx, ho_idx, _ = split_once(units_arr, y_units, train_frac, seed)\n",
    "    units_tr = units_arr[tr_idx]\n",
    "    units_ho = units_arr[ho_idx]\n",
    "    y_ho     = y_units[ho_idx]\n",
    "\n",
    "    # holdout → val/test in 50/50 of holdout size if train_frac=0.70; adjust generally:\n",
    "    # desired val:test = 0.15:0.15 → frac = 0.5 within holdout\n",
    "    frac_val = 0.5\n",
    "    val_idx, test_idx, _ = split_once(units_ho, y_ho, frac_val, seed+1)\n",
    "\n",
    "    units_va = units_ho[val_idx]\n",
    "    units_te = units_ho[test_idx]\n",
    "\n",
    "    def expand(uarr): return [n for u in uarr for n in u]\n",
    "    return expand(units_tr), expand(units_va), expand(units_te)\n",
    "\n",
    "def ensure_nonempty_folds(train, val, test):\n",
    "    \"\"\"\n",
    "    If any fold is empty, move the smallest unit (by size) from the largest fold to the empty one.\n",
    "    Uses lineage groups to define units.\n",
    "    \"\"\"\n",
    "    folds = {\"train\": train, \"val\": val, \"test\": test}\n",
    "    sizes = {k: len(v) for k, v in folds.items()}\n",
    "    if min(sizes.values()) > 0:\n",
    "        return train, val, test  # already OK\n",
    "\n",
    "    # Build group map for quick unit sizes\n",
    "    # (We infer current seed's group assignments below when called)\n",
    "    return None  # placeholder; we'll handle inside the main loop to know g_series context\n",
    "\n",
    "# Generate and save lineage‑blocked splits\n",
    "for seed in SEEDS:\n",
    "    df_groups = pd.read_parquet(GROUPS_FILES[seed])\n",
    "    if 'Neuron' in df_groups.columns:\n",
    "        df_groups = df_groups.set_index('Neuron')\n",
    "    if df_groups.index.name is None:\n",
    "        df_groups.index.name = 'Neuron'\n",
    "    if 'group_id' not in df_groups.columns:\n",
    "        raise KeyError(f\"'group_id' not found in {GROUPS_FILES[seed].name}. Columns: {list(df_groups.columns)}\")\n",
    "\n",
    "    g_series = df_groups['group_id'].astype(int)\n",
    "\n",
    "    # Build units (groups) and majority labels\n",
    "    units = make_group_units(g_series)\n",
    "    y_units = unit_majority_labels(units)\n",
    "\n",
    "    # Stratified at the GROUP level\n",
    "    train_ids, val_ids, test_ids = split_units_stratified(units, y_units, train_frac=0.70, seed=seed)\n",
    "\n",
    "    # Repair if any fold empty: move the smallest group from the largest fold\n",
    "    if len(train_ids) == 0 or len(val_ids) == 0 or len(test_ids) == 0:\n",
    "        # map neuron -> group\n",
    "        n2g = g_series.to_dict()\n",
    "        # invert: group -> member list\n",
    "        g2members = {}\n",
    "        for n, gid in n2g.items():\n",
    "            g2members.setdefault(gid, []).append(n)\n",
    "\n",
    "        def fold_groups(ids):\n",
    "            # unique groups present in this fold\n",
    "            return {n2g[n] for n in ids}\n",
    "\n",
    "        # find empty and largest folds\n",
    "        fold_lists = {\"train\": train_ids, \"val\": val_ids, \"test\": test_ids}\n",
    "        sizes = {k: len(v) for k, v in fold_lists.items()}\n",
    "        empty = [k for k, v in sizes.items() if v == 0]\n",
    "        if empty:\n",
    "            # largest by size\n",
    "            largest = max(fold_lists.keys(), key=lambda k: len(fold_lists[k]))\n",
    "            # pick the smallest group (by number of members) in largest\n",
    "            largest_group_ids = fold_groups(fold_lists[largest])\n",
    "            # compute sizes of those groups\n",
    "            cand = sorted(largest_group_ids, key=lambda gid: len(g2members[gid]))[0]\n",
    "            # move all members of that group\n",
    "            mems = set(g2members[cand])\n",
    "            # remove from largest\n",
    "            fold_lists[largest] = [x for x in fold_lists[largest] if x not in mems]\n",
    "            # put into the first empty fold\n",
    "            fold_lists[empty[0]] = sorted(list(mems))\n",
    "\n",
    "        train_ids, val_ids, test_ids = fold_lists[\"train\"], fold_lists[\"val\"], fold_lists[\"test\"]\n",
    "\n",
    "    payload = {\n",
    "        \"seed\": seed,\n",
    "        \"mode\": \"lineage_blocked\",\n",
    "        \"train\": sorted(train_ids),\n",
    "        \"val\": sorted(val_ids),\n",
    "        \"test\": sorted(test_ids),\n",
    "        \"notes\": {\n",
    "            \"bilateral_pairs_enforced\": True,\n",
    "            \"unknown_included\": True,\n",
    "            \"k_lineage\": 20,\n",
    "            \"split_strategy\": \"group-level stratified (majority label) with no-empty-folds repair\"\n",
    "        }\n",
    "    }\n",
    "    save_json(SPLIT_FILES_BLOCK[seed], payload)\n",
    "\n",
    "print(\"✔️ Lineage‑blocked splits regenerated (robust).\")\n"
   ]
  },
