    "# Use only seeds that have lineage-blocked split files\n",
    "from pathlib import Path\n",
    "AVAILABLE_SEEDS = sorted([s for s, p in SPLIT_FILE_BLOCKED.items() if Path(p).exists()])\n",
    "print(\"Found split files for seeds:\", AVAILABLE_SEEDS)\n",
    "\n",
    "# If you want to keep the name SEEDS_LONG used below:\n",
    "SEEDS_LONG = AVAILABLE_SEEDS\n"
   ]
