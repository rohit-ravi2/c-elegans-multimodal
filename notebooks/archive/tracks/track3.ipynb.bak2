   "source": [
    "# Ensure motif numeric floats\n",
    "motifs_num = motifs.copy()\n",
    "for c in motif_cols:\n",
    "    motifs_num[c] = pd.to_numeric(motifs_num[c], errors='coerce').fillna(0.0).astype(float)\n",
    "\n",
    "# Align & save lineage raw\n",
    "latents_sorted = latents.sort_index()\n",
    "latents_sorted.to_parquet(OUT_LINEAGE_PARQ, index=True)\n",
    "\n",
    "# Positional defaults\n",
    "md = metadata.copy()\n",
    "md['BodyRegion_raw'] = md['BodyRegion'].fillna('unknown').astype(str).str.lower()\n",
    "md['Side_raw'] = md['Side'].fillna('unknown').astype(str).str.upper()\n",
    "# Normalize side to L/R/UNKNOWN\n",
    "md['Side_raw'] = md['Side_raw'].where(md['Side_raw'].isin(['L','R']), 'unknown')\n",
    "# IsGlia logic\n",
    "if 'IsGlia' in md.columns:\n",
    "    md['IsGlia'] = pd.to_numeric(md['IsGlia'], errors='coerce').fillna(0).astype(int)\n",
    "else:\n",
    "    md['IsGlia'] = 0\n",
    "# If Type == Glia then IsGlia = 1\n",
    "md.loc[md['Type'].str.lower() == 'glia', 'IsGlia'] = 1\n",
    "\n",
    "# Label mapping → final classes\n",
    "def map_label(raw: str) -> str:\n",
    "    if pd.isna(raw):\n",
    "        return 'Unknown'\n",
    "    r = str(raw).strip().lower()\n",
    "    if 'interneuron' in r:\n",
    "        return 'Interneuron'\n",
    "    if 'sensory' in r:\n",
    "        return 'Sensory'\n",
    "    if 'motor' in r:\n",
    "        return 'Motor'\n",
    "    if 'glia' in r:\n",
    "        return 'Glia'\n",
    "    return 'Unknown'\n",
    "\n",
    "md['label_final'] = md['Type'].apply(map_label)\n",
    "\n",
    "# Merge features: index = Neuron\n",
    "# Start from union of neurons present in any block we care about, then inner-join to enforce availability.\n",
    "df = (struct_df\n",
    "      .join(latents_sorted, how='inner')\n",
    "      .join(motifs_num, how='inner')\n",
    "      .join(md[['BodyRegion_raw','Side_raw','IsGlia','label_final']], how='inner'))\n",
    "\n",
    "# Integer label ids\n",
    "class_order = ['Interneuron', 'Sensory', 'Motor', 'Glia', 'Unknown']\n",
    "label_to_id = {c: i for i, c in enumerate(class_order)}\n",
    "df['label_int'] = df['label_final'].map(label_to_id)\n",
    "\n",
    "# Column dictionary (for reproducibility)\n",
    "col_dict = {\n",
    "    \"Neuron_index\": \"Row index is neuron id\",\n",
    "    \"labels\": {\"label_final\": \"string final label\", \"label_int\": \"integer encoded via class_order\"},\n",
    "    \"positional\": [\"BodyRegion_raw\", \"Side_raw\", \"IsGlia\"],\n",
    "    \"structural\": list(struct_df.columns),\n",
    "    \"lineage\": list(latents_sorted.columns),\n",
    "    \"motifs\": motif_cols,\n",
    "    \"class_order\": class_order\n",
    "}\n",
    "with open(OUT_COLUMNS_JSON, \"w\") as f:\n",
    "    json.dump(col_dict, f, indent=2)\n",
    "\n",
    "# Save frozen features\n",
    "df_sorted = df.sort_index()\n",
    "df_sorted.to_parquet(OUT_FEATURES_PARQ, index=True)\n",
    "print(f\"✔️ Frozen features → {OUT_FEATURES_PARQ} | shape: {df_sorted.shape}\")\n",
    "\n",
    "# Label manifest\n",
    "counts = df_sorted['label_final'].value_counts().reindex(class_order, fill_value=0).to_dict()\n",
    "\n",
    "# Class weights via effective number of samples (Cui et al. 2019) with beta=0.999\n",
    "beta = 0.999\n",
    "def eff_num(n): return (1 - beta**n) / (1 - beta) if n > 0 else 0\n",
    "effs = {c: eff_num(n) for c, n in counts.items()}\n",
    "weights = {c: (sum(effs.values()) / effs[c] if effs[c] > 0 else 0.0) for c in class_order}\n",
    "# Normalize weights to mean 1.0\n",
    "mean_w = np.mean([w for w in weights.values() if w > 0])\n",
    "weights_norm = {c: (w / mean_w if mean_w > 0 else 1.0) for c, w in weights.items()}\n",
    "\n",
    "label_manifest = {\n",
    "    \"class_order\": class_order,\n",
    "    \"counts\": counts,\n",
    "    \"effective_numbers\": effs,\n",
    "    \"class_weights\": weights_norm,\n",
    "    \"notes\": {\n",
    "        \"beta_for_effective_number\": beta,\n",
    "        \"unknown_included\": True\n",
    "    }\n",
    "}\n",
    "save_json(OUT_LABELS_JSON, label_manifest)\n",
    "print(\"✔️ label_manifest.json written.\")\n",
    "print(json.dumps(label_manifest, indent=2))\n"
   ]
  },
