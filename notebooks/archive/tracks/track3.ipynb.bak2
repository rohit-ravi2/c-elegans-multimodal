     "text": [
      "✔️ Structural features → /home/rohit/Desktop/Projects/C-Elegans/track3/data/structural_features.parquet | shape: (1533, 11)\n"
     ]
    }
   ],
   "source": [
    "# Weighted degrees\n",
    "w_in_both  = {n: 0.0 for n in G.nodes()}\n",
    "w_out_both = {n: 0.0 for n in G.nodes()}\n",
    "for u, v, d in G.edges(data=True):\n",
    "    w_both = float(d.get('w_chem', 0.0)) + float(d.get('w_elec', 0.0))\n",
    "    w_out_both[u] += w_both\n",
    "    w_in_both[v]  += w_both\n",
    "\n",
    "# Raw degrees\n",
    "in_deg   = dict(G.in_degree())\n",
    "out_deg  = dict(G.out_degree())\n",
    "deg_tot  = {n: in_deg.get(n,0) + out_deg.get(n,0) for n in G.nodes()}\n",
    "\n",
    "# PageRank on combined weights\n",
    "weights = {(u, v): float(d.get('w_chem',0.0))+float(d.get('w_elec',0.0)) for u, v, d in G.edges(data=True)}\n",
    "# NetworkX PageRank expects weight attribute; attach temporary\n",
    "for (u, v), w in weights.items():\n",
    "    G[u][v]['w_both'] = w\n",
    "pr = nx.pagerank(G, alpha=0.85, weight='w_both')\n",
    "\n",
    "# Betweenness (approximate on unweighted graph)\n",
    "G_unw = nx.DiGraph()\n",
    "G_unw.add_nodes_from(G.nodes())\n",
    "G_unw.add_edges_from(G.edges())\n",
    "k = min(300, max(10, G.number_of_nodes()))\n",
    "btw = nx.betweenness_centrality(G_unw, k=k, normalized=True, seed=42)\n",
    "\n",
    "# Harmonic closeness (directed)\n",
    "clo_h = nx.harmonic_centrality(G_unw)\n",
    "\n",
    "# Undirected helpers for clustering/core/eigenvector\n",
    "G_u = nx.Graph()\n",
    "for u, v, d in G.edges(data=True):\n",
    "    w = float(d.get('w_both', 0.0))\n",
    "    if G_u.has_edge(u, v):\n",
    "        G_u[u][v]['weight'] += w\n",
    "    else:\n",
    "        G_u.add_edge(u, v, weight=w)\n",
    "\n",
    "clust_u = nx.clustering(G_u, weight=None)  # unweighted clustering as planned\n",
    "core_u = nx.core_number(G_u)\n",
    "\n",
    "# Eigenvector centrality can fail on disconnected/large graphs; wrap safely\n",
    "try:\n",
    "    eig_u = nx.eigenvector_centrality_numpy(G_u, weight='weight')\n",
    "except Exception:\n",
    "    eig_u = {n: 0.0 for n in G.nodes()}\n",
    "\n",
    "struct_df = pd.DataFrame({\n",
    "    \"in_deg\": pd.Series(in_deg),\n",
    "    \"out_deg\": pd.Series(out_deg),\n",
    "    \"deg_total\": pd.Series(deg_tot),\n",
    "    \"w_in_both\": pd.Series(w_in_both),\n",
    "    \"w_out_both\": pd.Series(w_out_both),\n",
    "    \"pr\": pd.Series(pr),\n",
    "    \"btw\": pd.Series(btw),\n",
    "    \"clo_h\": pd.Series(clo_h),\n",
    "    \"clust_u\": pd.Series(clust_u),\n",
    "    \"core_u\": pd.Series(core_u),\n",
    "    \"eig_u\": pd.Series(eig_u),\n",
    "}).fillna(0.0).sort_index()\n",
    "\n",
    "struct_df.to_parquet(OUT_STRUCT_PARQ, index=True)\n",
    "print(f\"✔️ Structural features → {OUT_STRUCT_PARQ} | shape: {struct_df.shape}\")\n"
   ]
  },
