   ],
   "source": [
    "# Cell 12 — Split Audits (disjointness, balance, lineage isolation, leakage probes) — FIXED\n",
    "\n",
    "def audit_split(name: str, payload: dict, g_series: pd.Series | None):\n",
    "    train = set(payload['train'])\n",
    "    val   = set(payload['val'])\n",
    "    test  = set(payload['test'])\n",
    "\n",
    "    # Disjointness\n",
    "    disjoint = (train.isdisjoint(val) and train.isdisjoint(test) and val.isdisjoint(test))\n",
    "\n",
    "    # Coverage (only labeled rows)\n",
    "    labeled = set(df_sorted.index.tolist())\n",
    "    covered = (train | val | test)\n",
    "    coverage_ok = (covered <= labeled) and (len(covered) == len(labeled))\n",
    "\n",
    "    # Class balance (proportions vs global)\n",
    "    def cls_counts(ids):\n",
    "        return df_sorted.loc[list(ids), 'label_final'].value_counts().to_dict()\n",
    "    cc_train = cls_counts(train)\n",
    "    cc_val   = cls_counts(val)\n",
    "    cc_test  = cls_counts(test)\n",
    "    cc_global = df_sorted['label_final'].value_counts().to_dict()\n",
    "\n",
    "    dev = {}\n",
    "    for c, gcnt in cc_global.items():\n",
    "        dev[c] = {\n",
    "            \"train\": (cc_train.get(c,0) / gcnt) if gcnt else None,\n",
    "            \"val\":   (cc_val.get(c,0) / gcnt) if gcnt else None,\n",
    "            \"test\":  (cc_test.get(c,0) / gcnt) if gcnt else None\n",
    "        }\n",
    "\n",
    "    # Bilateral audit\n",
    "    cross_pair_violation = 0\n",
    "    for base, members in pairs_map.items():\n",
    "        memb = set(m for m in members if m in covered)\n",
    "        if len(memb) >= 2:\n",
    "            in_train = memb & train\n",
    "            in_val   = memb & val\n",
    "            in_test  = memb & test\n",
    "            folds_present = sum([len(in_train)>0, len(in_val)>0, len(in_test)>0])\n",
    "            if folds_present > 1:\n",
    "                cross_pair_violation += 1\n",
    "\n",
    "    # Lineage isolation (blocked mode only)\n",
    "    lineage_isolation_ok = None\n",
    "    if g_series is not None:\n",
    "        # Ensure g_series index is Neuron ids\n",
    "        g_series = g_series.copy()\n",
    "        if g_series.index.name is None:\n",
    "            g_series.index.name = 'Neuron'\n",
    "        g_train = set(g_series.loc[list(train)].unique())\n",
    "        g_val   = set(g_series.loc[list(val)].unique())\n",
    "        g_test  = set(g_series.loc[list(test)].unique())\n",
    "        lineage_isolation_ok = (g_train.isdisjoint(g_val) and g_train.isdisjoint(g_test) and g_val.isdisjoint(g_test))\n",
    "\n",
    "    # Leakage probes on undirected skeleton\n",
    "    G_u = nx.Graph()\n",
    "    G_u.add_nodes_from(G.nodes())\n",
    "    G_u.add_edges_from(G.edges())\n",
    "\n",
    "    train_list = [n for n in train if n in G_u]\n",
    "    test_list  = [n for n in test  if n in G_u]\n",
    "    dists = []\n",
    "    direct_contacts = 0\n",
    "    train_set = set(train_list)\n",
    "    for t in test_list:\n",
    "        nbrs = set(G_u.neighbors(t)) if t in G_u else set()\n",
    "        if len(nbrs & train_set) > 0:\n",
    "            direct_contacts += 1\n",
    "        try:\n",
    "            lengths = nx.single_source_shortest_path_length(G_u, t, cutoff=4)\n",
    "            hits = [lengths[x] for x in train_list if x in lengths]\n",
    "            if hits:\n",
    "                dists.append(min(hits))\n",
    "        except Exception:\n",
    "            pass\n",
    "    avg_min_dist = float(np.mean(dists)) if dists else None\n",
    "    frac_direct  = float(direct_contacts/len(test_list)) if test_list else 0.0\n",
    "\n",
    "    audit = {\n",
    "        \"name\": name,\n",
    "        \"nodes\": {\n",
    "            \"train\": len(train),\n",
    "            \"val\": len(val),\n",
    "            \"test\": len(test),\n",
    "            \"total_labeled\": len(labeled),\n",
    "        },\n",
    "        \"checks\": {\n",
    "            \"disjoint\": disjoint,\n",
    "            \"coverage_full\": coverage_ok,\n",
    "            \"bilateral_cross_fold_pairs\": cross_pair_violation,\n",
    "            \"lineage_isolation_ok\": lineage_isolation_ok,\n",
    "        },\n",
    "        \"class_proportions_vs_global\": dev,\n",
    "        \"leakage_probes\": {\n",
    "            \"avg_min_shortest_path_train_to_test\": avg_min_dist,\n",
    "            \"fraction_test_with_direct_train_neighbor\": frac_direct\n",
    "        }\n",
    "    }\n",
    "    return audit\n",
    "\n",
    "# Run audits and save\n",
    "for seed in SEEDS:\n",
    "    # Random audit\n",
    "    payload_r = json.loads(Path(SPLIT_FILES_RANDOM[seed]).read_text())\n",
    "    audit_r = audit_split(f\"random_seed{seed}\", payload_r, g_series=None)\n",
    "    save_json(AUDIT_DIR / f\"audit_random_seed{seed}.json\", audit_r)\n",
    "\n",
    "    # Lineage-blocked audit — robustly read groups (index or column)\n",
    "    df_groups = pd.read_parquet(GROUPS_FILES[seed])\n",
    "    if 'Neuron' in df_groups.columns:\n",
    "        df_groups = df_groups.set_index('Neuron')\n",
    "    if df_groups.index.name is None:\n",
    "        df_groups.index.name = 'Neuron'\n",
    "    if 'group_id' not in df_groups.columns:\n",
    "        raise KeyError(f\"'group_id' not found in {GROUPS_FILES[seed].name}. Columns present: {list(df_groups.columns)}\")\n",
    "    g_series = df_groups['group_id'].astype(int)\n",
    "\n",
    "    payload_b = json.loads(Path(SPLIT_FILES_BLOCK[seed]).read_text())\n",
    "    audit_b = audit_split(f\"lineageblocked_seed{seed}\", payload_b, g_series=g_series)\n",
    "    save_json(AUDIT_DIR / f\"audit_lineageblocked_seed{seed}.json\", audit_b)\n",
    "\n",
    "print(\"✔️ Split audits saved to\", AUDIT_DIR)\n"
   ]
  },
