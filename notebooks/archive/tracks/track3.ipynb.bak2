   "source": [
    "# === Track 3 — Part 3: Baselines (LogReg / Linear SVM / MLP) ===\n",
    "\n",
    "import os, json\n",
    "from pathlib import Path\n",
    "from collections import defaultdict\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "\n",
    "from sklearn.compose import ColumnTransformer\n",
    "from sklearn.preprocessing import StandardScaler, OneHotEncoder\n",
    "from sklearn.pipeline import Pipeline\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "from sklearn.svm import LinearSVC\n",
    "from sklearn.neural_network import MLPClassifier\n",
    "from sklearn.metrics import (\n",
    "    accuracy_score, f1_score, classification_report, confusion_matrix\n",
    ")\n",
    "\n",
    "# Paths\n",
    "ROOT = Path.cwd()\n",
    "T3 = ROOT / \"track3\"\n",
    "DATA = T3 / \"data\"\n",
    "SPLITS = DATA / \"splits\"\n",
    "RESULTS = T3 / \"results\" / \"baseline\"\n",
    "RESULTS.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "# Inputs\n",
    "FEATURES_PARQ = DATA / \"features_frozen.parquet\"\n",
    "LABELS_JSON   = DATA / \"label_manifest.json\"\n",
    "COLS_JSON     = DATA / \"column_dictionary.json\"\n",
    "\n",
    "# Split files\n",
    "SEEDS = [13, 21, 34, 55, 89]\n",
    "SPLIT_FILE_RANDOM  = {s: SPLITS / f\"random_seed{s}.json\" for s in SEEDS}\n",
    "SPLIT_FILE_BLOCKED = {s: SPLITS / f\"lineageblocked_seed{s}.json\" for s in SEEDS}\n",
    "\n",
    "print(\"✔️ Baselines setup ready.\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 53,
   "id": "74a10c33",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load metadata manifests\n",
    "with open(LABELS_JSON, \"r\") as f:\n",
    "    label_manifest = json.load(f)\n",
    "with open(COLS_JSON, \"r\") as f:\n",
    "    col_dict = json.load(f)\n",
    "\n",
    "class_order = label_manifest[\"class_order\"]             # ['Interneuron','Sensory','Motor','Glia','Unknown']\n",
    "class_weights_map = label_manifest[\"class_weights\"]     # dict: class -> weight\n",
    "label_to_id = {c: i for i, c in enumerate(class_order)}\n",
    "\n",
    "# Load features (Parquet; if your env lacks parquet engine, add a CSV fallback)\n",
    "features = pd.read_parquet(FEATURES_PARQ)\n",
    "features = features.copy()  # avoid SettingWithCopy warnings\n",
    "\n",
    "# Columns by block\n",
    "struct_cols = col_dict[\"structural\"]\n",
    "lineage_cols = col_dict[\"lineage\"]\n",
    "motif_cols = col_dict[\"motifs\"]\n",
    "positional_raw = [\"BodyRegion_raw\", \"Side_raw\", \"IsGlia\"]\n",
    "\n",
    "# Final label col\n",
    "y_str = features[\"label_final\"].astype(str)\n",
    "y_int = y_str.map(label_to_id)\n",
    "\n",
    "# Column groups for preprocessing\n",
    "categorical_cols = [\"BodyRegion_raw\", \"Side_raw\"]\n",
    "numeric_cols = struct_cols + lineage_cols + motif_cols + [\"IsGlia\"]\n",
    "\n",
    "# Build a single ColumnTransformer to standardize numeric & one-hot categorical\n",
    "# Build a single ColumnTransformer to standardize numeric & one-hot categorical\n",
    "preprocess = ColumnTransformer(\n",
    "    transformers=[\n",
    "        (\"num\", StandardScaler(with_mean=True, with_std=True), numeric_cols),\n",
    "        (\"cat\", OneHotEncoder(handle_unknown=\"ignore\", sparse_output=False), categorical_cols),\n",
    "    ],\n",
    "    remainder=\"drop\",\n",
    "    verbose_feature_names_out=False\n",
    ")\n",
    "\n",
    "\n",
    "def build_model(model_name: str, seed: int):\n",
    "    \"\"\"\n",
    "    Returns an sklearn Pipeline with shared preprocess + specified classifier.\n",
    "    \"\"\"\n",
    "    if model_name == \"logreg\":\n",
    "        clf = LogisticRegression(\n",
    "            multi_class=\"ovr\",    # simple & stable for imbalanced classes\n",
    "            solver=\"liblinear\",\n",
    "            max_iter=1000,\n",
    "            class_weight={label_to_id[k]: v for k, v in class_weights_map.items()}\n",
    "        )\n",
    "    elif model_name == \"linsvm\":\n",
    "        # LinearSVC supports class_weight; needs decision_function_shape handling implicitly\n",
    "        clf = LinearSVC(\n",
    "            C=1.0,\n",
    "            max_iter=5000,\n",
    "            class_weight={label_to_id[k]: v for k, v in class_weights_map.items()},\n",
    "            random_state=seed\n",
    "        )\n",
    "    elif model_name == \"mlp\":\n",
    "        # MLP has no class_weight param; we'll pass sample_weight to fit()\n",
    "        clf = MLPClassifier(\n",
    "            hidden_layer_sizes=(256, 256),\n",
    "            activation=\"relu\",\n",
    "            learning_rate_init=1e-3,\n",
    "            alpha=1e-4,\n",
    "            batch_size=64,\n",
    "            max_iter=200,          # early_stopping enabled below\n",
    "            random_state=seed,\n",
    "            early_stopping=True,\n",
    "            n_iter_no_change=15,\n",
    "            verbose=False\n",
    "        )\n",
    "    else:\n",
    "        raise ValueError(f\"Unknown model_name: {model_name}\")\n",
    "\n",
    "    pipe = Pipeline(steps=[\n",
    "        (\"pre\", preprocess),\n",
    "        (\"clf\", clf)\n",
    "    ])\n",
    "    return pipe\n",
    "\n",
    "def sample_weights_for(y_ids: np.ndarray):\n",
    "    \"\"\"\n",
    "    Build per-sample weights using class_weights_map on integer labels.\n",
    "    \"\"\"\n",
    "    inv = {label_to_id[k]: v for k, v in class_weights_map.items()}\n",
    "    return np.array([inv.get(int(lbl), 1.0) for lbl in y_ids], dtype=float)\n",
    "def build_clf(model_name: str, seed: int):\n",
    "    if model_name == \"logreg\":\n",
    "        return LogisticRegression(\n",
    "            multi_class=\"ovr\",\n",
    "            solver=\"liblinear\",\n",
    "            max_iter=1000,\n",
    "            class_weight={label_to_id[k]: v for k, v in class_weights_map.items()}\n",
    "        )\n",
    "    elif model_name == \"linsvm\":\n",
    "        return LinearSVC(\n",
    "            C=1.0,\n",
    "            max_iter=5000,\n",
    "            class_weight={label_to_id[k]: v for k, v in class_weights_map.items()}\n",
    "            # NOTE: LinearSVC has no random_state param\n",
    "        )\n",
    "    elif model_name == \"mlp\":\n",
    "        return MLPClassifier(\n",
    "            hidden_layer_sizes=(256, 256),\n",
    "            activation=\"relu\",\n",
    "            learning_rate_init=1e-3,\n",
    "            alpha=1e-4,\n",
    "            batch_size=64,\n",
    "            max_iter=200,\n",
    "            random_state=seed,\n",
    "            early_stopping=True,\n",
    "            n_iter_no_change=15,\n",
    "            verbose=False\n",
    "        )\n",
    "    else:\n",
    "        raise ValueError(f\"Unknown model_name: {model_name}\")\n"
   ]
  },
