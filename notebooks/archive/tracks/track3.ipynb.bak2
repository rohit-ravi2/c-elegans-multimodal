   "source": [
    "# One-time helper: create lineage-blocked split for any missing seed\n",
    "def ensure_blocked_split(seed: int):\n",
    "    if seed in SPLIT_FILE_BLOCKED and Path(SPLIT_FILE_BLOCKED[seed]).exists():\n",
    "        return SPLIT_FILE_BLOCKED[seed]\n",
    "    # build groups series (Neuron -> group_id) from your existing source\n",
    "    g_series = pd.read_parquet(GROUPS_FILES[SEEDS[0]]).set_index('Neuron')['group_id']  # reuse any existing groups file\n",
    "    tr, va, te = lineage_blocked_split(g_series, seed=seed)\n",
    "    payload = {\"seed\": seed, \"mode\": \"lineage_blocked\", \"train\": tr, \"val\": va, \"test\": te}\n",
    "    outp = RESULTS_BASE / f\"splits/lineageblocked_seed{seed}.json\"\n",
    "    outp.parent.mkdir(parents=True, exist_ok=True)\n",
    "    outp.write_text(json.dumps(payload, indent=2))\n",
    "    SPLIT_FILE_BLOCKED[seed] = str(outp)\n",
    "    return str(outp)\n",
    "\n",
    "# Generate for a list of desired seeds\n",
    "for s in [101,123,145,167,189,211,233,255,277,299,321,343,365,387,409]:\n",
    "    try:\n",
    "        ensure_blocked_split(s)\n",
    "    except Exception as e:\n",
    "        print(f\"Could not make blocked split for seed {s}: {e}\")\n"
   ]
  },
