   "source": [
    "# Cell M3 — Sweep lambda_motif ∈ {0.25, 0.5, 0.75} on lineage_blocked across seeds\n",
    "\n",
    "LAMBDAS = [0.25, 0.5, 0.75]\n",
    "rows = []\n",
    "for seed in SEEDS:\n",
    "    for lam in LAMBDAS:\n",
    "        out = train_gcn_motif(seed, \"lineage_blocked\", SPLIT_FILE_BLOCKED,\n",
    "                              lambda_motif=lam, hidden=256, lr=1e-3, wd=1e-3, dropout=0.1,\n",
    "                              max_epochs=400, patience=40)\n",
    "        rows.append({\"seed\": seed, \"lambda_motif\": lam,\n",
    "                     \"val_macro_f1\": out[\"val_macro_f1\"], \"test_macro_f1\": out[\"test_macro_f1\"]})\n",
    "        print(f\"[seed {seed}] λ={lam:.2f} → val={out['val_macro_f1']:.3f}, test={out['test_macro_f1']:.3f}\")\n",
    "\n",
    "motif_score = pd.DataFrame(rows).sort_values([\"seed\",\"lambda_motif\"])\n",
    "motif_dir = RESULTS_GNN / \"motif_blend_lineage_blocked\"\n",
    "motif_dir.mkdir(parents=True, exist_ok=True)\n",
    "motif_path = motif_dir / \"scores.csv\"\n",
    "motif_score.to_csv(motif_path, index=False)\n",
    "\n",
    "print(\"\\n=== Motif blend (blocked) by seed ===\")\n",
    "display(motif_score)\n",
    "\n",
    "print(\"\\n=== Means by λ ===\")\n",
    "display(motif_score.groupby(\"lambda_motif\").agg(val_mean=(\"val_macro_f1\",\"mean\"),\n",
    "                                                test_mean=(\"test_macro_f1\",\"mean\"),\n",
    "                                                test_std=(\"test_macro_f1\",\"std\")).reset_index())\n",
    "print(f\"\\nSaved: {motif_path}\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 72,
   "id": "2a4c9146",
   "metadata": {},
   "outputs": [],
   "source": [
    "# === Cell 1: Motif-Gating Preprocessor ===\n",
    "import torch\n",
    "from torch_geometric.data import Data\n",
    "\n",
    "def apply_motif_gating(data: Data, motif_scores, threshold=0.2, keep_prob=0.5):\n",
    "    \"\"\"\n",
    "    data: PyG Data object\n",
    "    motif_scores: dict[(u,v)] -> float in [0,1]\n",
    "    threshold: edges with score < threshold are randomly dropped\n",
    "    keep_prob: probability of keeping low-score edges\n",
    "    \"\"\"\n",
    "    src, dst = data.edge_index\n",
    "    keep_mask = []\n",
    "    for u, v in zip(src.tolist(), dst.tolist()):\n",
    "        score = motif_scores.get((u, v), motif_scores.get((v, u), 0.0))\n",
    "        if score >= threshold:\n",
    "            keep_mask.append(True)\n",
    "        else:\n",
    "            keep_mask.append(torch.rand(1).item() < keep_prob)\n",
    "    keep_mask = torch.tensor(keep_mask, dtype=torch.bool)\n",
    "    data.edge_index = data.edge_index[:, keep_mask]\n",
    "    if data.edge_attr is not None:\n",
    "        data.edge_attr = data.edge_attr[keep_mask]\n",
    "    return data\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 73,
   "id": "8f802d88",
   "metadata": {},
   "outputs": [],
   "source": [
    "# === Cell 2: Motif Feature Fusion Layer ===\n",
    "import torch.nn as nn\n",
    "\n",
    "class MotifFusionHead(nn.Module):\n",
    "    def __init__(self, in_dim, motif_dim, out_dim, dropout=0.3):\n",
    "        super().__init__()\n",
    "        self.proj_gnn = nn.Linear(in_dim, out_dim)\n",
    "        self.proj_motif = nn.Linear(motif_dim, out_dim)\n",
    "        self.bn = nn.BatchNorm1d(out_dim)\n",
    "        self.dropout = nn.Dropout(dropout)\n",
    "        self.act = nn.ReLU()\n",
    "        \n",
    "    def forward(self, gnn_out, motif_feats):\n",
    "        fused = self.proj_gnn(gnn_out) + self.proj_motif(motif_feats)\n",
    "        fused = self.bn(fused)\n",
    "        fused = self.dropout(self.act(fused))\n",
    "        return fused\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 74,
   "id": "8db52d9d",
   "metadata": {},
   "outputs": [],
   "source": [
    "# === Cell 3: GCN with Motif Fusion ===\n",
    "from torch_geometric.nn import GCNConv\n",
    "\n",
    "class GCNMotif(nn.Module):\n",
    "    def __init__(self, in_dim, hidden_dim, motif_dim, num_classes, dropout=0.3):\n",
    "        super().__init__()\n",
    "        self.conv1 = GCNConv(in_dim, hidden_dim)\n",
    "        self.conv2 = GCNConv(hidden_dim, hidden_dim)\n",
    "        self.fusion = MotifFusionHead(hidden_dim, motif_dim, hidden_dim, dropout)\n",
    "        self.classifier = nn.Linear(hidden_dim, num_classes)\n",
    "        self.dropout = nn.Dropout(dropout)\n",
    "\n",
    "    def forward(self, x, edge_index, motif_feats):\n",
    "        x = self.dropout(torch.relu(self.conv1(x, edge_index)))\n",
    "        x = torch.relu(self.conv2(x, edge_index))\n",
    "        x = self.fusion(x, motif_feats)\n",
    "        return self.classifier(x)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 75,
   "id": "a5b838f3",
   "metadata": {},
   "outputs": [],
   "source": [
    "# === Cell 4: Train + Eval ===\n",
    "import torch.optim as optim\n",
    "\n",
    "def train_model(model, data, motif_feats, train_mask, val_mask, test_mask, \n",
    "                lr=0.001, weight_decay=0.001, epochs=200, patience=20):\n",
    "    optimizer = optim.Adam(model.parameters(), lr=lr, weight_decay=weight_decay)\n",
    "    best_val, best_test, counter = 0, 0, 0\n",
    "    \n",
    "    for epoch in range(epochs):\n",
    "        model.train()\n",
    "        optimizer.zero_grad()\n",
    "        out = model(data.x, data.edge_index, motif_feats)\n",
    "        loss = torch.nn.functional.cross_entropy(out[train_mask], data.y[train_mask])\n",
    "        loss.backward()\n",
    "        optimizer.step()\n",
    "        \n",
    "        # Eval\n",
    "        model.eval()\n",
    "        with torch.no_grad():\n",
    "            logits = model(data.x, data.edge_index, motif_feats)\n",
    "            val_f1 = f1_score(data.y[val_mask].cpu(), logits[val_mask].argmax(1).cpu(), average='macro')\n",
    "            test_f1 = f1_score(data.y[test_mask].cpu(), logits[test_mask].argmax(1).cpu(), average='macro')\n",
    "        \n",
    "        if val_f1 > best_val:\n",
    "            best_val, best_test = val_f1, test_f1\n",
    "            counter = 0\n",
    "        else:\n",
    "            counter += 1\n",
    "        \n",
    "        if counter >= patience:\n",
    "            break\n",
    "\n",
    "    return best_val, best_test\n"
   ]
  },
