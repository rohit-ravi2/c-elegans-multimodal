   "source": [
    "FINAL_RESULTS = RESULTS_GNN / \"final_gcn_trainSubgraph\"\n",
    "FINAL_RESULTS.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "rows = []\n",
    "for seed in SEEDS:\n",
    "    for mode, split_map in [(\"random\", SPLIT_FILE_RANDOM), (\"lineage_blocked\", SPLIT_FILE_BLOCKED)]:\n",
    "        tag = f\"gcn_{mode}_seed{seed}\"\n",
    "        out = train_gcn_final(seed, mode, split_map)\n",
    "        # save metrics + predictions\n",
    "        out_dir = FINAL_RESULTS / tag\n",
    "        out_dir.mkdir(parents=True, exist_ok=True)\n",
    "        with open(out_dir / \"train_metrics.json\",\"w\") as f: json.dump(out[\"train\"], f, indent=2)\n",
    "        with open(out_dir / \"val_metrics.json\",\"w\")   as f: json.dump(out[\"val\"],   f, indent=2)\n",
    "        with open(out_dir / \"test_metrics.json\",\"w\")  as f: json.dump(out[\"test\"],  f, indent=2)\n",
    "        pd.Series(out[\"preds\"]).to_csv(out_dir / \"preds_all_nodes.csv\", header=[\"pred_label_id\"])\n",
    "\n",
    "        rows.append({\n",
    "            \"mode\": mode, \"model\": \"GCN_trainSubgraph\",\n",
    "            \"seed\": seed, \"val_macro_f1\": out[\"val_macro_f1\"], \"test_macro_f1\": out[\"test_macro_f1\"],\n",
    "            \"best_epoch\": out[\"best_epoch\"]\n",
    "        })\n",
    "        print(f\"{tag}: val={out['val_macro_f1']:.3f} test={out['test_macro_f1']:.3f} (best_epoch={out['best_epoch']})\")\n",
    "\n",
    "score = pd.DataFrame(rows).sort_values([\"mode\",\"seed\"])\n",
    "score.to_csv(FINAL_RESULTS / \"scorecard.csv\", index=False)\n",
    "\n",
    "agg = (score.groupby([\"mode\",\"model\"])\n",
    "       .agg(val_macro_f1_mean=(\"val_macro_f1\",\"mean\"),\n",
    "            val_macro_f1_std=(\"val_macro_f1\",\"std\"),\n",
    "            test_macro_f1_mean=(\"test_macro_f1\",\"mean\"),\n",
    "            test_macro_f1_std=(\"test_macro_f1\",\"std\"))\n",
    "       .reset_index())\n",
    "agg.to_csv(FINAL_RESULTS / \"scorecard_agg.csv\", index=False)\n",
    "\n",
    "print(\"\\n=== Final GCN (train‑subgraph) Scorecard ===\")\n",
    "display(score); print()\n",
    "print(\"=== Aggregated ===\")\n",
    "display(agg)\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "6f23012b",
   "metadata": {},
   "source": [
    "## Motif weighted"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 69,
   "id": "51028fae",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Motif matrix: N=1533, K=418\n",
      "Edge weights ready: struct_norm min/max=0.015/1.000 motif_jacc min/max=0.056/1.000\n"
     ]
    }
   ],
   "source": [
    "# Cell M1 — Build motif-based edge weights and blend with structural weights\n",
    "\n",
    "import numpy as np\n",
    "import torch\n",
    "\n",
    "# 1) Pull motif membership matrix (N × K) as bool\n",
    "motif_cols = col_dict[\"motifs\"]\n",
    "M = features.loc[node_ids, motif_cols].astype(bool).values  # shape (N, K)\n",
    "N, K = M.shape\n",
    "print(f\"Motif matrix: N={N}, K={K}\")\n",
    "\n",
    "# 2) For each edge (u,v), compute normalized overlap between motif sets\n",
    "# Overlap = |S_u ∩ S_v| / |S_u ∪ S_v|  (Jaccard); fall back to 0 if union=0\n",
    "src = edge_index[0].cpu().numpy()\n",
    "dst = edge_index[1].cpu().numpy()\n",
    "\n",
    "Su = M[src]  # (E, K)\n",
    "Sv = M[dst]  # (E, K)\n",
    "inter = (Su & Sv).sum(axis=1).astype(np.float32)      # |∩|\n",
    "union = (Su | Sv).sum(axis=1).astype(np.float32)      # |∪|\n",
    "with np.errstate(divide='ignore', invalid='ignore'):\n",
    "    jacc = np.where(union > 0, inter / union, 0.0).astype(np.float32)\n",
    "\n",
    "edge_weight_struct = edge_weight.cpu().numpy().astype(np.float32)\n",
    "# normalize structural weights to [0,1] by dividing by 99th percentile (clip to 1)\n",
    "p99 = np.percentile(edge_weight_struct, 99) if len(edge_weight_struct) else 1.0\n",
    "p99 = max(p99, 1e-6)\n",
    "ew_struct_norm = np.clip(edge_weight_struct / p99, 0.0, 1.0)\n",
    "\n",
    "# cache numpy versions; trainer will blend with lambda_motif\n",
    "EW_STRUCT_NORM = torch.tensor(ew_struct_norm, dtype=torch.float32)\n",
    "EW_MOTIF_NORM  = torch.tensor(jacc,            dtype=torch.float32)\n",
    "\n",
    "print(\"Edge weights ready:\",\n",
    "      f\"struct_norm min/max={EW_STRUCT_NORM.min().item():.3f}/{EW_STRUCT_NORM.max().item():.3f}\",\n",
    "      f\"motif_jacc min/max={EW_MOTIF_NORM.min().item():.3f}/{EW_MOTIF_NORM.max().item():.3f}\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 70,
   "id": "9fb8f877",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell M2 — Final trainer variant: GCN with blended (struct ⊕ motif) edge weights\n",
    "\n",
    "def train_gcn_motif(seed, mode, split_map, lambda_motif=0.5,\n",
    "                    hidden=256, lr=1e-3, wd=1e-3, dropout=0.1,\n",
    "                    max_epochs=400, patience=40, device=None):\n",
    "    \"\"\"\n",
    "    lambda_motif in [0,1]: 0 = only structural, 1 = only motif weight; blends linearly.\n",
    "    Train on train-subgraph edges; eval on full graph.\n",
    "    \"\"\"\n",
    "    device = device or (\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
    "    tr_idx, va_idx, te_idx, train_mask, val_mask, test_mask, e_train = masks_for(seed, mode, split_map)\n",
    "\n",
    "    # Preprocess features: fit on TRAIN only\n",
    "    pre = make_preprocessor()\n",
    "    X_tr_df = features.iloc[tr_idx.cpu().numpy()][numeric_cols + categorical_cols]\n",
    "    X_all_df = features.loc[node_ids, numeric_cols + categorical_cols]\n",
    "    pre.fit(X_tr_df)\n",
    "    X_all_np = pre.transform(X_all_df).astype(np.float32)\n",
    "\n",
    "    X = torch.tensor(X_all_np, dtype=torch.float32, device=device)\n",
    "    y = torch.tensor(y_all,      dtype=torch.long,    device=device)\n",
    "\n",
    "    # Blended edge weights\n",
    "    ew_blend = (1.0 - lambda_motif) * EW_STRUCT_NORM + lambda_motif * EW_MOTIF_NORM\n",
    "    ew_blend = ew_blend.to(device)\n",
    "    ei_full  = edge_index.to(device)\n",
    "    # Train-only edges\n",
    "    ei_tr = ei_full[:, e_train]\n",
    "    ew_tr = ew_blend[e_train].to(device)\n",
    "\n",
    "    model = GCN_EdgeWeight_Node(X.shape[1], hidden, len(class_order), dropout=dropout).to(device)\n",
    "    opt   = torch.optim.Adam(model.parameters(), lr=lr, weight_decay=wd)\n",
    "    weights = class_weights_vec.to(device)\n",
    "\n",
    "    best = {\"epoch\": -1, \"val_macro_f1\": -1.0, \"state\": None}\n",
    "    wait = 0\n",
    "\n",
    "    for epoch in range(1, max_epochs+1):\n",
    "        model.train(); opt.zero_grad()\n",
    "        logits_tr = model(X, ei_tr, ew_tr)\n",
    "        loss = F.cross_entropy(logits_tr[train_mask.to(device)], y[train_mask.to(device)], weight=weights)\n",
    "        loss.backward(); opt.step()\n",
    "\n",
    "        model.eval()\n",
    "        with torch.no_grad():\n",
    "            logits = model(X, ei_full, ew_blend)\n",
    "            mv = eval_mask_node(logits, y, val_mask.to(device), class_order)[\"macro_f1\"]\n",
    "\n",
    "        if mv > best[\"val_macro_f1\"]:\n",
    "            best = {\"epoch\": epoch, \"val_macro_f1\": mv, \"state\": {k:v.detach().cpu() for k,v in model.state_dict().items()}}\n",
    "            wait = 0\n",
    "        else:\n",
    "            wait += 1\n",
    "            if wait >= patience:\n",
    "                break\n",
    "\n",
    "    if best[\"state\"] is not None:\n",
    "        model.load_state_dict(best[\"state\"])\n",
    "\n",
    "    model.eval()\n",
    "    with torch.no_grad():\n",
    "        logits = model(X, ei_full, ew_blend)\n",
    "        mtr = eval_mask_node(logits, y, train_mask.to(device), class_order)\n",
    "        mva = eval_mask_node(logits, y, val_mask.to(device),   class_order)\n",
    "        mte = eval_mask_node(logits, y, test_mask.to(device),  class_order)\n",
    "\n",
    "    return {\n",
    "        \"seed\": seed, \"mode\": mode, \"lambda_motif\": lambda_motif,\n",
    "        \"val_macro_f1\": mva[\"macro_f1\"], \"test_macro_f1\": mte[\"macro_f1\"],\n",
    "        \"train\": mtr, \"val\": mva, \"test\": mte\n",
    "    }\n"
   ]
  },
