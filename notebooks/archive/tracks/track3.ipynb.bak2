   "source": [
    "# === Cell N1: Soft motif weighting (multiplicative) ===\n",
    "import numpy as np\n",
    "import torch\n",
    "\n",
    "# Build (re)usable boolean motif matrix and Jaccard per edge\n",
    "M_bool = (features.loc[node_ids, motif_cols].fillna(0).values > 0)\n",
    "src = edge_index[0].cpu().numpy()\n",
    "dst = edge_index[1].cpu().numpy()\n",
    "Su, Sv = M_bool[src], M_bool[dst]\n",
    "inter = np.logical_and(Su, Sv).sum(axis=1).astype(\"float32\")\n",
    "union = np.logical_or(Su, Sv).sum(axis=1).astype(\"float32\")\n",
    "jacc = inter / np.maximum(union, 1.0)  # [0,1]\n",
    "EW_MOTIF = torch.tensor(jacc, dtype=torch.float32)\n",
    "\n",
    "# Normalize existing structural weights to ~[0,1]\n",
    "ew_struct = edge_weight.clone().detach().cpu().numpy().astype(\"float32\")\n",
    "p99 = max(np.percentile(ew_struct, 99), 1e-6)\n",
    "EW_STRUCT = torch.tensor(np.clip(ew_struct / p99, 0.0, 1.0), dtype=torch.float32)\n",
    "\n",
    "def blended_weights_multiplicative(alpha: float) -> torch.Tensor:\n",
    "    \"\"\"\n",
    "    alpha>=0: final = EW_STRUCT * (1 + alpha * EW_MOTIF), then rescale to [0,1].\n",
    "    Keeps topology intact; softly boosts motif-sharing edges.\n",
    "    \"\"\"\n",
    "    w = EW_STRUCT * (1.0 + alpha * EW_MOTIF)\n",
    "    w = w / (w.max().clamp(min=1e-6))  # normalize to [0,1]\n",
    "    return w\n"
   ]
  },
