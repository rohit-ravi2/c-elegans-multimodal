    "issues = []\n",
    "\n",
    "# Coverage vs. original motif set\n",
    "coverage = len(df_sorted) / len(motifs)\n",
    "if coverage < 0.95:\n",
    "    issues.append(f\"Coverage below 0.95: {coverage:.3f}\")\n",
    "\n",
    "# Duplicates\n",
    "if df_sorted.index.duplicated().any():\n",
    "    issues.append(\"Duplicate neurons found after merge.\")\n",
    "\n",
    "# Nulls (should be none in numeric blocks; categorical okay)\n",
    "numeric_blocks = col_dict['structural'] + col_dict['lineage'] + col_dict['motifs']\n",
    "null_numeric = int(df_sorted[numeric_blocks].isna().sum().sum())\n",
    "if null_numeric > 0:\n",
    "    issues.append(f\"Numeric nulls present: {null_numeric}\")\n",
    "\n",
    "# Label sanity\n",
    "if df_sorted['label_final'].isna().any():\n",
    "    issues.append(\"Some rows have NaN label_final.\")\n",
    "\n",
    "# Summarize\n",
    "if issues:\n",
    "    print(\"❌ Integrity issues:\")\n",
    "    for it in issues:\n",
    "        print(\"  -\", it)\n",
    "    raise AssertionError(\"Integrity checks failed. See messages above.\")\n",
    "else:\n",
    "    print(\"✔️ Integrity checks passed.\")\n"
   ]
