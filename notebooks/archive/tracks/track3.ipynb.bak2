   "source": [
    "# === Cell N3: Stacked fusion on blocked splits ===\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "\n",
    "def baseline_lr_probs(seed):\n",
    "    # Train LR baseline on TRAIN (same preprocess) and return probs for ALL nodes\n",
    "    tr_ids, va_ids, te_ids, *_ = load_split(SPLIT_FILE_BLOCKED[seed])\n",
    "    pre = make_preprocessor()\n",
    "    X_tr_df = features.loc[tr_ids, numeric_cols + categorical_cols]\n",
    "    X_all_df = features.loc[node_ids, numeric_cols + categorical_cols]\n",
    "    y_tr = features.loc[tr_ids, \"label_final\"].map(label_to_id).values\n",
    "    pre.fit(X_tr_df)\n",
    "    X_tr = pre.transform(X_tr_df)\n",
    "    X_all = pre.transform(X_all_df)\n",
    "    lr = LogisticRegression(multi_class=\"ovr\", solver=\"liblinear\", max_iter=1000,\n",
    "                            class_weight={label_to_id[k]: v for k,v in class_weights_map.items()})\n",
    "    lr.fit(X_tr, y_tr)\n",
    "    return lr, pre, lr.predict_proba(X_all)\n",
    "\n",
    "@torch.no_grad()\n",
    "def gcn_logits_for_all(seed, alpha=0.5, hidden=256, lr=1e-3, wd=1e-3, dropout=0.1,\n",
    "                       max_epochs=400, patience=40, device=None):\n",
    "    device = device or (\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
    "    tr_idx, va_idx, te_idx, train_mask, val_mask, test_mask, e_train = masks_for(seed, \"lineage_blocked\", SPLIT_FILE_BLOCKED)\n",
    "\n",
    "    # Preprocess features on TRAIN\n",
    "    pre = make_preprocessor()\n",
    "    X_tr_df = features.iloc[tr_idx.cpu().numpy()][numeric_cols + categorical_cols]\n",
    "    X_all_df = features.loc[node_ids, numeric_cols + categorical_cols]\n",
    "    pre.fit(X_tr_df)\n",
    "    X_all = torch.tensor(pre.transform(X_all_df).astype(np.float32), dtype=torch.float32, device=device)\n",
    "    y = torch.tensor(y_all, dtype=torch.long, device=device)\n",
    "\n",
    "    # Soft motif weights\n",
    "    ew_blend = blended_weights_multiplicative(alpha).to(device)\n",
    "    ei_full  = edge_index.to(device)\n",
    "    ei_tr    = ei_full[:, e_train]\n",
    "    ew_tr    = ew_blend[e_train]\n",
    "\n",
    "    model = GCN_EdgeWeight_Node(X_all.shape[1], hidden, len(class_order), dropout=dropout).to(device)\n",
    "    opt   = torch.optim.Adam(model.parameters(), lr=lr, weight_decay=wd)\n",
    "    weights = class_weights_vec.to(device)\n",
    "\n",
    "    best = {\"epoch\": -1, \"val_macro_f1\": -1.0, \"state\": None}\n",
    "    wait = 0\n",
    "\n",
    "    for epoch in range(1, max_epochs+1):\n",
    "        model.train()\n",
    "        with torch.enable_grad():  # <- force gradients even if an outer no_grad is active\n",
    "            opt.zero_grad()\n",
    "            logits_tr = model(X_all, ei_tr, ew_tr)\n",
    "            loss = F.cross_entropy(logits_tr[train_mask.to(device)], y[train_mask.to(device)], weight=weights)\n",
    "            assert loss.requires_grad, \"Loss has no grad; still under no_grad somewhere.\"\n",
    "            loss.backward()\n",
    "            opt.step()\n",
    "\n",
    "        model.eval()\n",
    "        with torch.no_grad():\n",
    "            logits = model(X_all, ei_full, ew_blend)\n",
    "            mv = eval_mask_node(logits, y, val_mask.to(device), class_order)[\"macro_f1\"]\n",
    "\n",
    "        if mv > best[\"val_macro_f1\"]:\n",
    "            best = {\"epoch\": epoch, \"val_macro_f1\": mv,\n",
    "                    \"state\": {k: v.detach().cpu() for k, v in model.state_dict().items()}}\n",
    "            wait = 0\n",
    "        else:\n",
    "            wait += 1\n",
    "            if wait >= patience:\n",
    "                break\n",
    "\n",
    "    if best[\"state\"] is not None:\n",
    "        model.load_state_dict(best[\"state\"])\n",
    "\n",
    "    model.eval()\n",
    "    with torch.no_grad():\n",
    "        logits = model(X_all, ei_full, ew_blend).detach().cpu().numpy()\n",
    "        probs = torch.softmax(torch.tensor(logits), dim=1).numpy()\n",
    "    return probs\n",
    "\n",
    "\n",
    "\n",
    "# Run stacking\n",
    "rows = []\n",
    "alpha_stack = 0.5  # start with mid-strength motif boost for GCN branch\n",
    "for seed in SEEDS:\n",
    "    lr_model, pre_used, base_probs = baseline_lr_probs(seed)\n",
    "    gcn_probs = gcn_logits_for_all(seed, alpha=alpha_stack)\n",
    "\n",
    "    # Build train/val/test masks\n",
    "    tr_ids, va_ids, te_ids, *_ = load_split(SPLIT_FILE_BLOCKED[seed])\n",
    "    tr_idx = np.array([node_index[n] for n in tr_ids])\n",
    "    va_idx = np.array([node_index[n] for n in va_ids])\n",
    "    te_idx = np.array([node_index[n] for n in te_ids])\n",
    "    y_all_int = features[\"label_final\"].map(label_to_id).values\n",
    "\n",
    "    # Stacker inputs: concat probs [N, 2C]\n",
    "    X_stack = np.hstack([base_probs, gcn_probs])\n",
    "    # Calibrator: train on TRAIN, tune on VAL, report TEST (simple LR)\n",
    "    stacker = LogisticRegression(max_iter=1000, multi_class=\"ovr\")\n",
    "    stacker.fit(X_stack[tr_idx], y_all_int[tr_idx])\n",
    "    pred_te = stacker.predict(X_stack[te_idx])\n",
    "    pred_va = stacker.predict(X_stack[va_idx])\n",
    "\n",
    "    f1_te = f1_score(y_all_int[te_idx], pred_te, average=\"macro\", zero_division=0)\n",
    "    f1_va = f1_score(y_all_int[va_idx], pred_va, average=\"macro\", zero_division=0)\n",
    "    rows.append({\"seed\": seed, \"val_macro_f1\": f1_va, \"test_macro_f1\": f1_te})\n",
    "    print(f\"[stacked seed {seed}] val={f1_va:.3f} test={f1_te:.3f}\")\n",
    "\n",
    "stack_df = pd.DataFrame(rows)\n",
    "display(stack_df)\n",
    "print(\"Stacked mean test macro-F1:\", stack_df[\"test_macro_f1\"].mean())\n"
   ]
  },
  {
