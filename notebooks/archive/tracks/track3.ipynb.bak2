     "text": [
      "✔️ Lineage groups computed & saved.\n"
     ]
    }
   ],
   "source": [
    "# Standardize lineage latents\n",
    "L = df_sorted[col_dict['lineage']].values\n",
    "scaler_L = StandardScaler()\n",
    "L_std = scaler_L.fit_transform(L)\n",
    "\n",
    "lineage_groups_by_seed = {}\n",
    "\n",
    "for seed in SEEDS:\n",
    "    km = KMeans(n_clusters=20, random_state=seed, n_init='auto')\n",
    "    g_ids = km.fit_predict(L_std)\n",
    "    # Ensure bilateral members share group: reassign minority to majority within each base group\n",
    "    g_series = pd.Series(g_ids, index=df_sorted.index, name=\"group_id\")\n",
    "    for base, members in pairs_map.items():\n",
    "        members = [m for m in members if m in g_series.index]\n",
    "        if len(members) >= 2:\n",
    "            vals = g_series.loc[members].values\n",
    "            tgt = Counter(vals).most_common(1)[0][0]\n",
    "            g_series.loc[members] = tgt\n",
    "\n",
    "    lineage_groups_by_seed[seed] = g_series.to_frame()\n",
    "    lineage_groups_by_seed[seed]['seed'] = seed\n",
    "    lineage_groups_by_seed[seed]['centroid_id'] = lineage_groups_by_seed[seed]['group_id']  # placeholder\n",
    "\n",
    "    lineage_groups_by_seed[seed].to_parquet(GROUPS_FILES[seed], index=True)\n",
    "\n",
    "print(\"✔️ Lineage groups computed & saved.\")\n"
   ]
  },
  {
   "cell_type": "code",
