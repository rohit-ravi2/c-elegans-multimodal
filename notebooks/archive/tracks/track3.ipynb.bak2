   ],
   "source": [
    "# === Overnight multi‑restart ensemble for SMB‑GCN (α=0.5) on existing 5 seeds ===\n",
    "import os, json, gc, time\n",
    "from pathlib import Path\n",
    "from copy import deepcopy\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import torch\n",
    "import torch.nn.functional as F\n",
    "from tqdm.auto import tqdm\n",
    "from sklearn.metrics import f1_score\n",
    "\n",
    "device = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n",
    "os.environ.setdefault(\"OMP_NUM_THREADS\",\"8\"); os.environ.setdefault(\"OPENBLAS_NUM_THREADS\",\"8\")\n",
    "torch.set_num_threads(int(os.environ[\"OMP_NUM_THREADS\"]))\n",
    "\n",
    "ALPHA = 0.5\n",
    "RESTARTS = 12              # increase if you want longer run\n",
    "MAX_EPOCHS = 600\n",
    "PATIENCE   = 80\n",
    "SEEDS_RUN  = SEEDS         # uses ONLY your existing 5 seeds (e.g., [13,21,34,55,89])\n",
    "\n",
    "OUT_DIR = RESULTS_GNN / \"overnight_restarts_alpha0p5\"\n",
    "RUNS_DIR = OUT_DIR / \"runs\"            # per seed / per restart caches\n",
    "ENSEMBLE_DIR = OUT_DIR / \"ensembles\"   # per seed + across-seed summaries\n",
    "for d in (RUNS_DIR, ENSEMBLE_DIR): d.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "# ---------- Ensure edge weights ready (struct + motif) ----------\n",
    "def _ensure_edge_weights():\n",
    "    global EW_STRUCT, EW_MOTIF\n",
    "    need_struct = 'EW_STRUCT' not in globals()\n",
    "    need_motif  = 'EW_MOTIF'  not in globals()\n",
    "    if not (need_struct or need_motif): return\n",
    "    # structural normalize to [0,1]\n",
    "    ew_struct_np = edge_weight.detach().cpu().numpy().astype(\"float32\")\n",
    "    p99 = max(np.percentile(ew_struct_np, 99), 1e-6)\n",
    "    EW_STRUCT_L = np.clip(ew_struct_np / p99, 0.0, 1.0).astype(\"float32\")\n",
    "    # motif Jaccard per edge\n",
    "    M_bool = (features.loc[node_ids, motif_cols].fillna(0).values > 0)\n",
    "    src = edge_index[0].cpu().numpy(); dst = edge_index[1].cpu().numpy()\n",
    "    inter = np.logical_and(M_bool[src], M_bool[dst]).sum(axis=1).astype(\"float32\")\n",
    "    union = np.maximum(np.logical_or(M_bool[src], M_bool[dst]).sum(axis=1).astype(\"float32\"), 1.0)\n",
    "    EW_MOTIF_L = (inter / union).astype(\"float32\")\n",
    "    globals()['EW_STRUCT'] = torch.tensor(EW_STRUCT_L, dtype=torch.float32)\n",
    "    globals()['EW_MOTIF']  = torch.tensor(EW_MOTIF_L,  dtype=torch.float32)\n",
    "\n",
    "_ensure_edge_weights()\n",
    "\n",
    "def blended_weights_multiplicative(alpha: float) -> torch.Tensor:\n",
    "    w = EW_STRUCT * (1.0 + float(alpha) * EW_MOTIF)\n",
    "    return w / (w.max().clamp(min=1e-6))\n",
    "\n",
    "# ---------- One training run → probs over ALL nodes ----------\n",
    "def train_one_run(seed:int, init_offset:int, alpha:float=ALPHA,\n",
    "                  hidden=256, lr=1e-3, wd=1e-3, dropout=0.1,\n",
    "                  max_epochs=MAX_EPOCHS, patience=PATIENCE):\n",
    "    # split/masks (lineage_blocked only)\n",
    "    tr_idx, va_idx, te_idx, m_tr, m_va, m_te, e_tr = masks_for(seed, \"lineage_blocked\", SPLIT_FILE_BLOCKED)\n",
    "\n",
    "    # preprocess (fit on train, transform all)\n",
    "    pre = make_preprocessor()\n",
    "    X_tr_df = features.iloc[tr_idx.cpu().numpy()][numeric_cols + categorical_cols]\n",
    "    X_all_df = features.loc[node_ids, numeric_cols + categorical_cols]\n",
    "    pre.fit(X_tr_df)\n",
    "    X_all = torch.tensor(pre.transform(X_all_df).astype(np.float32), dtype=torch.float32, device=device)\n",
    "    y_all = torch.tensor(features[\"label_final\"].map(label_to_id).values, dtype=torch.long, device=device)\n",
    "\n",
    "    # edges/weights\n",
    "    ei_full = edge_index.to(device)\n",
    "    ew_full = blended_weights_multiplicative(alpha).to(device)\n",
    "    ei_tr   = ei_full[:, e_tr]\n",
    "    ew_tr   = ew_full[e_tr]\n",
    "\n",
    "    # model/opt\n",
    "    model = GCN_EdgeWeight_Node(X_all.shape[1], hidden, len(class_order), dropout=dropout).to(device)\n",
    "    # distinct randomness per restart:\n",
    "    torch.manual_seed(seed + 1000*init_offset)\n",
    "    np.random.seed(seed + 1000*init_offset)\n",
    "\n",
    "    opt = torch.optim.Adam(model.parameters(), lr=lr, weight_decay=wd)\n",
    "    weights = torch.tensor([class_weights_map[c] for c in class_order], dtype=torch.float32, device=device)\n",
    "\n",
    "    best = {\"epoch\": -1, \"val_macro_f1\": -1.0, \"state\": None}\n",
    "    wait = 0\n",
    "    for ep in range(1, max_epochs+1):\n",
    "        model.train()\n",
    "        with torch.enable_grad():\n",
    "            opt.zero_grad()\n",
    "            logits_tr = model(X_all, ei_tr, ew_tr)\n",
    "            loss = F.cross_entropy(logits_tr[m_tr.to(device)], y_all[m_tr.to(device)], weight=weights)\n",
    "            loss.backward(); opt.step()\n",
    "        model.eval()\n",
    "        with torch.no_grad():\n",
    "            logits = model(X_all, ei_full, ew_full)\n",
    "            val_f1 = f1_score(y_all[m_va].cpu().numpy(), logits[m_va].argmax(1).cpu().numpy(),\n",
    "                              average=\"macro\", zero_division=0)\n",
    "        if val_f1 > best[\"val_macro_f1\"]:\n",
    "            best = {\"epoch\": ep, \"val_macro_f1\": float(val_f1),\n",
    "                    \"state\": {k: v.detach().cpu() for k, v in model.state_dict().items()}}\n",
    "            wait = 0\n",
    "        else:\n",
    "            wait += 1\n",
    "            if wait >= patience: break\n",
    "\n",
    "    if best[\"state\"] is not None: model.load_state_dict(best[\"state\"])\n",
    "    model.eval()\n",
    "    with torch.no_grad():\n",
    "        probs = torch.softmax(model(X_all, ei_full, ew_full), dim=1).detach().cpu().numpy()\n",
    "\n",
    "    # bookkeeping metrics\n",
    "    te = f1_score(y_all[m_te].cpu().numpy(), probs[m_te.cpu().numpy()].argmax(1),\n",
    "                  average=\"macro\", zero_division=0)\n",
    "    va = f1_score(y_all[m_va].cpu().numpy(), probs[m_va.cpu().numpy()].argmax(1),\n",
    "                  average=\"macro\", zero_division=0)\n",
    "    return probs, {\"val_macro_f1\": float(va), \"test_macro_f1\": float(te), \"best_epoch\": best[\"epoch\"]}\n",
    "\n",
    "# ---------- Run restarts per seed with caching ----------\n",
    "per_run_rows = []\n",
    "for seed in tqdm(SEEDS_RUN, desc=\"Seeds\"):\n",
    "    sdir = RUNS_DIR / f\"seed_{seed}\"\n",
    "    sdir.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "    # run RESTARTS times\n",
    "    for r in tqdm(range(RESTARTS), desc=f\"seed {seed} restarts\", leave=False):\n",
    "        rdir = sdir / f\"restart_{r:02d}\"\n",
    "        rdir.mkdir(parents=True, exist_ok=True)\n",
    "        probs_path = rdir / \"probs.npy\"\n",
    "        meta_path  = rdir / \"meta.json\"\n",
    "        if probs_path.exists() and meta_path.exists():\n",
    "            meta = json.loads(meta_path.read_text())\n",
    "            per_run_rows.append({\"seed\": seed, \"restart\": r, **{k:meta[k] for k in [\"val_macro_f1\",\"test_macro_f1\",\"best_epoch\"]}})\n",
    "            continue\n",
    "        try:\n",
    "            probs, meta = train_one_run(seed, r, alpha=ALPHA)\n",
    "        except Exception as e:\n",
    "            print(f\"[SKIP] seed={seed} restart={r}: {e}\")\n",
    "            continue\n",
    "        np.save(probs_path, probs)\n",
    "        meta_out = {**meta, \"seed\": seed, \"restart\": r, \"alpha\": ALPHA}\n",
    "        meta_path.write_text(json.dumps(meta_out, indent=2))\n",
    "        per_run_rows.append({\"seed\": seed, \"restart\": r, **{k:meta[k] for k in [\"val_macro_f1\",\"test_macro_f1\",\"best_epoch\"]}})\n",
    "        # memory hygiene\n",
    "        del probs; gc.collect()\n",
    "        if torch.cuda.is_available(): torch.cuda.empty_cache()\n",
    "\n",
    "per_run_df = pd.DataFrame(per_run_rows).sort_values([\"seed\",\"restart\"])\n",
    "per_run_csv = OUT_DIR / \"per_restart_metrics.csv\"\n",
    "per_run_df.to_csv(per_run_csv, index=False)\n",
    "print(\"✔️ Saved per‑restart metrics →\", per_run_csv)\n",
    "display(per_run_df.groupby(\"seed\").agg(val_mean=(\"val_macro_f1\",\"mean\"),\n",
    "                                       test_mean=(\"test_macro_f1\",\"mean\"),\n",
    "                                       n=(\"test_macro_f1\",\"count\")).reset_index())\n",
    "\n",
    "# ---------- Build per‑seed restart ensembles ----------\n",
    "seed_rows = []\n",
    "for seed in SEEDS_RUN:\n",
    "    # stack probs from all available restarts\n",
    "    sdir = RUNS_DIR / f\"seed_{seed}\"\n",
    "    probs_list = []\n",
    "    for r in range(RESTARTS):\n",
    "        pth = sdir / f\"restart_{r:02d}\" / \"probs.npy\"\n",
    "        if pth.exists():\n",
    "            probs_list.append(np.load(pth))\n",
    "    if not probs_list:\n",
    "        print(f\"[WARN] no probs for seed {seed}; skipping ensemble\"); \n",
    "        continue\n",
    "    P_seed = np.stack(probs_list, axis=0).mean(axis=0)  # [N,C]\n",
    "\n",
    "    # eval on this seed's split\n",
    "    tr_ids, va_ids, te_ids, *_ = load_split(SPLIT_FILE_BLOCKED[seed])\n",
    "    te_idx = np.array([node_index[n] for n in te_ids])\n",
    "    va_idx = np.array([node_index[n] for n in va_ids])\n",
    "    y_all = features[\"label_final\"].map(label_to_id).values\n",
    "\n",
    "    f1_te = f1_score(y_all[te_idx], P_seed[te_idx].argmax(1), average=\"macro\", zero_division=0)\n",
    "    f1_va = f1_score(y_all[va_idx], P_seed[va_idx].argmax(1), average=\"macro\", zero_division=0)\n",
    "    seed_rows.append({\"seed\": seed, \"val_macro_f1\": f1_va, \"test_macro_f1\": f1_te, \"n_restarts\": len(probs_list)})\n",
    "\n",
    "seed_df = pd.DataFrame(seed_rows).sort_values(\"seed\")\n",
    "seed_csv = ENSEMBLE_DIR / \"per_seed_ensemble.csv\"\n",
    "seed_df.to_csv(seed_csv, index=False)\n",
    "print(\"✔️ Saved per‑seed ensemble →\", seed_csv); display(seed_df)\n",
    "print(\"Per‑seed ensemble mean test macro‑F1:\", seed_df[\"test_macro_f1\"].mean())\n",
    "\n",
    "# ---------- Across‑seed ensemble (average probs across ALL restarts of ALL seeds) ----------\n",
    "all_probs = []\n",
    "for seed in SEEDS_RUN:\n",
    "    sdir = RUNS_DIR / f\"seed_{seed}\"\n",
    "    for r in range(RESTARTS):\n",
    "        pth = sdir / f\"restart_{r:02d}\" / \"probs.npy\"\n",
    "        if pth.exists():\n",
    "            all_probs.append(np.load(pth))\n",
    "if all_probs:\n",
    "    P_all = np.stack(all_probs, axis=0).mean(axis=0)\n",
    "    rows = []\n",
    "    for seed in SEEDS_RUN:\n",
    "        tr_ids, va_ids, te_ids, *_ = load_split(SPLIT_FILE_BLOCKED[seed])\n",
    "        te_idx = np.array([node_index[n] for n in te_ids])\n",
    "        va_idx = np.array([node_index[n] for n in va_ids])\n",
    "        y_all = features[\"label_final\"].map(label_to_id).values\n",
    "        f1_te = f1_score(y_all[te_idx], P_all[te_idx].argmax(1), average=\"macro\", zero_division=0)\n",
    "        f1_va = f1_score(y_all[va_idx], P_all[va_idx].argmax(1), average=\"macro\", zero_division=0)\n",
    "        rows.append({\"seed\": seed, \"val_macro_f1\": f1_va, \"test_macro_f1\": f1_te})\n",
    "    all_df = pd.DataFrame(rows).sort_values(\"seed\")\n",
    "    all_csv = ENSEMBLE_DIR / \"across_seed_ensemble.csv\"\n",
    "    all_df.to_csv(all_csv, index=False)\n",
    "    print(\"✔️ Saved across‑seed ensemble →\", all_csv); display(all_df)\n",
    "    print(\"Across‑seed ensemble mean test macro‑F1:\", all_df[\"test_macro_f1\"].mean())\n",
    "else:\n",
    "    print(\"[WARN] No probs found to build across‑seed ensemble.\")\n"
   ]
  },
  {
