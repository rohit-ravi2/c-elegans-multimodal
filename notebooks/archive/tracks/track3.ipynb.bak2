   "source": [
    "rows = []\n",
    "errors = []\n",
    "run_logs = []\n",
    "\n",
    "outer = tqdm(SEEDS, desc=\"GNN seeds\", leave=True)\n",
    "for seed in outer:\n",
    "    for mode, split_map in [(\"random\", SPLIT_FILE_RANDOM), (\"lineage_blocked\", SPLIT_FILE_BLOCKED)]:\n",
    "        tag = f\"{'sage' if PYG_AVAILABLE else 'gcn'}_{mode}_seed{seed}\"\n",
    "        try:\n",
    "            t0 = time.perf_counter()\n",
    "            out = train_one(seed, mode, split_map, hidden=256, lr=1e-3, patience=30, dropout=0.2)\n",
    "            dur = time.perf_counter() - t0\n",
    "\n",
    "            # Persist metrics\n",
    "            out_dir = RESULTS_GNN / tag\n",
    "            out_dir.mkdir(parents=True, exist_ok=True)\n",
    "            with open(out_dir / \"train_metrics.json\", \"w\") as f: json.dump(out[\"train\"], f, indent=2)\n",
    "            with open(out_dir / \"val_metrics.json\", \"w\") as f: json.dump(out[\"val\"], f, indent=2)\n",
    "            with open(out_dir / \"test_metrics.json\", \"w\") as f: json.dump(out[\"test\"], f, indent=2)\n",
    "            with open(out_dir / \"history.json\", \"w\") as f: json.dump(out[\"history\"], f, indent=2)\n",
    "\n",
    "            rows.append({\n",
    "                \"mode\": mode,\n",
    "                \"model\": \"GraphSAGE\" if PYG_AVAILABLE else \"GCN\",\n",
    "                \"seed\": seed,\n",
    "                \"val_macro_f1\": out[\"val_macro_f1\"],\n",
    "                \"test_macro_f1\": out[\"test_macro_f1\"],\n",
    "                \"best_epoch\": out[\"best_epoch\"]\n",
    "            })\n",
    "            run_logs.append({\"tag\": tag, \"seconds\": dur})\n",
    "\n",
    "        except Exception as e:\n",
    "            errors.append({\"tag\": tag, \"error\": str(e)})\n",
    "            print(f\"⚠️ {tag} failed: {e}\")\n",
    "\n",
    "scorecard = pd.DataFrame(rows).sort_values([\"mode\",\"model\",\"seed\"])\n",
    "scorecard_path = RESULTS_GNN / \"gnn_scorecard.csv\"\n",
    "scorecard.to_csv(scorecard_path, index=False)\n",
    "\n",
    "agg = (scorecard\n",
    "       .groupby([\"mode\", \"model\"])\n",
    "       .agg(val_macro_f1_mean=(\"val_macro_f1\",\"mean\"),\n",
    "            val_macro_f1_std=(\"val_macro_f1\",\"std\"),\n",
    "            test_macro_f1_mean=(\"test_macro_f1\",\"mean\"),\n",
    "            test_macro_f1_std=(\"test_macro_f1\",\"std\"))\n",
    "       .reset_index())\n",
    "agg_path = RESULTS_GNN / \"gnn_scorecard_agg.csv\"\n",
    "agg.to_csv(agg_path, index=False)\n",
    "\n",
    "with open(RESULTS_GNN / \"gnn_run_logs.json\",\"w\") as f:\n",
    "    json.dump(run_logs, f, indent=2)\n",
    "if errors:\n",
    "    with open(RESULTS_GNN / \"gnn_errors.json\",\"w\") as f:\n",
    "        json.dump(errors, f, indent=2)\n",
    "\n",
    "print(\"=== GNN Scorecard (per run) ===\")\n",
    "display(scorecard)\n",
    "print(\"\\n=== GNN Scorecard (aggregated) ===\")\n",
    "display(agg)\n",
    "print(f\"\\nSaved:\\n- {scorecard_path}\\n- {agg_path}\")\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "59eb9e64",
   "metadata": {},
   "source": [
    "## Part 4 continued: edge weight updates, baseline rerun"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 63,
   "id": "cf30ba33",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "torch.Size([2, 20568]) torch.Size([20568]) ← undirected edge_index/edge_weight ready\n"
     ]
    }
   ],
   "source": [
    "# Cell A — Build undirected edge_index (+ edge_weight) for PyG\n",
    "\n",
    "from torch_geometric.utils import to_undirected\n",
    "\n",
    "# Start from your directed H (relabelled DiGraph 0..N-1)\n",
    "H = nx.relabel_nodes(G, node_index)\n",
    "\n",
    "# Build directed edge_index and edge_weight from H\n",
    "edges_list = list(H.edges())\n",
    "if len(edges_list) == 0:\n",
    "    raise RuntimeError(\"Graph has no edges after relabeling.\")\n",
    "\n",
    "edge_index = torch.tensor(edges_list, dtype=torch.long).t().contiguous()  # shape [2, E]\n",
    "edge_weight = []\n",
    "for u, v in edges_list:\n",
    "    d = H[u][v]\n",
    "    w = float(d.get(\"w_chem\", 0.0)) + float(d.get(\"w_elec\", 0.0))\n",
    "    edge_weight.append(w if w > 0 else 1.0)\n",
    "edge_weight = torch.tensor(edge_weight, dtype=torch.float32)\n",
    "\n",
    "# Make undirected (coalesce parallel edges by mean weight)\n",
    "edge_index, edge_weight = to_undirected(edge_index, edge_attr=edge_weight, reduce=\"mean\")\n",
    "\n",
    "print(edge_index.shape, edge_weight.shape, \"← undirected edge_index/edge_weight ready\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 64,
   "id": "0f07f2f8",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell B — Node classification models (BN + residual head) and trainer\n",
    "\n",
    "import torch.nn as nn\n",
    "import torch.nn.functional as F\n",
    "from torch_geometric.nn import SAGEConv, GCNConv, BatchNorm\n",
    "\n",
    "class ResidualHead(nn.Module):\n",
    "    def __init__(self, in_dim, hidden, out_dim, dropout=0.1):\n",
    "        super().__init__()\n",
    "        self.fc1 = nn.Linear(in_dim, hidden)\n",
    "        self.bn1 = nn.BatchNorm1d(hidden)\n",
    "        self.fc2 = nn.Linear(hidden, out_dim)\n",
    "        self.dropout = nn.Dropout(dropout)\n",
    "        self.proj = nn.Linear(in_dim, out_dim)  # residual projection\n",
    "\n",
    "    def forward(self, x):\n",
    "        z = self.dropout(F.relu(self.bn1(self.fc1(x))))\n",
    "        return self.fc2(z) + self.proj(x)\n",
    "\n",
    "class SAGE_BN_Residual_Node(nn.Module):\n",
    "    def __init__(self, in_dim, hidden, out_dim, dropout=0.1):\n",
    "        super().__init__()\n",
    "        self.conv1 = SAGEConv(in_dim, hidden, normalize=False)\n",
    "        self.bn1   = BatchNorm(hidden)\n",
    "        self.conv2 = SAGEConv(hidden, hidden, normalize=False)\n",
    "        self.bn2   = BatchNorm(hidden)\n",
    "        self.drop  = nn.Dropout(dropout)\n",
    "        self.head  = ResidualHead(hidden, hidden, out_dim, dropout)\n",
    "\n",
    "    def forward(self, x, edge_index, edge_weight=None):\n",
    "        x = self.drop(F.relu(self.bn1(self.conv1(x, edge_index))))\n",
    "        x = self.drop(F.relu(self.bn2(self.conv2(x, edge_index))))\n",
    "        return self.head(x)\n",
    "\n",
    "class GCN_EdgeWeight_Node(nn.Module):\n",
    "    def __init__(self, in_dim, hidden, out_dim, dropout=0.1):\n",
    "        super().__init__()\n",
    "        self.conv1 = GCNConv(in_dim, hidden, normalize=True)\n",
    "        self.bn1   = BatchNorm(hidden)\n",
    "        self.conv2 = GCNConv(hidden, hidden, normalize=True)\n",
    "        self.bn2   = BatchNorm(hidden)\n",
    "        self.drop  = nn.Dropout(dropout)\n",
    "        self.head  = ResidualHead(hidden, hidden, out_dim, dropout)\n",
    "\n",
    "    def forward(self, x, edge_index, edge_weight=None):\n",
    "        x = self.drop(F.relu(self.bn1(self.conv1(x, edge_index, edge_weight))))\n",
    "        x = self.drop(F.relu(self.bn2(self.conv2(x, edge_index, edge_weight))))\n",
    "        return self.head(x)\n",
    "\n",
    "@torch.no_grad()\n",
    "def eval_mask_node(logits, y_true, mask, label_names):\n",
    "    pred = logits.argmax(dim=1)\n",
    "    yt = y_true[mask].cpu().numpy()\n",
    "    yp = pred[mask].cpu().numpy()\n",
    "    all_labels = list(range(len(label_names)))\n",
    "    acc = accuracy_score(yt, yp)\n",
    "    macro_f1 = f1_score(yt, yp, average=\"macro\", zero_division=0)\n",
    "    per_class_f1 = f1_score(yt, yp, average=None, labels=all_labels, zero_division=0)\n",
    "    cm = confusion_matrix(yt, yp, labels=all_labels)\n",
    "    rep = classification_report(yt, yp, labels=all_labels, target_names=label_names, zero_division=0, output_dict=True)\n",
    "    return {\"accuracy\": float(acc), \"macro_f1\": float(macro_f1),\n",
    "            \"per_class_f1\": {label_names[i]: float(per_class_f1[i]) for i in all_labels},\n",
    "            \"confusion_matrix\": cm.tolist(), \"report\": rep}\n",
    "\n",
    "def train_node_model(seed, mode, split_map, model_cls, hidden=256, lr=1e-3, wd=1e-3, dropout=0.1,\n",
    "                     max_epochs=300, patience=40, use_edge_weight=True, device=None):\n",
    "    device = device or (\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
    "\n",
    "    # Masks from split\n",
    "    tr_ids, va_ids, te_ids, *_ = load_split(split_map[seed])\n",
    "    tr_idx = torch.tensor([node_index[n] for n in tr_ids], dtype=torch.long, device=device)\n",
    "    va_idx = torch.tensor([node_index[n] for n in va_ids], dtype=torch.long, device=device)\n",
    "    te_idx = torch.tensor([node_index[n] for n in te_ids], dtype=torch.long, device=device)\n",
    "\n",
    "    # Preprocess features (fit on TRAIN only), then transform ALL nodes (as before)\n",
    "    pre = make_preprocessor()\n",
    "    X_tr_df = features.loc[tr_ids, numeric_cols + categorical_cols]\n",
    "    X_all_df = features.loc[node_ids, numeric_cols + categorical_cols]\n",
    "    pre.fit(X_tr_df)\n",
    "    X_all_np = pre.transform(X_all_df).astype(np.float32)\n",
    "\n",
    "    X = torch.tensor(X_all_np, dtype=torch.float32, device=device)\n",
    "    y = torch.tensor(y_all,      dtype=torch.long,    device=device)\n",
    "\n",
    "    train_mask = torch.zeros(len(node_ids), dtype=torch.bool, device=device); train_mask[tr_idx] = True\n",
    "    val_mask   = torch.zeros_like(train_mask); val_mask[va_idx] = True\n",
    "    test_mask  = torch.zeros_like(train_mask); test_mask[te_idx] = True\n",
    "\n",
    "    # Edge tensors\n",
    "    ei = edge_index.to(device)\n",
    "    ew = edge_weight.to(device) if (use_edge_weight and 'GCN' in model_cls.__name__) else None\n",
    "\n",
    "    # Model/opt\n",
    "    model = model_cls(X.shape[1], hidden, len(class_order), dropout=dropout).to(device)\n",
    "    opt   = torch.optim.Adam(model.parameters(), lr=lr, weight_decay=wd)\n",
    "    weights = class_weights_vec.to(device)\n",
    "\n",
    "    best = {\"epoch\": -1, \"val_macro_f1\": -1.0, \"state\": None}\n",
    "    wait = 0\n",
    "\n",
    "    for epoch in range(1, max_epochs+1):\n",
    "        model.train(); opt.zero_grad()\n",
    "        logits = model(X, ei, ew)\n",
    "        loss = F.cross_entropy(logits[train_mask], y[train_mask], weight=weights)\n",
    "        loss.backward(); opt.step()\n",
    "\n",
    "        model.eval()\n",
    "        with torch.no_grad():\n",
    "            logits = model(X, ei, ew)\n",
    "            mv = eval_mask_node(logits, y, val_mask, class_order)[\"macro_f1\"]\n",
    "\n",
    "        if mv > best[\"val_macro_f1\"]:\n",
    "            best = {\"epoch\": epoch, \"val_macro_f1\": mv, \"state\": {k:v.detach().cpu() for k,v in model.state_dict().items()}}\n",
    "            wait = 0\n",
    "        else:\n",
    "            wait += 1\n",
    "            if wait >= patience:\n",
    "                break\n",
    "\n",
    "    if best[\"state\"] is not None:\n",
    "        model.load_state_dict(best[\"state\"])\n",
    "\n",
    "    model.eval()\n",
    "    with torch.no_grad():\n",
    "        logits = model(X, ei, ew)\n",
    "        mtr = eval_mask_node(logits, y, train_mask, class_order)\n",
    "        mva = eval_mask_node(logits, y, val_mask,   class_order)\n",
    "        mte = eval_mask_node(logits, y, test_mask,  class_order)\n",
    "\n",
    "    return {\"best_epoch\": best[\"epoch\"], \"val_macro_f1\": mva[\"macro_f1\"], \"test_macro_f1\": mte[\"macro_f1\"],\n",
    "            \"train\": mtr, \"val\": mva, \"test\": mte}\n"
   ]
  },
