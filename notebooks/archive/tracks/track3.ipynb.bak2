    "scorecard = pd.DataFrame(rows)\n",
    "scorecard_path = RESULTS / \"baseline_scorecard.csv\"\n",
    "scorecard.sort_values(by=[\"mode\",\"model\",\"seed\"], inplace=True)\n",
    "scorecard.to_csv(scorecard_path, index=False)\n",
    "\n",
    "# Optional: aggregate by model/mode over seeds\n",
    "agg = (scorecard\n",
    "       .groupby([\"mode\", \"model\"])\n",
    "       .agg(val_macro_f1_mean=(\"val_macro_f1\",\"mean\"),\n",
    "            val_macro_f1_std=(\"val_macro_f1\",\"std\"),\n",
    "            test_macro_f1_mean=(\"test_macro_f1\",\"mean\"),\n",
    "            test_macro_f1_std=(\"test_macro_f1\",\"std\"),\n",
    "            test_acc_mean=(\"test_accuracy\",\"mean\"),\n",
    "            test_acc_std=(\"test_accuracy\",\"std\"))\n",
    "       .reset_index())\n",
    "agg_path = RESULTS / \"baseline_scorecard_agg.csv\"\n",
    "agg.to_csv(agg_path, index=False)\n",
    "\n",
    "print(\"=== Baseline Scorecard (per run) ===\")\n",
    "display(scorecard)\n",
    "\n",
    "print(\"\\n=== Baseline Scorecard (aggregated across seeds) ===\")\n",
    "display(agg)\n",
    "\n",
    "print(f\"\\nSaved:\\n- {scorecard_path}\\n- {agg_path}\")\n"
   ]
