   "source": [
    "# Cell C — Tiny grid on lineage‑blocked (hidden, lr, wd, dropout), SAGE vs GCN\n",
    "\n",
    "grid = [\n",
    "    (\"SAGE\", SAGE_BN_Residual_Node, True,  [256, 512], [1e-3, 3e-3], [1e-3], [0.1, 0.3]),\n",
    "    (\"GCN\",  GCN_EdgeWeight_Node,   True,  [256, 512], [1e-3, 3e-3], [1e-3], [0.1, 0.3]),\n",
    "]\n",
    "\n",
    "rows = []\n",
    "for seed in SEEDS:\n",
    "    for name, cls, use_w, hids, lrs, wds, drops in grid:\n",
    "        for h in hids:\n",
    "            for lr in lrs:\n",
    "                for wd in wds:\n",
    "                    for dr in drops:\n",
    "                        out = train_node_model(\n",
    "                            seed, \"lineage_blocked\", SPLIT_FILE_BLOCKED,\n",
    "                            model_cls=cls, hidden=h, lr=lr, wd=wd, dropout=dr,\n",
    "                            max_epochs=400, patience=40, use_edge_weight=use_w\n",
    "                        )\n",
    "                        rows.append({\n",
    "                            \"seed\": seed, \"model\": name, \"hidden\": h, \"lr\": lr, \"wd\": wd, \"dropout\": dr,\n",
    "                            \"val_macro_f1\": out[\"val_macro_f1\"], \"test_macro_f1\": out[\"test_macro_f1\"],\n",
    "                            \"best_epoch\": out[\"best_epoch\"]\n",
    "                        })\n",
    "                        print(f\"[seed {seed} | {name}] h={h}, lr={lr}, wd={wd}, do={dr} → \"\n",
    "                              f\"val={out['val_macro_f1']:.3f}, test={out['test_macro_f1']:.3f}\")\n",
    "\n",
    "grid_df = pd.DataFrame(rows).sort_values([\"model\",\"seed\",\"val_macro_f1\"], ascending=[True, True, False])\n",
    "grid_dir = RESULTS_GNN / \"grid_lineage_blocked\"\n",
    "grid_dir.mkdir(parents=True, exist_ok=True)\n",
    "grid_path = grid_dir / \"grid_results.csv\"\n",
    "grid_df.to_csv(grid_path, index=False)\n",
    "\n",
    "# Show best per seed/model\n",
    "best = (grid_df\n",
    "        .sort_values([\"seed\",\"model\",\"val_macro_f1\"], ascending=[True, True, False])\n",
    "        .groupby([\"seed\",\"model\"])\n",
    "        .head(1)\n",
    "        .reset_index(drop=True))\n",
    "best_path = grid_dir / \"grid_best_per_seed.csv\"\n",
    "best.to_csv(best_path, index=False)\n",
    "\n",
    "print(\"\\n=== Best per seed/model (by val macro‑F1) ===\")\n",
    "display(best)\n",
    "print(f\"\\nSaved:\\n- {grid_path}\\n- {best_path}\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 66,
   "id": "b1e162b5",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Build boolean masks for nodes and edges per split\n",
    "def masks_for(seed, mode, split_map):\n",
    "    tr_ids, va_ids, te_ids, *_ = load_split(split_map[seed])\n",
    "    tr_idx = torch.tensor([node_index[n] for n in tr_ids], dtype=torch.long)\n",
    "    va_idx = torch.tensor([node_index[n] for n in va_ids], dtype=torch.long)\n",
    "    te_idx = torch.tensor([node_index[n] for n in te_ids], dtype=torch.long)\n",
    "\n",
    "    train_mask = torch.zeros(len(node_ids), dtype=torch.bool); train_mask[tr_idx] = True\n",
    "    val_mask   = torch.zeros(len(node_ids), dtype=torch.bool); val_mask[va_idx]   = True\n",
    "    test_mask  = torch.zeros(len(node_ids), dtype=torch.bool); test_mask[te_idx]  = True\n",
    "\n",
    "    # Edge masks: keep only edges with BOTH endpoints in the mask\n",
    "    def edge_mask_for(node_mask):\n",
    "        src = edge_index[0]; dst = edge_index[1]\n",
    "        return node_mask[src] & node_mask[dst]\n",
    "\n",
    "    e_train = edge_mask_for(train_mask)\n",
    "    # For inference we use the full graph; for val/test eval we’ll still forward on full edges.\n",
    "\n",
    "    return tr_idx, va_idx, te_idx, train_mask, val_mask, test_mask, e_train\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 67,
   "id": "4f1f1c79",
   "metadata": {},
   "outputs": [],
   "source": [
    "def train_gcn_final(seed, mode, split_map,\n",
    "                    hidden=256, lr=1e-3, wd=1e-3, dropout=0.1,\n",
    "                    max_epochs=400, patience=40, device=None):\n",
    "    device = device or (\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
    "    tr_idx, va_idx, te_idx, train_mask, val_mask, test_mask, e_train = masks_for(seed, mode, split_map)\n",
    "\n",
    "    # Preprocess features: fit on TRAIN only\n",
    "    pre = make_preprocessor()\n",
    "    X_tr_df = features.iloc[tr_idx.cpu().numpy()][numeric_cols + categorical_cols]\n",
    "    X_all_df = features.loc[node_ids, numeric_cols + categorical_cols]\n",
    "    pre.fit(X_tr_df)\n",
    "    X_all_np = pre.transform(X_all_df).astype(np.float32)\n",
    "\n",
    "    X = torch.tensor(X_all_np, dtype=torch.float32, device=device)\n",
    "    y = torch.tensor(y_all,      dtype=torch.long,    device=device)\n",
    "\n",
    "    # Edge tensors\n",
    "    ei_full = edge_index.to(device)\n",
    "    ew_full = edge_weight.to(device)\n",
    "    # Train-only subgraph edges\n",
    "    ei_tr = ei_full[:, e_train]\n",
    "    ew_tr = ew_full[e_train]\n",
    "\n",
    "    model = GCN_EdgeWeight_Node(X.shape[1], hidden, len(class_order), dropout=dropout).to(device)\n",
    "    opt   = torch.optim.Adam(model.parameters(), lr=lr, weight_decay=wd)\n",
    "    weights = class_weights_vec.to(device)\n",
    "\n",
    "    best = {\"epoch\": -1, \"val_macro_f1\": -1.0, \"state\": None}\n",
    "    wait = 0\n",
    "\n",
    "    for epoch in range(1, max_epochs+1):\n",
    "        model.train(); opt.zero_grad()\n",
    "        logits_tr = model(X, ei_tr, ew_tr)          # train on train‑subgraph only\n",
    "        loss = F.cross_entropy(logits_tr[train_mask.to(device)], y[train_mask.to(device)], weight=weights)\n",
    "        loss.backward(); opt.step()\n",
    "\n",
    "        # Eval on full graph (transductive inference ok)\n",
    "        model.eval()\n",
    "        with torch.no_grad():\n",
    "            logits = model(X, ei_full, ew_full)\n",
    "            mv = eval_mask_node(logits, y, val_mask.to(device), class_order)[\"macro_f1\"]\n",
    "\n",
    "        if mv > best[\"val_macro_f1\"]:\n",
    "            best = {\"epoch\": epoch, \"val_macro_f1\": mv, \"state\": {k:v.detach().cpu() for k,v in model.state_dict().items()}}\n",
    "            wait = 0\n",
    "        else:\n",
    "            wait += 1\n",
    "            if wait >= patience:\n",
    "                break\n",
    "\n",
    "    if best[\"state\"] is not None:\n",
    "        model.load_state_dict(best[\"state\"])\n",
    "\n",
    "    model.eval()\n",
    "    with torch.no_grad():\n",
    "        logits = model(X, ei_full, ew_full)\n",
    "        mtr = eval_mask_node(logits, y, train_mask.to(device), class_order)\n",
    "        mva = eval_mask_node(logits, y, val_mask.to(device),   class_order)\n",
    "        mte = eval_mask_node(logits, y, test_mask.to(device),  class_order)\n",
    "        preds_all = logits.argmax(dim=1).cpu().numpy()\n",
    "\n",
    "    return {\n",
    "        \"seed\": seed, \"mode\": mode,\n",
    "        \"val_macro_f1\": mva[\"macro_f1\"], \"test_macro_f1\": mte[\"macro_f1\"],\n",
    "        \"best_epoch\": best[\"epoch\"],\n",
    "        \"train\": mtr, \"val\": mva, \"test\": mte,\n",
    "        \"preds\": {node_ids[i]: int(preds_all[i]) for i in range(len(node_ids))}\n",
    "    }\n"
   ]
  },
