    "# Cell 16b — Split diagnostics: show fold sizes per seed/mode\n",
    "diag_rows = []\n",
    "for seed in SEEDS:\n",
    "    for mode, split_map in [(\"random\", SPLIT_FILE_RANDOM), (\"lineage_blocked\", SPLIT_FILE_BLOCKED)]:\n",
    "        tr, va, te, *_ = load_split(split_map[seed])\n",
    "        diag_rows.append({\n",
    "            \"seed\": seed, \"mode\": mode,\n",
    "            \"n_train\": len(tr), \"n_val\": len(va), \"n_test\": len(te)\n",
    "        })\n",
    "diag_df = pd.DataFrame(diag_rows).sort_values([\"mode\",\"seed\"])\n",
    "display(diag_df)\n",
    "print(\"Any zeros?\", (diag_df[[\"n_train\",\"n_val\",\"n_test\"]] == 0).any().any())\n"
   ]
