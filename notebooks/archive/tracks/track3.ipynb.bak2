   ],
   "source": [
    "neurons_all = df_sorted.index.tolist()\n",
    "pairs_map = defaultdict(list)\n",
    "for n in neurons_all:\n",
    "    base = bilateral_base(n)\n",
    "    pairs_map[base].append(n)\n",
    "\n",
    "# Pairs to enforce same fold\n",
    "bilateral_groups = [sorted(v) for v in pairs_map.values() if len(v) >= 2]\n",
    "\n",
    "print(f\"Detected {len(bilateral_groups)} bilateral groups (L/R). \"\n",
    "      f\"Example(s): {bilateral_groups[:3] if bilateral_groups else 'None'}\")\n",
    "\n",
    "def group_units_for_split(neuron_ids):\n",
    "    \"\"\"\n",
    "    Returns a list of 'units' to split: bilateral pairs as single units, singletons as individual units.\n",
    "    \"\"\"\n",
    "    seen = set()\n",
    "    units = []\n",
    "    for base, members in pairs_map.items():\n",
    "        members = [m for m in members if m in neuron_ids]\n",
    "        if not members:\n",
    "            continue\n",
    "        if len(members) >= 2:\n",
    "            if any(m in seen for m in members):\n",
    "                continue\n",
    "            units.append(tuple(sorted(members)))\n",
    "            seen.update(members)\n",
    "    # singletons\n",
    "    for n in neuron_ids:\n",
    "        if n not in seen:\n",
    "            units.append((n,))\n",
    "    return units\n",
    "\n",
    "def expand_units(units):\n",
    "    return [n for u in units for n in u]\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 25,
   "id": "bfab7896",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
