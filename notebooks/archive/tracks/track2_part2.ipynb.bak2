    "DATA_DIR     = PROJECT_ROOT  # ← files are in root\n",
    "\n",
    "OUT_DIR      = PROJECT_ROOT / \"track2_outputs\" / datetime.now().strftime(\"%Y%m%d_%H%M%S\")\n",
    "OUT_DIR.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "# Files you actually have\n",
    "GRAPH_PATH          = DATA_DIR / \"merged_master_graph.gml\"  # (typo 'mastger' is correct per your file)\n",
    "LINEAGE_EMB_PATH    = DATA_DIR / \"lineage_embeddings.pkl\"    # will be used to build groups\n",
    "MOTIF_SUMMARY_PATH  = DATA_DIR / \"motif_summary.csv\"         # will be used for features/targets\n",
    "\n",
    "print(f\"[0] Paths:\\n- GRAPH_PATH={GRAPH_PATH.exists()}\\n- LINEAGE_EMB_PATH={LINEAGE_EMB_PATH.exists()}\\n- MOTIF_SUMMARY_PATH={MOTIF_SUMMARY_PATH.exists()}\")\n"
   ]
