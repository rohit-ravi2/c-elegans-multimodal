   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[10B] Paired GCN−MLP deltas (seed,fold-aligned):\n",
      "           metric  mean_delta  std_delta    t_stat   p_value   n\n",
      "0     val_macroF1    0.043917   0.124872  1.362121  0.194674  15\n",
      "1      val_balAcc    0.057544   0.119306  1.868020  0.082832  15\n",
      "2  val_weightedF1    0.052339   0.113715  1.782585  0.096344  15\n",
      "[10B] Saved stats & plots to: /home/rohit/Desktop/Projects/C-Elegans/track2_outputs/20250826_110441/runs_gcn/baselines_mlp_vs_gcn\n"
     ]
    }
   ],
   "source": [
    "# %% [10B] Statistical Comparison (GCN − MLP) + Plots\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "from pathlib import Path\n",
    "from scipy import stats\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "EXP_ROOT = RUN_DIR / \"baselines_mlp_vs_gcn\"\n",
    "DF_ALL = pd.read_csv(EXP_ROOT / \"cv_results_all.csv\")\n",
    "\n",
    "# --- 10B.1 Align rows by (seed, fold) for fair paired deltas ---\n",
    "def metric_table(df, metric):\n",
    "    return (df.pivot_table(index=[\"seed\",\"fold\"], columns=\"backbone\", values=metric)\n",
    "              .dropna(how=\"any\")\n",
    "              .sort_index())\n",
    "\n",
    "metrics = [\"val_macroF1\", \"val_balAcc\", \"val_weightedF1\"]\n",
    "tables = {m: metric_table(DF_ALL, m) for m in metrics}\n",
    "\n",
    "# --- 10B.2 Compute paired deltas and t-tests ---\n",
    "results = []\n",
    "for m, T in tables.items():\n",
    "    if not {\"mlp\",\"gcn\"}.issubset(T.columns):\n",
    "        print(f\"[10B] Skipping {m} (one backbone missing).\")\n",
    "        continue\n",
    "    delta = T[\"gcn\"] - T[\"mlp\"]\n",
    "    mu, sd = float(delta.mean()), float(delta.std(ddof=1))\n",
    "    t, p = stats.ttest_rel(T[\"gcn\"], T[\"mlp\"])\n",
    "    results.append({\"metric\": m, \"mean_delta\": mu, \"std_delta\": sd, \"t_stat\": float(t), \"p_value\": float(p), \"n\": int(len(delta))})\n",
    "\n",
    "    # Save per-pair deltas\n",
    "    out_pairs = EXP_ROOT / f\"paired_deltas_{m}.csv\"\n",
    "    delta.reset_index().rename(columns={0:\"delta\"}).to_csv(out_pairs, index=False)\n",
    "\n",
    "DF_STATS = pd.DataFrame(results)\n",
    "DF_STATS.to_csv(EXP_ROOT / \"paired_stats.csv\", index=False)\n",
    "\n",
    "print(\"[10B] Paired GCN−MLP deltas (seed,fold-aligned):\")\n",
    "print(DF_STATS)\n",
    "\n",
    "# --- 10B.3 Quick bar plots (optional) ---\n",
    "# (Each chart saved; plots do not specify styles or colors per your environment rules)\n",
    "for m, T in tables.items():\n",
    "    if not {\"mlp\",\"gcn\"}.issubset(T.columns):\n",
    "        continue\n",
    "    fig, ax = plt.subplots(figsize=(6,4))\n",
    "    means = [T[\"mlp\"].mean(), T[\"gcn\"].mean()]\n",
    "    xs = np.arange(2)\n",
    "    ax.bar(xs, means)  # default colors\n",
    "    ax.set_xticks(xs); ax.set_xticklabels([\"MLP\",\"GCN\"])\n",
    "    ax.set_ylabel(m)\n",
    "    ax.set_title(f\"{m}: mean across all (seed,fold)\")\n",
    "    fig.tight_layout()\n",
    "    fig_path = EXP_ROOT / f\"plot_{m}_mean_bar.png\"\n",
    "    plt.savefig(fig_path, dpi=150)\n",
    "    plt.close(fig)\n",
    "\n",
    "print(f\"[10B] Saved stats & plots to: {EXP_ROOT}\")\n"
   ]
  },
