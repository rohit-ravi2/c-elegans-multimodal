   ],
   "source": [
    "# %% [6] Tensor Assembly\n",
    "# Purpose: Attach processed feature matrices and encoded labels to PyG data.\n",
    "\n",
    "import torch\n",
    "\n",
    "# Load numeric and optional categorical features\n",
    "x_num = torch.tensor(np.load(OUT_DIR / \"X_num_proc.npy\"), dtype=torch.float)\n",
    "x_cat = None\n",
    "if (OUT_DIR / \"X_cat_idx.npy\").exists():\n",
    "    x_cat = torch.tensor(np.load(OUT_DIR / \"X_cat_idx.npy\"), dtype=torch.long)\n",
    "\n",
    "# Load encoded labels\n",
    "y = torch.tensor(supervised_df[\"class_index\"].values, dtype=torch.long)\n",
    "\n",
    "# Attach to pyg_data\n",
    "pyg_data.x_num = x_num\n",
    "if x_cat is not None:\n",
    "    pyg_data.x_cat = x_cat\n",
    "pyg_data.y = y\n",
    "\n",
    "print(f\"[6] x_num={x_num.shape} | x_cat={None if x_cat is None else x_cat.shape} \"\n",
    "      f\"| y={y.shape} | classes={classes}\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 15,
   "id": "6d0a2869",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[7] Model dims — num_dim=424 | cat_sizes=None | n_classes=3\n"
     ]
    }
   ],
   "source": [
    "# %% [7] Models\n",
    "# Purpose: Define baselines and GNN backbones with categorical embedding support.\n",
    "\n",
    "class CatEmbedder(nn.Module):\n",
    "    def __init__(self, cat_sizes, emb_dim=16, dropout=0.0):\n",
    "        super().__init__()\n",
    "        self.embs = nn.ModuleList([nn.Embedding(n, min(emb_dim, max(4, int(round(np.sqrt(n)+1))))) for n in cat_sizes])\n",
    "        self.drop = nn.Dropout(dropout)\n",
    "        self.out_dim = sum(e.embedding_dim for e in self.embs)\n",
    "\n",
    "    def forward(self, x_cat: torch.Tensor):\n",
    "        if x_cat is None:\n",
    "            return None\n",
    "        outs = [emb(x_cat[:,i]) for i, emb in enumerate(self.embs)]\n",
    "        out = torch.cat(outs, dim=-1)\n",
    "        return self.drop(out)\n",
    "\n",
    "class MLPBaseline(nn.Module):\n",
    "    def __init__(self, num_dim, cat_sizes, hidden=128, dropout=0.25, n_classes=3):\n",
    "        super().__init__()\n",
    "        self.ce = CatEmbedder(cat_sizes, emb_dim=16, dropout=dropout) if cat_sizes is not None else None\n",
    "        in_dim = num_dim + (0 if self.ce is None else self.ce.out_dim)\n",
    "        self.net = nn.Sequential(\n",
    "            nn.Linear(in_dim, hidden),\n",
    "            nn.ReLU(),\n",
    "            nn.Dropout(dropout),\n",
    "            nn.Linear(hidden, hidden),\n",
    "            nn.ReLU(),\n",
    "            nn.Dropout(dropout),\n",
    "            nn.Linear(hidden, n_classes)\n",
    "        )\n",
    "\n",
    "    def forward(self, x_num, x_cat=None):\n",
    "        if self.ce is not None and x_cat is not None:\n",
    "            x = torch.cat([x_num, self.ce(x_cat)], dim=-1)\n",
    "        else:\n",
    "            x = x_num\n",
    "        return self.net(x)\n",
    "\n",
    "class GCNBaseline(nn.Module):\n",
    "    def __init__(self, num_dim, cat_sizes, hidden=128, dropout=0.25, n_classes=3):\n",
    "        super().__init__()\n",
    "        self.ce = CatEmbedder(cat_sizes, emb_dim=16, dropout=dropout) if cat_sizes is not None else None\n",
    "        in_dim = num_dim + (0 if self.ce is None else self.ce.out_dim)\n",
    "        self.lin_in = nn.Linear(in_dim, hidden)\n",
    "        self.conv1 = GCNConv(hidden, hidden)\n",
    "        self.conv2 = GCNConv(hidden, hidden)\n",
    "        self.drop = nn.Dropout(dropout)\n",
    "        self.out = nn.Linear(hidden, n_classes)\n",
    "\n",
    "    def forward(self, data, x_num, x_cat=None):\n",
    "        x = x_num\n",
    "        if self.ce is not None and x_cat is not None:\n",
    "            x = torch.cat([x_num, self.ce(x_cat)], dim=-1)\n",
    "        x = self.lin_in(x)\n",
    "        x = self.drop(F.relu(self.conv1(x, data.edge_index)))\n",
    "        x = self.drop(F.relu(self.conv2(x, data.edge_index)))\n",
    "        return self.out(x)\n",
    "\n",
    "class GATBaseline(nn.Module):\n",
    "    def __init__(self, num_dim, cat_sizes, hidden=128, heads=4, dropout=0.25, n_classes=3):\n",
    "        super().__init__()\n",
    "        self.ce = CatEmbedder(cat_sizes, emb_dim=16, dropout=dropout) if cat_sizes is not None else None\n",
    "        in_dim = num_dim + (0 if self.ce is None else self.ce.out_dim)\n",
    "        self.lin_in = nn.Linear(in_dim, hidden)\n",
    "        self.gat1 = GATConv(hidden, hidden // heads, heads=heads, dropout=dropout)\n",
    "        self.gat2 = GATConv(hidden, hidden // heads, heads=heads, dropout=dropout)\n",
    "        self.drop = nn.Dropout(dropout)\n",
    "        self.out = nn.Linear(hidden, n_classes)\n",
    "\n",
    "    def forward(self, data, x_num, x_cat=None):\n",
    "        x = x_num\n",
    "        if self.ce is not None and x_cat is not None:\n",
    "            x = torch.cat([x_num, self.ce(x_cat)], dim=-1)\n",
    "        x = self.lin_in(x)\n",
    "        x = self.drop(F.elu(self.gat1(x, data.edge_index)))\n",
    "        x = self.drop(F.elu(self.gat2(x, data.edge_index)))\n",
    "        return self.out(x)\n",
    "\n",
    "class HybridFusion(nn.Module):\n",
    "    # Two streams: (A) GCN on features; (B) MLP; then fuse\n",
    "    def __init__(self, num_dim, cat_sizes, hidden=128, dropout=0.25, n_classes=3):\n",
    "        super().__init__()\n",
    "        self.gnn = GCNBaseline(num_dim, cat_sizes, hidden=hidden, dropout=dropout, n_classes=hidden)\n",
    "        self.mlp = MLPBaseline(num_dim, cat_sizes, hidden=hidden, dropout=dropout, n_classes=hidden)\n",
    "        self.fuse = nn.Sequential(\n",
    "            nn.Linear(hidden*2, hidden),\n",
    "            nn.ReLU(),\n",
    "            nn.Dropout(dropout),\n",
    "            nn.Linear(hidden, n_classes)\n",
    "        )\n",
    "\n",
    "    def forward(self, data, x_num, x_cat=None):\n",
    "        a = self.gnn(data, x_num, x_cat)\n",
    "        b = self.mlp(x_num, x_cat)\n",
    "        return self.fuse(torch.cat([a, b], dim=-1))\n",
    "\n",
    "def make_model(cfg, num_dim, cat_sizes, n_classes):\n",
    "    bb = cfg[\"backbone\"].lower()\n",
    "    if bb == \"mlp\":\n",
    "        return MLPBaseline(num_dim, cat_sizes, hidden=cfg[\"hidden_dim\"], dropout=cfg[\"dropout\"], n_classes=n_classes)\n",
    "    elif bb == \"gcn\":\n",
    "        return GCNBaseline(num_dim, cat_sizes, hidden=cfg[\"hidden_dim\"], dropout=cfg[\"dropout\"], n_classes=n_classes)\n",
    "    elif bb == \"gat\":\n",
    "        return GATBaseline(num_dim, cat_sizes, hidden=cfg[\"hidden_dim\"], heads=cfg[\"gat_heads\"], dropout=cfg[\"dropout\"], n_classes=n_classes)\n",
    "    elif bb == \"hybrid\":\n",
    "        return HybridFusion(num_dim, cat_sizes, hidden=cfg[\"hidden_dim\"], dropout=cfg[\"dropout\"], n_classes=n_classes)\n",
    "    else:\n",
    "        raise ValueError(\"Unknown backbone: \" + bb)\n",
    "\n",
    "# Infer dimensions from meta\n",
    "feature_meta = json.load(open(OUT_DIR / \"feature_meta.json\"))\n",
    "num_dim = len(feature_meta[\"num_cols_kept\"])\n",
    "cat_sizes = None\n",
    "if len(feature_meta[\"cat_cols\"]):\n",
    "    cat_sizes = [len(feature_meta[\"cat_maps\"][c][\"vocab\"]) for c in feature_meta[\"cat_cols\"]]\n",
    "\n",
    "n_classes = len(classes)\n",
    "print(f\"[7] Model dims — num_dim={num_dim} | cat_sizes={cat_sizes} | n_classes={n_classes}\")\n",
    "assert num_dim > 0 and n_classes >= 2, \"Invalid dims.\"\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 21,
   "id": "e23ddf51",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[8] CLEAN training utils ready (robust metrics, no warnings, tqdm).\n"
     ]
    }
   ],
   "source": [
    "# %% [8] Training Utils (Final CLEAN: robust metrics + no warnings + tqdm)\n",
    "\n",
    "import json, time, warnings\n",
    "import numpy as np\n",
    "import torch\n",
    "import torch.nn.functional as F\n",
    "from collections import Counter\n",
    "from sklearn.metrics import f1_score, balanced_accuracy_score, accuracy_score\n",
    "from tqdm import trange\n",
    "\n",
    "# Silence specific, known-benign warnings from sklearn\n",
    "warnings.filterwarnings(\"ignore\", message=\"y_pred contains classes not in y_true\")\n",
    "warnings.filterwarnings(\"ignore\", message=\"A single label was found in 'y_true' and 'y_pred'\")\n",
    "warnings.filterwarnings(\"ignore\", category=RuntimeWarning)\n",
    "\n",
    "CONFIG.setdefault(\"early_stop_metric\", \"balanced_acc\")  # or \"macro_f1\"\n",
    "CONFIG.setdefault(\"focal_gamma\", 2.0)\n",
    "CONFIG.setdefault(\"effective_beta\", 0.999)\n",
    "CONFIG.setdefault(\"zero_division\", 0)\n",
    "\n",
    "# ---------- Weights ----------\n",
    "def make_weights_ce(train_counts, n_classes, device):\n",
    "    total = sum(train_counts.values())\n",
    "    w = torch.tensor([total / max(1, train_counts.get(i, 0)) for i in range(n_classes)],\n",
    "                     dtype=torch.float32, device=device)\n",
    "    return w * (n_classes / w.sum())  # normalize mean=1\n",
    "\n",
    "def make_weights_effective_num(train_counts, n_classes, device, beta=0.999):\n",
    "    weights = []\n",
    "    for i in range(n_classes):\n",
    "        n_i = max(1, train_counts.get(i, 0))\n",
    "        eff_num = (1.0 - beta**n_i) / (1.0 - beta)\n",
    "        weights.append(1.0 / eff_num)\n",
    "    w = torch.tensor(weights, dtype=torch.float32, device=device)\n",
    "    return w * (n_classes / w.sum())\n",
    "\n",
    "# ---------- Loss ----------\n",
    "def make_loss(cfg, train_counts, n_classes, device):\n",
    "    loss_type = cfg.get(\"loss\", \"ce\")\n",
    "    if loss_type == \"focal\":\n",
    "        alpha = make_weights_ce(train_counts, n_classes, device)\n",
    "        gamma = cfg.get(\"focal_gamma\", 2.0)\n",
    "        def focal_loss(logits, target):\n",
    "            ce = F.cross_entropy(logits, target, reduction='none', weight=alpha)\n",
    "            pt = torch.exp(-ce)\n",
    "            return ((1 - pt) ** gamma * ce).mean()\n",
    "        return focal_loss\n",
    "    elif loss_type == \"effective_num\":\n",
    "        alpha = make_weights_effective_num(train_counts, n_classes, device, beta=cfg.get(\"effective_beta\", 0.999))\n",
    "        return lambda logits, target: F.cross_entropy(logits, target, weight=alpha)\n",
    "    else:\n",
    "        alpha = make_weights_ce(train_counts, n_classes, device)\n",
    "        return lambda logits, target: F.cross_entropy(logits, target, weight=alpha)\n",
    "\n",
    "# ---------- Metrics (clean, robust) ----------\n",
    "@torch.no_grad()\n",
    "def eval_metrics_fold(logits, y_true, zero_division=0):\n",
    "    \"\"\"\n",
    "    Robust metrics that:\n",
    "     - map predictions outside 'present' labels back into present (majority) to avoid warnings,\n",
    "     - handle single-class folds without crashing,\n",
    "     - never create empty arrays.\n",
    "    \"\"\"\n",
    "    y_pred = logits.argmax(dim=-1).cpu().numpy()\n",
    "    y_true_np = y_true.cpu().numpy()\n",
    "    present = np.unique(y_true_np)\n",
    "\n",
    "    # Edge case: empty validation (shouldn't happen, but be safe)\n",
    "    if present.size == 0 or y_true_np.size == 0:\n",
    "        return {\n",
    "            \"macro_f1\": float(\"nan\"),\n",
    "            \"weighted_f1\": float(\"nan\"),\n",
    "            \"balanced_acc\": float(\"nan\"),\n",
    "            \"accuracy\": float(\"nan\"),\n",
    "            \"per_class_f1\": {},\n",
    "            \"majority_balAcc\": float(\"nan\"),\n",
    "        }\n",
    "\n",
    "    # Map any predicted labels not in 'present' to the majority class of y_true\n",
    "    majority_class = Counter(y_true_np).most_common(1)[0][0]\n",
    "    y_pred_in_present = np.where(np.isin(y_pred, present), y_pred, majority_class)\n",
    "\n",
    "    if present.size == 1:\n",
    "        # Single-class case: compute metrics manually (no sklearn confusion matrix calls)\n",
    "        c = int(present[0])\n",
    "        tp = int((y_pred_in_present == c).sum())\n",
    "        n  = int(y_true_np.size)\n",
    "        acc = tp / n\n",
    "        # For precision and recall in single-class world:\n",
    "        fp = int((y_pred_in_present == c).sum() - tp)\n",
    "        fn = int((y_true_np == c).sum() - tp)  # positives are all samples\n",
    "        prec = tp / (tp + fp) if (tp + fp) > 0 else (0.0 if zero_division == 0 else 1.0)\n",
    "        rec  = tp / (tp + fn) if (tp + fn) > 0 else (0.0 if zero_division == 0 else 1.0)\n",
    "        f1 = 0.0 if (prec + rec) == 0 else (2 * prec * rec / (prec + rec))\n",
    "        return {\n",
    "            \"macro_f1\": float(f1),\n",
    "            \"weighted_f1\": float(f1),\n",
    "            \"balanced_acc\": float(acc),  # define as accuracy in single-class folds\n",
    "            \"accuracy\": float(acc),\n",
    "            \"per_class_f1\": {c: float(f1)},\n",
    "            \"majority_balAcc\": float(1.0),  # predicting the only class gives 1.0 baseline\n",
    "        }\n",
    "\n",
    "    # Multi-class, standard metrics with labels restricted to 'present'\n",
    "    macro_f1 = f1_score(y_true_np, y_pred_in_present, average=\"macro\", labels=present, zero_division=zero_division)\n",
    "    weighted_f1 = f1_score(y_true_np, y_pred_in_present, average=\"weighted\", labels=present, zero_division=zero_division)\n",
    "    bal_acc = balanced_accuracy_score(y_true_np, y_pred_in_present)\n",
    "    acc = accuracy_score(y_true_np, y_pred_in_present)\n",
    "    per_cls = f1_score(y_true_np, y_pred_in_present, average=None, labels=present, zero_division=zero_division)\n",
    "    per_class = {int(c): float(s) for c, s in zip(present, per_cls)}\n",
    "\n",
    "    # Majority baseline (macro recall average); for single-class handled above\n",
    "    majority_preds = np.full_like(y_true_np, majority_class)\n",
    "    majority_balAcc = balanced_accuracy_score(y_true_np, majority_preds)\n",
    "\n",
    "    return {\n",
    "        \"macro_f1\": float(macro_f1),\n",
    "        \"weighted_f1\": float(weighted_f1),\n",
    "        \"balanced_acc\": float(bal_acc),\n",
    "        \"accuracy\": float(acc),\n",
    "        \"per_class_f1\": per_class,\n",
    "        \"majority_balAcc\": float(majority_balAcc),\n",
    "    }\n",
    "\n",
    "# ---------- Trainer ----------\n",
    "def train_one_split(seed, fold_idx, cfg, pyg_data, masks, save_dir):\n",
    "    set_seed(seed, deterministic_cudnn=True)\n",
    "\n",
    "    train_idx = torch.tensor(masks[\"train_idx\"], dtype=torch.long, device=DEVICE)\n",
    "    val_idx   = torch.tensor(masks[\"val_idx\"], dtype=torch.long, device=DEVICE)\n",
    "\n",
    "    x_num = pyg_data.x_num.to(DEVICE)\n",
    "    x_cat = getattr(pyg_data, \"x_cat\", None)\n",
    "    if x_cat is not None:\n",
    "        x_cat = x_cat.to(DEVICE)\n",
    "    y     = pyg_data.y.to(DEVICE)\n",
    "\n",
    "    feature_meta = json.load(open(OUT_DIR / \"feature_meta.json\"))\n",
    "    num_dim = feature_meta[\"shapes\"][\"X_num_proc\"][1]\n",
    "    classes_json = json.load(open(OUT_DIR / \"classes.json\"))\n",
    "    n_classes = len(classes_json[\"classes\"])\n",
    "\n",
    "    model = make_model(cfg, num_dim, None if x_cat is None else [x_cat.max().item()+1], n_classes).to(DEVICE)\n",
    "\n",
    "    train_counts = Counter(y[train_idx].detach().cpu().numpy().tolist())\n",
    "    criterion = make_loss(cfg, train_counts, n_classes, DEVICE)\n",
    "    optimizer = torch.optim.AdamW(model.parameters(), lr=cfg[\"lr\"], weight_decay=cfg[\"weight_decay\"])\n",
    "\n",
    "    metric_key = \"balanced_acc\" if cfg[\"early_stop_metric\"] == \"balanced_acc\" else \"macro_f1\"\n",
    "    best_score, best_state, best_epoch, no_improve = -1, None, -1, 0\n",
    "\n",
    "    for epoch in trange(cfg[\"epochs\"], desc=f\"Seed {seed} Fold {fold_idx}\", leave=False):\n",
    "        model.train()\n",
    "        optimizer.zero_grad()\n",
    "        logits = model(pyg_data.to(DEVICE), x_num, x_cat) if cfg[\"backbone\"] != \"mlp\" else model(x_num, x_cat)\n",
    "        loss = criterion(logits[train_idx], y[train_idx])\n",
    "        loss.backward(); optimizer.step()\n",
    "\n",
    "        # Validation\n",
    "        model.eval()\n",
    "        with torch.no_grad():\n",
    "            v_logits = model(pyg_data.to(DEVICE), x_num, x_cat) if cfg[\"backbone\"] != \"mlp\" else model(x_num, x_cat)\n",
    "            val_metrics = eval_metrics_fold(v_logits[val_idx], y[val_idx], zero_division=cfg[\"zero_division\"])\n",
    "\n",
    "        score_now = val_metrics[metric_key]\n",
    "        if score_now > best_score:\n",
    "            best_score = score_now\n",
    "            best_state = {k: v.detach().cpu() for k, v in model.state_dict().items()}\n",
    "            best_epoch = epoch\n",
    "            no_improve = 0\n",
    "        else:\n",
    "            no_improve += 1\n",
    "\n",
    "        if CONFIG[\"verbose\"] and (epoch % 10 == 0 or epoch == cfg[\"epochs\"] - 1):\n",
    "            print(f\"[8] seed={seed} fold={fold_idx} epoch={epoch} loss={loss.item():.4f} \"\n",
    "                  f\"val_{metric_key}={val_metrics[metric_key]:.4f} macroF1={val_metrics['macro_f1']:.4f}\")\n",
    "\n",
    "        if no_improve >= cfg[\"patience\"]:\n",
    "            break\n",
    "\n",
    "    if best_state is not None:\n",
    "        model.load_state_dict({k: v.to(DEVICE) for k, v in best_state.items()})\n",
    "\n",
    "    # Final train/val metrics\n",
    "    model.eval()\n",
    "    with torch.no_grad():\n",
    "        logits = model(pyg_data.to(DEVICE), x_num, x_cat) if cfg[\"backbone\"] != \"mlp\" else model(x_num, x_cat)\n",
    "\n",
    "    tr_metrics = eval_metrics_fold(logits[train_idx], y[train_idx], zero_division=cfg[\"zero_division\"])\n",
    "    va_metrics = eval_metrics_fold(logits[val_idx], y[val_idx], zero_division=cfg[\"zero_division\"])\n",
    "\n",
    "    # Save\n",
    "    torch.save(model.state_dict(), save_dir / f\"model_seed{seed}_fold{fold_idx}.pt\")\n",
    "    np.save(save_dir / f\"logits_seed{seed}_fold{fold_idx}.npy\", logits.detach().cpu().numpy())\n",
    "    json.dump({\n",
    "        \"seed\": seed, \"fold\": fold_idx,\n",
    "        \"train\": tr_metrics, \"val\": va_metrics,\n",
    "        \"best_epoch\": best_epoch\n",
    "    }, open(save_dir / f\"metrics_seed{seed}_fold{fold_idx}.json\", \"w\"), indent=2)\n",
    "\n",
    "    return {\"seed\": seed, \"fold\": fold_idx, \"train\": tr_metrics, \"val\": va_metrics, \"best_epoch\": best_epoch}\n",
    "\n",
    "print(\"[8] CLEAN training utils ready (robust metrics, no warnings, tqdm).\")\n"
   ]
  },
