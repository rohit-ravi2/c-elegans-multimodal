   ],
   "source": [
    "# %% [2B] Re-derive Proxy Labels (K=3 from lineage embeddings)\n",
    "# Purpose: Create a coarser, more balanced proxy target by clustering lineage embeddings into 3 groups.\n",
    "# Output: Overwrites ./Track2Part2/labels_proxy.csv with the new 3-class labels.\n",
    "\n",
    "import pickle\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "from pathlib import Path\n",
    "from sklearn.cluster import KMeans\n",
    "\n",
    "FIXED_OUT_DIR = PROJECT_ROOT / \"Track2Part2\"\n",
    "LINEAGE_EMB_PATH = DATA_DIR / \"lineage_embeddings.pkl\"\n",
    "\n",
    "assert FIXED_OUT_DIR.exists(), \"Track2Part2 folder not found — run Cell 2A first.\"\n",
    "assert LINEAGE_EMB_PATH.exists(), \"lineage_embeddings.pkl not found.\"\n",
    "\n",
    "# Load lineage embeddings (dict or DataFrame accepted)\n",
    "with open(LINEAGE_EMB_PATH, \"rb\") as f:\n",
    "    lin_emb = pickle.load(f)\n",
    "\n",
    "if isinstance(lin_emb, dict):\n",
    "    lin_df = pd.DataFrame({\"neuron_id\": list(lin_emb.keys()), \"lin_vec\": list(lin_emb.values())})\n",
    "elif isinstance(lin_emb, pd.DataFrame):\n",
    "    lin_df = lin_emb.copy()\n",
    "    if \"neuron_id\" not in lin_df.columns:\n",
    "        lin_df = lin_df.reset_index().rename(columns={\"index\": \"neuron_id\"})\n",
    "else:\n",
    "    raise ValueError(\"Unsupported lineage_embeddings format\")\n",
    "\n",
    "lin_df[\"neuron_id\"] = lin_df[\"neuron_id\"].astype(str)\n",
    "\n",
    "# Expand vector column (if needed) into numeric columns\n",
    "if \"lin_vec\" in lin_df.columns:\n",
    "    max_len = max(len(v) for v in lin_df[\"lin_vec\"])\n",
    "    lin_mat = np.stack([np.pad(np.array(v, dtype=float), (0, max_len - len(v))) for v in lin_df[\"lin_vec\"]], axis=0)\n",
    "    lin_cols = [f\"lin_{i}\" for i in range(lin_mat.shape[1])]\n",
    "    lin_df = pd.concat([lin_df[[\"neuron_id\"]], pd.DataFrame(lin_mat, columns=lin_cols)], axis=1)\n",
    "else:\n",
    "    lin_cols = [c for c in lin_df.columns if c != \"neuron_id\"]\n",
    "\n",
    "# KMeans with K=3 (coarser clusters)\n",
    "K = 3\n",
    "km = KMeans(n_clusters=K, n_init=\"auto\", random_state=42)\n",
    "labels_k3 = km.fit_predict(lin_df[lin_cols].values)\n",
    "\n",
    "labels_proxy = pd.DataFrame({\"neuron_id\": lin_df[\"neuron_id\"], \"class_label\": labels_k3.astype(int)})\n",
    "\n",
    "# Persist (overwrites proxy labels)\n",
    "LABELS_PATH = FIXED_OUT_DIR / \"labels_proxy.csv\"\n",
    "labels_proxy.to_csv(LABELS_PATH, index=False)\n",
    "\n",
    "# Sanity report\n",
    "counts = labels_proxy[\"class_label\"].value_counts().sort_index()\n",
    "print(f\"[2B] Wrote new proxy labels (K={K}) → {str(LABELS_PATH)}\")\n",
    "print(f\"[2B] Class distribution: {dict(counts)}\")\n",
    "assert counts.min() > 0, \"One of the K=3 classes is empty — unexpected.\"\n",
    "print(\"[2B] OK. Re-run Cell [2] to reload these labels, then continue with Cell [3]+.\")\n"
   ]
  },
