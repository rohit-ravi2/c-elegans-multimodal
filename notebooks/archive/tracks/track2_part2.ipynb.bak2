   ],
   "source": [
    "# %% [4] Graph Load & PyG Data prep (patched)\n",
    "# Purpose: Load graph, align node order to supervised_df.neuron_id, create PyG data skeleton.\n",
    "\n",
    "# Load full graph\n",
    "G_full = nx.read_gml(GRAPH_PATH)\n",
    "\n",
    "# Subgraph restricted to supervised neurons\n",
    "kept_ids = set(supervised_df[\"neuron_id\"].tolist())\n",
    "G_sub = G_full.subgraph([n for n in G_full.nodes if str(n) in kept_ids]).copy()\n",
    "\n",
    "# Ensure consistent ordering\n",
    "order = supervised_df[\"neuron_id\"].tolist()\n",
    "id2idx = {nid: i for i, nid in enumerate(order)}\n",
    "\n",
    "# Relabel to numeric indices (0..N-1)\n",
    "G_ordered = nx.relabel_nodes(G_sub, id2idx, copy=True)\n",
    "\n",
    "# 🔑 Strip all attributes so every node is uniform\n",
    "for n in G_ordered.nodes:\n",
    "    G_ordered.nodes[n].clear()\n",
    "\n",
    "# Build PyG\n",
    "pyg_data = from_networkx(G_ordered)\n",
    "\n",
    "# Safety: add empty edge_index if no edges\n",
    "if not hasattr(pyg_data, \"edge_index\"):\n",
    "    pyg_data.edge_index = torch.empty((2, 0), dtype=torch.long)\n",
    "\n",
    "N = len(order)\n",
    "print(f\"[4] G_sub nodes={G_sub.number_of_nodes()} edges={G_sub.number_of_edges()} | \"\n",
    "      f\"ordered_N={N} | pyg_edges={pyg_data.edge_index.size(-1)}\")\n",
    "assert G_sub.number_of_nodes() == N, \"Graph node count must match supervised set.\"\n"
   ]
  },
  {
   "cell_type": "code",
