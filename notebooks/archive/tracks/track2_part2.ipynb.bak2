   "source": [
    "# %% [2] Load Aligned Data from Track2Part2\n",
    "# Purpose: Read the feature atlas, proxy labels, and lineage groups created in Cell 2A.\n",
    "# These are fixed to ./Track2Part2 so you always know where to look.\n",
    "\n",
    "import pandas as pd\n",
    "\n",
    "# Fixed paths\n",
    "FIXED_OUT_DIR = PROJECT_ROOT / \"Track2Part2\"\n",
    "FEATURE_ATLAS_PATH = FIXED_OUT_DIR / \"feature_atlas_v0.parquet\"\n",
    "LABELS_PATH        = FIXED_OUT_DIR / \"labels_proxy.csv\"\n",
    "GROUPS_PATH        = FIXED_OUT_DIR / \"lineage_region_groups.csv\"\n",
    "\n",
    "# Load\n",
    "feat_df   = pd.read_parquet(FEATURE_ATLAS_PATH)\n",
    "labels_df = pd.read_csv(LABELS_PATH)\n",
    "groups_df = pd.read_csv(GROUPS_PATH)\n",
    "\n",
    "# Standardize neuron_id dtype\n",
    "for df in (feat_df, labels_df, groups_df):\n",
    "    df[\"neuron_id\"] = df[\"neuron_id\"].astype(str)\n",
    "\n",
    "# Merge labels & groups\n",
    "meta_df = labels_df.merge(groups_df, on=\"neuron_id\", how=\"left\")\n",
    "full_df = feat_df.merge(meta_df, on=\"neuron_id\", how=\"inner\")\n",
    "\n",
    "# Exclude UNKNOWN class if it exists\n",
    "unknown_mask = full_df[\"class_label\"].astype(str).str.upper().eq(\"UNKNOWN\")\n",
    "unknown_ids = full_df.loc[unknown_mask, \"neuron_id\"].tolist()\n",
    "supervised_df = full_df.loc[~unknown_mask].copy()\n",
    "\n",
    "print(f\"[2] feature_atlas_v0 shape={feat_df.shape}\")\n",
    "print(f\"[2] labels_proxy shape={labels_df.shape}\")\n",
    "print(f\"[2] lineage_region_groups shape={groups_df.shape}\")\n",
    "print(f\"[2] After merge: full_df={full_df.shape} | supervised_df={supervised_df.shape} | UNKNOWN={len(unknown_ids)}\")\n",
    "\n",
    "# Sanity checks\n",
    "assert \"neuron_id\" in supervised_df.columns, \"neuron_id column missing.\"\n",
    "assert \"class_label\" in supervised_df.columns, \"class_label column missing.\"\n",
    "assert \"lineage_group\" in supervised_df.columns, \"lineage_group column missing.\"\n",
    "assert supervised_df[\"neuron_id\"].is_unique, \"neuron_id must be unique after merge.\"\n"
   ]
  },
