      "[2A] Loaded graph: nodes=1633 edges=10902 | directed=True\n",
      "[2A] Saved feature_atlas_v0: /home/rohit/Desktop/Projects/C-Elegans/Track2Part2/feature_atlas_v0.parquet shape=(1633, 425)\n",
      "[2A] Saved groups: /home/rohit/Desktop/Projects/C-Elegans/Track2Part2/lineage_region_groups.csv shape=(1633, 2)\n",
      "[2A] Saved proxy labels: /home/rohit/Desktop/Projects/C-Elegans/Track2Part2/labels_proxy.csv shape=(1633, 2)\n"
     ]
