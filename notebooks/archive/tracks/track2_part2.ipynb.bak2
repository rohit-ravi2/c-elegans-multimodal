   ],
   "source": [
    "# %% [9B] Baseline Runner: MLP vs GCN on identical splits\n",
    "# 1) Runs both backbones using the same SPLITS & config.\n",
    "# 2) Saves metrics under RUN_DIR/backbone=mlp|gcn.\n",
    "# 3) Prints a clean summary per seed.\n",
    "\n",
    "import copy, json\n",
    "import pandas as pd\n",
    "from pathlib import Path\n",
    "from tqdm import tqdm\n",
    "\n",
    "# --- 9B.1 Choose which backbones to compare ---\n",
    "BACKBONES = [\"mlp\", \"gcn\"]  # you can add \"gat\", \"graphsage\", etc. if your make_model supports them.\n",
    "\n",
    "# --- 9B.2 Shared training config knobs for a fair comparison ---\n",
    "BASE_CFG = copy.deepcopy(CONFIG)\n",
    "BASE_CFG[\"n_splits\"] = len(SPLITS)                # keep as-is\n",
    "BASE_CFG[\"early_stop_metric\"] = \"balanced_acc\"    # robust to imbalance\n",
    "BASE_CFG[\"patience\"] = max(40, CONFIG.get(\"patience\", 40))\n",
    "BASE_CFG[\"epochs\"] = max(200, CONFIG.get(\"epochs\", 200))\n",
    "BASE_CFG[\"loss\"] = BASE_CFG.get(\"loss\", \"effective_num\")  # \"ce\"|\"focal\"|\"effective_num\"\n",
    "BASE_CFG[\"verbose\"] = False\n",
    "\n",
    "# --- 9B.3 Where to write results ---\n",
    "EXP_ROOT = RUN_DIR / \"baselines_mlp_vs_gcn\"\n",
    "EXP_ROOT.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "def run_backbone(backbone_name: str):\n",
    "    cfg = copy.deepcopy(BASE_CFG)\n",
    "    cfg[\"backbone\"] = backbone_name\n",
    "    run_dir = EXP_ROOT / f\"backbone={backbone_name}\"\n",
    "    run_dir.mkdir(exist_ok=True, parents=True)\n",
    "\n",
    "    rows = []\n",
    "    for seed in cfg[\"seeds\"]:\n",
    "        for fold_idx, masks in enumerate(tqdm(SPLITS, desc=f\"{backbone_name} | seed {seed}\", leave=False)):\n",
    "            fold_dir = run_dir / f\"seed{seed}_fold{fold_idx}\"\n",
    "            fold_dir.mkdir(parents=True, exist_ok=True)\n",
    "            res = train_one_split(seed, fold_idx, cfg, pyg_data, masks, fold_dir)\n",
    "            rows.append({\n",
    "                \"backbone\": backbone_name,\n",
    "                \"seed\": res[\"seed\"],\n",
    "                \"fold\": res[\"fold\"],\n",
    "                \"train_macroF1\": res[\"train\"][\"macro_f1\"],\n",
    "                \"val_macroF1\": res[\"val\"][\"macro_f1\"],\n",
    "                \"train_balAcc\": res[\"train\"][\"balanced_acc\"],\n",
    "                \"val_balAcc\": res[\"val\"][\"balanced_acc\"],\n",
    "                \"train_weightedF1\": res[\"train\"][\"weighted_f1\"],\n",
    "                \"val_weightedF1\": res[\"val\"][\"weighted_f1\"],\n",
    "                \"val_majority_balAcc\": res[\"val\"][\"majority_balAcc\"],\n",
    "                \"best_epoch\": res[\"best_epoch\"],\n",
    "            })\n",
    "    df = pd.DataFrame(rows)\n",
    "    df.to_csv(run_dir / \"cv_results.csv\", index=False)\n",
    "    summ = df.groupby(\"seed\")[[\"val_macroF1\",\"val_balAcc\",\"val_weightedF1\"]].agg([\"mean\",\"std\"])\n",
    "    summ.to_csv(run_dir / \"cv_summary.csv\")\n",
    "    print(f\"[9B] {backbone_name} summary (mean±std across folds):\\n{summ}\\n\")\n",
    "    return df\n",
    "\n",
    "# --- 9B.4 Execute both backbones and keep a combined table ---\n",
    "all_results = []\n",
    "for bb in BACKBONES:\n",
    "    df_bb = run_backbone(bb)\n",
    "    all_results.append(df_bb)\n",
    "\n",
    "DF_ALL = pd.concat(all_results, ignore_index=True)\n",
    "DF_ALL.to_csv(EXP_ROOT / \"cv_results_all.csv\", index=False)\n",
    "\n",
    "# --- 9B.5 Quick side-by-side pivot (mean across folds per seed) ---\n",
    "pivot = (DF_ALL\n",
    "         .groupby([\"backbone\",\"seed\"])[[\"val_macroF1\",\"val_balAcc\",\"val_weightedF1\"]]\n",
    "         .mean()\n",
    "         .reset_index())\n",
    "print(\"[9B] Side-by-side means per seed:\")\n",
    "print(pivot.pivot(index=\"seed\", columns=\"backbone\", values=\"val_macroF1\"))\n",
    "print(pivot.pivot(index=\"seed\", columns=\"backbone\", values=\"val_balAcc\"))\n",
    "\n",
    "# --- 9B.6 Sanity: ensure both backbones produced the same number of fold results ---\n",
    "for bb in BACKBONES:\n",
    "    assert (DF_ALL[\"backbone\"] == bb).sum() == len(CONFIG[\"seeds\"]) * len(SPLITS), f\"Missing results for {bb}\"\n",
    "\n",
    "print(f\"[9B] Saved all runs under: {EXP_ROOT}\")\n"
   ]
  },
