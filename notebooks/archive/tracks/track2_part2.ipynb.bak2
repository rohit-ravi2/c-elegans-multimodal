     "text": [
      "[5] Created 5 folds with blocking on `lineage_group`.\n"
     ]
    }
   ],
   "source": [
    "# %% [5] Split Builder (StratifiedGroupKFold with blocking)\n",
    "# Purpose: Create K folds with group blocking to avoid leakage.\n",
    "\n",
    "labels = y_series.values\n",
    "groups = groups_series.values\n",
    "\n",
    "sgkf = StratifiedGroupKFold(n_splits=CONFIG[\"n_splits\"], shuffle=True, random_state=42)\n",
    "\n",
    "# Build masks per split; persist to disk\n",
    "SPLITS = []\n",
    "for fold_idx, (tr_idx, va_idx) in enumerate(sgkf.split(np.zeros_like(labels), labels, groups)):\n",
    "    mask_train = np.zeros(N, dtype=bool); mask_train[tr_idx] = True\n",
    "    mask_val   = np.zeros(N, dtype=bool); mask_val[va_idx] = True\n",
    "\n",
    "    fold_masks = {\n",
    "        \"train_idx\": tr_idx.tolist(),\n",
    "        \"val_idx\": va_idx.tolist()\n",
    "    }\n",
    "    SPLITS.append(fold_masks)\n",
    "    np.savez(OUT_DIR / f\"masks_fold{fold_idx}.npz\", train_idx=tr_idx, val_idx=va_idx)\n",
    "\n",
    "print(f\"[5] Created {len(SPLITS)} folds with blocking on `{CONFIG['group_field']}`.\")\n",
    "assert len(SPLITS) == CONFIG[\"n_splits\"], \"Unexpected number of splits.\"\n"
   ]
  },
  {
