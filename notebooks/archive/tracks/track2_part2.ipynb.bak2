   ],
   "source": [
    "# %% [2A] Bootstrap Feature Atlas v0 from available files\n",
    "# Purpose: create a minimal, high-signal feature atlas and proxy labels/groups.\n",
    "import pickle\n",
    "from sklearn.cluster import KMeans\n",
    "\n",
    "# 1) Create fixed output folder\n",
    "FIXED_OUT_DIR = PROJECT_ROOT / \"Track2Part2\"\n",
    "FIXED_OUT_DIR.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "# 2) Load graph\n",
    "assert GRAPH_PATH.exists(), \"Graph file missing.\"\n",
    "G_full = nx.read_gml(GRAPH_PATH)\n",
    "print(f\"[2A] Loaded graph: nodes={G_full.number_of_nodes()} edges={G_full.number_of_edges()} | directed={nx.is_directed(G_full)}\")\n",
    "\n",
    "# Normalize node ids\n",
    "node_ids = list(G_full.nodes())\n",
    "if isinstance(node_ids[0], (int, np.integer)):\n",
    "    neuron_id_list = [int(n) for n in node_ids]\n",
    "else:\n",
    "    neuron_id_list = [str(n) for n in node_ids]\n",
    "\n",
    "# 3) Graph features\n",
    "def safe_centrality(fn, G):\n",
    "    try:\n",
    "        vals = fn(G)\n",
    "        return {k: float(v) for k, v in vals.items()}\n",
    "    except Exception as e:\n",
    "        print(\"Centrality fallback:\", fn.__name__, e)\n",
    "        return {n: 0.0 for n in G.nodes()}\n",
    "\n",
    "deg      = dict(G_full.degree())\n",
    "in_deg   = dict(G_full.in_degree()) if nx.is_directed(G_full) else {n: 0 for n in G_full.nodes()}\n",
    "out_deg  = dict(G_full.out_degree()) if nx.is_directed(G_full) else {n: 0 for n in G_full.nodes()}\n",
    "betw     = safe_centrality(nx.betweenness_centrality, G_full)\n",
    "close    = safe_centrality(nx.closeness_centrality, G_full)\n",
    "try:\n",
    "    eigv = nx.eigenvector_centrality_numpy(G_full)\n",
    "    eigv = {k: float(v) for k, v in eigv.items()}\n",
    "except Exception as e:\n",
    "    print(\"Eigenvector fallback:\", e)\n",
    "    eigv = {n: 0.0 for n in G_full.nodes()}\n",
    "\n",
    "graph_feat = pd.DataFrame({\n",
    "    \"neuron_id\": [str(n) for n in G_full.nodes()],\n",
    "    \"degree\": [deg[n] for n in G_full.nodes()],\n",
    "    \"in_degree\": [in_deg[n] for n in G_full.nodes()],\n",
    "    \"out_degree\": [out_deg[n] for n in G_full.nodes()],\n",
    "    \"betweenness\": [betw[n] for n in G_full.nodes()],\n",
    "    \"closeness\": [close[n] for n in G_full.nodes()],\n",
    "    \"eigenvector\": [eigv[n] for n in G_full.nodes()],\n",
    "})\n",
    "\n",
    "# 4) Motif features\n",
    "assert MOTIF_SUMMARY_PATH.exists(), \"motif_summary.csv missing.\"\n",
    "motif_df = pd.read_csv(MOTIF_SUMMARY_PATH)\n",
    "\n",
    "# Find neuron_id column\n",
    "id_candidates = [c for c in motif_df.columns if c.lower() in [\"neuron_id\",\"neuron\",\"node\",\"name\",\"id\"]]\n",
    "if len(id_candidates) >= 1:\n",
    "    motif_id_col = id_candidates[0]\n",
    "elif \"Unnamed: 0\" in motif_df.columns:\n",
    "    motif_id_col = \"Unnamed: 0\"\n",
    "else:\n",
    "    motif_df = motif_df.reset_index().rename(columns={\"index\": \"neuron_id\"})\n",
    "    motif_id_col = \"neuron_id\"\n",
    "\n",
    "motif_df = motif_df.rename(columns={motif_id_col: \"neuron_id\"})\n",
    "motif_df[\"neuron_id\"] = motif_df[\"neuron_id\"].astype(str)\n",
    "\n",
    "motif_num = motif_df.select_dtypes(include=[np.number]).copy()\n",
    "motif_num[\"neuron_id\"] = motif_df[\"neuron_id\"]\n",
    "\n",
    "# Merge graph + motif\n",
    "atlas = graph_feat.merge(motif_num, on=\"neuron_id\", how=\"left\").fillna(0.0)\n",
    "\n",
    "# 5) Lineage embeddings\n",
    "with open(LINEAGE_EMB_PATH, \"rb\") as f:\n",
    "    lin_emb = pickle.load(f)\n",
    "\n",
    "if isinstance(lin_emb, dict):\n",
    "    lin_df = pd.DataFrame({\"neuron_id\": list(lin_emb.keys()), \"lin_vec\": list(lin_emb.values())})\n",
    "elif isinstance(lin_emb, pd.DataFrame):\n",
    "    lin_df = lin_emb.copy()\n",
    "    if \"neuron_id\" not in lin_df.columns:\n",
    "        lin_df = lin_df.reset_index().rename(columns={\"index\":\"neuron_id\"})\n",
    "else:\n",
    "    raise ValueError(\"Unsupported lineage_embeddings format.\")\n",
    "\n",
    "lin_df[\"neuron_id\"] = lin_df[\"neuron_id\"].astype(str)\n",
    "\n",
    "if \"lin_vec\" in lin_df.columns:\n",
    "    max_len = max(len(v) for v in lin_df[\"lin_vec\"])\n",
    "    lin_mat = np.stack([np.pad(np.array(v, dtype=float), (0, max_len-len(v))) for v in lin_df[\"lin_vec\"]], axis=0)\n",
    "    lin_cols = [f\"lin_{i}\" for i in range(lin_mat.shape[1])]\n",
    "    tmp = pd.DataFrame(lin_mat, columns=lin_cols)\n",
    "    lin_df = pd.concat([lin_df[[\"neuron_id\"]], tmp], axis=1)\n",
    "else:\n",
    "    lin_cols = [c for c in lin_df.columns if c != \"neuron_id\"]\n",
    "\n",
    "# KMeans groups\n",
    "K_GROUPS = 10\n",
    "km = KMeans(n_clusters=K_GROUPS, n_init=\"auto\", random_state=42)\n",
    "lin_groups = km.fit_predict(lin_df[lin_cols].values)\n",
    "\n",
    "groups_df = pd.DataFrame({\"neuron_id\": lin_df[\"neuron_id\"], \"lineage_group\": lin_groups.astype(int)})\n",
    "labels_proxy = pd.DataFrame({\"neuron_id\": lin_df[\"neuron_id\"], \"class_label\": lin_groups.astype(int)})\n",
    "\n",
    "# 6) Save artifacts in Track2Part2\n",
    "FEATURE_ATLAS_PATH = FIXED_OUT_DIR / \"feature_atlas_v0.parquet\"\n",
    "GROUPS_PATH        = FIXED_OUT_DIR / \"lineage_region_groups.csv\"\n",
    "LABELS_PATH        = FIXED_OUT_DIR / \"labels_proxy.csv\"\n",
    "\n",
    "atlas.to_parquet(FEATURE_ATLAS_PATH, index=False)\n",
    "groups_df.to_csv(GROUPS_PATH, index=False)\n",
    "labels_proxy.to_csv(LABELS_PATH, index=False)\n",
    "\n",
    "print(f\"[2A] Saved feature_atlas_v0: {FEATURE_ATLAS_PATH} shape={atlas.shape}\")\n",
    "print(f\"[2A] Saved groups: {GROUPS_PATH} shape={groups_df.shape}\")\n",
    "print(f\"[2A] Saved proxy labels: {LABELS_PATH} shape={labels_proxy.shape}\")\n"
   ]
  },
  {
