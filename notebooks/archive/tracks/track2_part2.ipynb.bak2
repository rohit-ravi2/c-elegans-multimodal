   "source": [
    "# %% [9] Cross-validation Execution (CLEAN)\n",
    "from tqdm import tqdm\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "RESULTS = []\n",
    "for seed in CONFIG[\"seeds\"]:\n",
    "    for fold_idx, masks in enumerate(SPLITS):\n",
    "        fold_dir = RUN_DIR / f\"seed{seed}_fold{fold_idx}\"\n",
    "        fold_dir.mkdir(exist_ok=True, parents=True)\n",
    "        res = train_one_split(seed, fold_idx, CONFIG, pyg_data, masks, fold_dir)\n",
    "        RESULTS.append(res)\n",
    "\n",
    "# To DataFrame\n",
    "df_res = pd.DataFrame([{\n",
    "    \"seed\": r[\"seed\"], \"fold\": r[\"fold\"],\n",
    "    \"train_macroF1\": r[\"train\"][\"macro_f1\"],\n",
    "    \"val_macroF1\": r[\"val\"][\"macro_f1\"],\n",
    "    \"train_balAcc\": r[\"train\"][\"balanced_acc\"],\n",
    "    \"val_balAcc\": r[\"val\"][\"balanced_acc\"],\n",
    "    \"train_weightedF1\": r[\"train\"][\"weighted_f1\"],\n",
    "    \"val_weightedF1\": r[\"val\"][\"weighted_f1\"],\n",
    "    \"val_majority_balAcc\": r[\"val\"][\"majority_balAcc\"],\n",
    "    \"best_epoch\": r[\"best_epoch\"],\n",
    "} for r in RESULTS])\n",
    "\n",
    "# Clean summary: mean ± std across folds for each seed\n",
    "summary = df_res.groupby(\"seed\")[[\"val_macroF1\",\"val_balAcc\",\"val_weightedF1\"]].agg([\"mean\",\"std\"])\n",
    "print(\"[9] CV summary (mean±std across folds):\\n\", summary)\n",
    "\n",
    "df_res.to_csv(RUN_DIR / \"cv_results.csv\", index=False)\n",
    "summary.to_csv(RUN_DIR / \"cv_summary.csv\")\n",
    "print(f\"[9] Saved: {RUN_DIR/'cv_results.csv'} and {RUN_DIR/'cv_summary.csv'}\")\n"
   ]
  },
