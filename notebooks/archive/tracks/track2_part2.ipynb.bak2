   ],
   "source": [
    "# %% [9C] Ablation Runner (auto-discovers blocks, builds features per set, runs CV cleanly)\n",
    "\n",
    "import json, copy\n",
    "import numpy as np, pandas as pd\n",
    "from pathlib import Path\n",
    "from tqdm import tqdm\n",
    "\n",
    "# --- 9C.1 Discover available blocks in current atlas --------------------------\n",
    "def discover_available_blocks():\n",
    "    blk = {}\n",
    "    blk[\"CORE\"]       = any(c in supervised_df.columns for c in [\"degree\",\"in_degree\",\"out_degree\",\"betweenness\",\"closeness\",\"eigenvector\"])\n",
    "    blk[\"B_TOPO\"]     = any(c.startswith(\"motif_\") for c in supervised_df.columns)\n",
    "    blk[\"A_CAUSAL\"]   = any(c.startswith(\"causal_\") or c.endswith(\"_causal\") for c in supervised_df.columns)\n",
    "    blk[\"A_INFOGEOM\"] = any(c.startswith(\"infogeom_\") or c.startswith(\"manifold_\") for c in supervised_df.columns)\n",
    "    blk[\"C_DYNAMICS\"] = any(c.startswith(\"attractor_\") or c.endswith(\"_posterior\") for c in supervised_df.columns)\n",
    "    return [b for b, ok in blk.items() if ok]\n",
    "\n",
    "AVAILABLE_BLOCKS = discover_available_blocks()\n",
    "print(f\"[9C] Available blocks: {AVAILABLE_BLOCKS}\")\n",
    "\n",
    "# --- 9C.2 Define the ablation sets you want to run ----------------------------\n",
    "# Compose sensible subsets from what's actually available.\n",
    "ABLA_SETS = []\n",
    "\n",
    "if \"CORE\" in AVAILABLE_BLOCKS:\n",
    "    ABLA_SETS.append((\"core_only\", [\"CORE\"]))\n",
    "if \"B_TOPO\" in AVAILABLE_BLOCKS:\n",
    "    ABLA_SETS.append((\"topo_only\", [\"B_TOPO\"]))\n",
    "if {\"CORE\",\"B_TOPO\"}.issubset(AVAILABLE_BLOCKS):\n",
    "    ABLA_SETS.append((\"core+topo\", [\"CORE\",\"B_TOPO\"]))\n",
    "\n",
    "# Add \"ALL\" = every available block\n",
    "ABLA_SETS.append((\"all_blocks\", AVAILABLE_BLOCKS.copy()))\n",
    "\n",
    "print(\"[9C] Planned ablations:\")\n",
    "for name, blocks in ABLA_SETS:\n",
    "    print(f\"  - {name}: {blocks}\")\n",
    "\n",
    "# --- 9C.3 Helper: run CV using features from an ablation folder ---------------\n",
    "def run_cv_with_features_from(save_dir: Path, cfg_base):\n",
    "    \"\"\"\n",
    "    Loads X_num/X_cat/y from save_dir (produced by prepare_features_for_blocks),\n",
    "    attaches them to pyg_data for this run only, and invokes train_one_split.\n",
    "    Returns a DataFrame of fold-level results.\n",
    "    \"\"\"\n",
    "    # Load features\n",
    "    X_num = np.load(save_dir / \"X_num_proc.npy\")\n",
    "    X_cat = np.load(save_dir / \"X_cat_idx.npy\") if (save_dir / \"X_cat_idx.npy\").exists() else None\n",
    "    meta  = json.load(open(save_dir / \"feature_meta.json\"))\n",
    "    classes = meta[\"classes\"]; n_classes = len(classes)\n",
    "\n",
    "    # Attach to pyg_data (temporary)\n",
    "    x_num_t = torch.tensor(X_num, dtype=torch.float, device=DEVICE)\n",
    "    x_cat_t = torch.tensor(X_cat, dtype=torch.long, device=DEVICE) if X_cat is not None else None\n",
    "    y_vec   = pd.read_csv(save_dir / \"id_targets.csv\")[\"class_index\"].values\n",
    "    y_t     = torch.tensor(y_vec, dtype=torch.long, device=DEVICE)\n",
    "\n",
    "    # Save original references to restore after run\n",
    "    x_num_backup = getattr(pyg_data, \"x_num\", None)\n",
    "    x_cat_backup = getattr(pyg_data, \"x_cat\", None)\n",
    "    y_backup     = getattr(pyg_data, \"y\", None)\n",
    "\n",
    "    pyg_data.x_num = x_num_t\n",
    "    if x_cat_t is not None: pyg_data.x_cat = x_cat_t\n",
    "    elif hasattr(pyg_data, \"x_cat\"): delattr(pyg_data, \"x_cat\")\n",
    "    pyg_data.y = y_t\n",
    "\n",
    "    # Config (do not change global CONFIG except backbone/epochs etc)\n",
    "    cfg = copy.deepcopy(CONFIG)\n",
    "    # IMPORTANT: ensure model dims and classes are consistent with this ablation\n",
    "    # (train_one_split reads num_dim & classes from feature_meta/classes.json in OUT_DIR;\n",
    "    #  so we temporarily write ablation meta to OUT_DIR to keep code simple)\n",
    "    # We'll stash, then restore.\n",
    "    OUT_BAK_META = None\n",
    "    OUT_BAK_CLASSES = None\n",
    "    if (OUT_DIR / \"feature_meta.json\").exists():\n",
    "        OUT_BAK_META = json.load(open(OUT_DIR / \"feature_meta.json\"))\n",
    "    if (OUT_DIR / \"classes.json\").exists():\n",
    "        OUT_BAK_CLASSES = json.load(open(OUT_DIR / \"classes.json\"))\n",
    "\n",
    "    json.dump(meta, open(OUT_DIR / \"feature_meta.json\", \"w\"), indent=2)\n",
    "    json.dump({\"classes\": classes}, open(OUT_DIR / \"classes.json\", \"w\"), indent=2)\n",
    "\n",
    "    rows = []\n",
    "    abla_run_dir = RUN_DIR / f\"ablation_runs/{save_dir.name}\"\n",
    "    abla_run_dir.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "    for seed in cfg[\"seeds\"]:\n",
    "        for fold_idx, masks in enumerate(tqdm(SPLITS, desc=f\"{save_dir.name} | seed {seed}\", leave=False)):\n",
    "            fold_dir = abla_run_dir / f\"seed{seed}_fold{fold_idx}\"\n",
    "            fold_dir.mkdir(parents=True, exist_ok=True)\n",
    "            res = train_one_split(seed, fold_idx, cfg, pyg_data, masks, fold_dir)\n",
    "            rows.append({\n",
    "                \"abla\": save_dir.name,\n",
    "                \"seed\": res[\"seed\"], \"fold\": res[\"fold\"],\n",
    "                \"train_macroF1\": res[\"train\"][\"macro_f1\"], \"val_macroF1\": res[\"val\"][\"macro_f1\"],\n",
    "                \"train_balAcc\": res[\"train\"][\"balanced_acc\"], \"val_balAcc\": res[\"val\"][\"balanced_acc\"],\n",
    "                \"train_weightedF1\": res[\"train\"][\"weighted_f1\"], \"val_weightedF1\": res[\"val\"][\"weighted_f1\"],\n",
    "                \"best_epoch\": res[\"best_epoch\"]\n",
    "            })\n",
    "\n",
    "    # Restore OUT_DIR meta files and pyg_data tensors\n",
    "    if OUT_BAK_META is not None:\n",
    "        json.dump(OUT_BAK_META, open(OUT_DIR / \"feature_meta.json\", \"w\"), indent=2)\n",
    "    if OUT_BAK_CLASSES is not None:\n",
    "        json.dump(OUT_BAK_CLASSES, open(OUT_DIR / \"classes.json\", \"w\"), indent=2)\n",
    "    pyg_data.x_num = x_num_backup\n",
    "    if x_cat_backup is not None: pyg_data.x_cat = x_cat_backup\n",
    "    elif hasattr(pyg_data, \"x_cat\"): delattr(pyg_data, \"x_cat\")\n",
    "    pyg_data.y = y_backup\n",
    "\n",
    "    df = pd.DataFrame(rows)\n",
    "    df.to_csv(abla_run_dir / \"cv_results.csv\", index=False)\n",
    "    summ = df.groupby(\"seed\")[[\"val_macroF1\",\"val_balAcc\",\"val_weightedF1\"]].agg([\"mean\",\"std\"])\n",
    "    summ.to_csv(abla_run_dir / \"cv_summary.csv\")\n",
    "    return df, summ, abla_run_dir\n",
    "\n",
    "# --- 9C.4 Execute: Build features per ablation set, then run CV ----------------\n",
    "ALL_ABLA_RESULTS = []\n",
    "BASE_DIR = RUN_DIR  # keep ablation artifacts under the current run folder\n",
    "\n",
    "for abla_name, blocks in ABLA_SETS:\n",
    "    # Build features for this block subset (into ABLA_DIR/<abla_name>)\n",
    "    Xz, Xc, yv, classes, meta, save_dir = prepare_features_for_blocks(blocks, abla_name, BASE_DIR)\n",
    "    print(f\"[9C] Built features for '{abla_name}': X_num={Xz.shape}, X_cat={None if Xc is None else Xc.shape}, classes={len(classes)}\")\n",
    "\n",
    "    # Run CV and collect metrics\n",
    "    df_res, df_summ, arun_dir = run_cv_with_features_from(save_dir, CONFIG)\n",
    "    print(f\"[9C] {abla_name} summary (mean±std across folds):\\n{df_summ}\\n\")\n",
    "    ALL_ABLA_RESULTS.append(df_res)\n",
    "\n",
    "# --- 9C.5 Combined comparison table -------------------------------------------\n",
    "ABL_ALL = pd.concat(ALL_ABLA_RESULTS, ignore_index=True)\n",
    "ABL_PIV = (ABL_ALL\n",
    "           .groupby([\"abla\",\"seed\"])[[\"val_macroF1\",\"val_balAcc\",\"val_weightedF1\"]]\n",
    "           .mean()\n",
    "           .reset_index())\n",
    "print(\"[9C] Side-by-side (per-seed means):\")\n",
    "print(ABL_PIV.pivot(index=\"seed\", columns=\"abla\", values=\"val_macroF1\"))\n",
    "\n",
    "# Save combined\n",
    "ABL_ROOT = RUN_DIR / \"ablation_runs\"\n",
    "ABL_ALL.to_csv(ABL_ROOT / \"ablation_cv_results_all.csv\", index=False)\n",
    "ABL_PIV.to_csv(ABL_ROOT / \"ablation_cv_seed_means.csv\", index=False)\n",
    "print(f\"[9C] Saved all ablation runs under: {ABL_ROOT}\")\n"
   ]
  },
