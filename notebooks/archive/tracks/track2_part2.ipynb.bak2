    "# %% [1] CONFIG — Feature blocks, model choices, training, calibration, logging\n",
    "\n",
    "CONFIG = {\n",
    "    # Blocks: toggle to run ablations later\n",
    "    \"feature_blocks_on\": {\n",
    "        \"A_CAUSAL\": True,       # causal DAG features\n",
    "        \"A_INFOGEOM\": True,     # information geometry / manifold coords\n",
    "        \"B_TOPO\": True,         # loops/voids/motif counts/topology\n",
    "        \"C_DYNAMICS\": True,     # attractor posteriors / dynamic tags\n",
    "        \"CORE\": True            # degree/centrality/basal/NPR/region/lineage encodings\n",
    "    },\n",
    "\n",
    "    # Model backbone: \"mlp\" | \"gcn\" | \"gat\" | \"hybrid\"\n",
    "    \"backbone\": \"gcn\",\n",
    "\n",
    "    # Loss: \"ce\" | \"focal\"\n",
    "    \"loss\": \"ce\",\n",
    "\n",
    "    # Calibration: \"none\" | \"temperature\" | \"isotonic\"\n",
    "    \"calibration\": \"temperature\",\n",
    "\n",
    "    # Splitting policy\n",
    "    \"lineage_blocking\": True,        # group by lineage (or region) to avoid leakage\n",
    "    \"group_field\": \"lineage_group\",  # or \"region_group\"\n",
    "\n",
    "    # Training\n",
    "    \"epochs\": 200,\n",
    "    \"patience\": 25,\n",
    "    \"lr\": 1e-3,\n",
    "    \"weight_decay\": 5e-4,\n",
    "    \"dropout\": 0.25,\n",
    "    \"hidden_dim\": 128,\n",
    "    \"gat_heads\": 4,\n",
    "\n",
    "    # Seeds and folds\n",
    "    \"seeds\": [13, 21, 34],\n",
    "    \"n_splits\": 5,\n",
    "\n",
    "    # Logging / saving\n",
    "    \"save_checkpoints\": True,\n",
    "    \"verbose\": True\n",
    "}\n",
    "\n",
    "print(\"[1] CONFIG OK:\", json.dumps(CONFIG, indent=2))\n"
   ]
  },
