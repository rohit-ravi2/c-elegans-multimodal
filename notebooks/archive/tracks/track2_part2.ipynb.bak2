   ],
   "source": [
    "# %% [3] Feature Blocks & Preprocessing (with label encoding)\n",
    "# Purpose: Define feature blocks, preprocess numerics/categoricals, prune collinearity,\n",
    "# and encode labels into contiguous integers for PyTorch.\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import json\n",
    "from sklearn.preprocessing import RobustScaler, StandardScaler, LabelEncoder\n",
    "\n",
    "# --- 3.1 Detect feature blocks ---------------------------------\n",
    "\n",
    "CORE_GRAPH_COLS = [\"degree\", \"in_degree\", \"out_degree\", \"betweenness\", \"closeness\", \"eigenvector\"]\n",
    "\n",
    "present = set(supervised_df.columns)\n",
    "core_cols_present = [c for c in CORE_GRAPH_COLS if c in present]\n",
    "motif_cols  = [c for c in supervised_df.columns if c.startswith(\"motif_\")]\n",
    "causal_cols = [c for c in supervised_df.columns if c.startswith(\"causal_\") or c.endswith(\"_causal\")]\n",
    "infogeom_cols = [c for c in supervised_df.columns if c.startswith(\"infogeom_\") or c.startswith(\"manifold_\")]\n",
    "dyn_cols    = [c for c in supervised_df.columns if c.startswith(\"attractor_\") or c.endswith(\"_posterior\")]\n",
    "\n",
    "BLOCKS = {\n",
    "    \"CORE\": core_cols_present,\n",
    "    \"B_TOPO\": motif_cols,\n",
    "    \"A_CAUSAL\": causal_cols,\n",
    "    \"A_INFOGEOM\": infogeom_cols,\n",
    "    \"C_DYNAMICS\": dyn_cols,\n",
    "}\n",
    "BLOCKS = {k: v for k,v in BLOCKS.items() if len(v) > 0}\n",
    "\n",
    "active_blocks = {}\n",
    "for bname, cols in BLOCKS.items():\n",
    "    if CONFIG[\"feature_blocks_on\"].get(bname, False):\n",
    "        active_blocks[bname] = cols\n",
    "\n",
    "# --- 3.2 Target and grouping ----------------------------------\n",
    "\n",
    "y_series      = supervised_df[\"class_label\"].astype(str).copy()\n",
    "groups_series = supervised_df[CONFIG[\"group_field\"]].astype(str)\n",
    "\n",
    "# --- 3.3 Clip tiny negative eigenvector values ----------------\n",
    "if \"eigenvector\" in active_blocks.get(\"CORE\", []):\n",
    "    ev = supervised_df[\"eigenvector\"].values\n",
    "    supervised_df.loc[(ev < 0) & (ev > -1e-12), \"eigenvector\"] = 0.0\n",
    "\n",
    "# --- 3.4 Split num/cat ----------------------------------------\n",
    "cat_cols, num_cols = [], []\n",
    "for block, cols in active_blocks.items():\n",
    "    for c in cols:\n",
    "        if supervised_df[c].dtype == \"object\" or supervised_df[c].dtype.name.startswith(\"category\"):\n",
    "            cat_cols.append(c)\n",
    "        else:\n",
    "            num_cols.append(c)\n",
    "cat_cols = sorted(set(cat_cols))\n",
    "num_cols = sorted(set(num_cols))\n",
    "\n",
    "# --- 3.5 Numeric preprocessing --------------------------------\n",
    "X_num = supervised_df[num_cols].copy()\n",
    "if X_num.isna().sum().sum() > 0:\n",
    "    X_num = X_num.fillna(X_num.median(numeric_only=True))\n",
    "\n",
    "robust = RobustScaler()\n",
    "zscaler = StandardScaler()\n",
    "X_num_robust = robust.fit_transform(X_num.values)\n",
    "X_num_proc   = zscaler.fit_transform(X_num_robust)\n",
    "\n",
    "# --- 3.6 Categorical encoding --------------------------------\n",
    "cat_maps, X_cat_idx = {}, None\n",
    "if len(cat_cols):\n",
    "    X_cat = supervised_df[cat_cols].astype(str).fillna(\"UNK\")\n",
    "    cat_arrays = []\n",
    "    for c in cat_cols:\n",
    "        vocab = sorted(X_cat[c].unique().tolist())\n",
    "        stoi  = {s:i for i,s in enumerate(vocab)}\n",
    "        cat_maps[c] = {\"vocab\": vocab}\n",
    "        cat_arrays.append(X_cat[c].map(stoi).values.reshape(-1,1))\n",
    "    X_cat_idx = np.concatenate(cat_arrays, axis=1)\n",
    "\n",
    "# --- 3.7 Prune collinear --------------------------------------\n",
    "def prune_collinear(df_num, threshold=0.98):\n",
    "    if df_num.shape[1] <= 1: return np.ones(df_num.shape[1], dtype=bool)\n",
    "    corr = np.corrcoef(df_num.values, rowvar=False)\n",
    "    keep = np.ones(df_num.shape[1], dtype=bool)\n",
    "    for i in range(df_num.shape[1]):\n",
    "        if not keep[i]: continue\n",
    "        for j in range(i+1, df_num.shape[1]):\n",
    "            if keep[j] and abs(corr[i,j]) > threshold:\n",
    "                keep[j] = False\n",
    "    return keep\n",
    "\n",
    "num_keep_mask = prune_collinear(pd.DataFrame(X_num_proc, columns=num_cols))\n",
    "X_num_proc    = X_num_proc[:, num_keep_mask]\n",
    "num_cols_kept = [c for c,k in zip(num_cols, num_keep_mask) if k]\n",
    "\n",
    "# --- 3.8 Label encoding ---------------------------------------\n",
    "le = LabelEncoder()\n",
    "y_int = le.fit_transform(y_series.values)\n",
    "classes = le.classes_.tolist()\n",
    "supervised_df[\"class_index\"] = y_int\n",
    "json.dump({\"classes\": classes}, open(OUT_DIR / \"classes.json\", \"w\"), indent=2)\n",
    "\n",
    "# --- 3.9 Save artifacts ---------------------------------------\n",
    "np.save(OUT_DIR / \"X_num_proc.npy\", X_num_proc)\n",
    "if X_cat_idx is not None:\n",
    "    np.save(OUT_DIR / \"X_cat_idx.npy\", X_cat_idx)\n",
    "supervised_df[[\"neuron_id\",\"class_index\"]].to_csv(OUT_DIR / \"id_targets.csv\", index=False)\n",
    "\n",
    "feature_meta = {\n",
    "    \"blocks_active\": list(active_blocks.keys()),\n",
    "    \"num_cols_kept\": num_cols_kept,\n",
    "    \"cat_cols\": cat_cols,\n",
    "    \"cat_maps\": cat_maps,\n",
    "    \"classes\": classes,\n",
    "    \"shapes\": {\n",
    "        \"X_num_proc\": list(X_num_proc.shape),\n",
    "        \"X_cat_idx\": None if X_cat_idx is None else list(X_cat_idx.shape),\n",
    "        \"n_rows\": int(supervised_df.shape[0])\n",
    "    }\n",
    "}\n",
    "json.dump(feature_meta, open(OUT_DIR / \"feature_meta.json\", \"w\"), indent=2)\n",
    "\n",
    "# --- 3.10 Sanity prints ---------------------------------------\n",
    "print(f\"[3] Blocks active: {list(active_blocks.keys())}\")\n",
    "print(f\"[3] Numeric kept: {len(num_cols_kept)} | Categorical: {len(cat_cols)}\")\n",
    "print(f\"[3] Classes: {classes}\")\n",
    "print(f\"[3] X_num_proc shape: {X_num_proc.shape} | X_cat_idx: {None if X_cat_idx is None else X_cat_idx.shape}\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 25,
   "id": "ee7501b9",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[3B] Feature builder ready: call prepare_features_for_blocks(blocks, abla_name, RUN_DIR).\n"
     ]
    }
   ],
   "source": [
    "# %% [3B] Feature Builder for Ablations (isolated; mirrors Cell 3)\n",
    "# Purpose: Build features for an arbitrary subset of blocks without touching OUT_DIR.\n",
    "#          Saves into ABLA_DIR/<abla_name>/ and returns tensors + metadata for immediate use.\n",
    "\n",
    "import re, json, numpy as np, pandas as pd\n",
    "from pathlib import Path\n",
    "from sklearn.preprocessing import RobustScaler, StandardScaler, LabelEncoder\n",
    "\n",
    "def _detect_blocks(df: pd.DataFrame):\n",
    "    \"\"\"Auto-detect block columns (same logic as Cell 3).\"\"\"\n",
    "    CORE_GRAPH_COLS = [\"degree\",\"in_degree\",\"out_degree\",\"betweenness\",\"closeness\",\"eigenvector\"]\n",
    "    present = set(df.columns)\n",
    "    core = [c for c in CORE_GRAPH_COLS if c in present]\n",
    "    topo = [c for c in df.columns if c.startswith(\"motif_\")]\n",
    "    causal = [c for c in df.columns if c.startswith(\"causal_\") or c.endswith(\"_causal\")]\n",
    "    infog = [c for c in df.columns if c.startswith(\"infogeom_\") or c.startswith(\"manifold_\")]\n",
    "    dyn   = [c for c in df.columns if c.startswith(\"attractor_\") or c.endswith(\"_posterior\")]\n",
    "    blocks = {\n",
    "        \"CORE\": core,\n",
    "        \"B_TOPO\": topo,\n",
    "        \"A_CAUSAL\": causal,\n",
    "        \"A_INFOGEOM\": infog,\n",
    "        \"C_DYNAMICS\": dyn,\n",
    "    }\n",
    "    return {k:v for k,v in blocks.items() if len(v) > 0}, CORE_GRAPH_COLS\n",
    "\n",
    "def _prune_collinear(X: np.ndarray, cols, thr=0.98):\n",
    "    if X.shape[1] <= 1:\n",
    "        return X, cols\n",
    "    corr = np.corrcoef(X, rowvar=False)\n",
    "    keep = np.ones(X.shape[1], dtype=bool)\n",
    "    for i in range(X.shape[1]):\n",
    "        if not keep[i]: continue\n",
    "        for j in range(i+1, X.shape[1]):\n",
    "            if keep[j] and abs(corr[i,j]) > thr:\n",
    "                keep[j] = False\n",
    "    return X[:, keep], [c for c,k in zip(cols, keep) if k]\n",
    "\n",
    "def prepare_features_for_blocks(active_block_names, abla_name: str, base_dir: Path):\n",
    "    \"\"\"\n",
    "    Builds features for the given block subset and writes under:\n",
    "        ABLA_DIR/<abla_name>/\n",
    "    Returns: x_num (np.ndarray), x_cat (np.ndarray or None), y (np.ndarray[int]),\n",
    "             classes (list[str]), meta (dict), save_dir (Path)\n",
    "    \"\"\"\n",
    "    # 0) Paths\n",
    "    ABLA_DIR = base_dir / \"ablation_features\"\n",
    "    save_dir = ABLA_DIR / abla_name\n",
    "    save_dir.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "    # 1) Detect columns\n",
    "    BLOCKS, CORE_GRAPH_COLS = _detect_blocks(supervised_df)\n",
    "    available = set(BLOCKS.keys())\n",
    "    wanted = [b for b in active_block_names if b in available]\n",
    "    assert len(wanted) > 0, f\"No requested blocks present. Requested={active_block_names}, available={sorted(available)}\"\n",
    "\n",
    "    # 2) Target & groups\n",
    "    y_series = supervised_df[\"class_label\"].astype(str).copy()\n",
    "    groups_series = supervised_df[CONFIG[\"group_field\"]].astype(str)\n",
    "\n",
    "    # 3) Cleanup: tiny negative eigenvector\n",
    "    if \"CORE\" in wanted and \"eigenvector\" in supervised_df.columns:\n",
    "        ev = supervised_df[\"eigenvector\"].values\n",
    "        supervised_df.loc[(ev < 0) & (ev > -1e-12), \"eigenvector\"] = 0.0\n",
    "\n",
    "    # 4) Assemble column list for this ablation\n",
    "    sel_cols = []\n",
    "    for b in wanted:\n",
    "        sel_cols.extend(BLOCKS[b])\n",
    "    # Dedup while preserving order\n",
    "    seen, ordered = set(), []\n",
    "    for c in sel_cols:\n",
    "        if c not in seen:\n",
    "            seen.add(c); ordered.append(c)\n",
    "    sel_cols = ordered\n",
    "\n",
    "    # 5) Split numeric/categorical\n",
    "    cat_cols, num_cols = [], []\n",
    "    for c in sel_cols:\n",
    "        if supervised_df[c].dtype == \"object\" or str(supervised_df[c].dtype).startswith(\"category\"):\n",
    "            cat_cols.append(c)\n",
    "        else:\n",
    "            num_cols.append(c)\n",
    "\n",
    "    # 6) Numeric preprocessing (robust -> z) with median impute\n",
    "    X_num = supervised_df[num_cols].copy()\n",
    "    if X_num.isna().sum().sum() > 0:\n",
    "        X_num = X_num.fillna(X_num.median(numeric_only=True))\n",
    "    robust = RobustScaler(); zscaler = StandardScaler()\n",
    "    Xr = robust.fit_transform(X_num.values); Xz = zscaler.fit_transform(Xr)\n",
    "    Xz, num_cols_kept = _prune_collinear(Xz, num_cols, thr=0.98)\n",
    "\n",
    "    # 7) Categorical encoding (indices)\n",
    "    X_cat, cat_maps = None, {}\n",
    "    if len(cat_cols):\n",
    "        Xc = supervised_df[cat_cols].astype(str).fillna(\"UNK\")\n",
    "        arrays = []\n",
    "        for c in cat_cols:\n",
    "            vocab = sorted(Xc[c].unique().tolist())\n",
    "            stoi  = {s:i for i,s in enumerate(vocab)}\n",
    "            cat_maps[c] = {\"vocab\": vocab}\n",
    "            arrays.append(Xc[c].map(stoi).values.reshape(-1,1))\n",
    "        X_cat = np.concatenate(arrays, axis=1)\n",
    "\n",
    "    # 8) Label encoding (contiguous)\n",
    "    le = LabelEncoder()\n",
    "    y = le.fit_transform(y_series.values)\n",
    "    classes = le.classes_.tolist()\n",
    "    # keep class_index column for downstream convenience\n",
    "    sf = supervised_df.copy()\n",
    "    sf[\"class_index\"] = y\n",
    "\n",
    "    # 9) Save artifacts in ablation-specific folder\n",
    "    np.save(save_dir / \"X_num_proc.npy\", Xz)\n",
    "    if X_cat is not None:\n",
    "        np.save(save_dir / \"X_cat_idx.npy\", X_cat)\n",
    "    sf[[\"neuron_id\",\"class_index\"]].to_csv(save_dir / \"id_targets.csv\", index=False)\n",
    "    meta = {\n",
    "        \"abla_name\": abla_name,\n",
    "        \"blocks_requested\": active_block_names,\n",
    "        \"blocks_used\": wanted,\n",
    "        \"num_cols_kept\": num_cols_kept,\n",
    "        \"cat_cols\": cat_cols,\n",
    "        \"shapes\": {\n",
    "            \"X_num_proc\": list(Xz.shape),\n",
    "            \"X_cat_idx\": None if X_cat is None else list(X_cat.shape),\n",
    "            \"n_rows\": int(sf.shape[0])\n",
    "        },\n",
    "        \"classes\": classes\n",
    "    }\n",
    "    json.dump(meta, open(save_dir / \"feature_meta.json\", \"w\"), indent=2)\n",
    "\n",
    "    # 10) Return tensors + meta\n",
    "    return Xz, X_cat, y, classes, meta, save_dir\n",
    "\n",
    "print(\"[3B] Feature builder ready: call prepare_features_for_blocks(blocks, abla_name, RUN_DIR).\")\n"
   ]
  },
