   "cell_type": "code",
   "execution_count": null,
   "id": "9da28eef",
   "metadata": {},
   "outputs": [],
   "source": [
    "# %% [3.0 Windowing Utilities & Metrics]\n",
    "# Purpose: Helper functions: window maker, cycle-average, FFT peak, correlations, and evaluation harness.\n",
    "\n",
    "def make_windows(X_np, Y_np, window_size=20, stride=5):\n",
    "    Xs, Ys = [], []\n",
    "    T = X_np.shape[0]\n",
    "    for start in range(0, T - window_size + 1, stride):\n",
    "        end = start + window_size\n",
    "        Xs.append(X_np[start:end])\n",
    "        Ys.append(Y_np[start:end])\n",
    "    return np.stack(Xs), np.stack(Ys)\n",
    "\n",
    "def cycle_average(traces_np, cycle_map):\n",
    "    # traces_np: [T, N] or [B,T,N]; returns dict {cid: [T]} for batch=1\n",
    "    if traces_np.ndim == 3:  # [B,T,N] → use first item\n",
    "        traces_np = traces_np[0]\n",
    "    T, N = traces_np.shape\n",
    "    out = {}\n",
    "    for cid, idxs in cycle_map.items():\n",
    "        if len(idxs) == 0: \n",
    "            continue\n",
    "        out[cid] = traces_np[:, idxs].mean(axis=1)\n",
    "    return out\n",
    "\n",
    "def dominant_peak(signal_1d):\n",
    "    # returns frequency-bin index of max amplitude (ignore DC)\n",
    "    fft_vals = np.abs(rfft(signal_1d))\n",
    "    if len(fft_vals) <= 2:\n",
    "        return 0\n",
    "    fft_vals[0] = 0.0  # drop DC\n",
    "    return int(np.argmax(fft_vals))\n",
    "\n",
    "def peak_match_rate(cycle_pred_dict, cycle_true_dict, tol_bins=1):\n",
    "    # fraction of cycles sharing dominant FFT peak within ±tol_bins\n",
    "    hits, total = 0, 0\n",
    "    for cid in set(cycle_true_dict.keys()) & set(cycle_pred_dict.keys()):\n",
    "        p1 = dominant_peak(cycle_true_dict[cid])\n",
    "        p2 = dominant_peak(cycle_pred_dict[cid])\n",
    "        hits += (abs(p1 - p2) <= tol_bins)\n",
    "        total += 1\n",
    "    return (hits / total) if total else np.nan\n",
    "\n",
    "def pearson_r(a, b):\n",
    "    a = np.asarray(a); b = np.asarray(b)\n",
    "    if a.std() == 0 or b.std() == 0: \n",
    "        return 0.0\n",
    "    return float(np.corrcoef(a, b)[0,1])\n",
    "\n",
    "def cycle_correlations(cycle_pred_dict, cycle_true_dict):\n",
    "    cors = []\n",
    "    for cid in set(cycle_true_dict.keys()) & set(cycle_pred_dict.keys()):\n",
    "        cors.append(pearson_r(cycle_pred_dict[cid], cycle_true_dict[cid]))\n",
    "    return np.array(cors, dtype=float)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "84d87c09",
   "metadata": {},
   "outputs": [],
   "source": [
    "# %% [3.1 Cycle-Aware LSTM (definition + training)]\n",
    "# Purpose: Define LSTM, train once on real data (Basal→NPR10), evaluate and store predictions.\n",
    "class CycleAwareLSTM(nn.Module):\n",
    "    def __init__(self, input_dim, hidden_dim=128, num_layers=2, output_dim=None, dropout=0.2):\n",
    "        super().__init__()\n",
    "        self.lstm = nn.LSTM(input_dim, hidden_dim, num_layers=num_layers,\n",
    "                            batch_first=True, dropout=dropout)\n",
    "        self.fc   = nn.Linear(hidden_dim, output_dim if output_dim else input_dim)\n",
    "    def forward(self, x):\n",
    "        out, _ = self.lstm(x)\n",
    "        return self.fc(out)\n",
    "\n",
    "def cycle_loss(pred, true, cycle_map):\n",
    "    # pred,true: [B,T,N]\n",
    "    mse = nn.MSELoss()\n",
    "    loss = 0.0\n",
    "    count = 0\n",
    "    for idxs in cycle_map.values():\n",
    "        if not idxs: \n",
    "            continue\n",
    "        pred_c = pred[..., idxs].mean(dim=-1)\n",
    "        true_c = true[..., idxs].mean(dim=-1)\n",
    "        loss  += mse(pred_c, true_c)\n",
    "        count += 1\n",
    "    return loss / max(count, 1)\n",
    "\n",
    "# Build training windows\n",
    "X_np = df_basal_ts.T.values  # [T,N]\n",
    "Y_np = df_npr10_ts.T.values  # [T,N]\n",
    "X_win, Y_win = make_windows(X_np, Y_np, window_size=20, stride=5)\n",
    "X_tensor = torch.tensor(X_win, dtype=torch.float32)  # [B,T,N]\n",
    "Y_tensor = torch.tensor(Y_win, dtype=torch.float32)\n",
    "\n",
    "print(\"Window shapes:\", X_tensor.shape, Y_tensor.shape)  # Sanity\n",
    "\n",
    "# Train once on real data\n",
    "model = CycleAwareLSTM(input_dim=X_tensor.shape[-1], output_dim=Y_tensor.shape[-1])\n",
    "opt    = torch.optim.Adam(model.parameters(), lr=0.005)\n",
    "mse    = nn.MSELoss()\n",
    "lambda_cycle = 1.0\n",
    "epochs = 60\n",
    "loader = DataLoader(TensorDataset(X_tensor, Y_tensor), batch_size=8, shuffle=True)\n",
    "\n",
    "for ep in range(epochs):\n",
    "    total = 0.0\n",
    "    for xb, yb in loader:\n",
    "        pred = model(xb)\n",
    "        loss = mse(pred, yb) + lambda_cycle * cycle_loss(pred, yb, cycle_map_real)\n",
    "        opt.zero_grad(); loss.backward(); opt.step()\n",
    "        total += loss.item()\n",
    "    if (ep+1) % 10 == 0:\n",
    "        print(f\"Epoch {ep+1}/{epochs} | Loss: {total/len(loader):.4f}\")\n",
    "\n",
    "# Predict on full sequence (no windowing) for evaluation\n",
    "with torch.no_grad():\n",
    "    X_full = torch.tensor(X_np[None, ...], dtype=torch.float32)  # [1,T,N]\n",
    "    Y_full = torch.tensor(Y_np[None, ...], dtype=torch.float32)\n",
    "    Y_hat  = model(X_full).numpy()[0]  # [T,N]\n",
    "\n",
    "print(\"✅ LSTM trained; full prediction shape:\", Y_hat.shape)\n"
   ]
  },
  {
   "cell_type": "code",
