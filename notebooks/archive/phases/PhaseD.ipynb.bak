   "source": [
    "# %% Cell 5 — Instantiate model, attach adj, prepare tensors and train/val split\n",
    "# Purpose: create model instance, set adjacency (A_norm), and build DataLoaders.\n",
    "# Requires: X_win, Y_win, X_gene (np or tensor), A_norm (scipy csr), starts, T_full present.\n",
    "\n",
    "# --- sanity checks: required variables present\n",
    "_required = [\"X_win\", \"Y_win\", \"X_gene\", \"A_norm\", \"starts\"]\n",
    "for v in _required:\n",
    "    if v not in globals():\n",
    "        raise RuntimeError(f\"Missing required variable '{v}' from earlier cells. Run Cells 0–3 first.\")\n",
    "\n",
    "# Convert to torch tensors with expected shapes\n",
    "if isinstance(X_win, np.ndarray):\n",
    "    X_win_t = torch.tensor(X_win, dtype=torch.float32)  # (B, T, N)\n",
    "else:\n",
    "    X_win_t = X_win.clone()\n",
    "if isinstance(Y_win, np.ndarray):\n",
    "    Y_win_t = torch.tensor(Y_win, dtype=torch.float32)\n",
    "else:\n",
    "    Y_win_t = Y_win.clone()\n",
    "\n",
    "# gene tensor\n",
    "if isinstance(X_gene, np.ndarray):\n",
    "    X_gene_t = torch.tensor(X_gene, dtype=torch.float32)  # (N, G)\n",
    "else:\n",
    "    X_gene_t = X_gene.clone()\n",
    "\n",
    "B, T, N = X_win_t.shape\n",
    "G = X_gene_t.shape[1]\n",
    "print(f\"Prepared tensors shapes -> X_win: {X_win_t.shape}, Y_win: {Y_win_t.shape}, X_gene: {X_gene_t.shape}\")\n",
    "print(f\"Adjacency (A_norm) nnz: {A_norm.nnz}, nodes: {len(common_neurons)}\")\n",
    "\n",
    "# instantiate model\n",
    "dyn_dim = 1\n",
    "gene_dim = G\n",
    "model = HybridGeneGraphLSTM(dyn_dim=dyn_dim, gene_dim=gene_dim, lstm_hidden=64, lstm_layers=2)\n",
    "model.set_adj(A_norm)   # attach scipy neighbor-normalized adjacency\n",
    "model.to(device)\n",
    "print(\"Model params:\", sum(p.numel() for p in model.parameters()))\n",
    "\n",
    "# DataLoader with train/val split\n",
    "dataset = TensorDataset(X_win_t, Y_win_t)\n",
    "train_len = int(0.8 * len(dataset))\n",
    "val_len = len(dataset) - train_len\n",
    "train_ds, val_ds = random_split(dataset, [train_len, val_len])\n",
    "train_loader = DataLoader(train_ds, batch_size=4, shuffle=True)\n",
    "val_loader = DataLoader(val_ds, batch_size=4)\n",
    "print(\"Dataset sizes: train\", train_len, \"val\", val_len)\n"
   ]
  },
