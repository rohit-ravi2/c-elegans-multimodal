     ]
    }
   ],
   "source": [
    "# -----------------------\n",
    "# Cell A — Prune adjacency to cycle co-membership edges (preferred)\n",
    "# -----------------------\n",
    "import numpy as np\n",
    "import scipy.sparse as sp\n",
    "\n",
    "# Load phaseC cycle membership (expanded per-cycle -> neuron mapping)\n",
    "cycles_file = os.path.join(INPUT_DIR, \"phaseC\", \"C2_cycles_basal.csv\")\n",
    "cycles_expanded_file = os.path.join(INPUT_DIR, \"phaseC\", \"C2_per_cycle_enrichment_basal_labeled.csv\")\n",
    "if os.path.exists(cycles_expanded_file):\n",
    "    df_cycles = pd.read_csv(cycles_expanded_file)\n",
    "    # Expect it has a 'neuron_norm' or similar column listing neurons per cycle (or you may need to expand)\n",
    "else:\n",
    "    # Fallback: build cycle edges from earlier df_pairs if you have it\n",
    "    df_cycles = None\n",
    "\n",
    "# Approach: create edges only if two neurons share an enriched cycle (reject_0.05 == True)\n",
    "edges_pruned = set()\n",
    "if df_cycles is not None and 'cycle_id' in df_cycles.columns:\n",
    "    # Expand — if you have per-cycle a row per cycle and need to expand to neurons, adapt as needed.\n",
    "    # Here I assume there's a file or we can re-use df_pairs grouped by tuple/cycle mapping.\n",
    "    # We'll fallback to using df_pairs & grouping by tuple (approx cycle)\n",
    "    try:\n",
    "        # If you have df_pairs (tuple->neuron) from earlier:\n",
    "        grouped = df_pairs.groupby(\"tuple\")[\"neuron\"].apply(list)\n",
    "        for ns in grouped:\n",
    "            for i in range(len(ns)):\n",
    "                for j in range(i+1, len(ns)):\n",
    "                    a, b = ns[i], ns[j]\n",
    "                    if a in neuron_to_idx and b in neuron_to_idx:\n",
    "                        edges_pruned.add((neuron_to_idx[a], neuron_to_idx[b]))\n",
    "    except Exception:\n",
    "        pass\n",
    "\n",
    "# Fallback: top-k neighbors by co-occurrence across tuples\n",
    "if len(edges_pruned) == 0:\n",
    "    # compute co-occurrence matrix from df_pairs\n",
    "    from collections import defaultdict\n",
    "    occ = defaultdict(int)\n",
    "    tuple_groups = df_pairs.groupby(\"tuple\")[\"neuron\"].apply(list)\n",
    "    for ns in tuple_groups:\n",
    "        for i in range(len(ns)):\n",
    "            for j in range(i+1, len(ns)):\n",
    "                a, b = ns[i], ns[j]\n",
    "                if a in neuron_to_idx and b in neuron_to_idx:\n",
    "                    occ[(neuron_to_idx[a], neuron_to_idx[b])] += 1\n",
    "                    occ[(neuron_to_idx[b], neuron_to_idx[a])] += 1\n",
    "    # for each node, pick top-k neighbors\n",
    "    k = 8\n",
    "    neighbors = {i: [] for i in range(len(common_neurons))}\n",
    "    for (i,j),c in occ.items():\n",
    "        neighbors[i].append((j,c))\n",
    "    for i in neighbors:\n",
    "        neighbors[i].sort(key=lambda x: -x[1])\n",
    "        for j,_ in neighbors[i][:k]:\n",
    "            edges_pruned.add((i,j))\n",
    "\n",
    "# Build symmetric adjacency\n",
    "edges_arr = np.array(list(edges_pruned), dtype=np.int64)\n",
    "rows = np.concatenate([edges_arr[:,0], edges_arr[:,1]])\n",
    "cols = np.concatenate([edges_arr[:,1], edges_arr[:,0]])\n",
    "data = np.ones(len(rows), dtype=np.float32)\n",
    "A_pruned = sp.coo_matrix((data,(rows,cols)), shape=(len(common_neurons),len(common_neurons))).tocsr()\n",
    "deg = np.array(A_pruned.sum(axis=1)).flatten(); deg[deg==0]=1.0\n",
    "A_pruned_norm = sp.diags(1.0/deg).dot(A_pruned)\n",
    "\n",
    "print(\"Pruned adjacency nnz:\", A_pruned_norm.nnz, \"avg degree:\", A_pruned_norm.nnz/len(common_neurons))\n",
    "# Replace adjacency used by model later with A_pruned_norm\n"
   ]
  },
