    "\n",
    "    sched.step(val_loss)\n",
    "    if val_loss < best_val_loss:\n",
    "        best_val_loss = val_loss\n",
    "        best_model = copy.deepcopy(model.state_dict())\n",
    "        pat = 0\n",
    "    else:\n",
    "        pat += 1\n",
    "\n",
    "    if ep % 10 == 0 or ep == 1:\n",
    "        print(f\"Epoch {ep}/{epochs} train_loss={loss_train.item():.4f} val_loss={val_loss:.4f} patience={pat}\")\n",
    "\n",
