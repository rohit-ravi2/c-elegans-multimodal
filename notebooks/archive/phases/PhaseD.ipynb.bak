   "source": [
    "# %% [5.1 Evaluation: Spectral Comparison]\n",
    "# Function: Compare FFT spectra of predicted vs true traces for one neuron.\n",
    "\n",
    "from scipy.fft import rfft, rfftfreq\n",
    "\n",
    "n = np.random.choice(len(df_basal_ts.index))\n",
    "neuron_name = df_basal_ts.index[n]\n",
