   "outputs": [],
   "source": [
    "# %% [3.2 Baselines: Identity & Ridge]\n",
    "# Purpose: Establish simple baselines to bound expectations.\n",
    "\n",
    "# Identity baseline: predict NPR10 = Basal\n",
    "Y_hat_identity = X_np.copy()\n",
    "\n",
    "# Ridge baseline: solve min_W ||XW - Y||_F^2 + alpha ||W||_F^2\n",
    "alpha = 1.0\n",
    "XTX   = X_np.T @ X_np\n",
    "W     = np.linalg.solve(XTX + alpha * np.eye(XTX.shape[0]), X_np.T @ Y_np)   # [N,N]\n",
    "Y_hat_ridge = X_np @ W\n",
    "\n",
    "# Sanity: shapes\n",
    "print(\"Baselines ready:\", Y_hat_identity.shape, Y_hat_ridge.shape)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "1908eb38",
   "metadata": {},
   "outputs": [],
   "source": [
    "# %% [3.3 Metrics: Neuron-Level MSE (Real vs Baselines)]\n",
    "# Purpose: Compare global neuron-level MSE of models vs true NPR10.\n",
    "\n",
    "def mse_np(a, b): \n",
    "    return float(np.mean((a - b) ** 2))\n",
    "\n",
    "mse_lstm     = mse_np(Y_hat, Y_np)\n",
    "mse_identity = mse_np(Y_hat_identity, Y_np)\n",
    "mse_ridge    = mse_np(Y_hat_ridge, Y_np)\n",
    "\n",
    "print(\"✅ Neuron-level MSE:\")\n",
    "print(\"  LSTM     :\", round(mse_lstm, 3))\n",
    "print(\"  Identity :\", round(mse_identity, 3))\n",
    "print(\"  Ridge    :\", round(mse_ridge, 3))\n",
    "\n",
    "# Save\n",
    "pd.DataFrame([{\n",
    "    \"mse_lstm\": mse_lstm, \"mse_identity\": mse_identity, \"mse_ridge\": mse_ridge\n",
    "}]).to_csv(os.path.join(WORK_DIR, \"D1_neuron_mse.csv\"), index=False)\n"
   ]
  },
  {
