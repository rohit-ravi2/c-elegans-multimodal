    "# %% [FIX] Robust model instantiation + training with explicit type checks\n",
    "import types\n",
    "\n",
    "# Sanity prints: check types & shapes for variables used to build the LSTM\n",
    "print(\"DEBUG: variable types and sample values:\")\n",
    "print(\"  N (neurons):\", type(N), N if isinstance(N, (int, np.integer)) else str(N))\n",
    "print(\"  D_per (per-neuron feature dim):\", type(D_per), D_per if isinstance(D_per, (int, np.integer)) else str(D_per))\n",
    "print(\"  B,T:\", type(B), B, type(T), T)\n",
    "print(\"  X_flat.shape:\", X_flat.shape if 'X_flat' in globals() else None)\n",
    "print(\"  Y_target.shape:\", Y_target.shape if 'Y_target' in globals() else None)\n",
    "print(\"  device:\", device, type(device))\n",
    "\n",
    "# Compute F robustly and force to int\n",
    "try:\n",
    "    F_raw = N * D_per\n",
    "except Exception as e:\n",
    "    # If N or D_per are tensors or torch.Size, coerce\n",
    "    N_val = int(torch.as_tensor(N).item()) if isinstance(N, torch.Tensor) else int(np.asarray(N))\n",
    "    D_val = int(torch.as_tensor(D_per).item()) if isinstance(D_per, torch.Tensor) else int(np.asarray(D_per))\n",
    "    F_raw = N_val * D_val\n",
    "\n",
    "F = int(F_raw)\n",
    "hidden_dim = int(256)\n",
    "num_layers = int(2)\n",
    "out_neurons = int(N)\n",
    "\n",
    "print(f\"Using input_dim F = {F} (type: {type(F)})\")\n",
    "print(f\"hidden_dim = {hidden_dim}, num_layers = {num_layers}, out_neurons = {out_neurons}\")\n",
    "\n",
    "# Redefine the model class (reuse previous if available)\n",
    "class GeneAwareTimeLSTM(nn.Module):\n",
    "    def __init__(self, input_dim, hidden_dim=256, num_layers=2, dropout=0.2, out_neurons=None):\n",
    "        super().__init__()\n",
    "        # ensure input_dim and hidden_dim are ints\n",
    "        input_dim = int(input_dim)\n",
    "        hidden_dim = int(hidden_dim)\n",
    "        num_layers = int(num_layers)\n",
    "        self.lstm = nn.LSTM(input_dim, hidden_dim, num_layers=num_layers, batch_first=True, dropout=dropout)\n",
    "        self.fc = nn.Linear(hidden_dim, int(out_neurons))\n",
    "    def forward(self, x):\n",
    "        out, _ = self.lstm(x)\n",
    "        y = self.fc(out)\n",
    "        return y\n",
    "\n",
    "# Instantiate model with explicit ints and send to device\n",
    "model = GeneAwareTimeLSTM(input_dim=F, hidden_dim=hidden_dim, num_layers=num_layers, dropout=0.2, out_neurons=out_neurons).to(device)\n",
    "print(\"Model instantiated OK. Param count:\", sum(p.numel() for p in model.parameters()))\n",
    "\n",
    "# Quick training loop (short) — same as before but shorter for debug\n",
    "opt = torch.optim.Adam(model.parameters(), lr=1e-3, weight_decay=1e-5)\n",
    "criterion = nn.MSELoss()\n",
    "lambda_cycle = 0.5\n",
    "\n",
    "# Ensure X_flat and Y_target are on device and have expected dtypes\n",
    "X_train = X_flat.to(device).float()\n",
    "Y_train = Y_target.to(device).float()\n",
    "dataset = TensorDataset(X_train, Y_train)\n",
    "loader = DataLoader(dataset, batch_size=4, shuffle=True)\n",
    "\n",
    "epochs = 6  # short debug run\n",
    "for ep in range(1, epochs+1):\n",
    "    model.train()\n",
    "    batch_losses = []\n",
    "    for xb, yb in loader:\n",
    "        pred = model(xb)\n",
    "        loss_neuron = criterion(pred, yb)\n",
    "        # optional cycle loss if cycle_map_real exists\n",
    "        if 'cycle_map_real' in globals():\n",
    "            # small safety wrapper: ignore cycles with invalid indices\n",
    "            def safe_cycle_loss(pred, true, cmap):\n",
    "                mse = nn.MSELoss()\n",
    "                total = 0.0; cnt = 0\n",
    "                for cid, idxs in cmap.items():\n",
    "                    idxs = [i for i in idxs if 0 <= i < pred.shape[2]]\n",
    "                    if not idxs:\n",
    "                        continue\n",
    "                    p_c = pred[..., idxs].mean(dim=-1)\n",
    "                    t_c = true[..., idxs].mean(dim=-1)\n",
    "                    total += mse(p_c, t_c)\n",
    "                    cnt += 1\n",
    "                return total / max(1, cnt)\n",
    "            loss_cycle = safe_cycle_loss(pred, yb, cycle_map_real)\n",
    "        else:\n",
    "            loss_cycle = 0.0\n",
    "        loss = loss_neuron + lambda_cycle * loss_cycle\n",
    "        opt.zero_grad()\n",
    "        loss.backward()\n",
    "        opt.step()\n",
    "        batch_losses.append(float(loss.item()))\n",
    "    print(f\"[DEBUG TRAIN] Epoch {ep}/{epochs} avg_loss: {np.mean(batch_losses):.4f}\")\n",
    "\n",
    "# After debug train, do a quick prediction sanity check\n",
    "model.eval()\n",
    "with torch.no_grad():\n",
    "    sample_pred = model(X_train[:1])\n",
    "print(\"Sample pred shape:\", sample_pred.shape)  # expect (1, T, N)\n"
   ]
