    "# %% [2.0 Load Phase A–C Data, Patched]\n",
    "# Function: Load attractors, cycles, and neuron metadata robustly.\n",
    "\n",
    "# Load attractors\n",
    "df_attractors = pd.read_csv(os.path.join(INPUT_DIR, \"phaseA\", \"A_CA_attractors.csv\"))\n",
    "print(\"✅ Attractors loaded:\", df_attractors.shape)\n",
    "print(df_attractors.head())\n",
    "\n",
    "# Load cycle enrichment (basal, npr10)\n",
    "df_cycles_basal = pd.read_csv(os.path.join(INPUT_DIR, \"phaseC\", \"C2_per_cycle_enrichment_basal_labeled.csv\"))\n",
    "df_cycles_npr10 = pd.read_csv(os.path.join(INPUT_DIR, \"phaseC\", \"C2_per_cycle_enrichment_npr10_labeled.csv\"))\n",
    "print(\"✅ Cycle enrichment loaded:\", df_cycles_basal.shape, df_cycles_npr10.shape)\n",
    "print(\"Columns (basal):\", df_cycles_basal.columns.tolist())\n",
    "print(\"Columns (npr10):\", df_cycles_npr10.columns.tolist())\n",
    "\n",
    "# Load metadata\n",
    "df_meta = pd.read_csv(os.path.join(INPUT_DIR, \"metadata\", \"neuron_metadata.csv\"))\n",
    "print(\"✅ Metadata loaded:\", df_meta.shape)\n",
    "print(\"Columns (metadata):\", df_meta.columns.tolist())\n",
    "\n",
    "# --- Align neuron columns dynamically ---\n",
    "def get_neuron_column(df):\n",
    "    for candidate in [\"neuron\", \"node\", \"label\", \"member\"]:\n",
    "        if candidate in df.columns:\n",
    "            return candidate\n",
    "    return None\n",
    "\n",
    "col_cycles_basal = get_neuron_column(df_cycles_basal)\n",
    "col_cycles_npr10 = get_neuron_column(df_cycles_npr10)\n",
    "col_meta = get_neuron_column(df_meta)\n",
    "\n",
    "neurons_A = set(df_attractors[\"neuron\"])\n",
    "neurons_C = set(df_cycles_basal[col_cycles_basal]) | set(df_cycles_npr10[col_cycles_npr10])\n",
    "neurons_M = set(df_meta[col_meta]) if col_meta else set()\n",
    "\n",
    "common = neurons_A & neurons_C & neurons_M\n",
    "print(f\"✅ Common neurons across datasets: {len(common)}\")\n",
    "print(\"Example common neurons:\", list(common)[:10])\n"
   ]
  },
