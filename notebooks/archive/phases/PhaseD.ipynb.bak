   "source": [
    "# %% [markdown]\n",
    "# ### Setup: Recursively find and copy Phase D input files into structured folders\n",
    "\n",
    "# %%\n",
    "import os\n",
    "import shutil\n",
    "\n",
    "# --- Base paths ---\n",
    "BASE_DIR = \"Projects/C-Elegans/PhaseD\"\n",
    "INPUT_DIR = os.path.join(BASE_DIR, \"inputs\")\n",
    "\n",
    "# Define required files grouped by category\n",
    "subdirs = {\n",
    "    \"phaseA\": [\"A_CA_attractors.csv\"],\n",
    "    \"phaseB\": [\n",
    "        \"neuron_to_tuples.csv\",\n",
    "        \"tuple_index_decoded_pairs.csv\",\n",
    "        \"tuple_to_neurons.csv\"\n",
    "    ],\n",
    "    \"phaseC\": [\n",
    "        \"C2_cycles_basal.csv\",\n",
    "        \"C2_cycles_npr10.csv\",\n",
    "        \"C2_per_cycle_enrichment_basal_labeled.csv\",\n",
    "        \"C2_per_cycle_enrichment_npr10_labeled.csv\",\n",
    "        \"C3_union_deltas.csv\",\n",
    "        \"C3_weighted_union_summary.csv\"\n",
    "    ],\n",
    "    \"metadata\": [\n",
    "        \"neuron_metadata.csv\",\n",
    "        \"neuron_master.csv\"\n",
    "    ],\n",
    "    \"expression\": [\n",
    "        \"expr_matrix.tsv\",\n",
    "        \"genome_data_master.tsv\"\n",
    "    ],\n",
    "    \"reference\": [\n",
    "        # optional placeholder\n",
    "        # \"worm_behaviors.csv\"\n",
    "    ]\n",
    "}\n",
    "\n",
    "# --- Create directories recursively ---\n",
    "for folder in [\"inputs\", \"working\", \"artifacts\"]:\n",
    "    os.makedirs(os.path.join(BASE_DIR, folder), exist_ok=True)\n",
    "for sub in subdirs.keys():\n",
    "    os.makedirs(os.path.join(INPUT_DIR, sub), exist_ok=True)\n",
    "\n",
    "# --- Recursive search utility ---\n",
    "def find_file(filename, search_root=\".\"):\n",
    "    \"\"\"Recursively search for a file starting at search_root.\"\"\"\n",
    "    for root, dirs, files in os.walk(search_root):\n",
    "        if filename in files:\n",
    "            return os.path.join(root, filename)\n",
    "    return None\n",
    "\n",
    "# --- Search & copy ---\n",
    "SEARCH_ROOT = \".\"   # change to your project root if needed\n",
    "\n",
    "for sub, files in subdirs.items():\n",
    "    for f in files:\n",
    "        src = find_file(f, SEARCH_ROOT)\n",
    "        dst = os.path.join(INPUT_DIR, sub, f)\n",
    "        if src:\n",
    "            shutil.copy(src, dst)\n",
    "            print(f\"✅ Found and copied {f} from {src} → inputs/{sub}/\")\n",
    "        else:\n",
    "            print(f\"⚠️ Missing: {f} (not found anywhere under {SEARCH_ROOT})\")\n",
    "\n",
    "print(\"\\n📂 Phase D structure ready (with recursive search).\")\n"
   ]
  },
