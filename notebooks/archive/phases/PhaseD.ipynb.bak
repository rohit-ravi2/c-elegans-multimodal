    "plt.xlabel(\"Timestep\")\n",
    "plt.ylabel(\"Activity\")\n",
    "plt.show()\n",
    "\n",
    "print(\"✅ Visualization complete — plotted neurons:\", list(sample_neurons))\n"
   ]
