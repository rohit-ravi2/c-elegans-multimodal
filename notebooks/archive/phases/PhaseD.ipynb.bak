   "source": [
    "# -----------------------\n",
    "# Cell C — Small model variant with learned neighbor mixing alpha\n",
    "# -----------------------\n",
    "class HybridGeneGraphLSTM_withAlpha(HybridGeneGraphLSTM):\n",
    "    def __init__(self, dyn_dim, gene_dim, lstm_hidden=64, lstm_layers=2):\n",
    "        super().__init__(dyn_dim, gene_dim, lstm_hidden=lstm_hidden, lstm_layers=lstm_layers)\n",
    "        # learn a scalar mixing weight (sigmoid to keep between 0 and 1)\n",
    "        self.alpha_param = nn.Parameter(torch.tensor(0.0))  # logits\n",
    "\n",
    "    def forward(self, X_dyn, X_gene, device, return_raw=False):\n",
    "        # call parent forward logic up to gcn_out but don't fuse yet\n",
    "        if X_dyn.dim() == 3:\n",
    "            X_dyn = X_dyn.unsqueeze(-1)\n",
    "        B, T, N, dd = X_dyn.shape\n",
    "        gene_expand = X_gene.unsqueeze(0).unsqueeze(0).expand(B, T, N, -1).to(device)\n",
    "        X_full = torch.cat([X_dyn.to(device), gene_expand], dim=-1)\n",
    "\n",
    "        X_seq = X_full.permute(0,2,1,3).contiguous().view(B * N, T, self.input_dim)\n",
    "        lstm_out, _ = self.lstm(X_seq)\n",
    "        lstm_last = lstm_out[:, -1, :]\n",
    "        H = lstm_last.shape[-1]\n",
    "        lstm_last_bn = lstm_last.view(B, N, H)\n",
    "\n",
    "        # neighbor aggregation\n",
    "        gcn_out_list=[]\n",
    "        for b in range(B):\n",
    "            node_feats_np = lstm_last_bn[b].detach().cpu().numpy()\n",
    "            neigh_np = self.neighbor_aggregate_numpy(node_feats_np)\n",
    "            gcn_out_list.append(torch.tensor(neigh_np, dtype=torch.float32, device=device))\n",
    "        gcn_out = torch.stack(gcn_out_list, dim=0)\n",
    "\n",
    "        # learned mix\n",
    "        alpha = torch.sigmoid(self.alpha_param)  # scalar in (0,1)\n",
    "        fused = alpha * gcn_out + (1.0 - alpha) * lstm_last_bn.to(device)\n",
    "        fused_flat = fused.view(B*N, H)\n",
    "        # to keep parity with earlier fc size, concatenate original lstm_last too\n",
    "        fused_concat = torch.cat([lstm_last_bn.to(device).view(B*N, H), fused_flat], dim=-1)\n",
    "        out_flat = self.fc(fused_concat).view(B, N)\n",
    "        out_seq = out_flat.unsqueeze(1).expand(B, T, N)\n",
    "        return out_seq\n",
    "\n",
    "# Instantiate and test alpha model quickly\n",
    "alpha_model = HybridGeneGraphLSTM_withAlpha(dyn_dim=1, gene_dim=G, lstm_hidden=64).to(device)\n",
    "alpha_model.set_adj(A_pruned_norm if 'A_pruned_norm' in globals() else A_norm)\n",
    "print(\"Alpha param initial:\", float(torch.sigmoid(alpha_model.alpha_param).item()))\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 42,
   "id": "54f05bc7",
   "metadata": {},
   "outputs": [],
   "source": [
    "# %% Cell 4 — Define HybridGeneGraphLSTM (forgiving forward + CPU neighbor aggregation)\n",
    "# Purpose: model that keeps the full per-neuron gene+dyn features (shared LSTM per neuron),\n",
    "#          then augments each neuron's representation with a neighbor-mean computed via A_norm (scipy CSR).\n",
    "# Notes: forward accepts X_dyn as (B,T,N) OR (B,T,N,1). neighbor aggregation done on CPU for robustness.\n",
    "\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.nn.functional as F\n",
    "\n",
    "class HybridGeneGraphLSTM(nn.Module):\n",
    "    def __init__(self, dyn_dim:int, gene_dim:int, lstm_hidden:int=128, lstm_layers:int=2):\n",
    "        super().__init__()\n",
    "        self.dyn_dim = dyn_dim\n",
    "        self.gene_dim = gene_dim\n",
    "        self.input_dim = dyn_dim + gene_dim\n",
    "        self.lstm_hidden = lstm_hidden\n",
    "        self.lstm_layers = lstm_layers\n",
    "\n",
    "        # Shared LSTM (runs per-neuron sequences after flattening B*N -> batch)\n",
    "        self.lstm = nn.LSTM(input_size=self.input_dim, hidden_size=lstm_hidden,\n",
    "                            num_layers=lstm_layers, batch_first=True, dropout=0.1)\n",
    "\n",
    "        # Fusion projection: concat(LSTM_hidden, neighbor_context) -> scalar output per neuron\n",
    "        self.fc = nn.Linear(lstm_hidden * 2, 1)\n",
    "\n",
    "        # adjacency placeholder (scipy csr) to be set externally via set_adj()\n",
    "        self.adj_norm = None\n",
    "\n",
    "    def set_adj(self, adj_norm_csr):\n",
    "        \"\"\"Attach normalized adjacency (scipy.sparse CSR).\"\"\"\n",
    "        self.adj_norm = adj_norm_csr\n",
    "\n",
    "    def neighbor_aggregate_numpy(self, node_feats_np):\n",
    "        \"\"\"Run A_norm @ node_feats_np (node_feats_np: (N, H) numpy) -> (N, H) numpy\"\"\"\n",
    "        if self.adj_norm is None:\n",
    "            raise RuntimeError(\"Adjacency (adj_norm) must be set before calling neighbor aggregation.\")\n",
    "        return self.adj_norm.dot(node_feats_np)\n",
    "\n",
    "    def forward(self, X_dyn, X_gene, device, return_raw=False):\n",
    "        \"\"\"\n",
    "        X_dyn: torch.Tensor (B, T, N) OR (B, T, N, dyn_dim)\n",
    "        X_gene: torch.Tensor (N, gene_dim)  (can be on CPU or device)\n",
    "        device: torch.device target for tensors\n",
    "        returns: preds (B, T, N)\n",
    "        \"\"\"\n",
    "        # Accept both (B,T,N) and (B,T,N,1)\n",
    "        if X_dyn.dim() == 3:\n",
    "            X_dyn = X_dyn.unsqueeze(-1)  # -> (B,T,N,1)\n",
    "        elif X_dyn.dim() != 4:\n",
    "            raise ValueError(f\"X_dyn must be 3D or 4D tensor; got shape {tuple(X_dyn.shape)}\")\n",
    "\n",
    "        B, T, N, dd = X_dyn.shape\n",
    "        if dd != self.dyn_dim:\n",
    "            raise ValueError(f\"dyn_dim mismatch: model expects {self.dyn_dim}, got {dd}\")\n",
    "\n",
    "        # expand gene to (B,T,N,G)\n",
    "        gene_expand = X_gene.unsqueeze(0).unsqueeze(0).expand(B, T, N, -1).to(device)  # (B,T,N,G)\n",
    "        X_full = torch.cat([X_dyn.to(device), gene_expand], dim=-1)  # (B,T,N,input_dim)\n",
    "\n",
    "        # Shared LSTM: flatten neurons into batch dimension (B*N, T, input_dim)\n",
    "        # Use permutation to get shape (B,N,T,input_dim) -> view(B*N, T, input_dim)\n",
    "        X_seq = X_full.permute(0,2,1,3).contiguous().view(B * N, T, self.input_dim)  # (B*N, T, input_dim)\n",
    "        lstm_out, _ = self.lstm(X_seq)  # (B*N, T, H)\n",
    "        lstm_last = lstm_out[:, -1, :]  # (B*N, H)\n",
    "        H = lstm_last.shape[-1]\n",
    "\n",
    "        # reshape to (B, N, H)\n",
    "        lstm_last_bn = lstm_last.view(B, N, H)\n",
    "\n",
    "        # neighbor aggregation on CPU via scipy.sparse (A_norm)\n",
    "        # loop over batch because A_norm dot is CPU numpy operation\n",
    "        gcn_out_list = []\n",
    "        for b in range(B):\n",
    "            node_feats_np = lstm_last_bn[b].detach().cpu().numpy()  # (N,H)\n",
    "            neigh_np = self.neighbor_aggregate_numpy(node_feats_np)  # (N,H)\n",
    "            gcn_out_list.append(torch.tensor(neigh_np, dtype=torch.float32, device=device))\n",
    "        gcn_out = torch.stack(gcn_out_list, dim=0)  # (B, N, H) on device\n",
    "\n",
    "        # fuse per-neuron hidden with neighbor context\n",
    "        fused = torch.cat([lstm_last_bn.to(device), gcn_out], dim=-1)  # (B, N, 2H)\n",
    "        fused_flat = fused.view(B * N, 2 * H)  # (B*N, 2H)\n",
    "        out_flat = self.fc(fused_flat).view(B, N)  # (B, N)\n",
    "        out_seq = out_flat.unsqueeze(1).expand(B, T, N)  # broadcast across time (B,T,N)\n",
    "\n",
    "        if return_raw:\n",
    "            # return also lstm_out reshaped to (B,T,N,H) for inspection if desired\n",
    "            lstm_out_bn = lstm_out.view(B, N, T, H).permute(0,2,1,3)  # (B,T,N,H)\n",
    "            return out_seq, lstm_out_bn\n",
    "\n",
    "        return out_seq\n",
    "\n",
    "# Sanity: simple constructor test if possible (delayed to Cell 5)\n"
   ]
  },
