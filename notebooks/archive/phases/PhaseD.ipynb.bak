   "source": [
    "# -----------------------\n",
    "# Fixed Cell B — Retrain ablation suite (true, zero, shuffled)\n",
    "# -----------------------\n",
    "import copy, random, statistics, time\n",
    "\n",
    "# Sanity: ensure required vars present\n",
    "_required = [\"X_win\", \"Y_win\", \"G_norm\", \"starts\", \"T_full\", \"common_neurons\"]\n",
    "for v in _required:\n",
    "    if v not in globals():\n",
    "        raise RuntimeError(f\"Missing required variable '{v}'. Run earlier cells to define it.\")\n",
    "\n",
    "# Ensure numpy arrays\n",
    "X_win_arr = np.asarray(X_win) if not isinstance(X_win, np.ndarray) else X_win\n",
    "Y_win_arr = np.asarray(Y_win) if not isinstance(Y_win, np.ndarray) else Y_win\n",
    "B_all, win_T, N = X_win_arr.shape\n",
    "assert win_T > 0 and N == len(common_neurons)\n",
    "print(\"Retrain inputs:\", \"B=\", B_all, \"win_T=\", win_T, \"N=\", N, \"T_full=\", T_full, \"num_starts=\", len(starts))\n",
    "\n",
    "# choose adjacency to use (pruned if available)\n",
    "A_use = A_pruned_norm if 'A_pruned_norm' in globals() else A_norm\n",
    "\n",
    "def train_model_with_gene_setting(X_win_np, Y_win_np, X_gene_arr, A_norm_local, starts_local, T_full_local, seed=0, epochs=40):\n",
    "    \"\"\"\n",
    "    Trains a fresh HybridGeneGraphLSTM on the provided X_win/Y_win with gene embeddings X_gene_arr.\n",
    "    Reconstructs full timeline using `starts_local` and window length inferred from X_win_np.\n",
    "    Returns (mse_full, trained_model).\n",
    "    \"\"\"\n",
    "    torch.manual_seed(seed); np.random.seed(seed); random.seed(seed)\n",
    "    # instantiate model fresh\n",
    "    dyn_dim = 1\n",
    "    gene_dim = X_gene_arr.shape[1]\n",
    "    model_local = HybridGeneGraphLSTM(dyn_dim=dyn_dim, gene_dim=gene_dim, lstm_hidden=64, lstm_layers=2)\n",
    "    model_local.set_adj(A_norm_local)\n",
    "    model_local.to(device)\n",
    "\n",
    "    # Prepare dataloaders (use same split scheme)\n",
    "    X_t = torch.tensor(X_win_np, dtype=torch.float32)\n",
    "    Y_t = torch.tensor(Y_win_np, dtype=torch.float32)\n",
    "    dataset = TensorDataset(X_t, Y_t)\n",
    "    train_len = int(0.8 * len(dataset))\n",
    "    val_len = len(dataset) - train_len\n",
    "    train_ds, val_ds = random_split(dataset, [train_len, val_len])\n",
    "    train_loader = DataLoader(train_ds, batch_size=4, shuffle=True)\n",
    "    val_loader = DataLoader(val_ds, batch_size=4)\n",
    "\n",
    "    opt = torch.optim.Adam(model_local.parameters(), lr=1e-3, weight_decay=1e-5)\n",
    "    crit = nn.MSELoss()\n",
    "    best_val = float(\"inf\"); wait=0; best_state=None\n",
    "    patience = 8\n",
    "\n",
    "    for epoch in range(1, epochs+1):\n",
    "        model_local.train()\n",
    "        train_loss = 0.0\n",
    "        for Xb, Yb in train_loader:\n",
    "            Xb = Xb.to(device); Yb = Yb.to(device)\n",
    "            opt.zero_grad()\n",
    "            preds = model_local(Xb, torch.tensor(X_gene_arr, dtype=torch.float32), device)\n",
    "            loss = crit(preds, Yb)\n",
    "            loss.backward()\n",
    "            opt.step()\n",
    "            train_loss += loss.item()\n",
    "        train_loss /= max(1, len(train_loader))\n",
    "\n",
    "        # val\n",
    "        model_local.eval()\n",
    "        val_loss = 0.0\n",
    "        with torch.no_grad():\n",
    "            for Xv, Yv in val_loader:\n",
    "                Xv = Xv.to(device); Yv = Yv.to(device)\n",
    "                pv = model_local(Xv, torch.tensor(X_gene_arr, dtype=torch.float32), device)\n",
    "                val_loss += crit(pv, Yv).item()\n",
    "        val_loss /= max(1, len(val_loader))\n",
    "\n",
    "        if val_loss < best_val - 1e-8:\n",
    "            best_val = val_loss\n",
    "            best_state = {k: v.cpu() for k, v in model_local.state_dict().items()}\n",
    "            wait = 0\n",
    "        else:\n",
    "            wait += 1\n",
    "            if wait >= patience:\n",
    "                # early stop\n",
    "                break\n",
    "\n",
    "    # restore best state\n",
    "    if best_state is not None:\n",
    "        model_local.load_state_dict(best_state)\n",
    "        model_local.to(device)\n",
    "\n",
    "    # inference across all windows (batch)\n",
    "    model_local.eval()\n",
    "    preds_list = []\n",
    "    with torch.no_grad():\n",
    "        # process in batches to reduce overhead\n",
    "        batch_size = 8\n",
    "        num_batches = int(np.ceil(X_win_np.shape[0] / batch_size))\n",
    "        for i in range(num_batches):\n",
    "            s = i * batch_size\n",
    "            e = min((i+1) * batch_size, X_win_np.shape[0])\n",
    "            Xb = torch.tensor(X_win_np[s:e], dtype=torch.float32).to(device)  # (b, win_T, N)\n",
    "            pb = model_local(Xb, torch.tensor(X_gene_arr, dtype=torch.float32), device).cpu().numpy()  # (b, win_T, N)\n",
    "            preds_list.append(pb)\n",
    "    preds_all = np.concatenate(preds_list, axis=0)   # (B, win_T, N)\n",
    "    assert preds_all.shape[0] == X_win_np.shape[0]\n",
    "\n",
    "    # Reconstruct into timeline using starts_local and win_T\n",
    "    recon = np.zeros((T_full_local, N), dtype=np.float32)\n",
    "    counts = np.zeros((T_full_local, N), dtype=np.float32)\n",
    "    for i_idx, s in enumerate(starts_local):\n",
    "        # safety check: ensure window fits (s + win_T <= T_full_local)\n",
    "        end = s + preds_all.shape[1]\n",
    "        if end > T_full_local:\n",
    "            # if last window overruns, truncate the preds segment to fit\n",
    "            take_len = max(0, T_full_local - s)\n",
    "            if take_len <= 0:\n",
    "                continue\n",
    "            recon[s: T_full_local, :] += preds_all[i_idx][:take_len, :]\n",
    "            counts[s: T_full_local, :] += 1.0\n",
    "        else:\n",
    "            recon[s:end, :] += preds_all[i_idx]\n",
    "            counts[s:end, :] += 1.0\n",
    "\n",
    "    counts[counts == 0] = 1.0\n",
    "    recon_full_local = recon / counts\n",
    "\n",
    "    # compute mse vs true (use Y_true_full defined earlier from pipeline)\n",
    "    mse_full = float(np.mean((recon_full_local - Y_true_full)**2))\n",
    "    return mse_full, model_local\n",
    "\n",
    "# Run retrain suite for a few seeds\n",
    "seeds = [0, 1, 2]\n",
    "results = {}\n",
    "\n",
    "# True genes\n",
    "mse_vals = []\n",
    "for s in seeds:\n",
    "    mse_s, model_s = train_model_with_gene_setting(X_win_arr, Y_win_arr, G_norm, A_use, starts, T_full, seed=s, epochs=40)\n",
    "    mse_vals.append(mse_s)\n",
    "results['true_gene_mean'] = float(np.mean(mse_vals)); results['true_gene_std'] = float(np.std(mse_vals))\n",
    "print(\"True genes mse:\", mse_vals)\n",
    "\n",
    "# Zero genes\n",
    "mse_vals = []\n",
    "for s in seeds:\n",
    "    mse_s, model_s = train_model_with_gene_setting(X_win_arr, Y_win_arr, np.zeros_like(G_norm), A_use, starts, T_full, seed=s, epochs=40)\n",
    "    mse_vals.append(mse_s)\n",
    "results['zero_gene_mean'] = float(np.mean(mse_vals)); results['zero_gene_std'] = float(np.std(mse_vals))\n",
    "print(\"Zero genes mse:\", mse_vals)\n",
    "\n",
    "# Shuffled genes (retrain)\n",
    "mse_vals = []\n",
    "for s in seeds:\n",
    "    perm = np.random.RandomState(s).permutation(len(common_neurons))\n",
    "    G_shuf = G_norm[perm]\n",
    "    mse_s, model_s = train_model_with_gene_setting(X_win_arr, Y_win_arr, G_shuf, A_use, starts, T_full, seed=s, epochs=40)\n",
    "    mse_vals.append(mse_s)\n",
    "results['shuf_gene_mean'] = float(np.mean(mse_vals)); results['shuf_gene_std'] = float(np.std(mse_vals))\n",
    "print(\"Shuffled genes mse:\", mse_vals)\n",
    "\n",
    "# Save summary\n",
    "pd.DataFrame([results]).to_csv(os.path.join(WORK_DIR, \"D3_retrain_ablation_summary_fixed.csv\"), index=False)\n",
    "print(\"Retrain ablation finished. Summary:\", results)\n"
   ]
  },
