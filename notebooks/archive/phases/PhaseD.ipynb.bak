      "Epoch 007 | train_loss=1.0141 | val_loss=0.9485\n",
      "Epoch 008 | train_loss=0.9952 | val_loss=0.9487\n",
      "Epoch 009 | train_loss=0.9878 | val_loss=0.9486\n",
      "Early stopping at epoch 9\n",
      "Restored best model with val_loss: 0.9480437636375427\n"
     ]
    }
   ],
   "source": [
    "# %% Cell 6 — Training loop with validation and early stopping\n",
    "# Purpose: train HybridGeneGraphLSTM; best model saved in memory (best_state)\n",
    "\n",
    "optimizer = torch.optim.Adam(model.parameters(), lr=1e-3, weight_decay=1e-5)\n",
    "criterion = nn.MSELoss()\n",
    "best_val = float(\"inf\")\n",
    "patience = 8\n",
    "wait = 0\n",
    "best_state = None\n",
    "\n",
    "num_epochs = 60   # modest default; increase as needed\n",
    "for epoch in range(1, num_epochs+1):\n",
    "    model.train()\n",
    "    train_loss = 0.0\n",
    "    for Xb, Yb in train_loader:\n",
    "        Xb = Xb.to(device)           # (b, T, N)\n",
    "        Yb = Yb.to(device)\n",
    "        optimizer.zero_grad()\n",
    "        preds = model(Xb, X_gene_t, device)  # model accepts (B,T,N) or (B,T,N,1)\n",
    "        loss = criterion(preds, Yb)\n",
    "        loss.backward()\n",
    "        optimizer.step()\n",
    "        train_loss += loss.item()\n",
    "    train_loss = train_loss / max(1, len(train_loader))\n",
    "\n",
    "    # validation\n",
    "    model.eval()\n",
    "    val_loss = 0.0\n",
    "    with torch.no_grad():\n",
    "        for Xv, Yv in val_loader:\n",
    "            Xv = Xv.to(device)\n",
    "            Yv = Yv.to(device)\n",
    "            pv = model(Xv, X_gene_t, device)\n",
    "            val_loss += criterion(pv, Yv).item()\n",
    "    val_loss = val_loss / max(1, len(val_loader))\n",
    "\n",
    "    print(f\"Epoch {epoch:03d} | train_loss={train_loss:.4f} | val_loss={val_loss:.4f}\")\n",
    "\n",
    "    if val_loss < best_val - 1e-6:\n",
    "        best_val = val_loss\n",
    "        best_state = {k: v.cpu() for k, v in model.state_dict().items()}\n",
    "        wait = 0\n",
    "    else:\n",
    "        wait += 1\n",
    "        if wait >= patience:\n",
    "            print(\"Early stopping at epoch\", epoch)\n",
    "            break\n",
    "\n",
    "# restore best model\n",
    "if best_state is not None:\n",
    "    model.load_state_dict(best_state)\n",
    "    model.to(device)\n",
    "    print(\"Restored best model with val_loss:\", best_val)\n"
   ]
  },
