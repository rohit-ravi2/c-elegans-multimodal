   "source": [
    "# %% [3.5 Metrics: Null Comparisons (Temporal, Identity/Attractor, Cycle Permutation)]\n",
    "# Purpose: Compare our predictions to NULL versions to show structure beyond chance.\n",
    "\n",
    "rng = np.random.default_rng(42)\n",
    "\n",
    "# --- Temporal null: shuffle true NPR10 across time (k repeats) and compare to our predictions\n",
    "def temporal_null_eval(Y_true_np, Y_pred_np, k=20):\n",
    "    cors, matches = [], []\n",
    "    for _ in range(k):\n",
    "        Y_true_shuf = temporal_shuffle(pd.DataFrame(Y_true_np.T)).T.values  # shuffle along time per neuron\n",
    "        pred_cycle = cycle_average(Y_pred_np, cycle_map_real)\n",
    "        true_cycle = cycle_average(Y_true_shuf, cycle_map_real)\n",
    "        cors.append(np.median(cycle_correlations(pred_cycle, true_cycle)))\n",
    "        matches.append(peak_match_rate(pred_cycle, true_cycle))\n",
    "    return np.array(cors), np.array(matches)\n",
    "\n",
    "# --- Identity/attractor null: permute neuron identities of true NPR10\n",
    "def identity_null_eval(Y_true_np, Y_pred_np, k=20):\n",
    "    cors, matches = [], []\n",
    "    for _ in range(k):\n",
    "        perm = rng.permutation(Y_true_np.shape[1])\n",
    "        Y_true_perm = Y_true_np[:, perm]\n",
    "        pred_cycle = cycle_average(Y_pred_np, cycle_map_real)\n",
    "        true_cycle = cycle_average(Y_true_perm, cycle_map_real)\n",
    "        cors.append(np.median(cycle_correlations(pred_cycle, true_cycle)))\n",
    "        matches.append(peak_match_rate(pred_cycle, true_cycle))\n",
    "    return np.array(cors), np.array(matches)\n",
    "\n",
    "# --- Cycle-permutation null: compute cycle averages with shuffled membership\n",
    "def cycle_perm_null_eval(Y_true_np, Y_pred_np, k=20):\n",
    "    cors, matches = [], []\n",
    "    for _ in range(k):\n",
    "        cnull = make_cycle_null(cycle_map_real, Y_true_np.shape[1])\n",
    "        pred_cycle = cycle_average(Y_pred_np, cnull)\n",
    "        true_cycle = cycle_average(Y_true_np,  cnull)\n",
    "        cors.append(np.median(cycle_correlations(pred_cycle, true_cycle)))\n",
    "        matches.append(peak_match_rate(pred_cycle, true_cycle))\n",
    "    return np.array(cors), np.array(matches)\n",
    "\n",
    "# Evaluate nulls\n",
    "temporal_c, temporal_m = temporal_null_eval(Y_np, Y_hat, k=25)\n",
    "identity_c, identity_m = identity_null_eval(Y_np, Y_hat, k=25)\n",
    "cycleperm_c, cycleperm_m = cycle_perm_null_eval(Y_np, Y_hat, k=25)\n",
    "\n",
    "# Real values for reference\n",
    "real_c   = float(np.median(cycle_correlations(cycle_average(Y_hat, cycle_map_real),\n",
    "                                              cycle_average(Y_np,  cycle_map_real))))\n",
    "real_m   = float(peak_match_rate(cycle_average(Y_hat, cycle_map_real),\n",
    "                                 cycle_average(Y_np,  cycle_map_real)))\n",
    "\n",
    "summary_nulls = pd.DataFrame({\n",
    "    \"metric\": [\"cycle_corr_median\", \"spectral_peak_match\"],\n",
    "    \"real\"  : [real_c, real_m],\n",
    "    \"temporal_null_mean\"  : [float(np.mean(temporal_c)), float(np.mean(temporal_m))],\n",
    "    \"identity_null_mean\"  : [float(np.mean(identity_c)), float(np.mean(identity_m))],\n",
    "    \"cycleperm_null_mean\" : [float(np.mean(cycleperm_c)), float(np.mean(cycleperm_m))],\n",
    "})\n",
    "summary_nulls.to_csv(os.path.join(WORK_DIR, \"D1_null_comparisons.csv\"), index=False)\n",
    "print(\"✅ Null comparisons written:\\n\", summary_nulls.round(3))\n",
    "\n",
    "# Simple barplot for spectral match comparison\n",
    "plt.figure(figsize=(6,4))\n",
    "labels = [\"Real\", \"Temporal\", \"Identity\", \"CyclePerm\"]\n",
    "vals   = [real_m, float(np.mean(temporal_m)), float(np.mean(identity_m)), float(np.mean(cycleperm_m))]\n",
    "plt.bar(labels, vals)\n",
    "plt.ylabel(\"Peak match rate\")\n",
    "plt.title(\"Spectral Agreement: Real vs. Nulls\")\n",
    "plt.tight_layout()\n",
    "plt.savefig(os.path.join(FIG_DIR, \"spectral_match_real_vs_nulls.png\"), dpi=150)\n",
    "plt.close()\n"
   ]
  },
