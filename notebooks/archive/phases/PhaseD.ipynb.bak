   "source": [
    "# %% [EVAL SHARED LSTM] Reconstruct full time-series, compute MSEs, compare baselines\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import os\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# preds is (B, T, N) from the shared LSTM cell\n",
    "assert 'preds' in globals(), \"Run the shared LSTM cell to produce `preds` (shape B,T,N).\"\n",
    "\n",
    "T_full = df_basal_z.shape[1]\n",
    "N = df_basal_z.shape[0]\n",
    "B = preds.shape[0]\n",
    "assert preds.shape == (B, window_size, N)\n",
    "\n",
    "# Reconstruct full sequence by averaging overlaps\n",
    "start_indices = list(range(0, T_full - window_size + 1, stride))\n",
    "assert len(start_indices) == B, f\"Window count mismatch: {len(start_indices)} vs {B}\"\n",
    "\n",
    "recon = np.zeros((T_full, N), dtype=np.float32)\n",
    "counts = np.zeros((T_full, N), dtype=np.float32)\n",
    "for b_idx, start in enumerate(start_indices):\n",
    "    end = start + window_size\n",
    "    recon[start:end, :] += preds[b_idx, :, :]\n",
    "    counts[start:end, :] += 1.0\n",
    "\n",
    "counts[counts == 0] = 1.0\n",
    "recon = recon / counts  # (T_full, N)\n",
    "\n",
    "Y_true_full = df_npr10_z.values.T  # (T_full, N)\n",
    "X_full_dyn  = df_basal_z.values.T  # (T_full, N)\n",
    "\n",
    "# MSEs\n",
    "mse_shared   = np.mean((recon - Y_true_full)**2)\n",
    "mse_identity = np.mean((X_full_dyn - Y_true_full)**2)\n",
    "\n",
    "# Ridge(dyn) baseline on full series (fast linear solve)\n",
    "W, *_ = np.linalg.lstsq(X_full_dyn, Y_true_full, rcond=None)  # (N,N)\n",
    "Y_ridge = X_full_dyn @ W\n",
    "mse_ridge = np.mean((Y_ridge - Y_true_full)**2)\n",
    "\n",
    "print(\"=== Shared LSTM Evaluation ===\")\n",
    "print(f\"Global MSE (shared):   {mse_shared:.3f}\")\n",
    "print(f\"Global MSE (identity): {mse_identity:.3f}\")\n",
    "print(f\"Global MSE (ridge):    {mse_ridge:.3f}\")\n",
    "\n",
    "# Per-neuron MSEs & delta vs identity\n",
    "mse_neuron_shared   = np.mean((recon - Y_true_full)**2, axis=0)\n",
    "mse_neuron_identity = np.mean((X_full_dyn - Y_true_full)**2, axis=0)\n",
    "mse_neuron_ridge    = np.mean((Y_ridge   - Y_true_full)**2, axis=0)\n",
    "\n",
    "df_mse = pd.DataFrame({\n",
    "    \"neuron\": df_basal_z.index,\n",
    "    \"mse_shared\": mse_neuron_shared,\n",
    "    \"mse_identity\": mse_neuron_identity,\n",
    "    \"mse_ridge\": mse_neuron_ridge,\n",
    "    \"delta_id_minus_shared\": mse_neuron_identity - mse_neuron_shared,\n",
    "    \"delta_ridge_minus_shared\": mse_neuron_ridge - mse_neuron_shared,\n",
    "})\n",
    "print(\"\\nTop 10 neurons improved vs identity:\")\n",
    "print(df_mse.sort_values(\"delta_id_minus_shared\", ascending=False).head(10))\n",
    "\n",
    "# Save\n",
    "df_mse.to_csv(os.path.join(WORK_DIR, \"D1_neuron_mse_shared.csv\"), index=False)\n",
    "\n",
    "# Quick visuals for a few representative neurons\n",
    "sample_idx = [0, N//5, 2*N//5, 3*N//5, 4*N//5]  # 5 neurons spread across index\n",
    "for ni in sample_idx:\n",
    "    plt.figure(figsize=(6,2))\n",
    "    plt.plot(Y_true_full[:, ni], label='True', linewidth=1.5)\n",
    "    plt.plot(recon[:, ni], label='Shared', linewidth=1.2)\n",
    "    plt.plot(X_full_dyn[:, ni], label='Basal', linewidth=1.0, alpha=0.6)\n",
    "    plt.title(f\"Neuron {df_basal_z.index[ni]} | mse_shared={mse_neuron_shared[ni]:.3f}\")\n",
    "    plt.legend(); plt.tight_layout(); plt.show()\n"
   ]
  },
