     ]
    }
   ],
   "source": [
    "# %% Cell 10 — Save artifacts & verdict summary\n",
    "# Purpose: persist recon, per-neuron MSE, and summary metrics to working/\n",
    "\n",
    "np.save(os.path.join(WORK_DIR, \"D3_recon_full.npy\"), recon_full)\n",
    "df_mse.to_csv(os.path.join(WORK_DIR, \"D3_neuron_mse_hybrid.csv\"), index=False)\n",
    "\n",
    "summary = {\n",
    "    \"mse_hybrid\": float(mse_hybrid),\n",
    "    \"mse_identity\": float(mse_identity),\n",
    "    \"mse_ridge\": float(mse_ridge),\n",
    "    \"mse_no_gene\": float(mse_no_gene),\n",
    "    \"mse_shuf\": float(mse_shuf),\n",
    "    \"flat_corr\": float(flat_corr)\n",
    "}\n",
    "pd.DataFrame([summary]).to_csv(os.path.join(WORK_DIR, \"D3_summary_metrics.csv\"), index=False)\n",
    "print(\"Saved artifacts to\", WORK_DIR)\n",
    "\n",
    "# Verdict (simple gates)\n",
    "mse_gain_ok = (mse_identity - mse_hybrid) / (mse_identity + 1e-12) > 0.15  # >15% improvement over identity\n",
    "gene_causal_ok = (mse_shuf - mse_hybrid) > 0.005\n",
    "verdict = {\n",
    "    \"mse_gain_over_identity\": bool(mse_gain_ok),\n",
    "    \"gene_causal_by_shuffle\": bool(gene_causal_ok)\n",
    "}\n",
    "print(\"VERDICT:\", verdict)\n"
   ]
  },
  {
