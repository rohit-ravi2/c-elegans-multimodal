    "# %% [0.0 Setup & Environment]\n",
    "# Purpose: Import libs, set paths, confirm files from Phase D exist. Safe to re-run.\n",
    "import os, json, math, random, itertools\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "import torch\n",
    "from torch import nn\n",
    "from torch.utils.data import TensorDataset, DataLoader\n",
    "from scipy.fft import rfft, rfftfreq\n",
    "\n",
    "BASE_DIR     = \"Projects/C-Elegans/PhaseD\"\n",
    "INPUT_DIR    = os.path.join(BASE_DIR, \"inputs\")\n",
    "WORK_DIR     = os.path.join(BASE_DIR, \"working\")\n",
    "ARTIFACT_DIR = os.path.join(BASE_DIR, \"artifacts\")\n",
    "FIG_DIR      = os.path.join(ARTIFACT_DIR, \"D1_figures\")\n",
    "os.makedirs(WORK_DIR, exist_ok=True)\n",
    "os.makedirs(ARTIFACT_DIR, exist_ok=True)\n",
    "os.makedirs(FIG_DIR, exist_ok=True)\n",
    "\n",
    "# Sanity: show important files\n",
    "print(\"CUDA available:\", torch.cuda.is_available())\n",
    "for path in [\n",
    "    os.path.join(WORK_DIR, \"D_time_series_basal.csv\"),\n",
    "    os.path.join(WORK_DIR, \"D_time_series_npr10.csv\"),\n",
    "    os.path.join(INPUT_DIR, \"phaseC\", \"C2_per_cycle_enrichment_npr10_labeled.csv\"),\n",
    "    os.path.join(INPUT_DIR, \"phaseB\", \"tuple_to_neurons.csv\"),\n",
    "    os.path.join(INPUT_DIR, \"metadata\", \"neuron_metadata.csv\"),\n",
    "]:\n",
    "    print((\"✅ \" if os.path.exists(path) else \"❌ \"), path)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "6d6ee6d9",
   "metadata": {},
   "outputs": [],
   "source": [
    "# %% [1.0 Load Phase D Outputs & Rebuild Cycle Map]\n",
    "# Purpose: Load fused time-series (Basal/NPR10), rebuild cycle→neuron mapping from inputs,\n",
    "# align to the 179-neuron index used in Phase D.\n",
    "\n",
    "# Load time-series (produced by Phase D)\n",
    "df_basal_ts = pd.read_csv(os.path.join(WORK_DIR, \"D_time_series_basal.csv\"), index_col=0)\n",
    "df_npr10_ts = pd.read_csv(os.path.join(WORK_DIR, \"D_time_series_npr10.csv\"), index_col=0)\n",
    "\n",
    "# Normalize neuron naming just in case\n",
    "df_basal_ts.index  = df_basal_ts.index.astype(str).str.upper()\n",
    "df_npr10_ts.index  = df_npr10_ts.index.astype(str).str.upper()\n",
    "\n",
    "# Rebuild cycle→neuron mapping for NPR10 condition\n",
    "df_enr_npr10 = pd.read_csv(os.path.join(INPUT_DIR, \"phaseC\", \"C2_per_cycle_enrichment_npr10_labeled.csv\"))\n",
    "df_t2n       = pd.read_csv(os.path.join(INPUT_DIR, \"phaseB\", \"tuple_to_neurons.csv\"))\n",
    "\n",
    "# Expand tuple_to_neurons into long form\n",
    "df_t2n_exp = df_t2n.assign(neuron=df_t2n[\"neurons\"].astype(str).str.split(\";\")).explode(\"neuron\")\n",
    "df_t2n_exp[\"neuron\"] = df_t2n_exp[\"neuron\"].str.strip().str.upper()\n",
    "\n",
    "# Join cycles to neuron list via cycle_id ↔ tuple_index\n",
    "if \"cycle_id\" not in df_enr_npr10.columns:\n",
    "    raise ValueError(\"cycle_id not found in enrichment file; expected in C2_per_cycle_enrichment_npr10_labeled.csv\")\n",
    "\n",
    "df_cycle_neurons_npr10 = df_enr_npr10.merge(\n",
    "    df_t2n_exp, left_on=\"cycle_id\", right_on=\"tuple_index\", how=\"left\"\n",
    ")\n",
    "\n",
    "# Keep only neurons present in our time-series index\n",
    "valid_neurons = set(df_basal_ts.index) & set(df_npr10_ts.index)\n",
    "df_cycle_neurons_npr10 = df_cycle_neurons_npr10[df_cycle_neurons_npr10[\"neuron\"].isin(valid_neurons)]\n",
    "\n",
    "# Build cycle→index map (indices in df_*_ts)\n",
    "neuron_to_idx = {n:i for i,n in enumerate(df_npr10_ts.index)}\n",
    "cycle_map_real = {}\n",
    "for cid, grp in df_cycle_neurons_npr10.groupby(\"cycle_id\"):\n",
    "    idxs = sorted({neuron_to_idx[n] for n in grp[\"neuron\"].tolist() if n in neuron_to_idx})\n",
    "    if idxs:\n",
    "        cycle_map_real[int(cid)] = idxs\n",
    "\n",
    "print(\"✅ Loaded time-series:\", df_basal_ts.shape, df_npr10_ts.shape)\n",
    "print(\"✅ Built cycle_map_real:\", len(cycle_map_real), \"cycles\")\n",
    "# Sanity: show example cycle content\n",
    "for k,v in list(cycle_map_real.items())[:3]:\n",
    "    print(\"  cycle\", k, \"→\", len(v), \"neurons (sample idx):\", v[:10])\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "0a610586",
   "metadata": {},
   "outputs": [],
   "source": [
    "# %% [2.0 Null Generator: Cycle Permutation (size-preserving)]\n",
    "# Purpose: Create a null cycle map by shuffling neuron assignments while preserving cycle sizes.\n",
    "# This tests whether our results depend on the specific motif membership.\n",
    "\n",
    "def make_cycle_null(cycle_map, n_neurons):\n",
    "    # preserve cycle sizes; sample without replacement per cycle from full index set\n",
    "    all_indices = list(range(n_neurons))\n",
    "    rng = np.random.default_rng()\n",
    "    null_map = {}\n",
    "    for cid, idxs in cycle_map.items():\n",
    "        k = len(idxs)\n",
    "        null_map[cid] = sorted(rng.choice(all_indices, size=k, replace=False).tolist())\n",
    "    return null_map\n",
    "\n",
    "cycle_map_null = make_cycle_null(cycle_map_real, n_neurons=df_npr10_ts.shape[0])\n",
    "\n",
    "# Sanity: compare size distributions\n",
    "real_sizes = sorted(len(v) for v in cycle_map_real.values())\n",
    "null_sizes = sorted(len(v) for v in cycle_map_null.values())\n",
    "print(\"✅ Cycle-permutation null built.\")\n",
    "print(\"  size match:\", (real_sizes == null_sizes))\n",
    "print(\"  cycles:\", len(real_sizes), \"| size range:\", (min(real_sizes), max(real_sizes)))\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "e28830a3",
   "metadata": {},
   "outputs": [],
   "source": [
    "# %% [2.1 Null Generator: Temporal Shuffle]\n",
    "# Purpose: Randomly circularly shift each neuron's series (breaks temporal alignment, preserves distribution).\n",
    "def temporal_shuffle(df_ts, rng=None):\n",
    "    rng = rng or np.random.default_rng()\n",
    "    arr = df_ts.values.copy()\n",
    "    T = arr.shape[1]\n",
    "    for i in range(arr.shape[0]):\n",
    "        k = int(rng.integers(0, T))\n",
    "        arr[i] = np.roll(arr[i], k)\n",
    "    return pd.DataFrame(arr, index=df_ts.index, columns=df_ts.columns)\n",
    "\n",
    "df_npr10_ts_temporal_null = temporal_shuffle(df_npr10_ts)\n",
    "df_basal_ts_temporal_null = temporal_shuffle(df_basal_ts)\n",
    "\n",
    "# Sanity: distribution preserved, correlation reduced\n",
    "orig_std  = float(df_npr10_ts.stack().std())\n",
    "null_std  = float(df_npr10_ts_temporal_null.stack().std())\n",
    "naive_corr = np.corrcoef(df_npr10_ts.values.flatten(), df_npr10_ts_temporal_null.values.flatten())[0,1]\n",
    "print(\"✅ Temporal null created. std true/null:\", round(orig_std,4), round(null_std,4), \"| flat corr:\", round(naive_corr,3))\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "fed54f1a",
   "metadata": {},
   "outputs": [],
   "source": [
    "# %% [2.2 Null Generator: Attractor/Identity Shuffle]\n",
    "# Purpose: Break neuron identity mapping by permuting row identities (preserves row-wise dynamics).\n",
    "def identity_shuffle_rows(df_ts, rng=None):\n",
    "    rng = rng or np.random.default_rng()\n",
    "    perm = rng.permutation(df_ts.index)\n",
    "    return df_ts.loc[perm].reset_index(drop=True), list(perm)\n",
    "\n",
    "df_basal_ts_attr_null, perm_basal = identity_shuffle_rows(df_basal_ts)\n",
    "df_npr10_ts_attr_null, perm_npr10 = identity_shuffle_rows(df_npr10_ts)\n",
    "\n",
    "# Sanity: same values, different row order\n",
    "print(\"✅ Identity/attractor null created. Same shapes:\", df_basal_ts_attr_null.shape, df_npr10_ts_attr_null.shape)\n",
    "print(\"  First 5 permuted indices (basal):\", perm_basal[:5])\n"
   ]
  },
