    "# %% [1.1 Verify Input Directory Structure]\n",
    "# Function: Print structure of inputs to ensure files are in correct subfolders.\n",
    "\n",
    "for root, dirs, files in os.walk(INPUT_DIR):\n",
    "    level = root.replace(INPUT_DIR, '').count(os.sep)\n",
    "    indent = ' ' * 4 * level\n",
    "    print(f\"{indent}{os.path.basename(root)}/\")\n",
    "    subindent = ' ' * 4 * (level + 1)\n",
    "    for f in files:\n",
    "        print(f\"{subindent}{f}\")\n",
    "\n",
    "# Sanity check: Confirm attractor and cycle files are present\n",
    "expected_files = [\n",
    "    \"A_CA_attractors.csv\",\n",
    "    \"C2_per_cycle_enrichment_basal_labeled.csv\",\n",
    "    \"C2_per_cycle_enrichment_npr10_labeled.csv\"\n",
    "]\n",
    "for f in expected_files:\n",
    "    found = any(f in files for _, _, files in os.walk(INPUT_DIR))\n",
    "    print(f\"Check {f}: {'✅ Found' if found else '❌ Missing'}\")\n"
