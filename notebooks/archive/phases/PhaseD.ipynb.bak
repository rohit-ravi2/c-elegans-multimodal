   "source": [
    "# %% [EVAL CURRENT MODEL]\n",
    "# Evaluate the currently-instantiated/trained model and compare with identity/ridge baselines.\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import os\n",
    "import matplotlib.pyplot as plt\n",
    "from sklearn.linear_model import Ridge\n",
    "\n",
    "device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
    "model.eval()\n",
    "\n",
    "# Predict on full windowed dataset\n",
    "with torch.no_grad():\n",
    "    Y_pred = model(X_flat.to(device)).cpu().numpy()   # shape (B, T, N)\n",
    "\n",
    "# Reconstruct full time-series prediction by averaging overlapping windows (simple approach)\n",
    "# We'll average predictions for each time-step across windows that include that time index.\n",
    "T_full = df_basal_z.shape[1]\n",
    "N = df_basal_z.shape[0]\n",
    "counts = np.zeros((T_full, N))\n",
    "recon = np.zeros((T_full, N))\n",
    "\n",
    "# Map windows back to time indices (same method as construction)\n",
    "start_indices = list(range(0, T_full - window_size + 1, stride))\n",
    "for b_idx, start in enumerate(start_indices):\n",
    "    end = start + window_size\n",
    "    recon[start:end, :] += Y_pred[b_idx, :, :]\n",
    "    counts[start:end, :] += 1.0\n",
    "# Avoid division by zero\n",
    "counts[counts == 0] = 1.0\n",
    "recon = recon / counts  # shape (T_full, N)\n",
    "\n",
    "# True full: Y_np (we had earlier) is shape (T,N). If not present, rebuild:\n",
    "Y_true_full = df_npr10_z.values.T  # shape (T,N) -- careful: earlier we used T x N\n",
    "# Ensure shapes align (T_full, N)\n",
    "print(\"recon shape:\", recon.shape, \"Y_true shape:\", Y_true_full.shape)\n",
    "\n",
    "# Compute MSE globally and per-neuron\n",
    "mse_global = np.mean((recon - Y_true_full)**2)\n",
    "mse_per_neuron = np.mean((recon - Y_true_full)**2, axis=0)  # length N\n",
    "\n",
    "# Baselines (identity: predict = basal)\n",
    "X_full_dyn = df_basal_z.values.T  # (T,N)\n",
    "mse_identity = np.mean((X_full_dyn - Y_true_full)**2)\n",
    "\n",
    "# Ridge dyn-only baseline (time-agnostic mapping per timepoint)\n",
    "from sklearn.linear_model import Ridge\n",
    "X_dyn_flat = X_full_dyn  # T x N (predictors)\n",
    "Y_flat = Y_true_full     # T x N (targets)\n",
    "# Fit ridge separately for each target neuron using same features (this is heavy); instead use linear solve approx:\n",
    "W = np.linalg.lstsq(X_dyn_flat, Y_flat, rcond=None)[0]  # F->N where F=N here\n",
    "Y_ridge = X_dyn_flat @ W\n",
    "mse_ridge = np.mean((Y_ridge - Y_true_full)**2)\n",
    "\n",
    "# Save and print summary\n",
    "summary = {\n",
    "    \"mse_global_model\": float(mse_global),\n",
    "    \"mse_identity\": float(mse_identity),\n",
    "    \"mse_ridge_dyn\": float(mse_ridge)\n",
    "}\n",
    "print(\"Evaluation summary:\", summary)\n",
    "\n",
    "# Per-neuron MSE DataFrame (top 10 worst)\n",
    "df_neuron_mse = pd.DataFrame({\n",
    "    \"neuron\": df_basal_z.index,\n",
    "    \"mse_model\": mse_per_neuron,\n",
    "    \"mse_identity\": np.mean((X_full_dyn - Y_true_full)**2, axis=0),\n",
    "})\n",
    "df_neuron_mse[\"delta_identity_minus_model\"] = df_neuron_mse[\"mse_identity\"] - df_neuron_mse[\"mse_model\"]\n",
    "print(df_neuron_mse.sort_values(\"delta_identity_minus_model\", ascending=False).head(10))\n",
    "\n",
    "# Save\n",
    "pd.DataFrame([summary]).to_csv(os.path.join(WORK_DIR, \"D1_eval_summary_current_model.csv\"), index=False)\n",
    "df_neuron_mse.to_csv(os.path.join(WORK_DIR, \"D1_neuron_mse_current_model.csv\"), index=False)\n",
    "\n",
    "# Quick plot for 5 example neurons\n",
    "sample_neurons = list(range(0, N, max(1, N//5)))[:5]\n",
    "import matplotlib.pyplot as plt\n",
    "for ni in sample_neurons:\n",
    "    plt.figure(figsize=(6,2))\n",
    "    plt.plot(Y_true_full[:, ni], label='True')\n",
    "    plt.plot(recon[:, ni], label='Model')\n",
    "    plt.plot(X_full_dyn[:, ni], label='Basal', alpha=0.5)\n",
    "    plt.title(f\"Neuron {df_basal_z.index[ni]} | mse_model={mse_per_neuron[ni]:.3f}\")\n",
    "    plt.legend()\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n"
   ]
  },
