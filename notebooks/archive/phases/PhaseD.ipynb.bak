   "source": [
    "# %% [2.3 Expand Phase C Cycles to Neurons]\n",
    "# Function: Map cycle enrichment results to actual neuron IDs using tuple mappings.\n",
    "\n",
    "# Load tuple-to-neuron mapping\n",
    "df_t2n = pd.read_csv(os.path.join(INPUT_DIR, \"phaseB\", \"tuple_to_neurons.csv\"))\n",
    "\n",
    "# Split semicolon-separated neuron lists\n",
    "df_t2n_expanded = df_t2n.assign(\n",
    "    neuron=df_t2n[\"neurons\"].str.split(\";\")\n",
    ").explode(\"neuron\")\n",
    "df_t2n_expanded[\"neuron\"] = df_t2n_expanded[\"neuron\"].str.strip().str.upper()\n",
    "\n",
    "print(\"✅ Tuple-to-neuron mapping expanded:\", df_t2n_expanded.shape)\n",
    "print(df_t2n_expanded.head())\n",
    "\n",
    "# Join cycles with tuple mapping\n",
    "# Step 1: ensure cycle_id is present in enrichment files\n",
    "print(\"Columns in cycle enrichment basal:\", df_cycles_basal.columns.tolist())\n",
    "\n",
    "if \"cycle_id\" in df_cycles_basal.columns:\n",
    "    # Join cycle enrichment → tuple mapping\n",
    "    df_cycle_neurons_basal = df_cycles_basal.merge(\n",
    "        df_t2n_expanded, left_on=\"cycle_id\", right_on=\"tuple_index\", how=\"left\"\n",
    "    )\n",
    "    df_cycle_neurons_npr10 = df_cycles_npr10.merge(\n",
    "        df_t2n_expanded, left_on=\"cycle_id\", right_on=\"tuple_index\", how=\"left\"\n",
    "    )\n",
    "    print(\"✅ Cycles expanded to neurons:\")\n",
    "    print(df_cycle_neurons_basal[[\"cycle_id\", \"neuron\"]].dropna().head(20))\n",
    "else:\n",
    "    print(\"⚠️ cycle_id missing in enrichment files — need to check tuple_index mapping.\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "3a373e75",
   "metadata": {},
   "outputs": [],
   "source": [
    "# %% [2.4 Align Attractors, Cycles, and Metadata by Neuron]\n",
    "# Function: Normalize IDs and compute overlaps now that cycles have real neurons.\n",
    "\n",
    "# Normalize neuron names\n",
    "df_attractors[\"neuron_norm\"] = df_attractors[\"neuron\"].str.upper()\n",
    "df_meta[\"neuron_norm\"] = df_meta[\"Neuron\"].str.upper()\n",
    "\n",
    "df_cycle_neurons_basal[\"neuron_norm\"] = df_cycle_neurons_basal[\"neuron\"].str.upper()\n",
    "df_cycle_neurons_npr10[\"neuron_norm\"] = df_cycle_neurons_npr10[\"neuron\"].str.upper()\n",
    "\n",
    "# Unique sets\n",
    "neurons_A = set(df_attractors[\"neuron_norm\"])\n",
    "neurons_C = set(df_cycle_neurons_basal[\"neuron_norm\"]) | set(df_cycle_neurons_npr10[\"neuron_norm\"])\n",
    "neurons_M = set(df_meta[\"neuron_norm\"])\n",
    "\n",
    "common = neurons_A & neurons_C & neurons_M\n",
    "\n",
    "print(\"✅ Normalized & expanded neurons:\")\n",
    "print(f\"- Phase A attractors: {len(neurons_A)} unique\")\n",
    "print(f\"- Phase C cycles: {len(neurons_C)} unique\")\n",
    "print(f\"- Metadata: {len(neurons_M)} unique\")\n",
    "print(f\"🔗 Common neurons across all: {len(common)}\")\n",
    "print(\"Example common neurons:\", list(common)[:20])\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "6d8d4e7e",
   "metadata": {},
   "outputs": [],
   "source": [
    "# %% [3.0 Build Temporal Dynamics Matrix with Real Cycle Neurons, Deduplicated]\n",
    "# Function: Collapse duplicate attractor rows, then fuse with cycles into time-series traces.\n",
    "\n",
    "timesteps = 100\n",
    "neurons = sorted(list(common))  # restrict strictly to the common set\n",
    "time_index = np.arange(timesteps)\n",
    "\n",
    "# Collapse duplicates: average basal/npr10 across repeats\n",
    "df_attractors_unique = (\n",
    "    df_attractors.groupby(\"neuron_norm\")[[\"basal\", \"npr10\"]]\n",
    "    .mean()\n",
    "    .reset_index()\n",
    ")\n",
    "\n",
    "# Build baseline matrices\n",
    "basal_baseline = df_attractors_unique.set_index(\"neuron_norm\").reindex(neurons)[\"basal\"].fillna(0).values\n",
    "ts_basal = np.tile(basal_baseline[:, None], (1, timesteps))\n",
    "\n",
    "npr10_baseline = df_attractors_unique.set_index(\"neuron_norm\").reindex(neurons)[\"npr10\"].fillna(0).values\n",
    "ts_npr10 = np.tile(npr10_baseline[:, None], (1, timesteps))\n",
    "\n",
    "# Filter cycles to only common neurons\n",
    "df_cycle_neurons_basal_filtered = df_cycle_neurons_basal[df_cycle_neurons_basal[\"neuron_norm\"].isin(neurons)]\n",
    "df_cycle_neurons_npr10_filtered = df_cycle_neurons_npr10[df_cycle_neurons_npr10[\"neuron_norm\"].isin(neurons)]\n",
    "\n",
    "# Inject cycles as oscillatory contributions\n",
    "for _, row in df_cycle_neurons_basal_filtered.iterrows():\n",
    "    n = row[\"neuron_norm\"]\n",
    "    idx = neurons.index(n)\n",
    "    ts_basal[idx, :] += 0.1 * np.sin(2 * np.pi * time_index / 20)\n",
    "\n",
    "for _, row in df_cycle_neurons_npr10_filtered.iterrows():\n",
    "    n = row[\"neuron_norm\"]\n",
    "    idx = neurons.index(n)\n",
    "    ts_npr10[idx, :] += 0.1 * np.sin(2 * np.pi * time_index / 18)\n",
    "\n",
    "# Save to working/\n",
    "df_basal_ts = pd.DataFrame(ts_basal, index=neurons, columns=time_index)\n",
    "df_npr10_ts = pd.DataFrame(ts_npr10, index=neurons, columns=time_index)\n",
    "df_basal_ts.to_csv(os.path.join(WORK_DIR, \"D_time_series_basal.csv\"))\n",
    "df_npr10_ts.to_csv(os.path.join(WORK_DIR, \"D_time_series_npr10.csv\"))\n",
    "\n",
    "print(\"✅ Time-series built with deduplicated attractors + real cycle neurons\")\n",
    "print(\"Basal shape:\", df_basal_ts.shape, \"| NPR10 shape:\", df_npr10_ts.shape)\n",
    "print(\"Example neurons:\", neurons[:10])\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "9e61c613",
   "metadata": {},
   "outputs": [],
   "source": [
    "# %% [3.1 Visualize Sample Neurons from Common Set]\n",
    "# Function: Plot time traces for a random subset of neurons (basal vs npr10).\n",
    "\n",
    "sample_neurons = np.random.choice(df_basal_ts.index, 5, replace=False)\n",
    "\n",
    "plt.figure(figsize=(12, 6))\n",
    "for n in sample_neurons:\n",
    "    plt.plot(df_basal_ts.columns, df_basal_ts.loc[n], label=f\"{n}-Basal\", alpha=0.8)\n",
    "    plt.plot(df_npr10_ts.columns, df_npr10_ts.loc[n], \"--\", label=f\"{n}-NPR10\", alpha=0.8)\n",
