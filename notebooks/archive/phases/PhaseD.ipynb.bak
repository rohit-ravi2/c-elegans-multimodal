   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Loaded tuple_to_neurons: (418, 2)\n",
      "Expanded pairs (filtered to common): (26749, 2)\n",
      "Raw unique edges count: (31354, 2)\n",
      "Valid remapped edges: (31354, 2)\n",
      "Adjacency CSR shape: (179, 179) nnz: 32040\n",
      "A_norm nnz: 32040\n"
     ]
    }
   ],
   "source": [
    "# %% Cell 2 — Build graph adjacency (tuple_to_neurons) and normalize into sparse matrix\n",
    "# Purpose: build adjacency among the restricted 'common_neurons' and produce a normalized neighbor-mean operator (CSR)\n",
    "\n",
    "tuple_csv = os.path.join(INPUT_DIR, \"phaseB\", \"tuple_to_neurons.csv\")\n",
    "df_tuples = pd.read_csv(tuple_csv)\n",
    "print(\"Loaded tuple_to_neurons:\", df_tuples.shape)\n",
    "\n",
    "# expand tuples -> list of (tuple, neuron)\n",
    "pairs = []\n",
    "for _, r in df_tuples.iterrows():\n",
    "    neurons = [n.strip().upper() for n in str(r['neurons']).split(';') if isinstance(r['neurons'], str)]\n",
    "    # keep only overlapping neurons (case as our dynamics are in original case)\n",
    "    for n in neurons:\n",
    "        if n in common_neurons:\n",
    "            pairs.append((r['tuple_index'], n))\n",
    "df_pairs = pd.DataFrame(pairs, columns=[\"tuple\",\"neuron\"])\n",
    "print(\"Expanded pairs (filtered to common):\", df_pairs.shape)\n",
    "\n",
    "# build co-membership edges\n",
    "edges_set = set()\n",
    "grouped = df_pairs.groupby(\"tuple\")[\"neuron\"].apply(list)\n",
    "for ns in grouped:\n",
    "    L = len(ns)\n",
    "    for i in range(L):\n",
    "        for j in range(i+1,L):\n",
    "            edges_set.add((ns[i], ns[j]))\n",
    "edges = np.array(list(edges_set))\n",
    "print(\"Raw unique edges count:\", edges.shape)\n",
    "\n",
    "# remap to indices 0..N-1 in the same order as common_neurons\n",
    "neuron_to_idx = {n:i for i,n in enumerate(common_neurons)}\n",
    "valid_edges = []\n",
    "for a,b in edges:\n",
    "    if a in neuron_to_idx and b in neuron_to_idx:\n",
    "        valid_edges.append((neuron_to_idx[a], neuron_to_idx[b]))\n",
    "valid_edges = np.array(valid_edges, dtype=np.int64)\n",
    "print(\"Valid remapped edges:\", valid_edges.shape)\n",
    "\n",
    "# Build symmetric adjacency (undirected)\n",
    "rows = np.concatenate([valid_edges[:,0], valid_edges[:,1]])\n",
    "cols = np.concatenate([valid_edges[:,1], valid_edges[:,0]])\n",
    "data = np.ones(len(rows), dtype=np.float32)\n",
    "A = sp.coo_matrix((data, (rows, cols)), shape=(len(common_neurons), len(common_neurons))).tocsr()\n",
    "print(\"Adjacency CSR shape:\", A.shape, \"nnz:\", A.nnz)\n",
    "\n",
    "# Normalize adjacency to neighbor-average: A_norm = D^{-1} A\n",
    "deg = np.array(A.sum(axis=1)).flatten()\n",
    "deg[deg==0] = 1.0\n",
    "invdeg = 1.0 / deg\n",
    "Dinv = sp.diags(invdeg)\n",
    "A_norm = Dinv.dot(A)  # row-normalized: each row sums to 1 or 0\n",
    "print(\"A_norm nnz:\", A_norm.nnz)\n"
   ]
  },
  {
   "cell_type": "code",
