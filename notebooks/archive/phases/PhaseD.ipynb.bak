   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Ablation/shuffle MSEs -> hybrid: 0.9879, no_gene: 0.9857, gene_shuf: 0.9879\n"
     ]
    }
   ],
   "source": [
    "# %% Cell 8 — Quick ablation & shuffled-gene checks (inference-only)\n",
    "# Purpose: evaluate effect of genes without costly retrain: (a) zero genes, (b) shuffled genes.\n",
    "# Note: more rigorous test retrains models under the ablation; this is a quick first-pass.\n",
    "\n",
    "# (A) No-gene inference: pass zero gene embeddings\n",
    "X_gene_zero = torch.zeros_like(X_gene_t)\n",
    "preds_no_gene = []\n",
    "with torch.no_grad():\n",
    "    for i in range(len(X_win_t)):\n",
    "        Xb = X_win_t[i:i+1].to(device)\n",
    "        p = model(Xb, X_gene_zero, device).cpu().numpy()[0]\n",
    "        preds_no_gene.append(p)\n",
    "preds_no_gene = np.stack(preds_no_gene)  # (B,T,N)\n",
    "# stitch\n",
    "recon_ng = np.zeros((T_full,N), dtype=np.float32); counts=np.zeros((T_full,N),dtype=np.float32)\n",
    "for i,s in enumerate(starts):\n",
    "    recon_ng[s:s+T,:] += preds_no_gene[i]; counts[s:s+T,:] += 1.0\n",
    "recon_ng /= np.where(counts==0,1,counts)\n",
    "mse_no_gene = np.mean((recon_ng - Y_true_full)**2)\n",
    "\n",
    "# (B) Shuffled gene PCs (permute neurons)\n",
    "perm = np.random.permutation(N)\n",
    "X_gene_shuf = X_gene_t[perm].clone()\n",
    "preds_shuf = []\n",
    "with torch.no_grad():\n",
    "    for i in range(len(X_win_t)):\n",
    "        Xb = X_win_t[i:i+1].to(device)\n",
    "        p = model(Xb, X_gene_shuf, device).cpu().numpy()[0]\n",
    "        preds_shuf.append(p)\n",
    "preds_shuf = np.stack(preds_shuf)\n",
    "recon_shuf = np.zeros((T_full,N), dtype=np.float32); counts=np.zeros((T_full,N),dtype=np.float32)\n",
    "for i,s in enumerate(starts):\n",
    "    recon_shuf[s:s+T,:] += preds_shuf[i]; counts[s:s+T,:] += 1.0\n",
    "recon_shuf /= np.where(counts==0,1,counts)\n",
    "mse_shuf = np.mean((recon_shuf - Y_true_full)**2)\n",
    "\n",
    "print(f\"Ablation/shuffle MSEs -> hybrid: {mse_hybrid:.4f}, no_gene: {mse_no_gene:.4f}, gene_shuf: {mse_shuf:.4f}\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 47,
   "id": "4db26b0c",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Flattened recon vs true corr: 0.122\n",
      "Forward duty (hybrid recon): 0.5\n",
      "Forward duty (true):       0.5\n",
      "Backward duty (hybrid): 0.4\n",
      "Backward duty (true):   0.48\n"
     ]
    }
   ],
   "source": [
    "# %% Cell 9 — Cycle-level summary + simple behavioral proxies (quick)\n",
    "# Purpose: compute flattened recon vs true correlation and sample motor duty proxies.\n",
    "# Note: real cycle mapping code (per-cycle neuron lists) can be plugged in for richer metrics.\n",
    "\n",
    "# Flattened correlation\n",
    "flat_corr = np.corrcoef(recon_full.flatten(), Y_true_full.flatten())[0,1]\n",
    "print(\"Flattened recon vs true corr:\", round(flat_corr, 3))\n",
    "\n",
    "# Simple motor proxies (heuristic lists; replace with your curated lists)\n",
    "forward_neurons = [n for n in common_neurons if n.startswith(\"AVB\") or n.startswith(\"SMB\")]  # example\n",
    "backward_neurons = [n for n in common_neurons if n.startswith(\"AVA\") or n.startswith(\"AIM\")]\n",
    "\n",
    "def duty_fraction(traces, neuron_list):\n",
    "    idxs = [common_neurons.index(n) for n in neuron_list if n in common_neurons]\n",
    "    if len(idxs) == 0:\n",
    "        return np.nan\n",
    "    return (traces[:, idxs] > np.median(traces[:, idxs])).mean()\n",
    "\n",
    "print(\"Forward duty (hybrid recon):\", duty_fraction(recon_full, forward_neurons))\n",
    "print(\"Forward duty (true):      \", duty_fraction(Y_true_full, forward_neurons))\n",
    "print(\"Backward duty (hybrid):\", duty_fraction(recon_full, backward_neurons))\n",
    "print(\"Backward duty (true):  \", duty_fraction(Y_true_full, backward_neurons))\n"
   ]
  },
  {
   "cell_type": "code",
