   "source": [
    "# %% [ALTERNATIVE MODEL] Per-neuron shared LSTM with gene conditioning\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "from torch.utils.data import DataLoader, TensorDataset\n",
    "\n",
    "# Prepare per-neuron sequences: we want shape (B*N, T, per_input_dim)\n",
    "# For each window b, we have X_win[b] shape (T,N)\n",
    "# Per-neuron input: dynamic scalar per time + gene embedding static -> vector per time [1 + G]\n",
    "B, T, N = X_win.shape\n",
    "G = df_gene_embed.shape[1]\n",
    "\n",
    "# Build dataset of shape (B*N, T, 1+G) and targets (B*N, T)\n",
    "X_neuron_list = []\n",
    "Y_neuron_list = []\n",
    "gene_np = df_gene_embed.values  # (N, G)\n",
    "for b in range(B):\n",
    "    dyn_bt = X_win[b]  # (T,N)\n",
    "    true_bt = Y_win[b] # (T,N)\n",
    "    for ni in range(N):\n",
    "        dyn_seq = dyn_bt[:, ni][:, None]         # (T,1)\n",
    "        gene_vec = np.tile(gene_np[ni][None, :], (T,1))  # (T,G)\n",
    "        inp = np.concatenate([dyn_seq, gene_vec], axis=1)  # (T, 1+G)\n",
    "        X_neuron_list.append(inp)\n",
    "        Y_neuron_list.append(true_bt[:, ni])  # (T,)\n",
    "\n",
    "X_neuron = np.stack(X_neuron_list)  # (B*N, T, 1+G)\n",
    "Y_neuron = np.stack(Y_neuron_list)  # (B*N, T)\n",
    "\n",
    "# Convert to tensors\n",
    "Xn = torch.tensor(X_neuron, dtype=torch.float32, device=device)\n",
    "Yn = torch.tensor(Y_neuron, dtype=torch.float32, device=device)\n",
    "\n",
    "print(\"Per-neuron dataset shape (samples, T, features):\", Xn.shape, \"targets:\", Yn.shape)\n",
    "\n",
    "# Define shared LSTM model\n",
    "class SharedNeuronLSTM(nn.Module):\n",
    "    def __init__(self, inp_dim, hidden_dim=64, num_layers=1, dropout=0.1):\n",
    "        super().__init__()\n",
    "        self.lstm = nn.LSTM(inp_dim, hidden_dim, num_layers=num_layers, batch_first=True)\n",
    "        self.fc = nn.Linear(hidden_dim, 1)\n",
    "    def forward(self, x):  # x: (batch, T, inp_dim)\n",
    "        out, _ = self.lstm(x)\n",
    "        out = self.fc(out).squeeze(-1)  # (batch, T)\n",
    "        return out\n",
    "\n",
    "# Instantiate and inspect param count\n",
    "inp_dim = 1 + G\n",
    "shared_model = SharedNeuronLSTM(inp_dim, hidden_dim=64).to(device)\n",
    "params = sum(p.numel() for p in shared_model.parameters())\n",
    "print(\"SharedNeuronLSTM params:\", params)  # expect << 10M\n",
    "\n",
    "# Train quickly\n",
    "ds = TensorDataset(Xn, Yn)\n",
    "loader = DataLoader(ds, batch_size=64, shuffle=True)\n",
    "optim = torch.optim.Adam(shared_model.parameters(), lr=3e-4, weight_decay=1e-5)\n",
    "crit = nn.MSELoss()\n",
    "epochs = 80\n",
    "for ep in range(1, epochs+1):\n",
    "    shared_model.train()\n",
    "    losses=[]\n",
    "    for xb, yb in loader:\n",
    "        optim.zero_grad()\n",
    "        pred = shared_model(xb)\n",
    "        loss = crit(pred, yb)\n",
    "        loss.backward()\n",
    "        optim.step()\n",
    "        losses.append(loss.item())\n",
    "    if ep % 10 == 0 or ep == 1:\n",
    "        print(f\"Epoch {ep}/{epochs} avg_loss={np.mean(losses):.4f}\")\n",
    "\n",
    "# Evaluate: reshape predictions back to (B,T,N)\n",
    "shared_model.eval()\n",
    "with torch.no_grad():\n",
    "    preds = []\n",
    "    for xb, _ in loader:\n",
    "        preds.append(shared_model(xb).cpu().numpy())\n",
    "preds = np.concatenate(preds, axis=0)  # (B*N, T)\n",
    "preds = preds.reshape(B, N, T).transpose(0,2,1)  # (B, T, N)  -- same layout as Y_win\n",
    "print(\"Shared model prediction shape:\", preds.shape)\n",
    "\n",
    "# Compute reconstruction to full T by same averaging as before\n",
    "# ... (use same averaging code as in CELL A) to reconstruct recon_shared shape (T,N)\n",
    "# Compute global mse\n",
    "# (omitted for brevity; you can reuse the recon averaging and MSE code in CELL A)\n"
   ]
  },
