   "source": [
    "# %% Cell 1 — Load dynamics and build / save CeNGEN PCA embeddings\n",
    "# Purpose: load D_time_series_basal/npr10 and raw CeNGEN, dedupe, PCA -> save embeddings\n",
    "\n",
    "# ---- Load dynamics (already generated by prior PhaseD steps) ----\n",
    "df_basal = pd.read_csv(os.path.join(WORK_DIR, \"D_time_series_basal.csv\"), index_col=0)\n",
    "df_npr10 = pd.read_csv(os.path.join(WORK_DIR, \"D_time_series_npr10.csv\"), index_col=0)\n",
    "print(\"Dynamics shapes (neurons x timesteps):\", df_basal.shape, df_npr10.shape)\n",
    "\n",
    "# ---- Load raw CeNGEN mapping (may be big) ----\n",
    "cengen_path = os.path.join(INPUT_DIR, \"expression\", \"gene_expr_CeNGEN_base_mapped.csv\")\n",
    "if not os.path.exists(cengen_path):\n",
    "    raise FileNotFoundError(f\"CeNGEN file not found at {cengen_path}\")\n",
    "df_cengen_raw = pd.read_csv(cengen_path, index_col=0)\n",
    "print(\"CeNGEN raw shape:\", df_cengen_raw.shape)\n",
    "\n",
    "# ---- Aggregate duplicates (if any) and restrict to overlap with dynamics ----\n",
    "df_cengen = df_cengen_raw.groupby(df_cengen_raw.index).mean()\n",
    "common_neurons = sorted(list(set(df_basal.index) & set(df_cengen.index)))\n",
    "print(\"Unique CeNGEN rows after aggregation:\", df_cengen.shape[0], \"Overlap with dynamics:\", len(common_neurons))\n",
    "\n",
    "df_cengen = df_cengen.loc[common_neurons]\n",
    "df_basal = df_basal.loc[common_neurons]\n",
    "df_npr10 = df_npr10.loc[common_neurons]\n",
    "\n",
    "# ---- PCA embeddings (50 PCs) ----\n",
    "pca_npy = os.path.join(WORK_DIR, \"CeNGEN_PCA50.npy\")\n",
    "pca_csv = os.path.join(WORK_DIR, \"CeNGEN_PCA50.csv\")\n",
    "if os.path.exists(pca_npy):\n",
    "    gene_embed = np.load(pca_npy)\n",
    "    print(\"Loaded existing PCA embeddings:\", gene_embed.shape)\n",
    "else:\n",
    "    pca = PCA(n_components=50)\n",
    "    gene_embed = pca.fit_transform(df_cengen.values)\n",
    "    np.save(pca_npy, gene_embed)\n",
    "    pd.DataFrame(gene_embed, index=common_neurons).to_csv(pca_csv)\n",
    "    print(\"Computed & saved PCA embeddings:\", gene_embed.shape)\n",
    "\n",
    "# ---- Sanity print ----\n",
    "print(\"Basal shape:\", df_basal.shape, \"NPR10 shape:\", df_npr10.shape, \"Gene embed shape:\", gene_embed.shape)\n"
   ]
