  {
   "cell_type": "code",
   "execution_count": null,
   "id": "68e3114d",
   "metadata": {},
   "outputs": [],
   "source": [
    "# %% [4.0 LSTM Model Prototype with Real Traces]\n",
    "# Function: Train a simple LSTM to map Basal → NPR10 dynamics.\n",
    "\n",
    "from torch import nn\n",
    "from torch.utils.data import DataLoader, TensorDataset\n",
    "\n",
    "# Convert DataFrames to tensors\n",
    "X = torch.tensor(df_basal_ts.values.T, dtype=torch.float32).unsqueeze(0)  # [1, timesteps, neurons]\n",
    "Y = torch.tensor(df_npr10_ts.values.T, dtype=torch.float32).unsqueeze(0)  # [1, timesteps, neurons]\n",
    "\n",
    "print(\"Input tensor shape:\", X.shape, \"| Target tensor shape:\", Y.shape)\n",
    "\n",
    "dataset = TensorDataset(X, Y)\n",
    "loader = DataLoader(dataset, batch_size=1, shuffle=False)\n",
    "\n",
    "# Define simple LSTM\n",
    "class ToyLSTM(nn.Module):\n",
    "    def __init__(self, input_dim, hidden_dim, output_dim):\n",
    "        super().__init__()\n",
    "        self.lstm = nn.LSTM(input_dim, hidden_dim, batch_first=True)\n",
    "        self.fc = nn.Linear(hidden_dim, output_dim)\n",
    "\n",
    "    def forward(self, x):\n",
    "        out, _ = self.lstm(x)\n",
    "        return self.fc(out)\n",
    "\n",
    "input_dim = X.shape[-1]   # 179 neurons\n",
    "hidden_dim = 64           # more capacity than before\n",
    "output_dim = Y.shape[-1]  # 179 neurons\n",
    "\n",
    "model = ToyLSTM(input_dim, hidden_dim, output_dim)\n",
    "criterion = nn.MSELoss()\n",
    "optimizer = torch.optim.Adam(model.parameters(), lr=0.01)\n",
    "\n",
    "# Training loop\n",
    "for epoch in range(10):\n",
    "    for xb, yb in loader:\n",
    "        pred = model(xb)\n",
    "        loss = criterion(pred, yb)\n",
    "        optimizer.zero_grad()\n",
    "        loss.backward()\n",
    "        optimizer.step()\n",
    "    print(f\"Epoch {epoch+1}, Loss: {loss.item():.6f}\")\n",
    "\n",
    "print(\"✅ LSTM trained on Basal → NPR10 mapping.\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "1424a4bf",
   "metadata": {},
   "outputs": [],
   "source": [
    "# %% [5.0 Evaluation: Prediction vs Ground Truth]\n",
    "# Function: Compare predicted and target traces for a few sample neurons.\n",
    "\n",
    "with torch.no_grad():\n",
    "    preds = model(X).squeeze(0).numpy()\n",
    "    true = Y.squeeze(0).numpy()\n",
    "\n",
    "# Pick 5 random neurons to visualize\n",
    "sample_idx = np.random.choice(range(len(df_basal_ts.index)), 5, replace=False)\n",
    "sample_neurons = df_basal_ts.index[sample_idx]\n",
    "\n",
    "plt.figure(figsize=(12, 6))\n",
    "for i, n in zip(sample_idx, sample_neurons):\n",
    "    plt.plot(true[:, i], label=f\"{n}-True\", alpha=0.8)\n",
    "    plt.plot(preds[:, i], \"--\", label=f\"{n}-Pred\", alpha=0.8)\n",
    "\n",
    "plt.legend(loc=\"upper right\", fontsize=8, ncol=2)\n",
    "plt.title(\"LSTM Predictions vs NPR10 Ground Truth\")\n",
    "plt.xlabel(\"Timestep\")\n",
    "plt.ylabel(\"Activity\")\n",
    "plt.show()\n",
    "\n",
    "# Compute MSE for each sampled neuron\n",
    "mse_per_neuron = {n: float(((true[:, i] - preds[:, i])**2).mean()) for i, n in zip(sample_idx, sample_neurons)}\n",
    "print(\"✅ Sample neuron MSEs:\", mse_per_neuron)\n",
    "\n",
    "# Global average MSE\n",
    "global_mse = float(((true - preds)**2).mean())\n",
    "print(\"Global MSE across all neurons:\", global_mse)\n"
   ]
  },
  {
   "cell_type": "code",
