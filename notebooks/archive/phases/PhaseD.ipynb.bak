   "source": [
    "# %% Cell 7 — Full reconstruction across windows & compute global/per-neuron MSEs\n",
    "# Purpose: run model across all windows, stitch overlapping windows into full timeline (averaging overlaps),\n",
    "#          compare hybrid to identity and ridge baselines and save per-neuron MSEs.\n",
    "\n",
    "model.eval()\n",
    "preds_all = []\n",
    "with torch.no_grad():\n",
    "    # batch inference across windows to reduce overhead\n",
    "    batch_size = 8\n",
    "    num_batches = int(np.ceil(X_win_t.shape[0] / batch_size))\n",
    "    for i in range(num_batches):\n",
    "        s = i * batch_size\n",
    "        e = min((i+1)*batch_size, X_win_t.shape[0])\n",
    "        Xb = X_win_t[s:e].to(device)                    # (b,T,N)\n",
    "        preds_b = model(Xb, X_gene_t, device).cpu().numpy()  # (b,T,N)\n",
    "        preds_all.append(preds_b)\n",
    "preds_all = np.concatenate(preds_all, axis=0)  # (B,T,N)\n",
    "print(\"Preds_all shape:\", preds_all.shape)\n",
    "\n",
    "# Reconstruct time-series by averaging overlapping windows\n",
    "B, Tw, N = preds_all.shape\n",
    "recon = np.zeros((T_full, N), dtype=np.float32)\n",
    "counts = np.zeros((T_full, N), dtype=np.float32)\n",
    "for i, s in enumerate(starts):\n",
    "    recon[s:s+Tw, :] += preds_all[i]\n",
    "    counts[s:s+Tw, :] += 1.0\n",
    "counts[counts == 0] = 1.0\n",
    "recon_full = recon / counts  # (T_full, N)\n",
    "\n",
    "# True (normalized) and identity baseline\n",
    "Y_true_full = Y_norm  # from Cell 3\n",
    "X_id_full = X_norm\n",
    "\n",
    "# Global MSEs\n",
    "mse_hybrid = np.mean((recon_full - Y_true_full)**2)\n",
    "mse_identity = np.mean((X_id_full - Y_true_full)**2)\n",
    "\n",
    "# Simple ridge via least-squares X->Y (time as rows)\n",
    "W, *_ = np.linalg.lstsq(X_id_full, Y_true_full, rcond=None)\n",
    "Y_ridge = X_id_full.dot(W)\n",
    "mse_ridge = np.mean((Y_ridge - Y_true_full)**2)\n",
    "\n",
    "print(f\"Global MSEs -> hybrid: {mse_hybrid:.4f}, identity: {mse_identity:.4f}, ridge: {mse_ridge:.4f}\")\n",
    "\n",
    "# Per-neuron MSE table\n",
    "mse_per_neuron_model = np.mean((recon_full - Y_true_full)**2, axis=0)\n",
    "mse_per_neuron_id = np.mean((X_id_full - Y_true_full)**2, axis=0)\n",
    "mse_per_neuron_ridge = np.mean((Y_ridge - Y_true_full)**2, axis=0)\n",
    "\n",
    "df_mse = pd.DataFrame({\n",
    "    \"neuron\": common_neurons,\n",
    "    \"mse_hybrid\": mse_per_neuron_model,\n",
    "    \"mse_identity\": mse_per_neuron_id,\n",
    "    \"mse_ridge\": mse_per_neuron_ridge,\n",
    "})\n",
    "df_mse[\"delta_id_minus_hybrid\"] = df_mse[\"mse_identity\"] - df_mse[\"mse_hybrid\"]\n",
    "df_mse = df_mse.sort_values(\"delta_id_minus_hybrid\", ascending=False)\n",
    "display(df_mse.head(12))\n",
    "df_mse.to_csv(os.path.join(WORK_DIR, \"D3_neuron_mse_hybrid.csv\"), index=False)\n"
   ]
  },
