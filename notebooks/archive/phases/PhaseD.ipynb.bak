  {
   "cell_type": "markdown",
   "id": "fe895b37",
   "metadata": {},
   "source": [
    "## Part 2"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "7ef5d3d4",
   "metadata": {},
   "outputs": [],
   "source": [
    "# %% [4.1 Sliding-Window Dataset Preparation]\n",
    "# Function: Convert time-series into overlapping windows for training.\n",
    "\n",
    "window_size = 20\n",
    "stride = 5\n",
    "\n",
    "def make_windows(X, Y, window_size, stride):\n",
    "    X_windows, Y_windows = [], []\n",
    "    for start in range(0, X.shape[0] - window_size + 1, stride):\n",
    "        end = start + window_size\n",
    "        X_windows.append(X[start:end])\n",
    "        Y_windows.append(Y[start:end])\n",
    "    return np.stack(X_windows), np.stack(Y_windows)\n",
    "\n",
    "# Shape [timesteps, neurons]\n",
    "X_np = df_basal_ts.T.values\n",
    "Y_np = df_npr10_ts.T.values\n",
    "\n",
    "X_win, Y_win = make_windows(X_np, Y_np, window_size, stride)\n",
    "print(\"✅ Windows created:\", X_win.shape, Y_win.shape)\n",
    "\n",
    "# Convert to tensors\n",
    "X_tensor = torch.tensor(X_win, dtype=torch.float32)\n",
    "Y_tensor = torch.tensor(Y_win, dtype=torch.float32)\n",
    "\n",
    "dataset = TensorDataset(X_tensor, Y_tensor)\n",
    "loader = DataLoader(dataset, batch_size=8, shuffle=True)\n",
    "\n",
    "print(\"Training samples:\", len(dataset))\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "f46ef1d4",
   "metadata": {},
   "outputs": [],
   "source": [
    "# %% [4.2 Cycle Membership Map]\n",
    "# Function: Build cycle→neuron index map for cycle-level loss.\n",
    "\n",
    "# Map neurons to indices\n",
    "neuron_to_idx = {n: i for i, n in enumerate(df_basal_ts.index)}\n",
    "\n",
    "cycle_map = {}\n",
    "for _, row in df_cycle_neurons_npr10_filtered.iterrows():\n",
    "    cid, n = row[\"cycle_id\"], row[\"neuron_norm\"]\n",
    "    if n in neuron_to_idx:\n",
    "        cycle_map.setdefault(cid, []).append(neuron_to_idx[n])\n",
    "\n",
    "print(\"✅ Cycle membership map built:\", len(cycle_map), \"cycles\")\n",
    "print(\"Example:\", list(cycle_map.items())[:3])\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "774cb8d6",
   "metadata": {},
   "outputs": [],
   "source": [
    "# %% [4.3 Cycle-Aware LSTM Training]\n",
    "# Function: Train LSTM with dual loss (neuron-level + cycle-level).\n",
    "\n",
    "class CycleAwareLSTM(nn.Module):\n",
    "    def __init__(self, input_dim, hidden_dim, output_dim, num_layers=2):\n",
    "        super().__init__()\n",
    "        self.lstm = nn.LSTM(input_dim, hidden_dim, num_layers=num_layers, batch_first=True)\n",
    "        self.fc = nn.Linear(hidden_dim, output_dim)\n",
    "\n",
    "    def forward(self, x):\n",
    "        out, _ = self.lstm(x)\n",
    "        return self.fc(out)\n",
    "\n",
    "model = CycleAwareLSTM(input_dim=X_tensor.shape[-1], hidden_dim=128, output_dim=Y_tensor.shape[-1])\n",
    "optimizer = torch.optim.Adam(model.parameters(), lr=0.005)\n",
    "criterion = nn.MSELoss()\n",
    "\n",
    "def cycle_loss(pred, true, cycle_map):\n",
    "    loss = 0.0\n",
    "    for neurons in cycle_map.values():\n",
    "        pred_cycle = pred[..., neurons].mean(dim=-1)\n",
    "        true_cycle = true[..., neurons].mean(dim=-1)\n",
    "        loss += criterion(pred_cycle, true_cycle)\n",
    "    return loss / len(cycle_map)\n",
    "\n",
    "# Training loop\n",
    "epochs = 50\n",
    "lambda_cycle = 0.5\n",
    "\n",
    "for epoch in range(epochs):\n",
    "    total_loss = 0.0\n",
    "    for xb, yb in loader:\n",
    "        pred = model(xb)\n",
    "        loss_neuron = criterion(pred, yb)\n",
    "        loss_cycle = cycle_loss(pred, yb, cycle_map)\n",
    "        loss = loss_neuron + lambda_cycle * loss_cycle\n",
    "\n",
    "        optimizer.zero_grad()\n",
    "        loss.backward()\n",
    "        optimizer.step()\n",
    "        total_loss += loss.item()\n",
    "\n",
    "    print(f\"Epoch {epoch+1}/{epochs} | Loss: {total_loss/len(loader):.6f}\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "94c2db3f",
   "metadata": {},
   "outputs": [],
   "source": [
    "# %% [5.2 Evaluate Cycle-Level Accuracy]\n",
    "# Function: Compare predicted vs true cycle-average traces.\n",
    "\n",
    "with torch.no_grad():\n",
    "    preds = model(X_tensor).numpy()\n",
    "    true = Y_tensor.numpy()\n",
    "\n",
    "# Pick a cycle\n",
    "cid, neurons_in_cycle = list(cycle_map.items())[0]\n",
    "cycle_pred = preds[0, :, neurons_in_cycle].mean(axis=-1)\n",
    "cycle_true = true[0, :, neurons_in_cycle].mean(axis=-1)\n",
    "\n",
    "plt.figure(figsize=(10, 4))\n",
    "plt.plot(cycle_true, label=\"True Cycle Avg\")\n",
    "plt.plot(cycle_pred, \"--\", label=\"Pred Cycle Avg\")\n",
    "plt.legend()\n",
    "plt.title(f\"Cycle {cid} Average Activity\")\n",
    "plt.show()\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "08023f01",
   "metadata": {},
   "source": [
    "## Part 3 Transformer Comparison"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "98743be0",
   "metadata": {},
   "outputs": [],
   "source": [
    "# %% [4.4 Cycle-Aware Transformer Definition]\n",
    "# Function: Define a small Transformer encoder for Basal → NPR10 mapping.\n",
    "\n",
    "class CycleAwareTransformer(nn.Module):\n",
    "    def __init__(self, input_dim, model_dim=128, num_heads=4, num_layers=2, output_dim=None):\n",
    "        super().__init__()\n",
    "        self.input_proj = nn.Linear(input_dim, model_dim)\n",
    "        \n",
    "        encoder_layer = nn.TransformerEncoderLayer(\n",
    "            d_model=model_dim,\n",
    "            nhead=num_heads,\n",
    "            dim_feedforward=model_dim*2,\n",
    "            dropout=0.1,\n",
    "            batch_first=True\n",
    "        )\n",
    "        self.transformer = nn.TransformerEncoder(encoder_layer, num_layers=num_layers)\n",
    "        \n",
    "        self.output_proj = nn.Linear(model_dim, output_dim if output_dim else input_dim)\n",
    "\n",
    "    def forward(self, x):\n",
    "        x = self.input_proj(x)          # [batch, time, model_dim]\n",
    "        x = self.transformer(x)         # [batch, time, model_dim]\n",
    "        return self.output_proj(x)      # [batch, time, output_dim]\n",
    "\n",
    "# Initialize model\n",
    "model_t = CycleAwareTransformer(\n",
    "    input_dim=X_tensor.shape[-1],\n",
    "    model_dim=128,\n",
    "    num_heads=4,\n",
    "    num_layers=2,\n",
    "    output_dim=Y_tensor.shape[-1]\n",
    ")\n",
    "\n",
    "optimizer_t = torch.optim.Adam(model_t.parameters(), lr=0.005)\n",
    "criterion = nn.MSELoss()\n",
    "\n",
    "print(\"✅ Transformer initialized with parameters:\", sum(p.numel() for p in model_t.parameters()))\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "389fc0b3",
   "metadata": {},
   "outputs": [],
   "source": [
    "# %% [4.5 Cycle-Aware Transformer Training]\n",
    "# Function: Train Transformer with neuron + cycle-level loss.\n",
    "\n",
    "epochs = 50\n",
    "lambda_cycle = 0.5\n",
    "\n",
    "for epoch in range(epochs):\n",
    "    total_loss = 0.0\n",
    "    for xb, yb in loader:\n",
    "        pred = model_t(xb)\n",
    "        loss_neuron = criterion(pred, yb)\n",
    "        loss_cycle = cycle_loss(pred, yb, cycle_map)\n",
    "        loss = loss_neuron + lambda_cycle * loss_cycle\n",
    "\n",
    "        optimizer_t.zero_grad()\n",
    "        loss.backward()\n",
    "        optimizer_t.step()\n",
    "        total_loss += loss.item()\n",
    "    \n",
    "    print(f\"[Transformer] Epoch {epoch+1}/{epochs} | Loss: {total_loss/len(loader):.6f}\")\n"
   ]
  },
