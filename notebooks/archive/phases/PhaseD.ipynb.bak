    "# %% [1.0 Imports & Environment Setup]\n",
    "# Function: Import required libraries, set paths, and confirm CUDA availability.\n",
    "\n",
    "import os\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import torch\n",
    "\n",
    "# Base directories\n",
    "BASE_DIR = \"Projects/C-Elegans/PhaseD\"\n",
    "INPUT_DIR = os.path.join(BASE_DIR, \"inputs\")\n",
    "WORK_DIR = os.path.join(BASE_DIR, \"working\")\n",
    "ARTIFACT_DIR = os.path.join(BASE_DIR, \"artifacts\")\n",
    "\n",
    "# Sanity check: create working dirs if missing\n",
    "for d in [WORK_DIR, ARTIFACT_DIR]:\n",
    "    os.makedirs(d, exist_ok=True)\n",
    "\n",
    "print(\"✅ Paths set:\")\n",
    "print(\"BASE_DIR:\", BASE_DIR)\n",
    "print(\"INPUT_DIR:\", INPUT_DIR)\n",
    "print(\"WORK_DIR:\", WORK_DIR)\n",
    "print(\"ARTIFACT_DIR:\", ARTIFACT_DIR)\n",
    "\n",
    "# CUDA check\n",
    "print(\"CUDA available:\", torch.cuda.is_available())\n",
    "if torch.cuda.is_available():\n",
    "    print(\"Device:\", torch.cuda.get_device_name(0))\n"
