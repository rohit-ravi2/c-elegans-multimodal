   ],
   "source": [
    "# %% [3.0 PATCHED] Build sliding windows from aligned dynamics\n",
    "# Purpose: build X_win, Y_win arrays shaped (B, T_window, N)\n",
    "\n",
    "def make_windows_from_TN(X_TN, Y_TN, window_size=20, stride=5):\n",
    "    # X_TN, Y_TN expected shape: [N, T]  (rows=neurons, cols=time)\n",
    "    N, T = X_TN.shape\n",
    "    Xs, Ys = [], []\n",
    "    for start in range(0, T - window_size + 1, stride):\n",
    "        end = start + window_size\n",
    "        Xs.append(X_TN[:, start:end])  # shape (N, window)\n",
    "        Ys.append(Y_TN[:, start:end])\n",
    "    Xs = np.stack([x.T for x in Xs])  # (B, window, N)\n",
    "    Ys = np.stack([y.T for y in Ys])  # (B, window, N)\n",
    "    return Xs, Ys\n",
    "\n",
    "window_size = 20\n",
    "stride = 5\n",
    "X_win, Y_win = make_windows_from_TN(df_basal_z.values, df_npr10_z.values, window_size=window_size, stride=stride)\n",
    "\n",
    "print(\"Window shapes (B, T, N):\", X_win.shape, Y_win.shape)\n",
    "# Expect: (17, 20, 179) (17, 20, 179) with defaults if T=100\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "id": "9a9f78af",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "X_with_genes shape (B, T, N, D): torch.Size([17, 20, 179, 51])\n",
      "Y_tensor shape (B, T, N): torch.Size([17, 20, 179])\n"
     ]
    }
   ],
   "source": [
    "# %% [3.1 PATCHED] Merge dynamics with gene embeddings -> X_with_genes tensor\n",
    "# Purpose: create X_with_genes shape (B, T, N * feature_per_neuron) OR (B, T, N, features)\n",
    "# We will build (B, T, N, D) then flatten time-step features for LSTM input as needed.\n",
    "\n",
    "import torch\n",
    "\n",
    "# gene embedding (N, gene_dim)\n",
    "gene_emb = torch.tensor(df_gene_embed.values, dtype=torch.float32, device=device)  # (N, G)\n",
    "N, G = gene_emb.shape\n",
    "B, T, N_check = X_win.shape\n",
    "assert N_check == N, f\"Neuron mismatch: X_win N={N_check}, gene_emb N={N}\"\n",
    "\n",
    "# Build tensors\n",
    "dyn_tensor = torch.tensor(X_win, dtype=torch.float32, device=device).unsqueeze(-1)  # (B,T,N,1)\n",
    "gene_broadcast = gene_emb.unsqueeze(0).unsqueeze(0).repeat(B, T, 1, 1)              # (B,T,N,G)\n",
    "\n",
    "# Concatenate features per neuron\n",
    "X_with_genes = torch.cat([dyn_tensor, gene_broadcast], dim=-1)  # (B, T, N, 1+G)\n",
    "Y_tensor = torch.tensor(Y_win, dtype=torch.float32, device=device)               # (B, T, N)\n",
    "\n",
    "print(\"X_with_genes shape (B, T, N, D):\", X_with_genes.shape)\n",
    "print(\"Y_tensor shape (B, T, N):\", Y_tensor.shape)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 12,
   "id": "40bcdba8",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Flattened input shape (B,T,F): torch.Size([17, 20, 9129])\n",
      "F (input dim) = 9129\n"
     ]
    }
   ],
   "source": [
    "# %% [4.0 PATCHED] Gene-aware LSTM model (time-series across T; per-time features flattened across neurons)\n",
    "# Purpose: LSTM over time with per-time feature vector of length (N * D_per_neuron).\n",
    "# Input: reshape X_with_genes -> X_flat (B, T, F) where F = N * (1+G)\n",
    "# Output: per-time predictions shaped (B, T, N)\n",
    "\n",
    "class GeneAwareTimeLSTM(nn.Module):\n",
    "    def __init__(self, input_dim, hidden_dim=256, num_layers=2, dropout=0.2, out_neurons=None):\n",
    "        super().__init__()\n",
    "        self.lstm = nn.LSTM(input_dim, hidden_dim, num_layers=num_layers, batch_first=True, dropout=dropout)\n",
    "        self.fc = nn.Linear(hidden_dim, out_neurons)\n",
    "    def forward(self, x):  # x: (B, T, F)\n",
    "        out, _ = self.lstm(x)\n",
    "        y = self.fc(out)   # (B, T, N)\n",
    "        return y\n",
    "\n",
    "# Prepare flattened X for training\n",
    "B, T, N, D_per = X_with_genes.shape\n",
    "F = N * D_per\n",
