   "source": [
    "# %% [PATCHED 1.1] Robust CeNGEN loading: detect & aggregate duplicate neuron rows, then build embeddings\n",
    "import numpy as np\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "from sklearn.decomposition import PCA\n",
    "\n",
    "# 1) Load raw CeNGEN (if not already loaded)\n",
    "raw_path = os.path.join(INPUT_DIR, \"expression\", \"gene_expr_CeNGEN_base_mapped.csv\")\n",
    "df_cengen_raw = pd.read_csv(raw_path, index_col=0)\n",
    "df_cengen_raw.index = df_cengen_raw.index.astype(str).str.upper().str.strip()\n",
    "\n",
    "print(\"CeNGEN raw shape (rows may include duplicates):\", df_cengen_raw.shape)\n",
    "\n",
    "# 2) Check for duplicate neuron names in the CeNGEN index\n",
    "dup_counts = df_cengen_raw.index.value_counts()\n",
    "n_dups = int((dup_counts > 1).sum())\n",
    "print(\"Duplicate neuron labels found:\", n_dups)\n",
    "if n_dups > 0:\n",
    "    print(\"Example duplicated neuron names and counts (first 10):\")\n",
    "    print(dup_counts[dup_counts > 1].head(10))\n",
    "\n",
    "# 3) Aggregate duplicate rows by mean so every neuron appears once\n",
    "if n_dups > 0:\n",
    "    # groupby index and mean\n",
    "    df_cengen_unique = df_cengen_raw.groupby(df_cengen_raw.index).mean()\n",
    "    print(\"After aggregation unique shape:\", df_cengen_unique.shape)\n",
    "else:\n",
    "    df_cengen_unique = df_cengen_raw.copy()\n",
    "    print(\"No duplicates; using original rows as unique neurons.\")\n",
    "\n",
    "# 4) Ensure dynamics neuron names are normalized & unique\n",
    "df_basal_ts.index = df_basal_ts.index.astype(str).str.upper().str.strip()\n",
    "df_npr10_ts.index = df_npr10_ts.index.astype(str).str.upper().str.strip()\n",
    "if df_basal_ts.index.duplicated().any():\n",
    "    print(\"Warning: duplicates in df_basal_ts index; aggregating by mean\")\n",
    "    df_basal_ts = df_basal_ts.groupby(df_basal_ts.index).mean()\n",
    "if df_npr10_ts.index.duplicated().any():\n",
    "    print(\"Warning: duplicates in df_npr10_ts index; aggregating by mean\")\n",
    "    df_npr10_ts = df_npr10_ts.groupby(df_npr10_ts.index).mean()\n",
    "\n",
    "# 5) Compute overlap and restrict to it (this is the 179 we expect)\n",
    "common_neurons = sorted(set(df_basal_ts.index) & set(df_cengen_unique.index))\n",
    "print(\"Overlapping neurons count:\", len(common_neurons))\n",
    "print(\"Example overlap (first 20):\", common_neurons[:20])\n",
    "\n",
    "if len(common_neurons) == 0:\n",
    "    raise ValueError(\"No overlap between dynamics and CeNGEN after dedup. Inspect names manually.\")\n",
    "\n",
    "# 6) Subset CeNGEN unique to overlap and sort both by the same order\n",
    "df_cengen_restrict = df_cengen_unique.loc[common_neurons].sort_index()\n",
    "df_basal_restrict = df_basal_ts.loc[common_neurons].sort_index()\n",
    "df_npr10_restrict = df_npr10_ts.loc[common_neurons].sort_index()\n",
    "\n",
    "print(\"Restricted CeNGEN shape:\", df_cengen_restrict.shape)   # Expect (179, ~22k)\n",
    "print(\"Restricted Basal shape:\", df_basal_restrict.shape)     # Expect (179, T)\n",
    "print(\"Restricted NPR10 shape:\", df_npr10_restrict.shape)     # Expect (179, T)\n",
    "\n",
    "# 7) Normalize gene matrix (log1p + zscore across neurons)\n",
    "df_cengen_log = np.log1p(df_cengen_restrict)\n",
    "sc = StandardScaler(with_mean=True, with_std=True)\n",
    "df_cengen_norm = pd.DataFrame(sc.fit_transform(df_cengen_log.fillna(0)),\n",
    "                             index=df_cengen_log.index,\n",
    "                             columns=df_cengen_log.columns)\n",
    "\n",
    "# 8) PCA to produce gene embeddings (unique neuron rows)\n",
    "pca = PCA(n_components=50, random_state=42)\n",
    "cengen_pca = pca.fit_transform(df_cengen_norm.values)  # shape (179, 50)\n",
    "df_gene_embed = pd.DataFrame(cengen_pca, index=df_cengen_norm.index,\n",
    "                             columns=[f\"PC{i+1}\" for i in range(cengen_pca.shape[1])])\n",
    "\n",
    "print(\"Final gene embedding shape (neurons x PCs):\", df_gene_embed.shape)\n",
    "print(\"First 10 neurons in embeddings index:\", df_gene_embed.index[:10].tolist())\n",
    "print(\"Sample embedding vector (first neuron, first 5 PCs):\", np.round(df_gene_embed.values[0,:5], 4))\n"
   ]
  },
