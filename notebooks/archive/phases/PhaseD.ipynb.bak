   "source": [
    "# %% [2.1 Normalize and Align Neuron IDs]\n",
    "# Function: Normalize column names and values to compare across datasets.\n",
    "\n",
    "# Normalize attractors\n",
    "df_attractors[\"neuron_norm\"] = df_attractors[\"neuron\"].str.upper()\n",
    "\n",
    "# Normalize cycles (basal & npr10 use \"label\" column)\n",
    "df_cycles_basal[\"neuron_norm\"] = df_cycles_basal[\"label\"].astype(str).str.upper()\n",
    "df_cycles_npr10[\"neuron_norm\"] = df_cycles_npr10[\"label\"].astype(str).str.upper()\n",
    "\n",
    "# Normalize metadata (column \"Neuron\")\n",
    "df_meta[\"neuron_norm\"] = df_meta[\"Neuron\"].astype(str).str.upper()\n",
    "\n",
    "# Compute intersections\n",
    "neurons_A = set(df_attractors[\"neuron_norm\"])\n",
    "neurons_C = set(df_cycles_basal[\"neuron_norm\"]) | set(df_cycles_npr10[\"neuron_norm\"])\n",
    "neurons_M = set(df_meta[\"neuron_norm\"])\n",
    "\n",
    "common = neurons_A & neurons_C & neurons_M\n",
    "\n",
    "print(f\"✅ Normalized neurons:\")\n",
    "print(f\"- Phase A attractors: {len(neurons_A)} unique\")\n",
    "print(f\"- Phase C cycles: {len(neurons_C)} unique\")\n",
    "print(f\"- Metadata: {len(neurons_M)} unique\")\n",
    "print(f\"🔗 Common neurons across all: {len(common)}\")\n",
    "print(\"Example common neurons:\", list(common)[:15])\n"
   ]
