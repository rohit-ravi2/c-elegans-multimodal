   "source": [
    "# %% [2.0 PATCHED] Detrend, z-score, and align dynamics (uses df_basal_restrict / df_npr10_restrict)\n",
    "# Purpose: ensure dynamics are restricted to the same neurons used for gene embeddings,\n",
    "# sort indices identically and produce df_basal_z / df_npr10_z (rows=neurons, cols=time).\n",
    "\n",
    "from scipy.signal import detrend\n",
    "import numpy as np\n",
    "\n",
    "def detrend_and_zscore_df(df):\n",
    "    arr = df.values.astype(float)\n",
    "    arr_dt = detrend(arr, axis=1, type='linear')\n",
    "    mu = arr_dt.mean(axis=1, keepdims=True)\n",
    "    sd = arr_dt.std(axis=1, keepdims=True)\n",
    "    sd[sd == 0] = 1.0\n",
    "    arr_z = (arr_dt - mu) / sd\n",
    "    return pd.DataFrame(arr_z, index=df.index, columns=df.columns)\n",
    "\n",
    "# Use the restricted dataframes created earlier in the pipeline:\n",
    "# df_basal_restrict, df_npr10_restrict, and df_gene_embed must exist from previous patched cell.\n",
    "# If they aren't present, run the patched CeNGEN loading cell we provided.\n",
    "\n",
    "# Ensure the variables exist\n",
    "assert 'df_cengen_restrict' in globals(), \"df_cengen_restrict missing — run the patched CeNGEN cell first.\"\n",
    "assert 'df_basal_restrict' in globals() and 'df_npr10_restrict' in globals(), \"Restricted dynamics missing.\"\n",
    "assert 'df_gene_embed' in globals(), \"df_gene_embed missing.\"\n",
    "\n",
    "# Sort indices to the same order and confirm identical index sets\n",
    "common_neurons = sorted(list(set(df_basal_restrict.index) & set(df_cengen_restrict.index)))\n",
    "df_basal_restrict = df_basal_restrict.loc[common_neurons].sort_index()\n",
    "df_npr10_restrict = df_npr10_restrict.loc[common_neurons].sort_index()\n",
    "df_gene_embed = df_gene_embed.loc[common_neurons].sort_index()\n",
    "\n",
    "# Apply detrend + zscore\n",
    "df_basal_z = detrend_and_zscore_df(df_basal_restrict)\n",
    "df_npr10_z = detrend_and_zscore_df(df_npr10_restrict)\n",
    "\n",
    "# Sanity prints\n",
    "print(\"---- SANITY: Dynamics & gene embedding alignment ----\")\n",
    "print(\"N neurons (expected 179):\", len(common_neurons))\n",
    "print(\"Basal norm shape:\", df_basal_z.shape)     # expect (179, T)\n",
    "print(\"NPR10 norm shape:\", df_npr10_z.shape)     # expect (179, T)\n",
    "print(\"Gene embedding shape:\", df_gene_embed.shape)  # expect (179, PCdim e.g. 50)\n",
    "print(\"First 5 neurons in dynamics index:\", df_basal_z.index[:5].tolist())\n",
    "print(\"First 5 neurons in gene embedding index:\", df_gene_embed.index[:5].tolist())\n"
   ]
