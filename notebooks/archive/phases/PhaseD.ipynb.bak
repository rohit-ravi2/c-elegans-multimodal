   "source": [
    "# %% [3.4 Metrics: Cycle-Level Correlation & Spectral Match (Real)]\n",
    "# Purpose: Evaluate cycle-average correlation and dominant frequency match (pred vs true).\n",
    "\n",
    "# Build cycle-average dicts\n",
    "pred_cycle = cycle_average(Y_hat, cycle_map_real)      # dict cid -> [T]\n",
    "true_cycle = cycle_average(Y_np,  cycle_map_real)\n",
    "\n",
    "# Correlations across cycles\n",
    "cors = cycle_correlations(pred_cycle, true_cycle)\n",
    "peak_match = peak_match_rate(pred_cycle, true_cycle, tol_bins=1)\n",
    "\n",
    "print(\"✅ Cycle-level metrics:\")\n",
    "print(\"  median r (pred vs true):\", round(float(np.median(cors)), 3), \"| N cycles:\", len(cors))\n",
    "print(\"  spectral peak match rate:\", round(peak_match, 3))\n",
    "\n",
    "# Save histogram figure\n",
    "plt.figure(figsize=(6,4))\n",
    "plt.hist(cors, bins=30, alpha=0.8)\n",
    "plt.title(\"Cycle-average correlation (LSTM vs True)\")\n",
    "plt.xlabel(\"Pearson r\"); plt.ylabel(\"Count\")\n",
    "plt.tight_layout()\n",
    "plt.savefig(os.path.join(FIG_DIR, \"cycle_corr_hist_real.png\"), dpi=150)\n",
    "plt.close()\n",
    "\n",
    "pd.DataFrame({\"cycle_id\": list(pred_cycle.keys()), \"corr\": cors}).to_csv(\n",
    "    os.path.join(WORK_DIR, \"D1_cycle_correlations_real.csv\"), index=False\n",
    ")\n"
   ]
  },
  {
