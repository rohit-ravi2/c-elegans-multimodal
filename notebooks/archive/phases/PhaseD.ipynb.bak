    "# %% [4.0 Behavioral Proxies: Motor Class Maps]\n",
    "# Purpose: Define neuron sets for Forward, Backward, Turning; map to indices present in our data.\n",
    "\n",
    "# Minimal curated lists (filtered by availability in df index)\n",
    "forward_names  = [\"AVBL\",\"AVBR\",\"PVCL\",\"PVCR\",\"DB1\",\"DB2\",\"DB3\",\"DB4\",\"DB5\",\"DB6\",\"DB7\",\"VB1\",\"VB2\",\"VB3\",\"VB4\",\"VB5\",\"VB6\",\"VB7\",\"VB8\",\"VB9\",\"VB10\",\"VB11\"]\n",
    "backward_names = [\"AVAL\",\"AVAR\",\"AVDL\",\"AVDR\",\"AVEL\",\"AVER\",\"DA1\",\"DA2\",\"DA3\",\"DA4\",\"DA5\",\"DA6\",\"DA7\",\"DA8\",\"DA9\",\"VA1\",\"VA2\",\"VA3\",\"VA4\",\"VA5\",\"VA6\",\"VA7\",\"VA8\",\"VA9\",\"VA10\",\"VA11\",\"VA12\"]\n",
    "turn_names     = [\"RIVL\",\"RIVR\",\"SMBDL\",\"SMBDR\",\"SMBVL\",\"SMBVR\",\"SMDVL\",\"SMDVR\",\"SMDL\",\"SMDR\",\"RIML\",\"RIMR\"]\n",
    "\n",
    "present = set(df_npr10_ts.index)\n",
    "F_idx = [i for i,n in enumerate(df_npr10_ts.index) if n in forward_names and n in present]\n",
    "B_idx = [i for i,n in enumerate(df_npr10_ts.index) if n in backward_names and n in present]\n",
    "T_idx = [i for i,n in enumerate(df_npr10_ts.index) if n in turn_names and n in present]\n",
    "\n",
    "print(\"✅ Motor class indices:\", {\"Forward\":len(F_idx), \"Backward\":len(B_idx), \"Turning\":len(T_idx)})\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "8b724503",
   "metadata": {},
   "outputs": [],
   "source": [
    "# %% [4.1 Behavioral Indices (Basal vs True-NPR10 vs Pred-NPR10)]\n",
    "# Purpose: Compute forward-backward bias, dominant frequency, and duty cycle for each class.\n",
    "\n",
    "def class_avg(traces_TxN, idxs):\n",
    "    if len(idxs) == 0: \n",
    "        return np.full(traces_TxN.shape[0], np.nan)\n",
    "    return traces_TxN[:, idxs].mean(axis=1)\n",
    "\n",
    "def dominant_freq(signal_1d):\n",
    "    # Return frequency-bin of max (ignore DC); convert to index only for comparison\n",
    "    spec = np.abs(rfft(signal_1d))\n",
    "    if len(spec) <= 2:\n",
    "        return 0\n",
    "    spec[0] = 0\n",
    "    return int(np.argmax(spec))\n",
    "\n",
    "def duty_cycle(signal_1d, thresh=\"median\"):\n",
    "    thr = np.nanmedian(signal_1d) if thresh==\"median\" else float(thresh)\n",
    "    return float(np.mean(signal_1d > thr))\n",
    "\n",
    "def behavior_metrics(traces_TxN, label):\n",
    "    F = class_avg(traces_TxN, F_idx)\n",
    "    B = class_avg(traces_TxN, B_idx)\n",
    "    T = class_avg(traces_TxN, T_idx)\n",
    "    metrics = {\n",
    "        \"label\": label,\n",
    "        \"forward_minus_backward\": float(np.nanmean(F) - np.nanmean(B)),\n",
    "        \"freq_forward\":  dominant_freq(F) if np.isfinite(F).all() else np.nan,\n",
    "        \"freq_backward\": dominant_freq(B) if np.isfinite(B).all() else np.nan,\n",
    "        \"freq_turning\":  dominant_freq(T) if np.isfinite(T).all() else np.nan,\n",
    "        \"duty_forward\":  duty_cycle(F),\n",
    "        \"duty_backward\": duty_cycle(B),\n",
    "        \"duty_turning\":  duty_cycle(T),\n",
    "    }\n",
    "    return metrics\n",
    "\n",
    "beh_basal   = behavior_metrics(X_np,      \"Basal\")\n",
    "beh_true    = behavior_metrics(Y_np,      \"True_NPR10\")\n",
    "beh_pred    = behavior_metrics(Y_hat,     \"Pred_NPR10\")\n",
    "beh_ridge   = behavior_metrics(Y_hat_ridge, \"Ridge_NPR10\")\n",
    "beh_id      = behavior_metrics(Y_hat_identity, \"Identity_NPR10\")\n",
    "\n",
    "df_beh = pd.DataFrame([beh_basal, beh_true, beh_pred, beh_ridge, beh_id])\n",
    "df_beh.to_csv(os.path.join(WORK_DIR, \"D1_behavioral_indices.csv\"), index=False)\n",
    "print(\"✅ Behavioral indices written:\\n\", df_beh)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "23e2374c",
   "metadata": {},
   "outputs": [],
   "source": [
    "# %% [5.0 Summary Tables & Success Gates]\n",
    "# Purpose: Consolidate metrics and print a high-level verdict for Phase D.1.\n",
    "\n",
    "# Load prior outputs\n",
    "df_neuron_mse  = pd.read_csv(os.path.join(WORK_DIR, \"D1_neuron_mse.csv\"))\n",
    "df_nulls       = pd.read_csv(os.path.join(WORK_DIR, \"D1_null_comparisons.csv\"))\n",
    "df_beh         = pd.read_csv(os.path.join(WORK_DIR, \"D1_behavioral_indices.csv\"))\n",
    "\n",
    "print(\"\\n=== Neuron-level MSEs ===\\n\", df_neuron_mse.round(3))\n",
    "print(\"\\n=== Real vs Nulls (Cycle Corr & Spectral Peak Match) ===\\n\", df_nulls.round(3))\n",
    "print(\"\\n=== Behavioral Indices ===\\n\", df_beh)\n",
    "\n",
    "# Success gates (tunable)\n",
    "gate_corr_delta   = 0.20\n",
    "gate_peak_pp_gain = 0.20   # 20 percentage points\n",
    "gate_mse_gain     = 0.15   # 15% better than Identity\n",
    "\n",
    "real_corr = float(df_nulls.loc[df_nulls[\"metric\"]==\"cycle_corr_median\",\"real\"])\n",
    "null_corr = float(df_nulls.loc[df_nulls[\"metric\"]==\"cycle_corr_median\",[\"temporal_null_mean\",\"identity_null_mean\",\"cycleperm_null_mean\"]].mean(axis=1))\n",
    "real_peak = float(df_nulls.loc[df_nulls[\"metric\"]==\"spectral_peak_match\",\"real\"])\n",
    "null_peak = float(df_nulls.loc[df_nulls[\"metric\"]==\"spectral_peak_match\",[\"temporal_null_mean\",\"identity_null_mean\",\"cycleperm_null_mean\"]].mean(axis=1))\n",
    "\n",
    "mse_lstm     = float(df_neuron_mse[\"mse_lstm\"])\n",
    "mse_identity = float(df_neuron_mse[\"mse_identity\"])\n",
    "mse_gain     = (mse_identity - mse_lstm) / max(mse_identity, 1e-9)\n",
    "\n",
    "print(\"\\n=== Success Gate Check ===\")\n",
    "print(\"  Corr Δ (real - avg null):\", round(real_corr - null_corr, 3), \">= ?\", gate_corr_delta)\n",
    "print(\"  Peak match Δpp:\", round((real_peak - null_peak)*100, 1), \">= ?\", gate_peak_pp_gain*100)\n",
    "print(\"  MSE gain vs Identity:\", round(mse_gain*100, 1), \"%  >= ?\", gate_mse_gain*100, \"%\")\n",
    "\n",
    "passed = (\n",
    "    (real_corr - null_corr) >= gate_corr_delta and\n",
    "    (real_peak - null_peak) >= gate_peak_pp_gain and\n",
    "    (mse_gain >= gate_mse_gain)\n",
    ")\n",
    "print(\"\\nPHASE D.1 VERDICT:\", \"✅ SUCCESS\" if passed else \"⚠️ NEEDS MORE EVIDENCE\")\n"
   ]
  },
