      "Windowed shapes (B, T, N): (17, 20, 179) (17, 20, 179) starts: 17\n",
      "Tensor shapes: torch.Size([17, 20, 179]) torch.Size([17, 20, 179]) torch.Size([179, 50])\n"
     ]
    }
   ],
   "source": [
    "# %% Cell 3 — Build sliding-window dataset + normalization\n",
    "# Purpose: create X_win (B,T,N,1), Y_win (B,T,N), normalize dynamics & gene PCs\n",
    "\n",
    "# Convert to numpy (shape (N,T)) -> we will transpose to (T,N)\n",
    "X_dyn = df_basal.values.T.astype(np.float32)   # (T,N)\n",
    "Y_dyn = df_npr10.values.T.astype(np.float32)   # (T,N)\n",
    "\n",
    "# Normalize per-neuron (zscore across time) to center dynamics\n",
    "X_means = X_dyn.mean(axis=0, keepdims=True)\n",
    "X_stds  = X_dyn.std(axis=0, keepdims=True) + 1e-8\n",
    "X_norm = (X_dyn - X_means) / X_stds\n",
    "Y_norm = (Y_dyn - X_means) / X_stds   # use same scaling for target\n",
    "\n",
    "# Normalize gene embeddings (zscore per PC)\n",
    "gene_mean = gene_embed.mean(axis=0, keepdims=True)\n",
    "gene_std  = gene_embed.std(axis=0, keepdims=True) + 1e-8\n",
    "G_norm = (gene_embed - gene_mean) / gene_std   # (N, G)\n",
    "\n",
    "# sliding windows\n",
    "T_full, N = X_norm.shape\n",
    "win_size, stride = 20, 5\n",
    "Xw, Yw = [], []\n",
    "starts = list(range(0, T_full - win_size + 1, stride))\n",
    "for s in starts:\n",
    "    Xw.append(X_norm[s:s+win_size, :])   # (win, N)\n",
    "    Yw.append(Y_norm[s:s+win_size, :])\n",
    "Xw = np.stack(Xw).astype(np.float32)   # (B, win, N)\n",
    "Yw = np.stack(Yw).astype(np.float32)\n",
    "print(\"Windowed shapes (B, T, N):\", Xw.shape, Yw.shape, \"starts:\", len(starts))\n",
    "\n",
    "# Convert to tensors in expected shapes\n",
    "X_win = torch.tensor(Xw)  # (B, T, N)\n",
    "Y_win = torch.tensor(Yw)  # (B, T, N)\n",
    "X_gene = torch.tensor(G_norm, dtype=torch.float32)  # (N, G)\n",
    "print(\"Tensor shapes:\", X_win.shape, Y_win.shape, X_gene.shape)\n"
   ]
  },
