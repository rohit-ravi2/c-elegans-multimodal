   "source": [
    "import pandas as pd, requests, io\n",
    "\n",
    "# Download latest mapping table\n",
    "url = \"https://ftp.wormbase.org/pub/wormbase/species/c_elegans/annotation/geneIDs.txt\"\n",
    "mapping = pd.read_csv(url, sep=\"\\t\", header=None, names=[\"WBGeneID\",\"SeqName\",\"GeneName\"])\n",
    "\n",
    "# clean nulls\n",
    "mapping = mapping.dropna(subset=[\"WBGeneID\"])\n",
    "print(\"Mapping loaded:\", mapping.shape)\n",
    "display(mapping.head())\n",
    "\n",
    "# merge with your stability table\n",
    "mapped = stable_tbl.copy()\n",
    "mapped.index.name = \"WBGeneID\"\n",
    "mapped = mapped.reset_index().merge(mapping[[\"WBGeneID\",\"GeneName\"]], on=\"WBGeneID\", how=\"left\")\n",
    "mapped = mapped.set_index(\"GeneName\").drop(columns=[\"WBGeneID\"])\n",
    "\n",
    "display(mapped.head(20))\n"
   ]
  },
