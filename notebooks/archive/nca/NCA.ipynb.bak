     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Nonlinear mediation (mean over folds)\n",
      "  Indirect effect (Expr→Motif→Role): -0.027936494350433348\n",
      "  Residual/direct effect (Motif parts not captured by Expr): 0.03380951881408691\n",
      "  Accuracies: {'acc_true': np.float64(0.8265079498291016), 'acc_indirect': np.float64(0.7926984310150147), 'acc_blocked': np.float64(0.820634925365448)}\n"
     ]
    }
   ],
   "source": [
    "# ==== NON-LINEAR MEDIATION: Expr -> Motif -> Role ====\n",
    "import numpy as np, torch, torch.nn as nn\n",
    "from sklearn.decomposition import PCA\n",
    "from sklearn.model_selection import KFold\n",
    "from sklearn.metrics import accuracy_score\n",
    "\n",
    "torch.manual_seed(1337); np.random.seed(1337)\n",
    "\n",
    "# Dimensionality reduction for stability\n",
    "pca_expr = PCA(n_components=64, random_state=0)\n",
    "Zx = pca_expr.fit_transform((expr - expr.mean())/(expr.std()+1e-6)).astype(np.float32)   # (N, 64)\n",
    "Zm = PCA(n_components=5, random_state=0).fit_transform(motifs).astype(np.float32)       # (N, 5)\n",
    "y = y_role.astype(int)  # 0/1/2\n",
    "\n",
    "class Enc(nn.Module):\n",
    "    def __init__(self, d_in=64, d_out=5):\n",
    "        super().__init__()\n",
    "        self.net = nn.Sequential(nn.Linear(d_in,128), nn.ReLU(),\n",
    "                                 nn.Linear(128,64), nn.ReLU(),\n",
    "                                 nn.Linear(64,d_out))\n",
    "    def forward(self,x): return self.net(x)\n",
    "\n",
    "class Clf(nn.Module):\n",
    "    def __init__(self, d_in=5):\n",
    "        super().__init__()\n",
    "        self.net = nn.Sequential(nn.Linear(d_in,64), nn.ReLU(),\n",
    "                                 nn.Linear(64,3))\n",
    "    def forward(self,m): return self.net(m)\n",
    "\n",
    "def softmax_acc(logits, y_true):\n",
    "    \"\"\"\n",
    "    Computes simple classification accuracy.\n",
    "    logits: (N, num_classes)\n",
    "    y_true: (N,)\n",
    "    \"\"\"\n",
    "    yhat = logits.argmax(1)\n",
    "    return (yhat == y_true).float().mean().item()\n",
    "\n",
    "\n",
    "kf = KFold(n_splits=5, shuffle=True, random_state=1337)\n",
    "indirect_effects = []; direct_effects = []; accs = []\n",
    "\n",
    "for tr, va in kf.split(Zx):\n",
    "    # Train encoder: Expr -> Motif (nonlinear)\n",
    "    enc = Enc().float()\n",
    "    opt = torch.optim.Adam(enc.parameters(), lr=2e-3)\n",
    "    crit = nn.MSELoss()\n",
    "    Xt = torch.tensor(Zx[tr]); Mt = torch.tensor(Zm[tr])\n",
    "    Xv = torch.tensor(Zx[va]); Mv = torch.tensor(Zm[va])\n",
    "    for ep in range(120):\n",
    "        opt.zero_grad(); loss = crit(enc(Xt), Mt); loss.backward(); opt.step()\n",
    "\n",
    "    # Train classifier: Motif -> Role (nonlinear)\n",
    "    clf = Clf().float()\n",
    "    opt2 = torch.optim.Adam(clf.parameters(), lr=2e-3)\n",
    "    crit2 = nn.CrossEntropyLoss()\n",
    "    Yt = torch.tensor(y[tr]); Yv = torch.tensor(y[va])\n",
    "    for ep in range(120):\n",
    "        opt2.zero_grad(); loss2 = crit2(clf(Mt), Yt); loss2.backward(); opt2.step()\n",
    "\n",
    "    # ACC with true motifs\n",
    "    acc_true = softmax_acc(clf(Mv).detach(), Yv)\n",
    "\n",
    "    # ACC with predicted motifs (indirect path active)\n",
    "    Mv_pred = enc(Xv).detach()\n",
    "    acc_indirect = softmax_acc(clf(Mv_pred), Yv)\n",
    "\n",
    "    # ACC when mediator is ablated (zeros) -- indirect path blocked\n",
    "    acc_blocked = softmax_acc(clf(torch.zeros_like(Mv)), Yv)\n",
    "\n",
    "    # Effects\n",
    "    # Indirect = ACC(predicted mediator) - ACC(blocked mediator)\n",
    "    # Direct  = ACC(true mediator) - ACC(predicted mediator)  (what expr can't explain via motif)\n",
    "    indirect_effects.append(float(acc_indirect - acc_blocked))\n",
    "    direct_effects.append(float(acc_true - acc_indirect))\n",
    "    accs.append({\"acc_true\":float(acc_true), \"acc_indirect\":float(acc_indirect), \"acc_blocked\":float(acc_blocked)})\n",
    "\n",
    "print(\"Nonlinear mediation (mean over folds)\")\n",
    "print(\"  Indirect effect (Expr→Motif→Role):\", np.mean(indirect_effects))\n",
    "print(\"  Residual/direct effect (Motif parts not captured by Expr):\", np.mean(direct_effects))\n",
    "print(\"  Accuracies:\", {k: np.mean([a[k] for a in accs]) for k in accs[0]})\n"
   ]
  },
