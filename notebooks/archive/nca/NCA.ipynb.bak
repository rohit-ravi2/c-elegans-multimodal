   ],
   "source": [
    "# ==== SPATIAL EMBEDDINGS via Laplacian Eigenmaps + EGNN-lite ====\n",
    "import networkx as nx, numpy as np, torch, torch.nn as nn\n",
    "from scipy import sparse\n",
    "from sklearn.decomposition import PCA\n",
    "from sklearn.model_selection import KFold\n",
    "\n",
    "# Build symmetric adjacency for Laplacian\n",
    "A = nx.to_scipy_sparse_array(G.subgraph(neurons), nodelist=neurons, weight='w', dtype=float, format='csr')\n",
    "A = ((A + A.T) / 2.0).tocsr()\n",
    "d = np.array(A.sum(1)).ravel()\n",
    "L = sparse.diags(d) - A\n",
    "# small eigendecomp (3 coords)\n",
    "L_reg = L + sparse.eye(L.shape[0])*1e-6\n",
    "vals, vecs = sparse.linalg.eigsh(L_reg, k=3, which='SM')\n",
    "coords = vecs.astype(np.float32)  # (N,3)\n",
    "\n",
    "# EGNN-lite: uses pairwise distances to modulate messages\n",
    "class EGNNLite(nn.Module):\n",
    "    def __init__(self, d_x, d_pos=3, hidden=64, steps=3):\n",
    "        super().__init__()\n",
    "        self.steps = steps\n",
    "        self.phi_e = nn.Sequential(nn.Linear(d_x*2+1, hidden), nn.ReLU(), nn.Linear(hidden, hidden))\n",
    "        self.phi_h = nn.Sequential(nn.Linear(d_x+hidden, hidden), nn.ReLU(), nn.Linear(hidden, d_x))\n",
    "        self.read = nn.Sequential(nn.Linear(d_x,64), nn.ReLU(), nn.Linear(64,5))\n",
    "    def forward(self, x, pos, adj):\n",
    "        h = x\n",
    "        for _ in range(self.steps):\n",
    "            # message passing with distances\n",
    "            # adj is (N,N) binary/weighted torch tensor\n",
    "            # build messages m_ij = phi_e([h_i,h_j, ||pos_i-pos_j||])\n",
    "            with torch.no_grad():\n",
    "                D = torch.cdist(pos, pos)  # (N,N)\n",
    "            hi = h.unsqueeze(1).repeat(1,h.size(0),1)\n",
    "            hj = h.unsqueeze(0).repeat(h.size(0),1,1)\n",
    "            m_in = torch.cat([hi, hj, D.unsqueeze(-1)], dim=-1)  # (N,N,2d+1)\n",
    "            m = self.phi_e(m_in) * adj.unsqueeze(-1)             # mask by adjacency\n",
    "            m = m.sum(1)                                         # aggregate\n",
    "            h = h + self.phi_h(torch.cat([h,m], dim=-1))         # update\n",
    "        return self.read(h)\n",
    "\n",
    "# Inputs: expression PCs + degree (small, fast)\n",
    "Zx = PCA(n_components=32, random_state=0).fit_transform((expr-expr.mean())/(expr.std()+1e-6)).astype(np.float32)\n",
    "deg_small = deg_df.reindex(neurons).values.astype(np.float32)\n",
    "Xgeo = np.hstack([Zx, deg_small]).astype(np.float32)\n",
    "Adj = (A>0).astype(np.float32).toarray()\n",
    "\n",
    "kf = KFold(n_splits=5, shuffle=True, random_state=1337)\n",
    "r_scores=[]\n",
    "for tr,va in kf.split(Xgeo):\n",
    "    model = EGNNLite(d_x=Xgeo.shape[1], steps=3).float()\n",
    "    opt = torch.optim.Adam(model.parameters(), lr=2e-3)\n",
    "    crit = nn.MSELoss()\n",
    "    xtr = torch.tensor(Xgeo[tr]); xva = torch.tensor(Xgeo[va])\n",
    "    ptr = torch.tensor(coords[tr]); pva = torch.tensor(coords[va])\n",
    "    atr = torch.tensor(Adj[np.ix_(tr,tr)]); ava = torch.tensor(Adj[np.ix_(va,va)])\n",
    "    ytr = torch.tensor(PCA(n_components=5, random_state=0).fit_transform(motifs[tr]).astype(np.float32))\n",
    "    # Fit\n",
    "    for ep in range(120):\n",
    "        opt.zero_grad()\n",
    "        loss = crit(model(xtr, ptr, atr), ytr); loss.backward(); opt.step()\n",
    "    # Eval correlation on PCs (approx)\n",
    "    with torch.no_grad():\n",
    "        pv = model(xva, pva, ava).numpy()\n",
    "    yv = PCA(n_components=5, random_state=0).fit_transform(motifs[va]).astype(np.float32)\n",
    "    r = np.corrcoef(yv.flatten(), pv.flatten())[0,1]\n",
    "    r_scores.append(float(r))\n",
    "print(\"EGNN-lite (geometry-aware) motif PC correlation:\", np.mean(r_scores))\n"
   ]
  },
