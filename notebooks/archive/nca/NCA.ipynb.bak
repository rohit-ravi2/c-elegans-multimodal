   ],
   "source": [
    "# ============================================================\n",
    "# 🧩 Cell F — What the GNCA Learned\n",
    "# ============================================================\n",
    "\n",
    "import torch\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from sklearn.decomposition import PCA\n",
    "from sklearn.manifold import TSNE\n",
    "from scipy.stats import pearsonr\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 1️⃣  Load best model & run final predictions\n",
    "# ------------------------------------------------------------\n",
    "model.load_state_dict(torch.load(EXPERIMENTS_OUT / \"gnca_motif_best.pt\", map_location=device))\n",
    "model.eval()\n",
    "\n",
    "with torch.no_grad():\n",
    "    y_pred = model(X, A).cpu().numpy()\n",
    "    y_true = y.cpu().numpy()\n",
    "\n",
    "motif_names = list(motif_df.columns)\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 2️⃣  Per-motif performance metrics\n",
    "# ------------------------------------------------------------\n",
    "perf = []\n",
    "for i, motif in enumerate(motif_names):\n",
    "    r, _ = pearsonr(y_true[:, i], y_pred[:, i])\n",
    "    mae = np.mean(np.abs(y_true[:, i] - y_pred[:, i]))\n",
    "    perf.append((motif, r, mae))\n",
    "\n",
    "perf_df = pd.DataFrame(perf, columns=[\"motif\", \"pearson_r\", \"mae\"])\n",
    "perf_df.to_csv(EXPERIMENTS_OUT / \"gnca_motif_performance.csv\", index=False)\n",
    "print(\"✅ Saved per-motif performance → gnca_motif_performance.csv\")\n",
    "display(perf_df)\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 3️⃣  Visualize predictions vs. truth\n",
    "# ------------------------------------------------------------\n",
    "fig, axes = plt.subplots(1, len(motif_names), figsize=(16, 3))\n",
    "for i, motif in enumerate(motif_names):\n",
    "    axes[i].scatter(y_true[:, i], y_pred[:, i], s=15, alpha=0.7)\n",
    "    axes[i].plot([0, 1], [0, 1], \"r--\")\n",
    "    axes[i].set_title(f\"{motif}\\nr={perf_df.iloc[i,1]:.2f}\")\n",
    "    axes[i].set_xlabel(\"True\"); axes[i].set_ylabel(\"Pred\")\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 4️⃣  Latent representation analysis\n",
    "# ------------------------------------------------------------\n",
    "with torch.no_grad():\n",
    "    hidden = model.fc_in(X).cpu().numpy()  # first-layer embeddings\n",
    "\n",
    "pca = PCA(n_components=2).fit_transform(hidden)\n",
    "tsne = TSNE(n_components=2, perplexity=15, random_state=42).fit_transform(hidden)\n",
    "\n",
    "fig, ax = plt.subplots(1, 2, figsize=(10, 4))\n",
    "ax[0].scatter(pca[:, 0], pca[:, 1], c=y_true[:, 0], cmap=\"viridis\", s=20)\n",
    "ax[0].set_title(\"PCA of hidden states (colored by motif 1)\")\n",
    "ax[1].scatter(tsne[:, 0], tsne[:, 1], c=y_true[:, 1], cmap=\"plasma\", s=20)\n",
    "ax[1].set_title(\"t-SNE of hidden states (colored by motif 2)\")\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 5️⃣  Saliency (feature influence) analysis\n",
    "# ------------------------------------------------------------\n",
    "X.requires_grad = True\n",
    "model.eval()\n",
    "pred_mean = model(X, A).mean()  # mean prediction scalar\n",
    "pred_mean.backward()\n",
    "\n",
    "saliency = X.grad.abs().mean(0).cpu().numpy()\n",
    "sal_df = pd.DataFrame({\n",
    "    \"gene\": expr_df.columns,\n",
    "    \"saliency\": saliency\n",
    "}).sort_values(\"saliency\", ascending=False)\n",
    "\n",
    "sal_df.to_csv(EXPERIMENTS_OUT / \"gnca_saliency_genes.csv\", index=False)\n",
    "print(\"✅ Saved GNCA saliency scores → gnca_saliency_genes.csv\")\n",
    "print(\"Top 10 influential genes:\")\n",
    "display(sal_df.head(10))\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 6️⃣  Fixed Integrated Gradients function (PyTorch-safe)\n",
    "# ------------------------------------------------------------\n",
    "def integrated_gradients(model, X, A, baseline=None, steps=50):\n",
    "    if baseline is None:\n",
    "        baseline = torch.zeros_like(X)\n",
    "    scaled_inputs = [baseline + (float(i)/steps) * (X - baseline) for i in range(steps + 1)]\n",
    "    grads = []\n",
    "    for inp in scaled_inputs:\n",
    "        inp = inp.detach().clone().requires_grad_()\n",
    "        out = model(inp, A).mean()\n",
    "        out.backward()\n",
    "        grads.append(inp.grad.detach().clone())\n",
    "    grads = torch.stack(grads).mean(0)\n",
    "    IG = ((X - baseline) * grads).mean(0).detach().cpu().numpy()   # ✅ detach before numpy()\n",
    "    return IG\n",
    "\n",
    "\n",
    "\n",
    "IG = integrated_gradients(model, X, A)\n",
    "ig_df = pd.DataFrame({\"gene\": expr_df.columns, \"integrated_gradients\": IG})\n",
    "ig_df = ig_df.sort_values(\"integrated_gradients\", ascending=False)\n",
    "ig_df.to_csv(EXPERIMENTS_OUT / \"gnca_integrated_gradients_genes.csv\", index=False)\n",
    "print(\"✅ Saved integrated gradients → gnca_integrated_gradients_genes.csv\")\n",
    "\n",
    "display(ig_df.head(10))\n"
   ]
  },
