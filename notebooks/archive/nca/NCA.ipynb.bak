   "source": [
    "# ==== CONDITIONAL DIFFUSION: p(Motif | Expr PCs) ====\n",
    "import torch, torch.nn as nn, numpy as np\n",
    "from sklearn.decomposition import PCA\n",
    "from sklearn.model_selection import train_test_split\n",
    "\n",
    "# Data\n",
    "Zx = PCA(n_components=32, random_state=0).fit_transform((expr-expr.mean())/(expr.std()+1e-6)).astype(np.float32)\n",
    "Ym = motifs.astype(np.float32)\n",
    "\n",
    "Xtr, Xva, Ytr, Yva = train_test_split(Zx, Ym, test_size=0.2, random_state=42)\n",
    "\n",
    "# Simple T-step DDPM setup\n",
    "T = 100\n",
    "betas = torch.linspace(1e-4, 0.02, T).float()\n",
    "alphas = 1.0 - betas\n",
    "alphas_cum = torch.cumprod(alphas, dim=0)\n",
    "\n",
    "class CondEpsNet(nn.Module):\n",
    "    def __init__(self, d_y=5, d_x=32):\n",
    "        super().__init__()\n",
    "        self.net = nn.Sequential(\n",
    "            nn.Linear(d_y + d_x + 1, 128), nn.ReLU(),\n",
    "            nn.Linear(128,128), nn.ReLU(),\n",
    "            nn.Linear(128, d_y)\n",
    "        )\n",
    "    def forward(self, y_noisy, x, t):\n",
    "        tnorm = (t.float()/T).unsqueeze(-1)\n",
    "        return self.net(torch.cat([y_noisy, x, tnorm], dim=1))\n",
    "\n",
    "def q_sample(y0, t, noise):\n",
    "    ac = alphas_cum[t].unsqueeze(-1)\n",
    "    return torch.sqrt(ac)*y0 + torch.sqrt(1.0 - ac)*noise\n",
    "\n",
    "net = CondEpsNet()\n",
    "opt = torch.optim.Adam(net.parameters(), lr=2e-3)\n",
    "Xtr_t = torch.tensor(Xtr); Ytr_t = torch.tensor(Ytr)\n",
    "\n",
    "# Train\n",
    "for step in range(4000):\n",
    "    idx = torch.randint(0, Xtr_t.size(0), (64,))\n",
    "    x = Xtr_t[idx]\n",
    "    y0 = Ytr_t[idx]\n",
    "    t = torch.randint(0, T, (x.size(0),))\n",
    "    noise = torch.randn_like(y0)\n",
    "    y_noisy = q_sample(y0, t, noise)\n",
    "    pred = net(y_noisy, x, t)\n",
    "    loss = nn.MSELoss()(pred, noise)\n",
    "    opt.zero_grad(); loss.backward(); opt.step()\n",
    "    if (step+1)%800==0:\n",
    "        print(\"step\", step+1, \"loss\", float(loss.detach()))\n",
    "\n",
    "# Sample motifs given expression (validation set)\n",
    "def p_sample_loop(x_cond, n_samples=1):\n",
    "    net.eval()\n",
    "    y = torch.randn((x_cond.size(0), Ym.shape[1]))\n",
    "    for t in reversed(range(T)):\n",
    "        tt = torch.full((x_cond.size(0),), t)\n",
    "        eps = net(y, x_cond, tt)\n",
    "        a = alphas[t]; ac = alphas_cum[t]\n",
    "        y = (1/torch.sqrt(a))*(y - (betas[t]/torch.sqrt(1-ac))*eps)\n",
    "        if t>0:\n",
    "            y += torch.sqrt(betas[t])*torch.randn_like(y)\n",
    "    return y\n",
    "\n",
    "with torch.no_grad():\n",
    "    Xv_t = torch.tensor(Xva)\n",
    "    y_gen = p_sample_loop(Xv_t)\n",
    "    # Compare generated to true via correlation\n",
    "    corr = np.corrcoef(y_gen.numpy().flatten(), Yva.flatten())[0,1]\n",
    "    print(\"Conditional diffusion motif correlation (val):\", float(corr))\n"
   ]
  },
