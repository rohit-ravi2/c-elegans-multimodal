   "source": [
    "# ==== CELL: Variance partitioning for Motifs (regression) & Role (classification) ====\n",
    "import numpy as np, pandas as pd\n",
    "from sklearn.linear_model import Ridge, LogisticRegression\n",
    "from sklearn.model_selection import KFold\n",
    "from sklearn.metrics import r2_score, accuracy_score\n",
    "\n",
    "# helpers\n",
    "def zscore(A): return (A - A.mean(0, keepdims=True)) / (A.std(0, keepdims=True) + 1e-6)\n",
    "\n",
    "# Features already available:\n",
    "X_expr = zscore(expr.values.astype(np.float32))                  # (N, G)\n",
    "X_deg  = zscore(deg_df.reindex(expr.index).values.astype(float)) # (N, 2)\n",
    "Y_motif = motifs.astype(np.float32)                               # (N, 5)\n",
    "\n",
    "# Behavior labels (rebuild if missing)\n",
    "try:\n",
    "    y_role  # exists\n",
    "except NameError:\n",
    "    sensory = [n for n in neurons if n.startswith((\"AF\",\"AL\",\"AS\",\"AVM\",\"AWA\",\"AWC\",\"ASE\",\"ASH\",\"URX\",\"OL\"))]\n",
    "    motor   = [n for n in neurons if n.startswith((\"DA\",\"DB\",\"DD\",\"VA\",\"VB\",\"VD\",\"AS\"))]\n",
    "    role = []\n",
    "    for n in neurons:\n",
    "        if n in sensory: role.append(0)\n",
    "        elif n in motor: role.append(2)\n",
    "        else: role.append(1)\n",
    "    y_role = np.array(role)\n",
    "\n",
    "kf = KFold(n_splits=5, shuffle=True, random_state=1337)\n",
    "\n",
    "def motif_partition():\n",
    "    res = {\"expr\":[], \"deg\":[], \"both\":[], \"expr_partial\":[], \"deg_partial\":[]}\n",
    "    for tr, va in kf.split(X_expr):\n",
    "        # train\n",
    "        m_expr = Ridge(alpha=1.0).fit(X_expr[tr], Y_motif[tr])\n",
    "        m_deg  = Ridge(alpha=1.0).fit(X_deg[tr],  Y_motif[tr])\n",
    "        m_both = Ridge(alpha=1.0).fit(np.hstack([X_expr[tr], X_deg[tr]]), Y_motif[tr])\n",
    "        # predict\n",
    "        yv = Y_motif[va]\n",
    "        r2_e = r2_score(yv, m_expr.predict(X_expr[va]))\n",
    "        r2_d = r2_score(yv, m_deg.predict(X_deg[va]))\n",
    "        r2_b = r2_score(yv, m_both.predict(np.hstack([X_expr[va], X_deg[va]])))\n",
    "        res[\"expr\"].append(r2_e); res[\"deg\"].append(r2_d); res[\"both\"].append(r2_b)\n",
    "        # partial contributions\n",
    "        res[\"expr_partial\"].append(max(0.0, r2_b - r2_d))\n",
    "        res[\"deg_partial\"].append(max(0.0, r2_b - r2_e))\n",
    "    return {k:(float(np.mean(v)), float(np.std(v))) for k,v in res.items()}\n",
    "\n",
    "def role_partition():\n",
    "    res = {\"expr\":[], \"deg\":[], \"both\":[], \"expr_partial\":[], \"deg_partial\":[]}\n",
    "    for tr, va in kf.split(X_expr):\n",
    "        # classifiers\n",
    "        c_expr = LogisticRegression(max_iter=200, multi_class=\"multinomial\").fit(X_expr[tr], y_role[tr])\n",
    "        c_deg  = LogisticRegression(max_iter=200, multi_class=\"multinomial\").fit(X_deg[tr],  y_role[tr])\n",
    "        c_both = LogisticRegression(max_iter=200, multi_class=\"multinomial\").fit(np.hstack([X_expr[tr], X_deg[tr]]), y_role[tr])\n",
    "        yv = y_role[va]\n",
    "        a_e = accuracy_score(yv, c_expr.predict(X_expr[va]))\n",
    "        a_d = accuracy_score(yv, c_deg.predict(X_deg[va]))\n",
    "        a_b = accuracy_score(yv, c_both.predict(np.hstack([X_expr[va], X_deg[va]])))\n",
    "        res[\"expr\"].append(a_e); res[\"deg\"].append(a_d); res[\"both\"].append(a_b)\n",
    "        # partial (Δaccuracy)\n",
    "        res[\"expr_partial\"].append(max(0.0, a_b - a_d))\n",
    "        res[\"deg_partial\"].append(max(0.0, a_b - a_e))\n",
    "    return {k:(float(np.mean(v)), float(np.std(v))) for k,v in res.items()}\n",
    "\n",
    "motif_var = motif_partition()\n",
    "role_var  = role_partition()\n",
    "print(\"== Motif variance partition (R² mean±sd) ==\"); print(motif_var)\n",
    "print(\"\\n== Role variance partition (Acc mean±sd) ==\"); print(role_var)\n"
   ]
  },
  {
