    "# === TASK C: Predict Synapse Sign (proxy) ===\n",
    "inh = [c for c in expr.columns if c.startswith((\"UNC-25\",\"GAD\",\"VGAT\",\"SNF-11\"))]\n",
    "exc = [c for c in expr.columns if c.startswith((\"CHA-1\",\"UNC-17\",\"EAT-4\",\"GLT\"))]\n",
    "score = zexpr[exc].mean(1).fillna(0) - zexpr[inh].mean(1).fillna(0)\n",
    "y_sign = (score >= 0).astype(int).values\n",
    "\n",
    "scoresC=[run_foldB(*split) for split in kf.split(X)]\n",
    "print(\"Mean AUC (sign):\",np.mean([s[\"auc\"] for s in scoresC]))\n"
