   "source": [
    "# === FULL SYNC + SAFE MOTIF REBUILD ===\n",
    "\n",
    "print(f\"Before sync: {len(neurons)} neurons listed, {G.number_of_nodes()} nodes in graph.\")\n",
    "\n",
    "# keep only neurons actually present in the graph\n",
    "neurons = [n for n in neurons if n in G.nodes()]\n",
    "print(f\"✅ After sync: {len(neurons)} neurons retained inside graph.\")\n",
    "\n",
    "# restrict degree table and expression to same index\n",
    "deg_df = deg_df.loc[deg_df.index.intersection(neurons)]\n",
    "expr   = expr.loc[expr.index.intersection(neurons)]\n",
    "\n",
    "def motif_counts_synced(G, neurons):\n",
    "    \"\"\"Compute basic motif participation counts safely.\"\"\"\n",
    "    idx = {n:i for i,n in enumerate(neurons)}\n",
    "    M = np.zeros((len(neurons),5),dtype=np.float32)\n",
    "    # 0 reciprocal, 1 chain, 2 feedforward, 3 divergent, 4 convergent\n",
    "    for u,v in G.edges():\n",
    "        if u not in idx or v not in idx: continue\n",
    "        if G.has_edge(v,u):\n",
    "            M[idx[u],0]+=1; M[idx[v],0]+=1\n",
    "    for a in neurons:\n",
    "        outs = set(G.successors(a)) if a in G else set()\n",
    "        ins  = set(G.predecessors(a)) if a in G else set()\n",
    "        if len(outs)>1: M[idx[a],3]+=len(outs)\n",
    "        if len(ins)>1:  M[idx[a],4]+=len(ins)\n",
    "        for b in outs:\n",
    "            if b not in G: continue\n",
    "            outs_b = set(G.successors(b))\n",
    "            M[idx[a],1]+=len(outs_b)\n",
    "            M[idx[a],2]+=len(outs.intersection(outs_b))\n",
    "    return (M - M.mean(0)) / (M.std(0)+1e-6)\n",
    "\n",
    "motifs = motif_counts_synced(G, neurons)\n",
    "print(f\"✅ Motif matrix rebuilt: {motifs.shape}\")\n"
   ]
  },
