   "source": [
    "# ============================================================\n",
    "# 📘 Cell H (final robust) — GO / KEGG Biological Enrichment\n",
    "# ============================================================\n",
    "\n",
    "import pandas as pd\n",
    "import mygene\n",
    "import matplotlib.pyplot as plt\n",
    "from collections import Counter\n",
    "from pathlib import Path\n",
    "import time\n",
    "\n",
    "EXPERIMENTS_OUT = Path(\"/mnt/ssd4tb/Desktop/C-Elegans/data/processed/experiments\")\n",
    "\n",
    "# 1️⃣ Load top genes\n",
    "sal_df = pd.read_csv(EXPERIMENTS_OUT / \"gnca_saliency_genes.csv\")\n",
    "ig_df  = pd.read_csv(EXPERIMENTS_OUT / \"gnca_integrated_gradients_genes.csv\")\n",
    "\n",
    "TOP_N = 200\n",
    "top_genes = pd.concat([\n",
    "    sal_df.head(TOP_N)[\"gene\"],\n",
    "    ig_df.head(TOP_N)[\"gene\"]\n",
    "]).drop_duplicates().tolist()\n",
    "print(f\"Analyzing {len(top_genes)} top-ranked GNCA genes\")\n",
    "\n",
    "# 2️⃣ Query MyGene.info\n",
    "mg = mygene.MyGeneInfo()\n",
    "fields = \"go.BP,go.MF,go.CC,pathway.kegg\"\n",
    "species_id = 6239  # C. elegans\n",
    "\n",
    "try:\n",
    "    results = mg.querymany(top_genes, scopes=\"wormbase\", species=species_id,\n",
    "                           fields=fields, as_dataframe=True, verbose=False)\n",
    "except Exception as e:\n",
    "    print(f\"⚠️ Query failed ({e}); retrying with broader scopes ...\")\n",
    "    time.sleep(2)\n",
    "    results = mg.querymany(top_genes, scopes=\"symbol,entrezgene,ensemblgene\",\n",
    "                           species=species_id, fields=fields, as_dataframe=True, verbose=False)\n",
    "\n",
    "print(\"✅ Retrieved annotations with columns:\", list(results.columns))\n",
    "\n",
    "# 3️⃣  Helper to flatten any format\n",
    "def flatten_terms(col_candidates):\n",
    "    \"\"\"Extract all term names from whichever column exists.\"\"\"\n",
    "    for c in col_candidates:\n",
    "        if c in results.columns:\n",
    "            vals = results[c].dropna().values\n",
    "            out = []\n",
    "            for v in vals:\n",
    "                if isinstance(v, list):\n",
    "                    for item in v:\n",
    "                        if isinstance(item, dict):\n",
    "                            out.append(item.get(\"term\") or item.get(\"name\") or str(item))\n",
    "                        else:\n",
    "                            out.append(str(item))\n",
    "                elif isinstance(v, dict):\n",
    "                    out.append(v.get(\"term\") or v.get(\"name\") or str(v))\n",
    "                else:\n",
    "                    out.append(str(v))\n",
    "            return out\n",
    "    return []\n",
    "\n",
    "# 4️⃣  Extract and count\n",
    "go_bp = flatten_terms([\"go.BP.name\", \"go.BP\"])\n",
    "go_mf = flatten_terms([\"go.MF.name\", \"go.MF\"])\n",
    "go_cc = flatten_terms([\"go.CC.name\", \"go.CC\"])\n",
    "kegg  = flatten_terms([\"pathway.kegg.name\", \"pathway.kegg\"])\n",
    "\n",
    "def top_terms(term_list, label, n=15):\n",
    "    if not term_list:\n",
    "        return pd.DataFrame(columns=[label, \"count\"])\n",
    "    counts = Counter(term_list)\n",
    "    df = pd.DataFrame(counts.most_common(n), columns=[label, \"count\"])\n",
    "    return df\n",
    "\n",
    "bp_df = top_terms(go_bp, \"GO Biological Process\")\n",
    "mf_df = top_terms(go_mf, \"GO Molecular Function\")\n",
    "cc_df = top_terms(go_cc, \"GO Cellular Component\")\n",
    "kg_df = top_terms(kegg,  \"KEGG Pathway\")\n",
    "\n",
    "# 5️⃣ Plot\n",
    "def plot_enrichment(df, title, color):\n",
    "    if df.empty:\n",
    "        print(f\"(no {title} terms found)\")\n",
    "        return\n",
    "    plt.figure(figsize=(8,4))\n",
    "    plt.barh(df.iloc[::-1,0], df.iloc[::-1,1], color=color)\n",
    "    plt.xlabel(\"Frequency among top genes\")\n",
    "    plt.title(title)\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "plot_enrichment(bp_df, \"GO: Biological Process\", \"seagreen\")\n",
    "plot_enrichment(mf_df, \"GO: Molecular Function\", \"mediumblue\")\n",
    "plot_enrichment(cc_df, \"GO: Cellular Component\", \"purple\")\n",
    "plot_enrichment(kg_df, \"KEGG Pathway\", \"orange\")\n",
    "\n",
    "# 6️⃣ Save\n",
    "out_path = EXPERIMENTS_OUT / \"gnca_go_kegg_enrichment_final.xlsx\"\n",
    "with pd.ExcelWriter(out_path) as writer:\n",
    "    bp_df.to_excel(writer, sheet_name=\"GO_BP\", index=False)\n",
    "    mf_df.to_excel(writer, sheet_name=\"GO_MF\", index=False)\n",
    "    cc_df.to_excel(writer, sheet_name=\"GO_CC\", index=False)\n",
    "    kg_df.to_excel(writer, sheet_name=\"KEGG\", index=False)\n",
    "print(f\"✅ Saved enrichment tables → {out_path}\")\n"
   ]
  },
