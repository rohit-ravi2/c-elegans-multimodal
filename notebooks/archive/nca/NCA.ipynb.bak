    "import pandas as pd\n",
    "from pathlib import Path\n",
    "from tqdm import tqdm\n",
    "\n",
    "# Paths\n",
    "edges_path = Path(\"/mnt/ssd4tb/Desktop/C-Elegans/data/processed/csv/merged_edges_with_relatedness.csv\")\n",
    "motif_path = Path(\"/mnt/ssd4tb/Desktop/C-Elegans/data/processed/motifs/motif_matrix.csv\")\n",
    "\n",
    "# Load and clean\n",
    "edges = pd.read_csv(edges_path)\n",
    "edges[\"Source\"] = edges[\"Source\"].astype(str).str.strip().str.upper()\n",
    "edges[\"Target\"] = edges[\"Target\"].astype(str).str.strip().str.upper()\n",
    "\n",
    "neurons = sorted(set(edges[\"Source\"]) | set(edges[\"Target\"]))\n",
    "motif_df = pd.DataFrame(0, index=neurons, columns=[\"reciprocal\", \"chain\", \"feedforward\", \"divergent\", \"convergent\"])\n",
    "\n",
    "print(f\"Building motif matrix for {len(neurons)} neurons and {len(edges)} edges…\")\n",
    "\n",
    "# --- Divergent / Convergent / Reciprocal ---\n",
    "for _, row in tqdm(edges.iterrows(), total=len(edges), desc=\"Stage 1: Divergent+Convergent+Reciprocal\"):\n",
    "    src, tgt = row[\"Source\"], row[\"Target\"]\n",
    "    motif_df.loc[src, \"divergent\"] += 1\n",
    "    motif_df.loc[tgt, \"convergent\"] += 1\n",
    "    if (edges[\"Source\"].eq(tgt) & edges[\"Target\"].eq(src)).any():\n",
    "        motif_df.loc[src, \"reciprocal\"] += 1\n",
    "        motif_df.loc[tgt, \"reciprocal\"] += 1\n",
    "\n",
    "# --- Chain and Feed-forward ---\n",
    "for n in tqdm(neurons, desc=\"Stage 2: Chain+Feedforward\"):\n",
    "    downstream = edges.loc[edges[\"Source\"] == n, \"Target\"].tolist()\n",
    "    for t in downstream:\n",
    "        second_hop = edges.loc[edges[\"Source\"] == t, \"Target\"].tolist()\n",
    "        for u in second_hop:\n",
    "            if n != u:\n",
    "                motif_df.loc[n, \"chain\"] += 1\n",
    "                motif_df.loc[u, \"feedforward\"] += 1\n",
    "\n",
    "# Normalize\n",
    "motif_df = (motif_df > 0).astype(int)\n",
    "\n",
    "# Save\n",
    "motif_df.to_csv(motif_path)\n",
    "print(f\"\\n✅ Rebuilt motif matrix → {motif_path}\")\n",
    "print(f\"Shape: {motif_df.shape}\")\n",
    "print(\"Motif counts:\")\n",
    "print(motif_df.sum())\n"
   ]
  },
