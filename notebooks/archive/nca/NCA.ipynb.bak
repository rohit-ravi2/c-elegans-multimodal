   "source": [
    "from Bio import SeqIO\n",
    "\n",
    "fasta_path = \"caenorhabditis_elegans.PRJNA13758.WBPS19.genomic.fa\"\n",
    "\n",
    "# Count and preview first few records\n",
    "records = SeqIO.parse(fasta_path, \"fasta\")\n",
    "for i, rec in enumerate(records):\n",
    "    print(f\"{i+1:3d}. {rec.id:30s} length={len(rec.seq)}\")\n",
    "    if i >= 9:\n",
    "        break\n"
   ]
