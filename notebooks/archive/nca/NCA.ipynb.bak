   "source": [
    "# Cell D-prep — Rebuild motif_matrix.csv from connectome\n",
    "import pandas as pd, numpy as np, networkx as nx\n",
    "from pathlib import Path\n",
    "from tqdm import tqdm\n",
    "\n",
    "DATA_ROOT = Path(\"/mnt/ssd4tb/Desktop/C-Elegans/data\")\n",
    "edges_path = DATA_ROOT / \"processed\" / \"csv\" / \"merged_edges_with_relatedness.csv\"\n",
    "motif_out = DATA_ROOT / \"processed\" / \"motifs\" / \"motif_matrix.csv\"\n",
    "motif_out.parent.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "# === 1️⃣ Load connectome edges ===\n",
    "edges = pd.read_csv(edges_path)\n",
    "print(\"Loaded edges:\", edges.shape)\n",
    "print(\"Columns:\", edges.columns.tolist())\n",
    "\n",
    "# Expect: ['Source', 'Target', 'Type', 'SynapseCount', 'SourceFile', 'Relatedness']\n",
    "G = nx.DiGraph()\n",
    "for _, r in edges.iterrows():\n",
    "    G.add_edge(r[\"Source\"], r[\"Target\"], weight=r.get(\"SynapseCount\", 1.0))\n",
    "\n",
    "print(f\"Graph built: {G.number_of_nodes()} neurons, {G.number_of_edges()} synapses\")\n",
    "\n",
    "# === 2️⃣ Compute motif participation ===\n",
    "# We'll detect: 0=reciprocal, 1=chain (A→B→C), 2=feedforward loop (A→B, A→C, B→C),\n",
    "# 3=divergent (A→B, A→C), 4=convergent (A→C, B→C)\n",
    "motif_names = [\"reciprocal\", \"chain\", \"feedforward\", \"divergent\", \"convergent\"]\n",
    "motif_participation = {n: np.zeros(len(motif_names), dtype=int) for n in G.nodes()}\n",
    "\n",
    "nodes = list(G.nodes())\n",
    "for i, a in enumerate(tqdm(nodes, desc=\"Scanning motifs\")):\n",
    "    for b in G.successors(a):\n",
    "        # reciprocal\n",
    "        if G.has_edge(b, a):\n",
    "            motif_participation[a][0] = 1\n",
    "            motif_participation[b][0] = 1\n",
    "        # divergent (A→B, A→C)\n",
    "        for c in G.successors(a):\n",
    "            if b != c:\n",
    "                motif_participation[a][3] = 1\n",
    "                motif_participation[b][4] = 1  # B as convergent input target\n",
    "                motif_participation[c][4] = 1\n",
    "                # feedforward (A→B, A→C, B→C)\n",
    "                if G.has_edge(b, c):\n",
    "                    motif_participation[a][2] = 1\n",
    "                    motif_participation[b][1] = 1  # part of chain\n",
    "                    motif_participation[c][4] = 1\n",
    "        # chain (A→B→C)\n",
    "        for c in G.successors(b):\n",
    "            if c != a:\n",
    "                motif_participation[a][1] = 1\n",
    "                motif_participation[b][1] = 1\n",
    "                motif_participation[c][1] = 1\n",
    "\n",
    "# === 3️⃣ Save neuron × motif matrix ===\n",
    "motif_df = pd.DataFrame.from_dict(motif_participation, orient=\"index\", columns=motif_names)\n",
    "motif_df.index.name = \"Neuron\"\n",
    "motif_df.to_csv(motif_out)\n",
    "print(f\"✅ Saved motif matrix → {motif_out}\")\n",
    "print(motif_df.sum().to_string())\n",
    "print(\"Matrix shape:\", motif_df.shape)\n"
   ]
  },
