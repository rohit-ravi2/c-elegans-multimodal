   ],
   "source": [
    "# ============================================================\n",
    "# 🧬 Cell G — Biological Context Mapping & Neurotransmitter Enrichment\n",
    "# ============================================================\n",
    "# Goal: Compare GNCA's top-ranked genes (saliency + IG) with known\n",
    "# CeNGEN neurotransmitter and neuropeptide marker sets.\n",
    "\n",
    "import pandas as pd\n",
    "from pathlib import Path\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "EXPERIMENTS_OUT = Path(\"/mnt/ssd4tb/Desktop/C-Elegans/data/processed/experiments\")\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 1️⃣  Load GNCA feature importance tables\n",
    "# ------------------------------------------------------------\n",
    "sal_path = EXPERIMENTS_OUT / \"gnca_saliency_genes.csv\"\n",
    "ig_path  = EXPERIMENTS_OUT / \"gnca_integrated_gradients_genes.csv\"\n",
    "\n",
    "sal_df = pd.read_csv(sal_path)\n",
    "ig_df  = pd.read_csv(ig_path)\n",
    "\n",
    "# Top-N selection\n",
    "TOP_N = 100\n",
    "sal_top = set(sal_df.head(TOP_N)[\"gene\"])\n",
    "ig_top  = set(ig_df.head(TOP_N)[\"gene\"])\n",
    "combined_top = sal_top.union(ig_top)\n",
    "print(f\"Loaded {len(sal_df)} saliency and {len(ig_df)} IG genes | {len(combined_top)} unique top candidates\")\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 2️⃣  Define canonical neurotransmitter / neuropeptide marker sets\n",
    "# ------------------------------------------------------------\n",
    "marker_sets = {\n",
    "    \"serotonin\": {\n",
    "        \"tph-1\", \"cat-4\", \"bas-1\", \"mod-5\", \"ser-4\", \"ser-1\", \"ser-7\"\n",
    "    },\n",
    "    \"dopamine\": {\n",
    "        \"cat-2\", \"cat-4\", \"bas-1\", \"dat-1\", \"dop-1\", \"dop-2\", \"dop-3\", \"dop-4\"\n",
    "    },\n",
    "    \"acetylcholine\": {\n",
    "        \"cha-1\", \"unc-17\", \"ace-1\", \"ace-2\", \"cho-1\", \"gar-1\", \"gar-2\"\n",
    "    },\n",
    "    \"GABA\": {\n",
    "        \"unc-25\", \"unc-47\", \"snf-11\", \"gab-1\", \"exp-1\", \"lgc-35\"\n",
    "    },\n",
    "    \"glutamate\": {\n",
    "        \"eat-4\", \"glr-1\", \"glr-2\", \"nmr-1\", \"avr-14\", \"avr-15\"\n",
    "    },\n",
    "    \"neuropeptide\": {\n",
    "        \"flp-1\", \"flp-3\", \"flp-10\", \"nlp-1\", \"nlp-3\", \"nlp-12\", \"nlp-21\"\n",
    "    },\n",
    "    \"mechanosensory/adhesion\": {\n",
    "        \"mec-3\", \"mec-4\", \"mec-7\", \"mec-10\", \"mec-17\", \"unc-6\", \"unc-40\"\n",
    "    }\n",
    "}\n",
    "\n",
    "# optional: mapping from WormBase IDs to names if file exists\n",
    "map_path = Path(\"/mnt/ssd4tb/Desktop/C-Elegans/data/genomes/gene_name_map.tsv\")\n",
    "if map_path.exists():\n",
    "    try:\n",
    "        map_df = pd.read_csv(map_path, sep=\"\\t\")\n",
    "        map_df.columns = [c.lower() for c in map_df.columns]\n",
    "        wb_col = [c for c in map_df.columns if \"wb\" in c or \"wormbase\" in c][0]\n",
    "        name_col = [c for c in map_df.columns if \"gene\" in c][0]\n",
    "        id2name = dict(zip(map_df[wb_col], map_df[name_col]))\n",
    "        # Map to gene names if possible\n",
    "        combined_top_named = {id2name.get(g, g) for g in combined_top}\n",
    "    except Exception as e:\n",
    "        print(f\"⚠️ Mapping skipped ({e})\")\n",
    "        combined_top_named = combined_top\n",
    "else:\n",
    "    combined_top_named = combined_top\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 3️⃣  Compute enrichment counts\n",
    "# ------------------------------------------------------------\n",
    "enrichment = []\n",
    "for system, markers in marker_sets.items():\n",
    "    hits = [g for g in combined_top_named if g.lower() in markers]\n",
    "    enrichment.append({\n",
    "        \"system\": system,\n",
    "        \"hits\": len(hits),\n",
    "        \"hit_genes\": \", \".join(hits)\n",
    "    })\n",
    "\n",
    "enrich_df = pd.DataFrame(enrichment).sort_values(\"hits\", ascending=False)\n",
    "display(enrich_df)\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 4️⃣  Plot enrichment summary\n",
    "# ------------------------------------------------------------\n",
    "plt.figure(figsize=(8,4))\n",
    "plt.barh(enrich_df[\"system\"], enrich_df[\"hits\"], color=\"forestgreen\")\n",
    "plt.gca().invert_yaxis()\n",
    "plt.xlabel(\"Hits in top-ranked GNCA genes\")\n",
    "plt.title(f\"Neurotransmitter/Peptide Enrichment (Top {TOP_N})\")\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Save results\n",
    "out_path = EXPERIMENTS_OUT / \"gnca_neurotransmitter_enrichment.csv\"\n",
    "enrich_df.to_csv(out_path, index=False)\n",
    "print(f\"✅ Saved enrichment summary → {out_path}\")\n"
   ]
  },
