   "source": [
    "import pandas as pd, gzip, io, requests\n",
    "\n",
    "# Latest release (update WS290 to newer if needed)\n",
    "url = \"https://ftp.wormbase.org/pub/wormbase/species/c_elegans/annotation/c_elegans.PRJNA13758.WS290.geneIDs.txt.gz\"\n",
    "\n",
    "print(\"Downloading mapping from WormBase...\")\n",
    "r = requests.get(url, timeout=120)\n",
    "r.raise_for_status()\n",
    "\n",
    "with gzip.open(io.BytesIO(r.content), \"rt\") as f:\n",
    "    mapping = pd.read_csv(f, sep=\"\\t\", header=None, names=[\"WBGeneID\",\"SeqName\",\"GeneName\"])\n",
    "\n",
    "print(\"✅ Mapping loaded:\", mapping.shape)\n",
    "display(mapping.head())\n",
    "\n",
    "# Merge with your stability table\n",
    "mapped = stable_tbl.copy()\n",
    "mapped.index.name = \"WBGeneID\"\n",
    "mapped = mapped.reset_index().merge(mapping[[\"WBGeneID\",\"GeneName\"]], on=\"WBGeneID\", how=\"left\")\n",
    "mapped = mapped.set_index(\"GeneName\").drop(columns=[\"WBGeneID\"])\n",
    "display(mapped.head(20))\n"
   ]
  },
