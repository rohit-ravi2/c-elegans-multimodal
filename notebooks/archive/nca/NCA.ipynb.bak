   "source": [
    "# === TASK B: Predict Neuropeptide Expression (binary) ===\n",
    "from sklearn.metrics import roc_auc_score, average_precision_score, f1_score\n",
    "\n",
    "peptide_genes = [c for c in expr.columns if c.startswith((\"NLP-\",\"FLP-\",\"INS-\"))]\n",
    "zexpr = (expr - expr.mean()) / (expr.std()+1e-6)\n",
    "y_pep = (zexpr[peptide_genes].max(1) > 1.0).astype(int).values\n",
    "\n",
    "kf = KFold(n_splits=5, shuffle=True, random_state=1337)\n",
    "def run_foldB(tr,va):\n",
    "    model = nn.Sequential(\n",
    "        nn.Linear(X.shape[1],128), nn.ReLU(),\n",
    "        nn.Linear(128,64), nn.ReLU(),\n",
    "        nn.Linear(64,1)\n",
    "    )\n",
    "    opt = torch.optim.Adam(model.parameters(), lr=2e-3)\n",
    "    crit = nn.BCEWithLogitsLoss()\n",
    "    Xt = torch.tensor(X[tr],dtype=torch.float32)\n",
    "    yt = torch.tensor(y_pep[tr,None],dtype=torch.float32)\n",
    "    Xv = torch.tensor(X[va],dtype=torch.float32)\n",
    "    yv = y_pep[va]\n",
    "    for ep in range(80):\n",
    "        model.train(); opt.zero_grad()\n",
    "        loss = crit(model(Xt),yt); loss.backward(); opt.step()\n",
    "    model.eval(); p = torch.sigmoid(model(Xv)).detach().numpy().ravel()\n",
    "    return {\n",
    "        \"auc\":roc_auc_score(yv,p),\n",
    "        \"ap\":average_precision_score(yv,p),\n",
    "        \"f1\":f1_score(yv,(p>0.5).astype(int))\n",
    "    }\n",
    "\n",
    "scores=[run_foldB(*split) for split in kf.split(X)]\n",
    "print(\"Mean AUC:\",np.mean([s[\"auc\"] for s in scores]))\n"
   ]
  },
