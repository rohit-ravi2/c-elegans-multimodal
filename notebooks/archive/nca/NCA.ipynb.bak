    "# ==== CELL: CCA alignment between expression and motif spaces ====\n",
    "from sklearn.cross_decomposition import CCA\n",
    "\n",
    "p_expr = PCA(n_components=50, random_state=0).fit_transform(X_expr)\n",
    "p_mtf  = PCA(n_components=5,  random_state=0).fit_transform(Y_motif)\n",
    "\n",
    "cca = CCA(n_components=3, max_iter=1000)\n",
    "U, V = cca.fit_transform(p_expr, p_mtf)\n",
    "cc = [np.corrcoef(U[:,i], V[:,i])[0,1] for i in range(U.shape[1])]\n",
    "print(\"Canonical correlations (expr <-> motif):\", [round(float(c),3) for c in cc])\n"
   ]
  },
