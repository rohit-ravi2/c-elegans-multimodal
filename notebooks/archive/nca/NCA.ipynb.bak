   "source": [
    "# ==== CELL: In-silico gene KO experiment (ΔMotif vs ΔRole) ====\n",
    "import numpy as np\n",
    "from sklearn.model_selection import train_test_split\n",
    "\n",
    "# pick top-variance genes as candidates (or your prior list)\n",
    "gene_var = expr.var(0).sort_values(ascending=False)\n",
    "ko_genes = list(gene_var.head(20).index)[:10]  # 10 genes\n",
    "\n",
    "# small train/val split\n",
    "tr_idx, va_idx = train_test_split(np.arange(len(neurons)), test_size=0.3, random_state=42, stratify=y_role)\n",
    "\n",
    "def fit_motif_regressor(Xe):\n",
    "    model = Ridge(alpha=1.0).fit(np.hstack([Xe[tr_idx], X_deg[tr_idx]]), Y_motif[tr_idx])\n",
    "    pv = model.predict(np.hstack([Xe[va_idx], X_deg[va_idx]]))\n",
    "    r2 = r2_score(Y_motif[va_idx], pv)\n",
    "    return r2\n",
    "\n",
    "def fit_role_classifier(Xe):\n",
    "    clf = LogisticRegression(max_iter=300, multi_class=\"multinomial\").fit(np.hstack([Xe[tr_idx], X_deg[tr_idx]]), y_role[tr_idx])\n",
    "    acc = accuracy_score(y_role[va_idx], clf.predict(np.hstack([Xe[va_idx], X_deg[va_idx]])))\n",
    "    return acc\n",
    "\n",
    "# baseline\n",
    "Xe_base = X_expr.copy()\n",
    "base_motif = fit_motif_regressor(Xe_base)\n",
    "base_role  = fit_role_classifier(Xe_base)\n",
    "\n",
    "effects = []\n",
    "for g in ko_genes:\n",
    "    Xe = Xe_base.copy()\n",
    "    j = expr.columns.get_loc(g)\n",
    "    Xe[:, j] = 0.0  # gene \"KO\"\n",
    "    effects.append({\n",
    "        \"gene\": g,\n",
    "        \"dR2_motif\": fit_motif_regressor(Xe) - base_motif,\n",
    "        \"dACC_role\":  fit_role_classifier(Xe) - base_role\n",
    "    })\n",
    "\n",
    "effects_df = pd.DataFrame(effects).sort_values(\"dR2_motif\")\n",
    "print(\"KO effects (negative means performance drop):\")\n",
    "display(effects_df)\n"
   ]
  },
