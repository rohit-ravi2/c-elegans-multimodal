    "# CELL 0: Config & utils\n",
    "import os, json, math, random, gc, time\n",
    "from dataclasses import dataclass\n",
    "import numpy as np, pandas as pd, networkx as nx\n",
    "\n",
    "import torch\n",
    "from torch import nn\n",
    "from torch.utils.data import Dataset, DataLoader\n",
    "\n",
    "RNG_SEED = 1337\n",
    "random.seed(RNG_SEED); np.random.seed(RNG_SEED); torch.manual_seed(RNG_SEED)\n",
    "\n",
    "@dataclass\n",
    "class CFG:\n",
    "    ROOT: str = \"./\"\n",
    "    DATA: str = \"./DATA_PROCESSED\"\n",
    "    OUT: str = \"./ARTIFACTS\"\n",
    "    BATCH: int = 64\n",
    "    EPOCHS: int = 150\n",
    "    LR: float = 2e-3\n",
    "    WD: float = 1e-3\n",
    "    STEPS: int = 8           # NCA unroll steps\n",
    "    HIDDEN: int = 64\n",
    "    DROPOUT: float = 0.10\n",
    "    KFOLDS: int = 5\n",
    "    DEVICE: str = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n",
    "\n",
    "os.makedirs(CFG.OUT, exist_ok=True)\n",
    "\n",
    "def save_json(obj, path):\n",
    "    with open(path, \"w\") as f: json.dump(obj, f, indent=2)\n",
    "\n",
    "def bootstrap_ci(arr, iters=2000, alpha=0.05):\n",
    "    arr = np.asarray(arr)\n",
    "    n = len(arr)\n",
    "    boots = []\n",
    "    for _ in range(iters):\n",
    "        s = np.random.choice(arr, size=n, replace=True)\n",
    "        boots.append(np.mean(s))\n",
    "    lo = np.quantile(boots, alpha/2); hi = np.quantile(boots, 1-alpha/2)\n",
    "    return float(np.mean(arr)), float(lo), float(hi)\n",
    "\n",
    "def spearmanr(x, y):\n",
    "    rx = pd.Series(x).rank().values\n",
    "    ry = pd.Series(y).rank().values\n",
    "    return np.corrcoef(rx, ry)[0,1]\n"
   ]
  },
