    "# Fix neuron name mismatch (trim whitespace, unify case, align)\n",
    "import pandas as pd\n",
    "from pathlib import Path\n",
    "\n",
    "motif_path = Path(\"/mnt/ssd4tb/Desktop/C-Elegans/data/processed/motifs/motif_matrix.csv\")\n",
    "motif_df = pd.read_csv(motif_path, index_col=0)\n",
    "print(\"Original motif_df shape:\", motif_df.shape)\n",
    "\n",
    "# Clean neuron labels (strip spaces, unify uppercase)\n",
    "motif_df.index = motif_df.index.astype(str).str.strip().str.upper()\n",
    "expr_df.index = expr_df.index.astype(str).str.strip().str.upper()\n",
    "\n",
    "# Find intersection\n",
    "common_neurons = sorted(set(expr_df.index) & set(motif_df.index))\n",
    "print(f\"Found {len(common_neurons)} overlapping neurons out of {len(expr_df)} expr entries\")\n",
    "\n",
    "# Subset both\n",
    "motif_df = motif_df.loc[common_neurons]\n",
    "expr_df = expr_df.loc[common_neurons]\n",
    "\n",
    "# Sanity check\n",
    "print(\"Aligned motif_df shape:\", motif_df.shape)\n",
    "print(\"Aligned expr_df shape:\", expr_df.shape)\n",
    "print(\"Motif head:\\n\", motif_df.head())\n",
    "\n",
    "# Save cleaned motif matrix back\n",
    "motif_df.to_csv(motif_path)\n",
    "print(f\"✅ Cleaned and aligned motif matrix saved → {motif_path}\")\n"
   ]
