   "source": [
    "# === UNIVERSAL CONTINUATION BLOCK ===\n",
    "# Integrates with previous NCA notebook variables\n",
    "import pandas as pd, numpy as np, networkx as nx, torch, torch.nn as nn\n",
    "from sklearn.metrics import mean_absolute_error, roc_auc_score, average_precision_score, f1_score\n",
    "\n",
    "# --- 1. Auto-detect existing variables ---\n",
    "def detect_existing_data():\n",
    "    g, e, x = None, None, None\n",
    "    globals_ = globals()\n",
    "    for cand in ['edges','edge_df','E','connectome_edges','edges_df']:\n",
    "        if cand in globals_:\n",
    "            e = globals_[cand]\n",
    "            break\n",
    "    for cand in ['expr','expression','expr_df','X','cengen_expr']:\n",
    "        if cand in globals_:\n",
    "            x = globals_[cand]\n",
    "            break\n",
    "    for cand in ['G','graph','connectome_graph','nxG']:\n",
    "        if cand in globals_:\n",
    "            g = globals_[cand]\n",
    "            break\n",
    "    return x,e,g\n",
    "\n",
    "expr, edges, G_existing = detect_existing_data()\n",
    "assert expr is not None, \"Expression dataframe (expr) not found—please ensure your existing variable is named expr.\"\n",
    "assert edges is not None, \"Edges dataframe (edges) not found—please ensure your existing variable is named edges.\"\n",
    "\n",
    "# --- 2. Canonicalize neuron IDs ---\n",
    "def canon(s): return str(s).strip().upper().replace(\"  \",\" \")\n",
    "edges = edges.copy()\n",
    "edges.columns = [c.lower().strip() for c in edges.columns]\n",
    "if 'source' not in edges.columns or 'target' not in edges.columns:\n",
    "    for c in edges.columns:\n",
    "        if 'pre' in c: edges = edges.rename(columns={c:'source'})\n",
    "        if 'post' in c: edges = edges.rename(columns={c:'target'})\n",
    "expr = expr.copy()\n",
    "edges['source'] = edges['source'].map(canon)\n",
    "edges['target'] = edges['target'].map(canon)\n",
    "expr.index = expr.index.map(canon)\n",
    "neurons = sorted(set(edges['source']).union(edges['target']))\n",
    "expr = expr.loc[expr.index.intersection(neurons)]\n",
    "print(f\"✅ Using {expr.shape[0]} neurons × {expr.shape[1]} genes; {len(edges)} edges\")\n",
    "\n",
    "# --- 3. Build base graph if not present ---\n",
    "if G_existing is None:\n",
    "    G = nx.DiGraph()\n",
    "    for _,r in edges.iterrows():\n",
    "        G.add_edge(r['source'], r['target'], w=float(r.get('synapsecount',1)))\n",
    "else:\n",
    "    G = G_existing\n",
    "\n",
    "# --- PATCHED DEGREE FEATURE BUILDER ---\n",
    "\n",
    "# --- FINAL PATCHED DEGREE FEATURE BUILDER (robust for any graph type) ---\n",
    "\n",
    "in_deg = []\n",
    "out_deg = []\n",
    "\n",
    "for n in neurons:\n",
    "    # compute weighted degrees if weights exist\n",
    "    indeg_val = 0.0\n",
    "    outdeg_val = 0.0\n",
    "\n",
    "    # Defensive: iterate edges manually to avoid view objects\n",
    "    if G.is_directed():\n",
    "        # incoming edges\n",
    "        for _, src, data in G.in_edges(n, data=True):\n",
    "            indeg_val += float(data.get(\"w\", 1.0))\n",
    "        # outgoing edges\n",
    "        for _, tgt, data in G.out_edges(n, data=True):\n",
    "            outdeg_val += float(data.get(\"w\", 1.0))\n",
    "    else:\n",
    "        # undirected fallback\n",
    "        for _, _, data in G.edges(n, data=True):\n",
    "            indeg_val += float(data.get(\"w\", 1.0))\n",
    "            outdeg_val = indeg_val\n",
    "\n",
    "    in_deg.append(indeg_val)\n",
    "    out_deg.append(outdeg_val)\n",
    "\n",
    "deg_df = pd.DataFrame({\"in_deg\": in_deg, \"out_deg\": out_deg}, index=neurons)\n",
    "deg_df = (deg_df - deg_df.mean(numeric_only=True)) / (deg_df.std(numeric_only=True) + 1e-6)\n",
    "\n",
    "print(f\"✅ Degree features built: {deg_df.shape}\")\n",
    "display(deg_df.head())\n",
    "\n",
    "\n",
    "# --- FINAL MOTIF CLEANUP AND SAFEGUARD ---\n",
    "# Remove old motif_counts from memory so it can’t be accidentally called\n",
    "if 'motif_counts' in globals():\n",
    "    del motif_counts\n",
    "\n",
    "# Ensure neurons, expr, deg_df all aligned to graph\n",
    "neurons = [n for n in expr.index if n in G.nodes()]\n",
    "expr   = expr.loc[neurons]\n",
    "deg_df = deg_df.loc[deg_df.index.intersection(neurons)]\n",
    "\n",
    "# Define the single correct motif function\n",
    "def motif_counts_safe(G, neurons):\n",
    "    idx = {n:i for i,n in enumerate(neurons)}\n",
    "    M = np.zeros((len(neurons),5),dtype=np.float32)\n",
    "    for u,v in G.edges():\n",
    "        if u not in idx or v not in idx: continue\n",
    "        if G.has_edge(v,u):\n",
    "            M[idx[u],0]+=1; M[idx[v],0]+=1\n",
    "    for a in neurons:\n",
    "        if a not in G: continue\n",
    "        outs = set(G.successors(a))\n",
    "        ins  = set(G.predecessors(a))\n",
    "        if len(outs)>1: M[idx[a],3]+=len(outs)\n",
    "        if len(ins)>1:  M[idx[a],4]+=len(ins)\n",
    "        for b in outs:\n",
    "            if b not in G: continue\n",
    "            outs_b = set(G.successors(b))\n",
    "            M[idx[a],1]+=len(outs_b)\n",
    "            M[idx[a],2]+=len(outs.intersection(outs_b))\n",
    "    return (M - M.mean(0)) / (M.std(0)+1e-6)\n",
    "\n",
    "motifs = motif_counts_safe(G, neurons)\n",
    "print(f\"✅ Final motif matrix ready: {motifs.shape}\")\n",
    "\n",
    "# Confirm integrity\n",
    "print(f\"All matrices aligned — expr: {expr.shape}, deg_df: {deg_df.shape}, motifs: {motifs.shape}\")\n",
    "\n",
    "# --- 6. Merge all features ---\n",
    "Xg = (expr - expr.mean())/(expr.std()+1e-6)\n",
    "X = np.concatenate([Xg.values, deg_df.values, motifs], axis=1).astype(np.float32)\n",
    "print(f\"✅ Feature tensor: {X.shape}\")\n",
    "\n",
    "# --- 7. Quick sanity test: predict motif participation using simple MLP ---\n",
    "class TinyNN(nn.Module):\n",
    "    def __init__(self, indim, outdim=5):\n",
    "        super().__init__()\n",
    "        self.net = nn.Sequential(\n",
    "            nn.Linear(indim,128), nn.ReLU(),\n",
    "            nn.Linear(128,64), nn.ReLU(),\n",
    "            nn.Linear(64,outdim)\n",
    "        )\n",
    "    def forward(self,x): return self.net(x)\n",
    "\n",
    "model = TinyNN(X.shape[1], motifs.shape[1])\n",
    "opt = torch.optim.Adam(model.parameters(), lr=2e-3)\n",
    "crit = nn.MSELoss()\n",
    "\n",
    "Xt = torch.tensor(X, dtype=torch.float32)\n",
    "yt = torch.tensor(motifs, dtype=torch.float32)\n",
    "\n",
    "for epoch in range(80):\n",
    "    model.train(); opt.zero_grad()\n",
    "    pred = model(Xt)\n",
    "    loss = crit(pred, yt)\n",
    "    loss.backward(); opt.step()\n",
    "print(f\"✅ Quick test loss: {loss.item():.4f}\")\n",
    "\n",
    "# --- 8. Ready state for Tasks A–D ---\n",
    "globals().update({\"expr\":expr,\"edges\":edges,\"neurons\":neurons,\"G\":G,\"deg_df\":deg_df,\"motifs\":motifs,\"X\":X})\n",
    "print(\"Environment primed for Tasks A–D.\")\n"
   ]
  },
