   "source": [
    "# === TASK D: Predict Behavioral Role (3-class) ===\n",
    "sensory = [n for n in neurons if n.startswith((\"AF\",\"AL\",\"AS\",\"AVM\",\"AWA\",\"AWC\",\"ASE\",\"ASH\",\"URX\",\"OL\"))]\n",
    "motor   = [n for n in neurons if n.startswith((\"DA\",\"DB\",\"DD\",\"VA\",\"VB\",\"VD\",\"AS\"))]\n",
    "role = []\n",
    "for n in neurons:\n",
    "    if n in sensory: role.append(0)         # sensory\n",
    "    elif n in motor: role.append(2)         # motor\n",
    "    else: role.append(1)                    # interneuron\n",
    "y_role = np.array(role)\n",
    "\n",
    "def run_foldD(tr,va):\n",
    "    model = nn.Sequential(\n",
    "        nn.Linear(X.shape[1],128), nn.ReLU(),\n",
    "        nn.Linear(128,64), nn.ReLU(),\n",
    "        nn.Linear(64,3)\n",
    "    )\n",
    "    opt = torch.optim.Adam(model.parameters(), lr=2e-3)\n",
    "    crit = nn.CrossEntropyLoss()\n",
    "    Xt = torch.tensor(X[tr],dtype=torch.float32)\n",
    "    yt = torch.tensor(y_role[tr],dtype=torch.long)\n",
    "    Xv = torch.tensor(X[va],dtype=torch.float32)\n",
    "    yv = y_role[va]\n",
    "    for ep in range(100):\n",
    "        model.train(); opt.zero_grad()\n",
    "        loss = crit(model(Xt),yt); loss.backward(); opt.step()\n",
    "    model.eval()\n",
    "    with torch.no_grad():\n",
    "        pv = model(Xv).numpy()\n",
    "    acc = (pv.argmax(1)==yv).mean()\n",
    "    return {\"acc\":acc}\n",
    "\n",
    "scoresD=[run_foldD(*split) for split in kf.split(X)]\n",
    "print(\"Mean Accuracy (role):\",np.mean([s[\"acc\"] for s in scoresD]))\n"
   ]
  },
