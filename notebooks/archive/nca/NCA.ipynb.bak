   "source": [
    "# --- PATCHED MOTIF COMPUTATION (robust to missing nodes) ---\n",
    "\n",
    "# Remove neuron names not in the actual graph\n",
    "neurons_in_graph = [n for n in neurons if n in G.nodes()]\n",
    "missing = set(neurons) - set(neurons_in_graph)\n",
    "if missing:\n",
    "    print(f\"⚠️ {len(missing)} neuron IDs not in graph — dropping: {sorted(list(missing))[:10]}{'...' if len(missing)>10 else ''}\")\n",
    "neurons = neurons_in_graph  # update canonical neuron list\n",
    "\n",
    "def motif_counts_safe(G, neurons):\n",
    "    idx = {n:i for i,n in enumerate(neurons)}\n",
    "    M = np.zeros((len(neurons),5),dtype=np.float32)\n",
    "    for u,v in G.edges():\n",
    "        if u not in idx or v not in idx: \n",
    "            continue\n",
    "        if G.has_edge(v,u):\n",
    "            M[idx[u],0]+=1; M[idx[v],0]+=1\n",
    "    for a in neurons:\n",
    "        outs = set(G.successors(a)) if a in G else set()\n",
    "        ins  = set(G.predecessors(a)) if a in G else set()\n",
    "        if len(outs)>1: M[idx[a],3]+=len(outs)\n",
    "        if len(ins)>1:  M[idx[a],4]+=len(ins)\n",
    "        for b in outs:\n",
    "            if b not in G: continue\n",
    "            outs_b = set(G.successors(b))\n",
    "            M[idx[a],1]+=len(outs_b)\n",
    "            M[idx[a],2]+=len(outs.intersection(outs_b))\n",
    "    return (M - M.mean(0)) / (M.std(0)+1e-6)\n",
    "\n",
    "motifs = motif_counts_safe(G, neurons)\n",
    "print(f\"✅ Motif matrix built successfully: {motifs.shape}\")\n"
   ]
  },
