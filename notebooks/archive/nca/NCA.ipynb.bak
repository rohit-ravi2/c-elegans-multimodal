   "source": [
    "# ==== CELL: Degree-binned permutation for Task B/C or Role ====\n",
    "from sklearn.metrics import roc_auc_score\n",
    "import numpy as np, pandas as pd\n",
    "\n",
    "deg_cont = deg_df[\"out_deg\"].reindex(expr.index).values  # one structural scalar\n",
    "def degree_bins(v, nbins=5):\n",
    "    return pd.qcut(v, q=min(nbins, len(np.unique(v))), duplicates=\"drop\").astype(str).values\n",
    "\n",
    "def perm_pvalue_auc(y_true, y_score, deg, iters=2000, seed=1337):\n",
    "    rng = np.random.default_rng(seed)\n",
    "    bins = degree_bins(deg)\n",
    "    auc_obs = roc_auc_score(y_true, y_score)\n",
    "    ge = 0\n",
    "    for _ in range(iters):\n",
    "        y_perm = y_true.copy()\n",
    "        for b in np.unique(bins):\n",
    "            idx = np.where(bins==b)[0]\n",
    "            rng.shuffle(y_perm[idx])\n",
    "        auc_p = roc_auc_score(y_perm, y_score)\n",
    "        ge += (auc_p >= auc_obs)\n",
    "    return auc_obs, (ge+1)/(iters+1)\n",
    "\n",
    "print(\"Example usage: pass your y_true and model scores from Task B/C here to get degree-aware p-values.\")\n"
   ]
  },
