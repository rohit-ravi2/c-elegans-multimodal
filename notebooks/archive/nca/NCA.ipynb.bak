   "source": [
    "import pandas as pd\n",
    "\n",
    "# Load your local CeNGEN-mapped expression file\n",
    "mapping_df = pd.read_csv(\"data/processed/csv/gene_expr_CeNGEN_base_mapped.csv\")\n",
    "\n",
    "# Inspect columns to identify mapping columns\n",
    "print(mapping_df.columns[:10])  # just to verify the header structure\n",
    "display(mapping_df.head(5))"
   ]
  },
