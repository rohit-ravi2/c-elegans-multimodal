   "source": [
    "# === TASK A: Predict Motif Participation (per-neuron regression) ===\n",
    "from sklearn.model_selection import KFold\n",
    "from sklearn.metrics import mean_absolute_error\n",
    "import numpy as np, torch, torch.nn as nn\n",
    "\n",
    "kf = KFold(n_splits=5, shuffle=True, random_state=1337)\n",
    "X_np = X\n",
    "y_np = motifs\n",
    "\n",
    "def run_fold(train_idx, val_idx, tag):\n",
    "    model = nn.Sequential(\n",
    "        nn.Linear(X_np.shape[1], 128), nn.ReLU(),\n",
    "        nn.Linear(128, 64), nn.ReLU(),\n",
    "        nn.Linear(64, y_np.shape[1])\n",
    "    )\n",
    "    opt = torch.optim.Adam(model.parameters(), lr=2e-3)\n",
    "    crit = nn.MSELoss()\n",
    "    Xt = torch.tensor(X_np[train_idx], dtype=torch.float32)\n",
    "    yt = torch.tensor(y_np[train_idx], dtype=torch.float32)\n",
    "    Xv = torch.tensor(X_np[val_idx], dtype=torch.float32)\n",
    "    yv = torch.tensor(y_np[val_idx], dtype=torch.float32)\n",
    "\n",
    "    for ep in range(100):\n",
    "        model.train(); opt.zero_grad()\n",
    "        loss = crit(model(Xt), yt)\n",
    "        loss.backward(); opt.step()\n",
    "    model.eval()\n",
    "    with torch.no_grad():\n",
    "        pv = model(Xv).numpy()\n",
    "    spearman = np.corrcoef(yv.flatten(), pv.flatten())[0,1]\n",
    "    mae = mean_absolute_error(yv.flatten(), pv.flatten())\n",
    "    return {\"tag\":tag, \"r\":spearman, \"mae\":mae}\n",
    "\n",
    "folds = []\n",
    "for i,(tr,va) in enumerate(kf.split(X_np),1):\n",
    "    res = run_fold(tr,va,f\"fold{i}\")\n",
    "    print(res); folds.append(res)\n",
    "print(\"Average r:\", np.mean([f[\"r\"] for f in folds]))\n"
   ]
  },
