   "source": [
    "# ============================================================\n",
    "# 📘 Cell G2 — Map WormBase IDs → gene names, then re-run enrichment\n",
    "# ============================================================\n",
    "import re, pandas as pd\n",
    "from pathlib import Path\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "DATA_ROOT = Path(\"/mnt/ssd4tb/Desktop/C-Elegans/data\")\n",
    "EXPERIMENTS_OUT = DATA_ROOT / \"processed\" / \"experiments\"\n",
    "\n",
    "sal_path = EXPERIMENTS_OUT / \"gnca_saliency_genes.csv\"\n",
    "ig_path  = EXPERIMENTS_OUT / \"gnca_integrated_gradients_genes.csv\"\n",
    "\n",
    "sal_df = pd.read_csv(sal_path)\n",
    "ig_df  = pd.read_csv(ig_path)\n",
    "\n",
    "# ---------- 1) Build WBGene -> gene_name map from any GTF/GFF3 ----------\n",
    "def parse_attrs(attr_str):\n",
    "    # Works for both GTF (key \"gene_name\"/\"gene_id\") and GFF3 (key \"Name\"/\"ID\")\n",
    "    d = {}\n",
    "    # split on ; and strip\n",
    "    for kv in re.split(r';\\s*', str(attr_str).strip('; ')):\n",
    "        if not kv: continue\n",
    "        if '=' in kv: k,v = kv.split('=',1)\n",
    "        elif ' ' in kv: k,v = kv.split(' ',1)\n",
    "        else: continue\n",
    "        d[k.strip().strip('\"')] = v.strip().strip('\"')\n",
    "    return d\n",
    "\n",
    "def collect_maps():\n",
    "    wb2name = {}\n",
    "    # look in common places\n",
    "    candidates = []\n",
    "    for sub in [\"processed/gtf\", \"processed/gff3\", \"genomes\", \"processed/genomes\", \"raw/gtf\", \"raw/gff3\"]:\n",
    "        p = DATA_ROOT / sub\n",
    "        if p.exists():\n",
    "            candidates += list(p.rglob(\"*.gtf\")) + list(p.rglob(\"*.gff3\"))\n",
    "    # deduplicate while keeping order\n",
    "    seen = set(); gt_files = []\n",
    "    for f in candidates:\n",
    "        if f not in seen:\n",
    "            gt_files.append(f); seen.add(f)\n",
    "    if not gt_files:\n",
    "        print(\"⚠️ No GTF/GFF3 found under data/, mapping will be empty.\")\n",
    "        return {}\n",
    "    # parse a few files until we get a good number of mappings\n",
    "    for gt in gt_files:\n",
    "        try:\n",
    "            print(f\"Parsing: {gt.name}\")\n",
    "            with gt.open() as fh:\n",
    "                for line in fh:\n",
    "                    if line.startswith(\"#\"): continue\n",
    "                    parts = line.rstrip(\"\\n\").split(\"\\t\")\n",
    "                    if len(parts) < 9: continue\n",
    "                    attrs = parse_attrs(parts[8])\n",
    "                    # Try both formats\n",
    "                    wb = attrs.get(\"gene_id\") or attrs.get(\"gene\") or attrs.get(\"ID\")\n",
    "                    name = attrs.get(\"gene_name\") or attrs.get(\"Name\") or attrs.get(\"gene\")\n",
    "                    # Keep only proper WBGene IDs and decent names\n",
    "                    if wb and re.match(r\"^WBGene\\d{8}$\", wb):\n",
    "                        if name and not re.match(r\"^WBGene\\d{8}$\", name):\n",
    "                            wb2name.setdefault(wb, name)\n",
    "        except Exception as e:\n",
    "            print(f\"  (skip {gt.name}: {e})\")\n",
    "        if len(wb2name) > 5000:  # enough\n",
    "            break\n",
    "    print(f\"✅ built map size: {len(wb2name)}\")\n",
    "    return wb2name\n",
    "\n",
    "wb2name = collect_maps()\n",
    "\n",
    "# Fallback: if still empty, try a simple heuristic (strip version suffixes etc.)\n",
    "if not wb2name:\n",
    "    print(\"⚠️ Map empty; will pass through WBGene IDs unchanged.\")\n",
    "    def to_name(x): return x\n",
    "else:\n",
    "    def to_name(x): return wb2name.get(x, x)\n",
    "\n",
    "# ---------- 2) Map top-N features to gene names ----------\n",
    "TOP_N = 100\n",
    "sal_top = sal_df.head(TOP_N)[\"gene\"].map(to_name)\n",
    "ig_top  = ig_df.head(TOP_N)[\"gene\"].map(to_name)\n",
    "combined_top = set(sal_top).union(set(ig_top))\n",
    "print(f\"Top set size after mapping: {len(combined_top)}\")\n",
    "\n",
    "# ---------- 3) Define marker sets (gene names, lowercase) ----------\n",
    "marker_sets = {\n",
    "    \"serotonin\": {\"tph-1\",\"cat-4\",\"bas-1\",\"mod-5\",\"ser-4\",\"ser-1\",\"ser-7\"},\n",
    "    \"dopamine\": {\"cat-2\",\"cat-4\",\"bas-1\",\"dat-1\",\"dop-1\",\"dop-2\",\"dop-3\",\"dop-4\"},\n",
    "    \"acetylcholine\": {\"cha-1\",\"unc-17\",\"ace-1\",\"ace-2\",\"cho-1\",\"gar-1\",\"gar-2\"},\n",
    "    \"GABA\": {\"unc-25\",\"unc-47\",\"snf-11\",\"gab-1\",\"exp-1\",\"lgc-35\"},\n",
    "    \"glutamate\": {\"eat-4\",\"glr-1\",\"glr-2\",\"nmr-1\",\"avr-14\",\"avr-15\"},\n",
    "    \"neuropeptide\": {\"flp-1\",\"flp-3\",\"flp-10\",\"nlp-1\",\"nlp-3\",\"nlp-12\",\"nlp-21\"},\n",
    "    \"mechanosensory/adhesion\": {\"mec-3\",\"mec-4\",\"mec-7\",\"mec-10\",\"mec-17\",\"unc-6\",\"unc-40\"},\n",
    "}\n",
    "combined_lc = {str(g).lower() for g in combined_top}\n",
    "\n",
    "# ---------- 4) Enrichment counts ----------\n",
    "rows = []\n",
    "for system, markers in marker_sets.items():\n",
    "    hits = sorted(combined_lc & {m.lower() for m in markers})\n",
    "    rows.append({\"system\": system, \"hits\": len(hits), \"hit_genes\": \", \".join(hits)})\n",
    "enrich_df = pd.DataFrame(rows).sort_values(\"hits\", ascending=False)\n",
    "display(enrich_df)\n",
    "\n",
    "# ---------- 5) Plot ----------\n",
    "plt.figure(figsize=(8,4))\n",
    "plt.barh(enrich_df[\"system\"], enrich_df[\"hits\"])\n",
    "plt.gca().invert_yaxis()\n",
    "plt.xlabel(f\"Hits in top-{TOP_N} GNCA genes (mapped to names)\")\n",
    "plt.title(\"Neurotransmitter/Peptide Enrichment\")\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Save\n",
    "out_path = EXPERIMENTS_OUT / \"gnca_neurotransmitter_enrichment_mapped.csv\"\n",
    "enrich_df.to_csv(out_path, index=False)\n",
    "print(f\"✅ Saved → {out_path}\")\n"
   ]
  },
