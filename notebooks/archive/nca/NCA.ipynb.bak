    "# ==== CELL: Residual pathway test (behavior) ====\n",
    "from sklearn.linear_model import LinearRegression\n",
    "from sklearn.metrics import r2_score\n",
    "\n",
    "# Reduce dims for stability\n",
    "p_expr = PCA(n_components=16, random_state=0).fit_transform(X_expr)\n",
    "p_motif= PCA(n_components=3,  random_state=0).fit_transform(Y_motif)\n",
    "\n",
    "# Step 1: predict behavior from expression alone\n",
    "lr1 = LinearRegression().fit(p_expr, y_role)  # treating labels as ordinal proxy\n",
    "r2_expr_only = r2_score(y_role, lr1.predict(p_expr))\n",
    "\n",
    "# Step 2: regress expression effect out of behavior, then try to predict residual from expression again\n",
    "beh_resid = y_role - lr1.predict(p_expr)\n",
    "lr2 = LinearRegression().fit(p_expr, beh_resid)\n",
    "r2_expr_on_resid = r2_score(beh_resid, lr2.predict(p_expr))\n",
    "\n",
    "# Step 3: predict behavior from motifs alone\n",
    "lr3 = LinearRegression().fit(p_motif, y_role)\n",
    "r2_motif = r2_score(y_role, lr3.predict(p_motif))\n",
    "\n",
    "print(f\"R²(behavior ~ expr) = {r2_expr_only:.3f}\")\n",
    "print(f\"R²(residual after expr ~ expr) = {r2_expr_on_resid:.3f}  (should drop to ~0)\")\n",
    "print(f\"R²(behavior ~ motif) = {r2_motif:.3f}  (should be notably higher)\")\n"
   ]
  },
