     "text": [
      "Indirect effect a*b ≈ -0.0000, Sobel z≈-0.00, p≈1\n",
      "Direct expr effect c' ≈ 0.0000  (should be smaller than total expr-only model)\n"
     ]
    }
   ],
   "source": [
    "# ==== CELL: Mediation test (Expression -> Motif -> Role) ====\n",
    "from sklearn.decomposition import PCA\n",
    "from sklearn.linear_model import LinearRegression\n",
    "from scipy.stats import norm\n",
    "\n",
    "# Reduce dimensionality for a stable test\n",
    "p_expr = PCA(n_components=16, random_state=0).fit_transform(X_expr)\n",
    "p_motif= PCA(n_components=3,  random_state=0).fit_transform(Y_motif)\n",
    "\n",
    "# Encode role as 1-vs-rest for a smooth mediation proxy (choose \"motor\" as 1)\n",
    "y_motor = (y_role==2).astype(float)\n",
    "\n",
    "# Paths:\n",
    "# a: expr -> motif (regress each motif PC on expr PCs, take mean beta magnitude)\n",
    "a_model = LinearRegression().fit(p_expr, p_motif)\n",
    "a_hat   = a_model.coef_.mean()  # coarse scalar proxy of a-path strength\n",
    "\n",
    "# b & c': role ~ expr + motif (linear prob. proxy)\n",
    "XZ = np.hstack([p_expr, p_motif])\n",
    "bc_model = LinearRegression().fit(XZ, y_motor)\n",
    "# Split coefficients\n",
    "b_hat = np.mean(bc_model.coef_[-p_motif.shape[1]:])   # motif part\n",
    "c_prime_hat = np.mean(bc_model.coef_[:p_expr.shape[1]])  # direct expr part\n",
    "\n",
    "# Sobel test for indirect effect (a*b)\n",
    "# (Use rough var estimates from residuals; fine for signal check.)\n",
    "res_a = p_motif - a_model.predict(p_expr)\n",
    "res_b = y_motor - bc_model.predict(XZ)\n",
    "sa = res_a.std(); sb = res_b.std()\n",
    "sobel_se = np.sqrt((b_hat**2)*(sa.mean()**2) + (a_hat**2)*(sb**2))\n",
    "z = (a_hat*b_hat) / (sobel_se + 1e-8)\n",
    "p = 2*(1 - norm.cdf(abs(z)))\n",
    "\n",
    "print(f\"Indirect effect a*b ≈ {a_hat*b_hat:.4f}, Sobel z≈{z:.2f}, p≈{p:.3g}\")\n",
    "print(f\"Direct expr effect c' ≈ {c_prime_hat:.4f}  (should be smaller than total expr-only model)\")\n"
   ]
  },
