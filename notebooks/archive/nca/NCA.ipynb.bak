   "source": [
    "# ============================================================\n",
    "# 🧠 Cell E — Graph-Neural Cellular Automaton (GNCA)\n",
    "# Predicts motif participation (reciprocal, chain, etc.) from expression + connectome\n",
    "# ============================================================\n",
    "\n",
    "import torch, torch.nn as nn, torch.nn.functional as F\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "import numpy as np, pandas as pd\n",
    "# ------------------------------------------------------------\n",
    "# 🔧 Patch: Remove duplicate neuron indices\n",
    "# ------------------------------------------------------------\n",
    "def dedup_index(df, label):\n",
    "    before = len(df)\n",
    "    df = df[~df.index.duplicated(keep=\"first\")]\n",
    "    after = len(df)\n",
    "    if before != after:\n",
    "        print(f\"⚠️  Removed {before - after} duplicate indices from {label}\")\n",
    "    return df\n",
    "\n",
    "expr_df = dedup_index(expr_df, \"expr_df\")\n",
    "motif_df = dedup_index(motif_df, \"motif_df\")\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 1️⃣  Sanitize and align neuron indices\n",
    "# ------------------------------------------------------------\n",
    "expr_df.index  = expr_df.index.astype(str).str.strip().str.upper()\n",
    "motif_df.index = motif_df.index.astype(str).str.strip().str.upper()\n",
    "edges_df[\"Source\"] = edges_df[\"Source\"].astype(str).str.strip().str.upper()\n",
    "edges_df[\"Target\"] = edges_df[\"Target\"].astype(str).str.strip().str.upper()\n",
    "\n",
    "common_neurons = sorted(set(expr_df.index) & set(motif_df.index))\n",
    "print(f\"✅ Common neurons found: {len(common_neurons)}\")\n",
    "\n",
    "# Safe reindexing (drop NaNs automatically)\n",
    "expr_df  = expr_df.reindex(common_neurons).dropna()\n",
    "motif_df = motif_df.reindex(common_neurons).dropna()\n",
    "\n",
    "print(f\"✅ After alignment: expr={expr_df.shape}, motif={motif_df.shape}\")\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 2️⃣  Build adjacency matrix (undirected)\n",
    "# ------------------------------------------------------------\n",
    "neuron_index = {n: i for i, n in enumerate(common_neurons)}\n",
    "N = len(common_neurons)\n",
    "A = torch.zeros((N, N), dtype=torch.float32)\n",
    "\n",
    "for _, row in edges_df.iterrows():\n",
    "    s, t = row[\"Source\"], row[\"Target\"]\n",
    "    if s in neuron_index and t in neuron_index:\n",
    "        i, j = neuron_index[s], neuron_index[t]\n",
    "        A[i, j] = A[j, i] = 1.0  # symmetric simplified graph\n",
    "\n",
    "print(f\"✅ Adjacency built: {A.shape}\")\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 3️⃣  Prepare tensors (fresh rebuild)\n",
    "# ------------------------------------------------------------\n",
    "X = StandardScaler().fit_transform(expr_df.values)\n",
    "y = motif_df.values.astype(np.float32)\n",
    "\n",
    "X = torch.tensor(X, dtype=torch.float32)\n",
    "y = torch.tensor(y, dtype=torch.float32)\n",
    "\n",
    "device = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n",
    "X, y, A = X.to(device), y.to(device), A.to(device)\n",
    "print(f\"✅ Rebuilt tensors: X={X.shape}, y={y.shape}, A={A.shape}, device={device}\")\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 4️⃣  Define GNCA model\n",
    "# ------------------------------------------------------------\n",
    "class GNCA(nn.Module):\n",
    "    def __init__(self, in_dim, hidden_dim, out_dim, steps=3, dropout=0.3):\n",
    "        super().__init__()\n",
    "        self.fc_in = nn.Linear(in_dim, hidden_dim)\n",
    "        self.fc_msg = nn.Linear(hidden_dim, hidden_dim)\n",
    "        self.fc_out = nn.Linear(hidden_dim, out_dim)\n",
    "        self.steps = steps\n",
    "        self.dropout = nn.Dropout(dropout)\n",
    "\n",
    "    def forward(self, X, A):\n",
    "        # X: [N, in_dim], A: [N, N]\n",
    "        h = F.relu(self.fc_in(X))\n",
    "        for _ in range(self.steps):\n",
    "            msg = self.fc_msg(self.dropout(h))\n",
    "            h = h + torch.matmul(A, msg) / (A.sum(1, keepdim=True) + 1)\n",
    "            h = F.relu(h)\n",
    "        return torch.sigmoid(self.fc_out(h))\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 5️⃣  Train GNCA\n",
    "# ------------------------------------------------------------\n",
    "model = GNCA(in_dim=X.shape[1], hidden_dim=64, out_dim=y.shape[1], steps=3, dropout=0.3).to(device)\n",
    "opt = torch.optim.Adam(model.parameters(), lr=1e-3)\n",
    "loss_fn = nn.BCELoss()\n",
    "\n",
    "best_loss, best_r = np.inf, 0\n",
    "for epoch in range(1, 201):\n",
    "    model.train()\n",
    "    pred = model(X, A)\n",
    "    loss = loss_fn(pred, y)\n",
    "    opt.zero_grad(); loss.backward(); opt.step()\n",
    "\n",
    "    if epoch % 20 == 0 or epoch == 1:\n",
    "        model.eval()\n",
    "        with torch.no_grad():\n",
    "            r = np.corrcoef(pred.flatten().cpu(), y.flatten().cpu())[0, 1]\n",
    "        print(f\"Epoch {epoch:03d} | loss={loss.item():.4f} | r={r:.3f}\")\n",
    "        if loss.item() < best_loss:\n",
    "            best_loss, best_r = loss.item(), r\n",
    "            torch.save(model.state_dict(), EXPERIMENTS_OUT / \"gnca_motif_best.pt\")\n",
    "\n",
    "print(f\"\\n✅ Training complete | Best loss={best_loss:.6f} | Final Pearson r={best_r:.3f}\")\n"
   ]
  },
